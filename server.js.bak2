// ESKÄ° TELEFON BAZLI SÄ°STEM KALDIRILDI - SADECE TC BAZLI SÄ°STEM KULLANILIYOR

// Kurum - Veli GiriÅ Bilgisi Getir (ESKÄ° - KALDIRILDI)
app.get('/kurum/veli-giris-bilgisi', requireAuth, async (req, res) => {
  if (req.session.userType !== 'kurum_yonetici') {
    return res.status(403).json({ success: false, message: 'Yetkisiz eriÅim!' });
  }
  
  try {
    let { telefon } = req.query;
    
    if (!telefon) {
      return res.json({ success: false, message: 'Telefon numarasÄą gerekli!' });
    }
    
    // Telefon formatÄąnÄą temizle (.0 ile biten)
    telefon = telefon.toString().trim();
    const telefonTemiz = telefon.endsWith('.0') ? telefon.replace('.0', '') : telefon;
    const telefonNokta = telefonTemiz + '.0';
    
    // Veli hesabÄąnÄą bul - hem temiz hem de .0 formatÄąnda ara
    const veli = await dbGet(
      'SELECT username, password_hash, created_at FROM users WHERE (telefon = ? OR telefon = ? OR username = ? OR username = ?) AND user_type = ?',
      [telefonTemiz, telefonNokta, telefonTemiz, telefonNokta, 'veli']
    );
    
    if (!veli) {
      return res.json({ 
        success: true, 
        hesapVar: false 
      });
    }
    
    // Ä°lk Åifre hash'i
    const ilkSifreHash = '$2b$10$';  // bcrypt baÅlangÄącÄą
    const defaultPassword = 'Veli2024!';
    
    // Åifre deÄiÅtirilmiÅ mi kontrol et
    // (Basit kontrol: created_at ile password_hash hash'i aynÄą zamanda mÄą oluÅturulmuÅ)
    // Daha gÃžvenli: password_hash'i "Veli2024!" ile karÅÄąlaÅtÄąr
    const sifreDegismis = !await bcrypt.compare(defaultPassword, veli.password_hash);
    
    // Username'deki .0 formatÄąnÄą temizle
    let usernameTemiz = veli.username.toString();
    if (usernameTemiz.endsWith('.0')) {
      usernameTemiz = usernameTemiz.replace('.0', '');
    }
    
    console.log(`\nðïļ VELÄ° BÄ°LGÄ°SÄ° GÃSTERÄ°LDÄ°`);
    console.log(`   Telefon: ${telefon}`);
    console.log(`   Username (orijinal): ${veli.username}`);
    console.log(`   Username (temiz): ${usernameTemiz}`);
    console.log(`   Åifre deÄiÅmiÅ: ${sifreDegismis ? 'Evet' : 'HayÄąr'}`);
    
    res.json({
      success: true,
      hesapVar: true,
      username: usernameTemiz,
      sifre: defaultPassword,
      sifreDegismis: sifreDegismis
    });
  } catch (error) {
    console.error('Veli bilgi getirme hatasÄą:', error);
    res.json({ success: false, message: 'Bir hata oluÅtu!' });
  }
});

// Kurum - ÃÄrenci KayÄąt GÃžncelle
app.post('/kurum/ogrenci-kayit-guncelle/:id', requireAuth, async (req, res) => {
  if (req.session.userType !== 'kurum_yonetici') {
    return res.status(403).json({ success: false, message: 'Yetkiniz yok!' });
  }
  
  try {
    const { id } = req.params;
    const {
      sinif, ogrenci_adi_soyadi, telefon, tc_kimlik_no,
      veli_adi, veli_telefon, tutar, odeme_durumu,
      odeme_turu, edessis_kaydi, taksit
    } = req.body;
    
    await dbRun(
      `UPDATE ogrenci_kayitlari SET
        sinif = ?, ogrenci_adi_soyadi = ?, telefon = ?, tc_kimlik_no = ?,
        veli_adi = ?, veli_telefon = ?, tutar = ?, odeme_durumu = ?,
        odeme_turu = ?, edessis_kaydi = ?, taksit = ?,
        updated_at = datetime('now')
      WHERE id = ?`,
      [sinif, ogrenci_adi_soyadi, telefon, tc_kimlik_no,
       veli_adi, veli_telefon, tutar, odeme_durumu,
       odeme_turu, edessis_kaydi, taksit, id]
    );
    
    res.json({ success: true, message: 'ÃÄrenci kaydÄą gÃžncellendi!' });
  } catch (error) {
    console.error('ÃÄrenci kayÄąt gÃžncelleme hatasÄą:', error);
    res.json({ success: false, message: 'GÃžncelleme sÄąrasÄąnda bir hata oluÅtu!' });
  }
});

// Kurum - ÃÄrenci KayÄąt Sil
app.post('/kurum/ogrenci-kayit-sil/:id', requireAuth, async (req, res) => {
  if (req.session.userType !== 'kurum_yonetici') {
    return res.status(403).json({ success: false, message: 'Yetkiniz yok!' });
  }
  
  try {
    const { id } = req.params;
    await dbRun('DELETE FROM ogrenci_kayitlari WHERE id = ?', [id]);
    res.json({ success: true, message: 'ÃÄrenci kaydÄą silindi!' });
  } catch (error) {
    console.error('ÃÄrenci kayÄąt silme hatasÄą:', error);
    res.json({ success: false, message: 'Silme sÄąrasÄąnda bir hata oluÅtu!' });
  }
});

// Kurum - TÃM ÃÄrenci KayÄątlarÄąnÄą Sil
app.post('/kurum/ogrenci-kayitlari-tumunu-sil', requireAuth, async (req, res) => {
  if (req.session.userType !== 'kurum_yonetici') {
    return res.status(403).json({ success: false, message: 'Yetkiniz yok!' });
  }
  
  try {
    const { onayKodu } = req.body;
    
    // GÃžvenlik kontrolÃž: "SÄ°L" yazmasÄą gerekiyor
    if (onayKodu !== 'SÄ°L') {
      return res.json({ success: false, message: 'Onay kodu hatalÄą! "SÄ°L" yazmanÄąz gerekiyor.' });
    }
    
    // KaÃ§ kayÄąt var?
    const kayitSayisi = await dbGet('SELECT COUNT(*) as sayi FROM ogrenci_kayitlari');
    
    // TÃžm kayÄątlarÄą sil
    await dbRun('DELETE FROM ogrenci_kayitlari');
    
    console.log(`\nâ ïļ  TÃM ÃÄRENCÄ° KAYITLARI SÄ°LÄ°NDÄ°!`);
    console.log(`   Silinen kayÄąt sayÄąsÄą: ${kayitSayisi.sayi}`);
    console.log(`   Yapan kullanÄącÄą: ${req.session.username}\n`);
    
    res.json({ 
      success: true, 
      message: `${kayitSayisi.sayi} ÃķÄrenci kaydÄą baÅarÄąyla silindi!` 
    });
  } catch (error) {
    console.error('Toplu silme hatasÄą:', error);
    res.json({ success: false, message: 'Silme iÅlemi sÄąrasÄąnda bir hata oluÅtu!' });
  }
});

// Kurum - Excel Import
app.post('/kurum/ogrenci-import-excel', requireAuth, upload.single('excelFile'), async (req, res) => {
  if (req.session.userType !== 'kurum_yonetici') {
    return res.status(403).json({ success: false, message: 'Yetkiniz yok!' });
  }
  
  try {
    const { sinav_id, pdfPath } = req.body;
    const isUploaded = !!req.file;
    const sourcePath = isUploaded ? req.file.path : pdfPath;
    if (!sinav_id) {
      return res.status(400).json({ success: false, error: 'Sinav ID eksik!' });
    }
    if (!sourcePath || !fs.existsSync(sourcePath)) {
      return res.status(400).json({ success: false, error: 'PDF dosyasi bulunamadi!' });
    }
    console.log('SINAV SONUCU ANALIZ EDILIYOR:', isUploaded && req.file ? req.file.originalname : path.basename(sourcePath));
    console.log('Sinav ID:', sinav_id);
    // PDF\'i yukle
    const pdfBytes = fs.readFileSync(sourcePath);
    const pdfDoc = await PDFDocument.load(pdfBytes);
    const totalPages = pdfDoc.getPageCount();
    
    console.log(`ð Toplam sayfa: ${totalPages}`);
    
    // Her sayfayÄą ayrÄą PDF olarak kaydet
    const sayfaYollari = [];
    
    for (let i = 0; i < totalPages; i++) {
      const singlePagePdf = await PDFDocument.create();
      const [copiedPage] = await singlePagePdf.copyPages(pdfDoc, [i]);
      singlePagePdf.addPage(copiedPage);
      const singlePageBytes = await singlePagePdf.save();
      
      // Dosya adÄą: sinav_ID_sayfa_NUMARA_timestamp.pdf
      const sayfaFileName = `sinav_${sinav_id}_sayfa_${i + 1}_${Date.now()}.pdf`;
      const sayfaYolu = path.join('uploads', 'sinav-sonuclari', sayfaFileName);
      
      // KlasÃķr yoksa oluÅtur
      const dir = path.dirname(sayfaYolu);
      if (!fs.existsSync(dir)) {
        fs.mkdirSync(dir, { recursive: true });
      }
      
      fs.writeFileSync(sayfaYolu, singlePageBytes);
      sayfaYollari.push(sayfaYolu);
      
      console.log(`   â Sayfa ${i + 1}/${totalPages} kaydedildi`);
    }
    
    // Orijinal PDF'i de kaydet
    const orijinalFileName = `sinav_${sinav_id}_orijinal_${Date.now()}.pdf`;
    const orijinalYol = path.join('uploads', 'sinav-sonuclari', orijinalFileName);
    fs.copyFileSync(req.file.path, orijinalYol);
    
    // VeritabanÄąna kaydet - sinavlar tablosuna orijinal PDF yolunu ekle
    await dbRun(
      'UPDATE sinavlar SET dosya_yolu = ?, sonuc_yuklendi = 1 WHERE id = ?',
      [orijinalYol, sinav_id]
    );
    
    // GeÃ§ici dosyayÄą sil
    fs.unlinkSync(req.file.path);
    
    console.log(`â PDF baÅarÄąyla ${totalPages} sayfaya ayrÄąldÄą!`);
    
    res.json({
      success: true,
      data: {
        sayfaSayisi: totalPages,
        sayfaYollari: sayfaYollari,
        orijinalYol: orijinalYol,
        // AkÄąllÄą eÅleÅtirme (analiz/pattern seÃ§imi) ekranÄąna yÃķnlendir
        redirectTo: `/kurum/sinav-sonuc-yukle/${sinav_id}`
      }
    });
    
  } catch (error) {
    console.error('â PDF ayÄąrma hatasÄą:', error);
    res.status(500).json({ success: false, error: error.message });
  }
});

// ESKÄ° SÄ°STEM (Yedek olarak kalÄąyor)
app.post('/kurum/sinav-sonuc-yukle-analiz', requireAuth, uploadLimiter, pdfUpload.single('pdfFile'), async (req, res) => {
  if (req.session.userType !== 'kurum_yonetici') {
    return res.status(403).json({ success: false, error: 'Yetkiniz yok!' });
  }
  
  try {
    const { sinav_id, pdfPath } = req.body;
    const isUploaded = !!req.file;
    const sourcePath = isUploaded ? req.file.path : pdfPath;
    if (!sinav_id) {
      return res.status(400).json({ success: false, error: 'Sinav ID eksik!' });
    }
    if (!sourcePath || !fs.existsSync(sourcePath)) {
      return res.status(400).json({ success: false, error: 'PDF dosyasi bulunamadi!' });
    }
    console.log('SINAV SONUCU ANALIZ EDILIYOR:', isUploaded && req.file ? req.file.originalname : path.basename(sourcePath));
    console.log('Sinav ID:', sinav_id);
    // PDF\'i yukle
    const pdfBytes = fs.readFileSync(sourcePath);
    const pdfDoc = await PDFDocument.load(pdfBytes);
    const totalPages = pdfDoc.getPageCount();
    
    console.log(`ð Toplam sayfa: ${totalPages}`);
    
    // Sadece ilk sayfayÄą analiz et
    const singlePagePdf = await PDFDocument.create();
    const [copiedPage] = await singlePagePdf.copyPages(pdfDoc, [0]);
    singlePagePdf.addPage(copiedPage);
    const singlePageBytes = await singlePagePdf.save();
    
    // GeÃ§ici dosya oluÅtur
    const tempFileName = `temp_analyze_sinav_${Date.now()}.pdf`;
    const tempFilePath = path.join('uploads', tempFileName);
    fs.writeFileSync(tempFilePath, singlePageBytes);
    
    // Text Ã§Äąkar - HÄ°BRÄ°T YÃNTEM
    const extractionResult = await extractTextHybrid(tempFilePath);
    const text = extractionResult.text;
    
    console.log(`ð Ä°lk sayfa text uzunluÄu: ${text.length} (YÃķntem: ${extractionResult.method})`);
    
    if (extractionResult.garbled) {
      console.log('â ïļ Ä°lk sayfada encoding sorunu tespit edildi!');
      console.log('ðĄ Manuel giriÅ Ãķnerilir.');
    }
    
    // Potansiyel isim adaylarÄąnÄą bul - YENÄ° GELÄ°ÅMÄ°Å SÄ°STEM
    const lines = text.split('\n').map(l => l.trim()).filter(l => l.length > 0);
    const potansiyelIsimler = [];
    
    console.log(`ð Analiz: ${lines.length} satÄąr bulundu`);
    
    // 1. GELÄ°ÅMÄ°Å FÄ°LTRELEME: Yeni looksLikeName fonksiyonunu kullan
    for (let i = 0; i < Math.min(lines.length, 80); i++) { // 80 satÄąra Ã§ÄąkardÄąk
      const line = lines[i];
      
      // Ä°sim gibi mi kontrol et (yeni fonksiyon)
      if (!looksLikeName(line)) continue;
      
      // Ä°smi temizle (yeni fonksiyon)
      const cleanLine = cleanExtractedName(line);
      if (!cleanLine || cleanLine.length < 5) continue;
      
      // Kelime sayÄąsÄą kontrolÃž
      const words = cleanLine.split(/\s+/);
      const wordCount = words.length;
      
      // GÃžven seviyesi hesapla
      let confidence = 'medium';
      
      // Sadece harf ve boÅluk + 2-3 kelime = yÃžksek gÃžven
      if (wordCount === 2 || wordCount === 3) {
        confidence = 'high';
      }
      // 4-6 kelime = dÃžÅÃžk gÃžven
      else if (wordCount > 3) {
        confidence = 'low';
      }
      
      potansiyelIsimler.push({
        text: cleanLine,
        lineNumber: i,
        confidence: confidence,
        originalLine: line // Orijinal satÄąrÄą da sakla
      });
      
      console.log(`   â Aday ${potansiyelIsimler.length}: "${cleanLine}" (SatÄąr: ${i}, GÃžven: ${confidence})`);
    }
    
    // 2. HiÃ§ isim bulunamadÄąysa, en uzun satÄąrlarÄą gÃķster (fallback)
    if (potansiyelIsimler.length === 0) {
      console.log('â ïļ HiÃ§ isim adayÄą bulunamadÄą, en uzun satÄąrlar gÃķsteriliyor...');
      
      const longLines = lines
        .map((line, i) => ({ line, index: i, length: line.length }))
        .filter(l => l.length >= 10 && l.length <= 100)
        .sort((a, b) => b.length - a.length)
        .slice(0, 10);
      
      longLines.forEach(l => {
        potansiyelIsimler.push({
          text: l.line,
          lineNumber: l.index,
          confidence: 'low',
          originalLine: l.line
        });
      });
      
      console.log(`   â ${potansiyelIsimler.length} uzun satÄąr eklendi (fallback)`);
    }
    
    // ð§  AkÄąllÄą sistem ile ilk sayfayÄą test et
    console.log('\nð§  AkÄąllÄą sistem ile ilk sayfa test ediliyor...');
    const testMatch = await intelligentCascadeMatching(
      text, 
      sinav_id, 
      req.session.userId, 
      tempFilePath
    );
    
    let autoSelectedPattern = null;
    let autoConfidence = 0;
    
    if (testMatch && testMatch.confidence >= 0.80) {
      autoSelectedPattern = {
        text: testMatch.extractedName,
        lineNumber: testMatch.lineNumber,
        confidence: testMatch.confidence,
        strategy: testMatch.usedStrategy,
        matchedStudent: testMatch.ogrenciAd
      };
      autoConfidence = testMatch.confidence;
      console.log(`â Otomatik pattern bulundu: "${testMatch.extractedName}" (GÃžven: ${(autoConfidence * 100).toFixed(0)}%)`);
    } else {
      console.log('â ïļ Otomatik pattern bulunamadÄą, manuel seÃ§im gerekli');
    }
    
    // GeÃ§ici dosyalarÄą temizle
    fs.unlinkSync(tempFilePath);
    
    console.log(`â ${potansiyelIsimler.length} potansiyel isim bulundu`);
    potansiyelIsimler.forEach(p => console.log(`   - ${p.text} (satÄąr ${p.lineNumber}, gÃžven: ${p.confidence})`));
    
    res.json({
      success: true,
      data: {
        totalPages: totalPages,
        uploadPath: req.file.path,
        originalName: req.file.originalname,
        sinavId: sinav_id,
        potansiyelIsimler: potansiyelIsimler.slice(0, 15), // Ä°lk 15 aday
        ornekText: text.substring(0, 500), // KullanÄącÄąya gÃķster
        allLines: lines, // TÃžm satÄąrlarÄą da gÃķnder (frontend iÃ§in)
        autoSelectedPattern: autoSelectedPattern, // ðŊ Otomatik seÃ§ilen pattern
        useAutoMode: autoConfidence >= 0.85 // %85+ gÃžven varsa direkt kullan
      }
    });
    
  } catch (error) {
    console.error('SonuÃ§ analiz hatasÄą:', error);
    
    // DosyayÄą temizle
    if (req.file && req.file.path) {
      try { fs.unlinkSync(req.file.path); } catch (e) {}
    }
    
    res.status(500).json({ 
      success: false, 
      error: 'Analiz sÄąrasÄąnda bir hata oluÅtu: ' + error.message 
    });
  }
});

// Kurum - SonuÃ§ PDF Kaydet (TÃžm sayfalarÄą iÅle, eÅleÅtir, kaydet)
app.post('/kurum/sinav-sonuc-yukle-kaydet', requireAuth, async (req, res) => {
  if (req.session.userType !== 'kurum_yonetici') {
    return res.status(403).json({ success: false, error: 'Yetkiniz yok!' });
  }
  
  try {
    const { sinav_id, pdfPath, selectedPattern, selectedLineNumber, manuelEslesmeler } = req.body;
    
    if (!sinav_id || !pdfPath) {
      return res.status(400).json({ success: false, error: 'SÄąnav ID veya PDF dosya yolu eksik!' });
    }
    
    console.log('\nð§  AKILLI SINAV SONUÃLARI YÃKLENÄ°YOR');
    console.log('â SÄąnav ID:', sinav_id);
    console.log('â PDF Path:', pdfPath);
    console.log('ðŊ Mod: AkÄąllÄą Cascade Matching (5 strateji)');
    
    const results = [];
    let matchedCount = 0;
    let unmatchedCount = 0;
    let savedCount = 0;
    let strategyStats = {};
    
    // SÄąnav bilgilerini al
    const sinav = await dbGet('SELECT * FROM sinavlar WHERE id = ?', [sinav_id]);
    
    if (!sinav) {
      return res.status(400).json({ success: false, error: 'SÄąnav bulunamadÄą!' });
    }
    
    // SonuÃ§ klasÃķrÃžnÃž oluÅtur
    const sonucKlasoru = path.join('uploads', 'sinav-sonuclari', `sinav_${sinav_id}`);
    if (!fs.existsSync(sonucKlasoru)) {
      fs.mkdirSync(sonucKlasoru, { recursive: true });
    }
    
    // PDF'i yÃžkle
    if (!fs.existsSync(pdfPath)) {
      return res.status(400).json({ success: false, error: 'PDF dosyasÄą bulunamadÄą!' });
    }
    
    const pdfBytes = fs.readFileSync(pdfPath);
    const pdfDoc = await PDFDocument.load(pdfBytes);
    const totalPages = pdfDoc.getPageCount();
    
    console.log(`ð Toplam sayfa: ${totalPages}`);
    console.log(`ð SonuÃ§ klasÃķrÃž: ${sonucKlasoru}`);
    
    // Manuel eÅleÅmeleri map'e Ã§evir (sayfa numarasÄą â ÃķÄrenci ID)
    const manuelMap = {};
    if (manuelEslesmeler && Array.isArray(manuelEslesmeler)) {
      manuelEslesmeler.forEach(m => {
        if (m.sayfaNo && m.ogrenciId) {
          manuelMap[m.sayfaNo] = m.ogrenciId;
        }
      });
      console.log(`ð ${Object.keys(manuelMap).length} manuel eÅleÅme alÄąndÄą`);
    }
    
    // Her sayfayÄą iÅle
    for (let i = 0; i < totalPages; i++) {
      try {
        const sayfaNo = i + 1;
        console.log(`\nð Sayfa ${sayfaNo}/${totalPages} iÅleniyor...`);
        
        // Bu sayfayÄą ayrÄą bir PDF olarak oluÅtur
        const singlePagePdf = await PDFDocument.create();
        const [copiedPage] = await singlePagePdf.copyPages(pdfDoc, [i]);
        singlePagePdf.addPage(copiedPage);
        const singlePageBytes = await singlePagePdf.save();
        
        // GeÃ§ici dosya adÄą oluÅtur
        const tempFileName = `temp_sinav_page_${sayfaNo}_${Date.now()}.pdf`;
        const tempFilePath = path.join('uploads', tempFileName);
        fs.writeFileSync(tempFilePath, singlePageBytes);
        
        // Bu sayfadan text Ã§Äąkar
        const extractionResult = await extractTextHybrid(tempFilePath);
        const text = extractionResult.text;
        const isGarbled = extractionResult.garbled || false;
        
        let ogrenciId = null;
        let ogrenciAdi = 'BÄ°LÄ°NMEYEN';
        let kaynak = 'kurum';
        let usedStrategy = null;
        let confidence = 0;
        let extractedName = '';
        
        // Manuel eÅleÅme var mÄą kontrol et
        if (manuelMap[sayfaNo]) {
          // Manuel eÅleÅme var
          ogrenciId = manuelMap[sayfaNo];
          const ogrenci = await dbGet('SELECT * FROM ogrenci_kayitlari WHERE id = ?', [ogrenciId]);
          if (ogrenci) {
            ogrenciAdi = ogrenci.ogrenci_adi_soyadi;
            console.log(`â Manuel eÅleÅme: ${ogrenciAdi} (ID: ${ogrenciId})`);
            matchedCount++;
            usedStrategy = 'Manuel';
            confidence = 1.0;
          } else {
            console.log(`â ïļ Manuel eÅleÅme geÃ§ersiz! ÃÄrenci ID ${ogrenciId} bulunamadÄą.`);
            unmatchedCount++;
          }
        } else {
          // ð§  AKILLI CASCADE MATCHING KULLAN
          const matchResult = await intelligentCascadeMatching(
            text, 
            sinav_id, 
            req.session.userId,
            tempFilePath
          );
          
          if (matchResult && matchResult.confidence >= 0.75) {
            // BaÅarÄąlÄą eÅleÅme
            ogrenciId = matchResult.ogrenciId;
            ogrenciAdi = matchResult.ogrenciAd;
            kaynak = matchResult.kaynak;
            extractedName = matchResult.extractedName;
            confidence = matchResult.confidence;
            usedStrategy = matchResult.usedStrategy;
            
            // Strateji istatistiklerini gÃžncelle
            strategyStats[usedStrategy] = (strategyStats[usedStrategy] || 0) + 1;
            
            console.log(`â AkÄąllÄą eÅleÅme: ${ogrenciAdi} (Strateji: ${usedStrategy}, GÃžven: ${(confidence * 100).toFixed(0)}%)`);
            matchedCount++;
          } else {
            // EÅleÅme baÅarÄąsÄąz
            console.log(`â TÃžm stratejiler baÅarÄąsÄąz - Manuel gerekli`);
            unmatchedCount++;
          }
        }
        
        // PDF'i kaydet
        const sanitizedName = ogrenciAdi.replace(/[^a-zA-ZÃ§ÃÄÄÄąÄ°ÃķÃÅÅÃžÃ\s]/g, '').replace(/\s+/g, '_');
        const finalFileName = ogrenciId 
          ? `${sayfaNo}_${sanitizedName}_${ogrenciId}.pdf`
          : `${sayfaNo}_BILINMEYEN_${Date.now()}.pdf`;
        
        const finalFilePath = path.join(sonucKlasoru, finalFileName);
        fs.writeFileSync(finalFilePath, singlePageBytes);
        
        console.log(`ðū PDF kaydedildi: ${finalFileName}`);
        
        // VeritabanÄąna kaydet (eÄer eÅleÅme varsa)
        if (ogrenciId) {
          try {
            // sinav_katilimcilari tablosunu gÃžncelle
            await dbRun(`
              UPDATE sinav_katilimcilari 
              SET pdf_path = ?, sonuc_durumu = 'yuklendi' 
              WHERE sinav_id = ? AND ogrenci_id = ? AND ogrenci_kaynak = ?
            `, [finalFilePath, sinav_id, ogrenciId, kaynak]);
            
            savedCount++;
            console.log(`â VeritabanÄąna kaydedildi`);
          } catch (dbError) {
            console.error(`â VeritabanÄą kayÄąt hatasÄą:`, dbError);
          }
        }
        
        // SonuÃ§ listesine ekle
        results.push({
          sayfaNo: sayfaNo,
          ogrenciId: ogrenciId,
          ogrenciAdi: ogrenciAdi,
          pdfYolu: finalFilePath,
          eslesti: !!ogrenciId,
          extractedName: extractedName,
          isGarbled: isGarbled,
          strategy: usedStrategy,
          confidence: confidence
        });
        
        // GeÃ§ici dosyayÄą temizle
        fs.unlinkSync(tempFilePath);
        
      } catch (pageError) {
        console.error(`â Sayfa ${i + 1} iÅlenirken hata:`, pageError);
        results.push({
          sayfaNo: i + 1,
          ogrenciId: null,
          ogrenciAdi: 'HATA',
          pdfYolu: null,
          eslesti: false,
          error: pageError.message
        });
        unmatchedCount++;
      }
    }
    
    // SÄąnavÄą gÃžncelle (sonuc_yuklendi = 1)
    await dbRun('UPDATE sinavlar SET sonuc_yuklendi = 1 WHERE id = ?', [sinav_id]);
    
    // YÃžklenen PDF dosyasÄąnÄą temizle
    try {
      fs.unlinkSync(pdfPath);
    } catch (cleanError) {
      console.error('â ïļ GeÃ§ici PDF temizlenemedi:', cleanError);
    }
    
    console.log('\nâ Ä°ÅLEM TAMAMLANDI!');
    console.log(`   Toplam sayfa: ${totalPages}`);
    console.log(`   EÅleÅen: ${matchedCount}`);
    console.log(`   EÅleÅmeyen: ${unmatchedCount}`);
    console.log(`   Kaydedilen: ${savedCount}`);
    console.log(`\nð Strateji Ä°statistikleri:`);
    Object.entries(strategyStats).forEach(([strategy, count]) => {
      console.log(`   ${strategy}: ${count} sayfa`);
    });
    
    res.json({
      success: true,
      message: `${matchedCount}/${totalPages} sayfa otomatik eÅleÅtirildi (AkÄąllÄą Sistem)`,
      data: {
        totalPages: totalPages,
        matchedCount: matchedCount,
        unmatchedCount: unmatchedCount,
        savedCount: savedCount,
        strategyStats: strategyStats,
        results: results
      }
    });
    
  } catch (error) {
    console.error('â SonuÃ§ kaydetme hatasÄą:', error);
    
    res.status(500).json({ 
      success: false, 
      error: 'Kaydetme sÄąrasÄąnda bir hata oluÅtu: ' + error.message 
    });
  }
});

// Kurum - Manuel SÄąnav SonuÃ§ EÅleÅtirme
app.post('/kurum/sinav-manuel-eslestir/:id', requireAuth, async (req, res) => {
  if (req.session.userType !== 'kurum_yonetici') {
    return res.status(403).json({ success: false, message: 'Yetkiniz yok!' });
  }
  
  try {
    const sinavId = req.params.id;
    const { eslesmeler } = req.body;
    
    if (!eslesmeler || eslesmeler.length === 0) {
      return res.json({ success: false, message: 'EÅleÅtirme bilgisi eksik!' });
    }
    
    console.log(`\nð MANUEL EÅLEÅTIRME (SÄąnav ID: ${sinavId})`);
    console.log(`   ${eslesmeler.length} adet eÅleÅtirme yapÄąlacak`);
    
    let basarili = 0;
    let hatali = 0;
    
    for (const eslesme of eslesmeler) {
      try {
        const { sayfaNo, pdfYolu, ogrenciId, kaynak } = eslesme;
        
        console.log(`   ð Sayfa ${sayfaNo}:`);
        console.log(`      - ÃÄrenci ID: ${ogrenciId}`);
        console.log(`      - Kaynak: ${kaynak}`);
        console.log(`      - PDF Yolu: ${pdfYolu}`);
        console.log(`      - Dosya var mÄą: ${pdfYolu ? fs.existsSync(pdfYolu) : 'PDF yolu boÅ'}`);
        
        // PDF dosyasÄąnÄą yeni isimle kaydet
        if (pdfYolu && fs.existsSync(pdfYolu)) {
          // ÃÄrenci bilgilerini al
          let ogrenci;
          if (kaynak === 'veli') {
            ogrenci = await dbGet('SELECT ad_soyad FROM ogrenciler WHERE id = ?', [ogrenciId]);
          } else {
            ogrenci = await dbGet('SELECT ogrenci_adi_soyadi as ad_soyad FROM ogrenci_kayitlari WHERE id = ?', [ogrenciId]);
          }
          
          if (ogrenci) {
            // Yeni dosya adÄą oluÅtur
            const sonucKlasoru = path.join('uploads', 'sinav-sonuclari', `sinav_${sinavId}`);
            if (!fs.existsSync(sonucKlasoru)) {
              fs.mkdirSync(sonucKlasoru, { recursive: true });
            }
            
            const timestamp = Date.now();
            const safeIsim = ogrenci.ad_soyad.replace(/[^a-zA-ZÃ§ÃÄÄÄąÄ°ÃķÃÅÅÃžÃ\s]/g, '').replace(/\s+/g, '_');
            const yeniDosyaAdi = `${safeIsim}_${timestamp}.pdf`;
            const yeniDosyaYolu = path.join(sonucKlasoru, yeniDosyaAdi);
            
            // DosyayÄą kopyala
            fs.copyFileSync(pdfYolu, yeniDosyaYolu);
            
            // sinav_katilimcilari tablosunu gÃžncelle
            await dbRun(`
              UPDATE sinav_katilimcilari 
              SET pdf_path = ?, sonuc_durumu = 'yuklendi'
              WHERE sinav_id = ? AND ogrenci_id = ? AND ogrenci_kaynak = ?
            `, [yeniDosyaYolu, sinavId, ogrenciId, kaynak]);
            
            console.log(`   â BaÅarÄąlÄą: ${ogrenci.ad_soyad}`);
            basarili++;
          } else {
            console.log(`   â ÃÄrenci bulunamadÄą: ${ogrenciId}`);
            hatali++;
          }
        } else {
          console.log(`   â PDF dosyasÄą bulunamadÄą: ${pdfYolu}`);
          hatali++;
        }
      } catch (error) {
        console.error(`   â EÅleÅtirme hatasÄą:`, error);
        hatali++;
      }
    }
    
    // SÄąnavÄąn sonuc_yuklendi durumunu gÃžncelle (ama henÃžz yayÄąnlanmamÄąÅ)
    await dbRun('UPDATE sinavlar SET sonuc_yuklendi = 1, sonuc_yayinlandi = 0 WHERE id = ?', [sinavId]);
    
    // â GÃNCEL Ä°STATÄ°STÄ°KLERÄ° HESAPLA
    const istatistikler = await dbGet(`
      SELECT 
        COUNT(*) as toplam,
        SUM(CASE WHEN pdf_path IS NOT NULL AND pdf_path != '' THEN 1 ELSE 0 END) as eslesmis,
        SUM(CASE WHEN pdf_path IS NULL OR pdf_path = '' THEN 1 ELSE 0 END) as eslesmemis
      FROM sinav_katilimcilari
      WHERE sinav_id = ?
    `, [sinavId]);
    
    console.log(`\nð MANUEL EÅLEÅTIRME TAMAMLANDI:`);
    console.log(`   â BaÅarÄąlÄą: ${basarili}`);
    console.log(`   â HatalÄą: ${hatali}`);
    console.log(`\nð GÃNCEL DURUM:`);
    console.log(`   Toplam KatÄąlÄąmcÄą: ${istatistikler.toplam}`);
    console.log(`   EÅleÅen: ${istatistikler.eslesmis}`);
    console.log(`   EÅleÅmeyen: ${istatistikler.eslesmemis}`);
    
    res.json({ 
      success: true, 
      message: `${basarili} ÃķÄrenci eÅleÅtirildi! ${hatali > 0 ? `(${hatali} hata)` : ''}`,
      matchedCount: istatistikler.eslesmis || 0,
      unmatchedCount: istatistikler.eslesmemis || 0,
      totalCount: istatistikler.toplam || 0
    });
  } catch (error) {
    console.error('â Manuel eÅleÅtirme hatasÄą:', error);
    res.json({ success: false, message: 'Bir hata oluÅtu!' });
  }
});

// ð Kurum - EÅleÅmemiÅ PDF SayfalarÄąnÄą Listele
app.get('/kurum/sinav-eslesmemis-pdfler/:id', requireAuth, async (req, res) => {
  if (req.session.userType !== 'kurum_yonetici') {
    return res.status(403).json({ success: false, error: 'Yetkiniz yok!' });
  }
  
  try {
    const sinavId = req.params.id;
    
    console.log('\nð TÃM PDF SAYFALARI LÄ°STELENÄ°YOR (EÅleÅen + EÅleÅmeyen):', sinavId);
    
    // TÃM yÃžklenmiÅ PDF'leri al - HEM EÅLEÅEN HEM EÅLEÅMEYEN
    // pdf_path NULL olanlar = henÃžz eÅleÅmemiÅ (BÄ°LÄ°NMEYEN)
    // pdf_path dolu olanlar = eÅleÅmiÅ
    // BÄ°LÄ°NMEYEN olanlar = PDF var ama ÃķÄrenci eÅleÅmemiÅ
    const eslesmemisOgrenciler = await dbAll(`
      SELECT 
        sk.id as katilimci_id,
        sk.ogrenci_id,
        sk.ogrenci_kaynak as kaynak,
        sk.pdf_path,
        sk.sonuc_durumu,
        CASE 
          WHEN sk.ogrenci_kaynak = 'kurum' THEN ok.ogrenci_adi_soyadi
          WHEN sk.ogrenci_kaynak = 'veli' THEN o.ad_soyad
          ELSE 'BÄ°LÄ°NMEYEN'
        END as ad_soyad,
        CASE 
          WHEN sk.ogrenci_kaynak = 'kurum' THEN ok.sinif
          WHEN sk.ogrenci_kaynak = 'veli' THEN o.sinif
        END as sinif
      FROM sinav_katilimcilari sk
      LEFT JOIN ogrenci_kayitlari ok ON sk.ogrenci_id = ok.id AND sk.ogrenci_kaynak = 'kurum'
      LEFT JOIN ogrenciler o ON sk.ogrenci_id = o.id AND sk.ogrenci_kaynak = 'veli'
      WHERE sk.sinav_id = ?
      ORDER BY 
        CASE 
          WHEN sk.pdf_path IS NOT NULL AND (ok.ogrenci_adi_soyadi = 'BÄ°LÄ°NMEYEN' OR o.ad_soyad = 'BÄ°LÄ°NMEYEN' OR (ok.ogrenci_adi_soyadi IS NULL AND o.ad_soyad IS NULL)) THEN 0
          WHEN sk.pdf_path IS NULL THEN 1
          ELSE 2
        END,
        sk.id
    `, [sinavId]);
    
    // EÅleÅtirilebilir ÃķÄrencileri al (tÃžm katÄąlÄąmcÄąlar)
    const tumOgrenciler = await dbAll(`
      SELECT 
        sk.ogrenci_id,
        sk.ogrenci_kaynak as kaynak,
        CASE 
          WHEN sk.ogrenci_kaynak = 'kurum' THEN ok.ogrenci_adi_soyadi
          WHEN sk.ogrenci_kaynak = 'veli' THEN o.ad_soyad
        END as ad_soyad,
        CASE 
          WHEN sk.ogrenci_kaynak = 'kurum' THEN ok.sinif
          WHEN sk.ogrenci_kaynak = 'veli' THEN o.sinif
        END as sinif
      FROM sinav_katilimcilari sk
      LEFT JOIN ogrenci_kayitlari ok ON sk.ogrenci_id = ok.id AND sk.ogrenci_kaynak = 'kurum'
      LEFT JOIN ogrenciler o ON sk.ogrenci_id = o.id AND sk.ogrenci_kaynak = 'veli'
      WHERE sk.sinav_id = ?
      ORDER BY ad_soyad
    `, [sinavId]);
    
    // Orijinal PDF yolunu bul - eÅleÅmiÅ herhangi bir ÃķÄrencinin PDF'inden al
    let orijinalPdfYolu = null;
    
    // Ãnce sinavlar tablosuna bak
    const sinav = await dbGet('SELECT dosya_yolu FROM sinavlar WHERE id = ?', [sinavId]);
    if (sinav && sinav.dosya_yolu) {
        orijinalPdfYolu = sinav.dosya_yolu;
    } else {
        // Yoksa eÅleÅmiÅ herhangi bir ÃķÄrencinin PDF'ini al
        const eslesmisOgrenci = await dbGet(
            'SELECT pdf_path FROM sinav_katilimcilari WHERE sinav_id = ? AND pdf_path IS NOT NULL LIMIT 1',
            [sinavId]
        );
        if (eslesmisOgrenci && eslesmisOgrenci.pdf_path) {
            orijinalPdfYolu = eslesmisOgrenci.pdf_path;
        }
    }
    
    console.log(`   ð EÅleÅmemiÅ: ${eslesmemisOgrenciler.length}`);
    console.log(`   ðĨ Toplam ÃÄrenci: ${tumOgrenciler.length}`);
    console.log(`   ð PDF Yolu: ${orijinalPdfYolu}`);
    
    res.json({
      success: true,
      data: {
        eslesmemisPdfler: eslesmemisOgrenciler,
        tumOgrenciler: tumOgrenciler,
        orijinalPdfYolu: orijinalPdfYolu
      }
    });
    
  } catch (error) {
    console.error('â EÅleÅmemiÅ PDF listeleme hatasÄą:', error);
    res.json({ success: false, error: error.message });
  }
});

// ð Kurum - Mevcut PDF'i BaÅka ÃÄrenciye Ata
app.post('/kurum/sinav-pdf-yeniden-eslestir', requireAuth, async (req, res) => {
  if (req.session.userType !== 'kurum_yonetici') {
    return res.status(403).json({ success: false, message: 'Yetkiniz yok!' });
  }
  
  try {
    const { katilimci_id, yeni_ogrenci_id, yeni_kaynak, sinav_id } = req.body;
    
    console.log(`\nð PDF YENÄ°DEN EÅLEÅTÄ°RÄ°LÄ°YOR`);
    console.log(`   KatÄąlÄąmcÄą ID: ${katilimci_id}`);
    console.log(`   Yeni ÃÄrenci ID: ${yeni_ogrenci_id}`);
    console.log(`   Yeni Kaynak: ${yeni_kaynak}`);
    
    // Eski katÄąlÄąmcÄąnÄąn PDF yolunu al
    const eskiKatilimci = await dbGet('SELECT pdf_path FROM sinav_katilimcilari WHERE id = ?', [katilimci_id]);
    
    if (!eskiKatilimci || !eskiKatilimci.pdf_path) {
      return res.json({ success: false, message: 'PDF bulunamadÄą!' });
    }
    
    // Yeni ÃķÄrenci bilgilerini al
    let yeniOgrenci;
    if (yeni_kaynak === 'kurum') {
      yeniOgrenci = await dbGet('SELECT ogrenci_adi_soyadi as ad_soyad FROM ogrenci_kayitlari WHERE id = ?', [yeni_ogrenci_id]);
    } else {
      yeniOgrenci = await dbGet('SELECT ad_soyad FROM ogrenciler WHERE id = ?', [yeni_ogrenci_id]);
    }
    
    if (!yeniOgrenci) {
      return res.json({ success: false, message: 'ÃÄrenci bulunamadÄą!' });
    }
    
    // Eski PDF yolunu al
    const eskiPdfPath = eskiKatilimci.pdf_path;
    
    // Yeni dosya adÄą oluÅtur
    const sinavKlasoru = path.join(__dirname, 'uploads', 'sinav-sonuclari', `sinav_${sinav_id}`);
    const guvenliIsim = yeniOgrenci.ad_soyad.replace(/[^a-zA-Z0-9ÄÃžÅÃķÃ§Ä°ÄÃÅÃÃ\s]/g, '').replace(/\s+/g, '_');
    const timestamp = Date.now();
    const yeniDosyaAdi = `${guvenliIsim}_${timestamp}.pdf`;
    const yeniDosyaYolu = path.join(sinavKlasoru, yeniDosyaAdi);
    
    // DosyayÄą kopyala/taÅÄą
    const eskiTamYol = path.join(__dirname, eskiPdfPath);
    if (fs.existsSync(eskiTamYol)) {
      fs.copyFileSync(eskiTamYol, yeniDosyaYolu);
    }
    
    // VeritabanÄąnÄą gÃžncelle
    const relativePath = path.join('uploads', 'sinav-sonuclari', `sinav_${sinav_id}`, yeniDosyaAdi);
    
    // Yeni ÃķÄrenci iÃ§in kayÄąt oluÅtur/gÃžncelle
    await dbRun(`
      UPDATE sinav_katilimcilari 
      SET pdf_path = ?, sonuc_durumu = 'yuklendi'
      WHERE sinav_id = ? AND ogrenci_id = ? AND ogrenci_kaynak = ?
    `, [relativePath, sinav_id, yeni_ogrenci_id, yeni_kaynak]);
    
    // Eski kaydÄą temizle (PDF'i kaldÄąr)
    await dbRun(`
      UPDATE sinav_katilimcilari 
      SET pdf_path = NULL, sonuc_durumu = 'bekleniyor'
      WHERE id = ?
    `, [katilimci_id]);
    
    // Eski dosyayÄą sil
    if (fs.existsSync(eskiTamYol)) {
      fs.unlinkSync(eskiTamYol);
    }
    
    console.log(`   â PDF baÅarÄąyla "${yeniOgrenci.ad_soyad}" iÃ§in atandÄą`);
    
    res.json({ 
      success: true, 
      message: `â PDF baÅarÄąyla "${yeniOgrenci.ad_soyad}" ile eÅleÅtirildi!`
    });
    
  } catch (error) {
    console.error('â PDF yeniden eÅleÅtirme hatasÄą:', error);
    res.json({ success: false, message: 'Bir hata oluÅtu: ' + error.message });
  }
});

// ðĪ Kurum - Tek ÃÄrenci Ä°Ã§in PDF EÅleÅtir
app.post('/kurum/sinav-tek-ogrenci-eslestir', requireAuth, upload.single('pdf'), async (req, res) => {
  if (req.session.userType !== 'kurum_yonetici') {
    return res.status(403).json({ success: false, message: 'Yetkiniz yok!' });
  }
  
  try {
    const { sinav_id, ogrenci_id, kaynak } = req.body;
    const pdfFile = req.file;
    
    if (!pdfFile) {
      return res.json({ success: false, message: 'PDF dosyasÄą yÃžklenmedi!' });
    }
    
    console.log(`\nðĪ TEK ÃÄRENCÄ° EÅLEÅTÄ°RME`);
    console.log(`   SÄąnav ID: ${sinav_id}`);
    console.log(`   ÃÄrenci ID: ${ogrenci_id}`);
    console.log(`   Kaynak: ${kaynak}`);
    console.log(`   PDF: ${pdfFile.filename}`);
    
    // ÃÄrenci bilgilerini al
    let ogrenci;
    if (kaynak === 'kurum') {
      ogrenci = await dbGet('SELECT ogrenci_adi_soyadi as ad_soyad FROM ogrenci_kayitlari WHERE id = ?', [ogrenci_id]);
    } else {
      ogrenci = await dbGet('SELECT ad_soyad FROM ogrenciler WHERE id = ?', [ogrenci_id]);
    }
    
    if (!ogrenci) {
      return res.json({ success: false, message: 'ÃÄrenci bulunamadÄą!' });
    }
    
    // SÄąnav klasÃķrÃžnÃž oluÅtur
    const sinavKlasoru = path.join(__dirname, 'uploads', 'sinav-sonuclari', `sinav_${sinav_id}`);
    if (!fs.existsSync(sinavKlasoru)) {
      fs.mkdirSync(sinavKlasoru, { recursive: true });
    }
    
    // Dosya adÄąnÄą oluÅtur
    const guvenliIsim = ogrenci.ad_soyad.replace(/[^a-zA-Z0-9ÄÃžÅÃķÃ§Ä°ÄÃÅÃÃ\s]/g, '').replace(/\s+/g, '_');
    const timestamp = Date.now();
    const yeniDosyaAdi = `${guvenliIsim}_${timestamp}.pdf`;
    const yeniDosyaYolu = path.join(sinavKlasoru, yeniDosyaAdi);
    
    // DosyayÄą taÅÄą
    fs.copyFileSync(pdfFile.path, yeniDosyaYolu);
    fs.unlinkSync(pdfFile.path); // GeÃ§ici dosyayÄą sil
    
    // VeritabanÄąnÄą gÃžncelle
    const relativePath = path.join('uploads', 'sinav-sonuclari', `sinav_${sinav_id}`, yeniDosyaAdi);
    await dbRun(`
      UPDATE sinav_katilimcilari 
      SET pdf_path = ?, sonuc_durumu = 'yuklendi'
      WHERE sinav_id = ? AND ogrenci_id = ? AND ogrenci_kaynak = ?
    `, [relativePath, sinav_id, ogrenci_id, kaynak]);
    
    // SÄąnavÄąn sonuc_yuklendi durumunu gÃžncelle
    await dbRun('UPDATE sinavlar SET sonuc_yuklendi = 1 WHERE id = ?', [sinav_id]);
    
    console.log(`   â BaÅarÄąlÄą: ${ogrenci.ad_soyad} iÃ§in PDF eÅleÅtirildi`);
    
    res.json({ 
      success: true, 
      message: `â ${ogrenci.ad_soyad} iÃ§in sonuÃ§ baÅarÄąyla eÅleÅtirildi!`
    });
    
  } catch (error) {
    console.error('â Tek ÃķÄrenci eÅleÅtirme hatasÄą:', error);
    res.json({ success: false, message: 'Bir hata oluÅtu: ' + error.message });
  }
});

// ðĒ Kurum - SÄąnav SonuÃ§larÄąnÄą YayÄąnla (Velilere gÃķrÃžnÃžr hale getir)
app.post('/kurum/sinav-sonuclari-yayinla/:id', requireAuth, async (req, res) => {
  if (req.session.userType !== 'kurum_yonetici') {
    return res.status(403).json({ success: false, message: 'Yetkiniz yok!' });
  }
  
  try {
    const sinavId = req.params.id;
    
    console.log('\nðĒ SINAV SONUÃLARI YAYINLANIYOR:', sinavId);
    
    // SÄąnav bilgilerini al
    const sinav = await dbGet('SELECT * FROM sinavlar WHERE id = ?', [sinavId]);
    
    if (!sinav) {
      return res.json({ success: false, message: 'SÄąnav bulunamadÄą!' });
    }
    
    if (!sinav.sonuc_yuklendi) {
      return res.json({ success: false, message: 'HenÃžz sonuÃ§ yÃžklenmemiÅ!' });
    }
    
    if (sinav.sonuc_yayinlandi) {
      return res.json({ success: false, message: 'SonuÃ§lar zaten yayÄąnlanmÄąÅ!' });
    }
    
    // EÅleÅmiÅ sonuÃ§ sayÄąsÄąnÄą kontrol et
    const eslesmisler = await dbAll(`
      SELECT COUNT(*) as sayi 
      FROM sinav_katilimcilari 
      WHERE sinav_id = ? AND pdf_path IS NOT NULL
    `, [sinavId]);
    
    const eslesmeSayisi = eslesmisler[0]?.sayi || 0;
    
    if (eslesmeSayisi === 0) {
      return res.json({ success: false, message: 'HiÃ§ eÅleÅmiÅ sonuÃ§ yok! LÃžtfen Ãķnce eÅleÅtirme yapÄąn.' });
    }
    
    // SÄąnavÄą yayÄąnla
    await dbRun('UPDATE sinavlar SET sonuc_yayinlandi = 1 WHERE id = ?', [sinavId]);
    
    console.log(`   â YayÄąnlandÄą: ${eslesmeSayisi} sonuÃ§ velilere gÃķrÃžnÃžr hale geldi`);
    
    res.json({ 
      success: true, 
      message: `â SonuÃ§lar yayÄąnlandÄą! ${eslesmeSayisi} ÃķÄrencinin velisi artÄąk sonuÃ§larÄą gÃķrebilir.`
    });
    
  } catch (error) {
    console.error('â YayÄąnlama hatasÄą:', error);
    res.json({ success: false, message: 'Bir hata oluÅtu: ' + error.message });
  }
});

// Kurum - SÄąnav SonuÃ§ WhatsApp Bildirim GÃķnder
app.post('/kurum/sinav-sonuc-whatsapp-gonder/:id', requireAuth, async (req, res) => {
  if (req.session.userType !== 'kurum_yonetici') {
    return res.status(403).json({ success: false, message: 'Yetkiniz yok!' });
  }
  
  try {
    const sinavId = req.params.id;
    
    // SÄąnav bilgilerini al
    const sinav = await dbGet('SELECT * FROM sinavlar WHERE id = ?', [sinavId]);
    
    if (!sinav) {
      return res.json({ success: false, message: 'SÄąnav bulunamadÄą!' });
    }
    
    // Sonucu yÃžklenmiÅ katÄąlÄąmcÄąlarÄą al (hem kurum hem veli ÃķÄrencileri)
    const kurumKatilimcilari = await dbAll(`
      SELECT 
        sk.*,
        ok.ogrenci_adi_soyadi as ogrenci_adi,
        ok.veli_adi,
        ok.veli_telefon,
        ok.telefon as ogrenci_telefon,
        'kurum' as kaynak
      FROM sinav_katilimcilari sk
      INNER JOIN ogrenci_kayitlari ok ON sk.ogrenci_id = ok.id AND sk.ogrenci_kaynak = 'kurum'
      WHERE sk.sinav_id = ? AND sk.sonuc_durumu IN ('yuklendi', 'bildirildi') AND sk.pdf_path IS NOT NULL
    `, [sinavId]);
    
    const veliKatilimcilari = await dbAll(`
      SELECT 
        sk.*,
        o.ad_soyad as ogrenci_adi,
        u.ad_soyad as veli_adi,
        u.telefon as veli_telefon,
        o.telefon as ogrenci_telefon,
        'veli' as kaynak
      FROM sinav_katilimcilari sk
      INNER JOIN ogrenciler o ON sk.ogrenci_id = o.id AND sk.ogrenci_kaynak = 'veli'
      LEFT JOIN users u ON o.veli_id = u.id
      WHERE sk.sinav_id = ? AND sk.sonuc_durumu IN ('yuklendi', 'bildirildi') AND sk.pdf_path IS NOT NULL
    `, [sinavId]);
    
    const katilimcilar = [...kurumKatilimcilari, ...veliKatilimcilari];
    
    if (katilimcilar.length === 0) {
      return res.json({ success: false, message: 'Sonucu yÃžklenmiÅ ÃķÄrenci bulunamadÄą!' });
    }
    
    console.log(`\nðą WHATSAPP BÄ°LDÄ°RÄ°MLERÄ° GÃNDERÄ°LÄ°YOR`);
    console.log(`   SÄąnav: ${sinav.ad}`);
    console.log(`   Toplam katÄąlÄąmcÄą: ${katilimcilar.length}\n`);
    
    let basarili = 0;
    let basarisiz = 0;
    
    // Her ÃķÄrenci iÃ§in veli telefonuna bildirim gÃķnder
    for (const katilimci of katilimcilar) {
      // Veli telefonu Ãķncelikli, yoksa ÃķÄrenci telefonu
      const telefon = katilimci.veli_telefon || katilimci.ogrenci_telefon;
      
      console.log(`   ð ${katilimci.ogrenci_adi} (Veli: ${katilimci.veli_adi || 'Bilinmiyor'}) â ${telefon || 'TELEFON YOK'}`);
      
      if (!telefon) {
        console.log(`   â ïļ ${katilimci.ogrenci_adi} - Telefon numarasÄą yok!`);
        basarisiz++;
        continue;
      }
      
      // WhatsApp mesajÄąnÄą oluÅtur
      const mesaj = `ð SÄąnav Sonucu AÃ§ÄąklandÄą

SayÄąn ${katilimci.veli_adi || 'Veli'},

${katilimci.ogrenci_adi} ÃķÄrencinizin sÄąnav sonucu aÃ§ÄąklanmÄąÅtÄąr.

ð SÄąnav: ${sinav.ad}
ð Tarih: ${new Date(sinav.tarih).toLocaleDateString('tr-TR')}

ðĨ Sonucu gÃķrÃžntÃžlemek iÃ§in sisteme giriÅ yapÄąn:
ð ${req.protocol}://${req.get('host')}/login

âââââââââââââââââ
ðŦ SÄąnav Merkezi`;
      
      // WhatsApp gÃķnder
      const result = await whatsappBildirimGonder(
        telefon,
        mesaj,
        'sinav_sonuc'
      );
      
      if (result.success) {
        console.log(`   â ${katilimci.ogrenci_adi} - ${telefon}`);
        basarili++;
        
        // Bildirim durumunu gÃžncelle
        await dbRun(
          'UPDATE sinav_katilimcilari SET sonuc_durumu = ?, whatsapp_gonderim_tarihi = datetime("now") WHERE id = ?',
          ['bildirildi', katilimci.id]
        );
      } else {
        console.log(`   â ${katilimci.ogrenci_adi} - ${telefon} - ${result.message}`);
        basarisiz++;
      }
      
      // API rate limit iÃ§in kÃžÃ§Ãžk gecikme
      await new Promise(resolve => setTimeout(resolve, 500));
    }
    
    console.log(`\nâ Bildirim gÃķnderimi tamamlandÄą!`);
    console.log(`   BaÅarÄąlÄą: ${basarili}`);
    console.log(`   BaÅarÄąsÄąz: ${basarisiz}`);
    
    res.json({ 
      success: true, 
      message: `${basarili} bildirim gÃķnderildi, ${basarisiz} baÅarÄąsÄąz.`,
      basarili: basarili,
      basarisiz: basarisiz
    });
    
  } catch (error) {
    console.error('WhatsApp bildirim hatasÄą:', error);
    res.json({ success: false, message: 'Bildirim gÃķnderilirken bir hata oluÅtu!' });
  }
});

// Veli - SÄąnav SonuÃ§larÄą
app.get('/veli/sinav-sonuclari', requireAuth, requireRole('veli'), async (req, res) => {
  try {
    console.log(`\nð SINAV SONUÃLARI (Veli ID: ${req.session.userId}, Username: ${req.session.username})`);
    
    // 1. Veli'nin kendi eklediÄi ÃķÄrenciler (ogrenciler tablosu)
    const veliOgrencileri = await dbAll('SELECT * FROM ogrenciler WHERE veli_id = ?', [req.session.userId]);
    console.log(`   Veli ekledi: ${veliOgrencileri.length} ÃķÄrenci`);
    
    // 2. Kurum tarafÄąndan eklenen ÃķÄrenciler (TC eÅleÅmesi ile)
    const kurumOgrencileri = await dbAll(`
      SELECT 
        id,
        ogrenci_adi_soyadi as ad_soyad,
        sinif,
        tc_kimlik_no as tc_no,
        telefon,
        'kurum' as kaynak
      FROM ogrenci_kayitlari
      WHERE REPLACE(CAST(tc_kimlik_no AS TEXT), '.0', '') = ?
    `, [req.session.username]);
    console.log(`   Kurum ekledi: ${kurumOgrencileri.length} ÃķÄrenci (TC eÅleÅtirme)`);
    
    // 3. Ä°ki listeyi birleÅtir
    const ogrenciler = [...veliOgrencileri, ...kurumOgrencileri];
    console.log(`   ð TOPLAM: ${ogrenciler.length} ÃķÄrenci`);
    
    if (ogrenciler.length === 0) {
      return res.render('veli/sinav-sonuclari', {
        user: { username: req.session.username, type: req.session.userType },
        sonuclar: [],
        ogrenciler: [],
        error: 'HenÃžz ÃķÄrenci kaydÄąnÄąz bulunmuyor.',
        success: req.session.success
      });
    }
    
    // Veli'nin kendi eklediÄi ÃķÄrencilerin sonuÃ§larÄą (ogrenciler tablosu)
    const veliSonuclari = await dbAll(`
      SELECT 
        sk.id,
        sk.sinav_id,
        sk.ogrenci_id,
        sk.pdf_path,
        sk.sonuc_durumu,
        sk.pdf_goruldu,
        sk.pdf_gorunme_tarihi,
        sk.pdf_indirilme_sayisi,
        'veli' as kaynak,
        s.ad as sinav_adi,
        s.tarih as sinav_tarihi,
        s.sinif,
        s.ders,
        s.sinav_durumu,
        o.ad_soyad as ogrenci_adi_soyadi,
        o.sinif as ogrenci_sinif
      FROM sinav_katilimcilari sk
      INNER JOIN sinavlar s ON sk.sinav_id = s.id
      INNER JOIN ogrenciler o ON sk.ogrenci_id = o.id
      WHERE sk.ogrenci_kaynak = 'veli'
        AND o.veli_id = ?
        AND s.sonuc_yayinlandi = 1
        AND sk.pdf_path IS NOT NULL
    `, [req.session.userId]);
    
    console.log(`   â Veli ekledi: ${veliSonuclari.length} sonuÃ§`);
    
    // Kurum tarafÄąndan eklenen ÃķÄrencilerin sonuÃ§larÄą (ogrenci_kayitlari tablosu)
    const kurumSonuclari = await dbAll(`
      SELECT 
        sk.id,
        sk.sinav_id,
        sk.ogrenci_id,
        sk.pdf_path,
        sk.sonuc_durumu,
        sk.pdf_goruldu,
        sk.pdf_gorunme_tarihi,
        sk.pdf_indirilme_sayisi,
        'kurum' as kaynak,
        s.ad as sinav_adi,
        s.tarih as sinav_tarihi,
        s.sinif,
        s.ders,
        s.sinav_durumu,
        ok.ogrenci_adi_soyadi,
        ok.sinif as ogrenci_sinif
      FROM sinav_katilimcilari sk
      INNER JOIN sinavlar s ON sk.sinav_id = s.id
      INNER JOIN ogrenci_kayitlari ok ON sk.ogrenci_id = ok.id
      WHERE sk.ogrenci_kaynak = 'kurum'
        AND REPLACE(CAST(ok.tc_kimlik_no AS TEXT), '.0', '') = (SELECT username FROM users WHERE id = ?)
        AND s.sonuc_yayinlandi = 1
        AND sk.pdf_path IS NOT NULL
    `, [req.session.userId]);
    
    console.log(`   â Kurum ekledi: ${kurumSonuclari.length} sonuÃ§`);
    
    // Ä°ki kaynaÄÄą birleÅtir
    const sonuclar = [...veliSonuclari, ...kurumSonuclari].sort((a, b) => {
      return new Date(b.sinav_tarihi) - new Date(a.sinav_tarihi);
    });
    
    console.log(`   ð Toplam: ${sonuclar.length} sonuÃ§`);
    
    res.render('veli/sinav-sonuclari', {
      user: { username: req.session.username, type: req.session.userType },
      sonuclar: sonuclar,
      ogrenciler: ogrenciler,
      error: req.session.error,
      success: req.session.success
    });
    
    req.session.error = null;
    req.session.success = null;
  } catch (error) {
    console.error('SÄąnav sonuÃ§larÄą hatasÄą:', error);
    req.session.error = 'SÄąnav sonuÃ§larÄą yÃžklenirken bir hata oluÅtu!';
    res.redirect('/veli/dashboard');
  }
});

// Veli - SÄąnav SonuÃ§ PDF Ä°ndir
app.get('/veli/sinav-sonuc-indir/:katilimciId', requireAuth, requireRole('veli'), async (req, res) => {
  try {
    const katilimciId = req.params.katilimciId;
    
    // Ãnce ogrenci_kaynak'a bak
    const katilimciBilgi = await dbGet('SELECT ogrenci_kaynak, ogrenci_id, pdf_path FROM sinav_katilimcilari WHERE id = ?', [katilimciId]);
    
    if (!katilimciBilgi) {
      return res.status(404).send('SonuÃ§ bulunamadÄą!');
    }
    
    let yetkiVar = false;
    
    // Kaynak'a gÃķre yetki kontrolÃž
    if (katilimciBilgi.ogrenci_kaynak === 'veli') {
      // Veli'nin kendi eklediÄi ÃķÄrenci
      const ogrenci = await dbGet('SELECT veli_id FROM ogrenciler WHERE id = ?', [katilimciBilgi.ogrenci_id]);
      yetkiVar = ogrenci && ogrenci.veli_id === req.session.userId;
    } else {
      // Kurum ekledi, veli telefonuyla kontrol
      const user = await dbGet('SELECT telefon FROM users WHERE id = ?', [req.session.userId]);
      const ogrenci = await dbGet('SELECT veli_telefon FROM ogrenci_kayitlari WHERE id = ?', [katilimciBilgi.ogrenci_id]);
      yetkiVar = ogrenci && user && user.telefon === ogrenci.veli_telefon;
    }
    
    if (!yetkiVar) {
      return res.status(403).send('Bu sonuca eriÅim yetkiniz yok!');
    }
    
    // PDF var mÄą kontrol et
    if (!katilimciBilgi.pdf_path || !fs.existsSync(katilimciBilgi.pdf_path)) {
      return res.status(404).send('PDF dosyasÄą bulunamadÄą!');
    }
    
    // PDF indirme kaydÄąnÄą gÃžncelle
    const simdi = new Date().toISOString();
    await dbRun(`
      UPDATE sinav_katilimcilari 
      SET 
        pdf_goruldu = 1,
        pdf_gorunme_tarihi = ?,
        pdf_indirilme_sayisi = COALESCE(pdf_indirilme_sayisi, 0) + 1
      WHERE id = ?
    `, [simdi, katilimciId]);
    
    console.log(`\nðĨ PDF Ä°NDÄ°RME KAYDI`);
    console.log(`   KatÄąlÄąmcÄą ID: ${katilimciId}`);
    console.log(`   Tarih: ${simdi}`);
    console.log(`   Veli ID: ${req.session.userId}`);
    
    // PDF'i indir
    res.download(katilimciBilgi.pdf_path, path.basename(katilimciBilgi.pdf_path), (err) => {
      if (err) {
        console.error('PDF indirme hatasÄą:', err);
        res.status(500).send('PDF indirilemedi!');
      }
    });
    
  } catch (error) {
    console.error('PDF indirme hatasÄą:', error);
    res.status(500).send('Bir hata oluÅtu!');
  }
});

// Veli Profil
app.get('/veli/profil', requireAuth, requireRole('veli'), async (req, res) => {
  try {
    const kullanici = await dbGet('SELECT * FROM users WHERE id = ?', [req.session.userId]);
    
    // Talep edilen sÄąnavlarÄą getir
    const talepEdilenSinavlar = await dbAll(`
      SELECT 
        s.*,
        st.durum,
        st.talep_tarihi,
        st.yanitlanma_tarihi,
        st.yanit,
        COUNT(DISTINCT o.id) as ogrenci_sayisi
      FROM sinav_talepleri st
      INNER JOIN sinavlar s ON st.sinav_id = s.id
      LEFT JOIN ogrenciler o ON o.veli_id = ?
      WHERE st.veli_id = ?
      GROUP BY s.id, st.id
      ORDER BY st.talep_tarihi DESC
    `, [req.session.userId, req.session.userId]);
    
    // Login hatalarÄąnÄą filtrele - sadece profil ile ilgili hatalarÄą gÃķster
    let error = req.session.error;
    if (error && (error.includes('KullanÄącÄą adÄą veya Åifre') || error.includes('Åifre hatalÄą'))) {
      error = null; // Login hatalarÄąnÄą gÃķsterme
    }
    
    res.render('veli_profil', {
      user: { username: req.session.username, type: req.session.userType },
      kullanici: kullanici,
      talepEdilenSinavlar: talepEdilenSinavlar,
      error: error,
      success: req.session.success
    });
    req.session.error = null;
    req.session.success = null;
  } catch (error) {
    console.error('Profil hatasÄą:', error);
    req.session.error = 'Profil yÃžklenirken bir hata oluÅtu!';
    res.redirect('/veli/dashboard');
  }
});

// Veli Profil GÃžncelleme
app.post('/veli/profil', requireAuth, requireRole('veli'), async (req, res) => {
  try {
    const { ad_soyad, telefon, current_password, new_password } = req.body;
    
    if (!ad_soyad) {
      req.session.error = 'Ad Soyad alanÄą zorunludur';
      res.redirect('/veli/profil');
      return;
    }
    
    // Åifre deÄiÅtirme kontrolÃž
    if (new_password && new_password.trim() !== '') {
      if (!current_password || current_password.trim() === '') {
        req.session.error = 'Åifre deÄiÅtirmek iÃ§in mevcut Åifrenizi girmelisiniz!';
        res.redirect('/veli/profil');
        return;
      }
      
      if (new_password.length < 6) {
        req.session.error = 'Yeni Åifre en az 6 karakter olmalÄądÄąr!';
        res.redirect('/veli/profil');
        return;
      }
      
      // Mevcut Åifreyi kontrol et
      const kullanici = await dbGet('SELECT password_hash FROM users WHERE id = ?', [req.session.userId]);
      const sifreDogruMu = await bcrypt.compare(current_password, kullanici.password_hash);
      
      if (!sifreDogruMu) {
        req.session.error = 'Mevcut Åifreniz yanlÄąÅ!';
        res.redirect('/veli/profil');
        return;
      }
      
      // Yeni Åifreyi hashle
      const yeniSifreHash = await bcrypt.hash(new_password, 10);
      
      // Profil ve Åifreyi gÃžncelle
      await dbRun(
        'UPDATE users SET ad_soyad = ?, telefon = ?, password_hash = ? WHERE id = ?',
        [ad_soyad, telefon, yeniSifreHash, req.session.userId]
      );
      
      console.log(`â Veli Åifre deÄiÅtirdi: User ID ${req.session.userId}`);
      req.session.success = 'Profil bilgileriniz ve Åifreniz baÅarÄąyla gÃžncellendi!';
    } else {
      // Sadece profil bilgilerini gÃžncelle
      await dbRun(
        'UPDATE users SET ad_soyad = ?, telefon = ? WHERE id = ?',
        [ad_soyad, telefon, req.session.userId]
      );
      
      req.session.success = 'Profil bilgileriniz baÅarÄąyla gÃžncellendi!';
    }
    
    res.redirect('/veli/profil');
  } catch (error) {
    console.error('Profil gÃžncelleme hatasÄą:', error);
    req.session.error = 'Profil gÃžncellenirken bir hata oluÅtu!';
    res.redirect('/veli/profil');
  }
});

