app.post('/register', async (req, res) => {
  const { username, email, password, user_type } = req.body;
  
  try {
    // KullanÄącÄą adÄą kontrolÃž
    const existingUser = await dbGet('SELECT * FROM users WHERE username = ? OR email = ?', [username, email]);
    if (existingUser) {
      req.session.error = existingUser.username === username 
        ? 'Bu kullanÄącÄą adÄą zaten kullanÄąlÄąyor!'
        : 'Bu e-posta adresi zaten kullanÄąlÄąyor!';
      return res.redirect('/register');
    }
    
    // Åifreyi hashle
    const passwordHash = await bcrypt.hash(password, 10);
    
    // KullanÄącÄąyÄą kaydet
    await dbRun('INSERT INTO users (username, email, password_hash, user_type) VALUES (?, ?, ?, ?)', 
      [username, email, passwordHash, user_type]);
    
    req.session.success = 'KayÄąt baÅarÄąlÄą! GiriÅ yapabilirsiniz.';
    res.redirect('/login');
  } catch (error) {
    console.error('Register hatasÄą:', error);
    req.session.error = 'KayÄąt sÄąrasÄąnda bir hata oluÅtu!';
    res.redirect('/register');
  }
});

