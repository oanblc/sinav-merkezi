// Kurum - Talep YÃķnetimi
app.get('/kurum/talepler', requireAuth, async (req, res) => {
  if (req.session.userType !== 'kurum_yonetici') {
    return res.status(403).send('Bu sayfaya eriÅim yetkiniz yok!');
  }
  
  try {
    // SÄąnav Talepleri (Veli -> Kurum)
    const sinavTalepleri = await dbAll(`
      SELECT 
        st.*,
        s.ad as sinav_adi,
        s.fiyat,
        s.tarih as sinav_tarihi,
        s.sinif,
        s.ders,
        u.username as veli_username,
        u.email as veli_email,
        u.telefon as veli_telefon,
        u.ad_soyad as veli_ad_soyad,
        'sinav' as talep_tipi
      FROM sinav_talepleri st
      INNER JOIN sinavlar s ON st.sinav_id = s.id
      INNER JOIN users u ON st.veli_id = u.id
    `);
    
    // Rehber ÃÄretmen Talepleri (Hem kurum hem veli ÃķÄrencileri)
    const rehberTalepleri = await dbAll(`
      SELECT 
        ot.*,
        ot.ad_soyad as sinav_adi,
        0 as fiyat,
        NULL as sinav_tarihi,
        ot.sinif,
        NULL as ders,
        v.username as veli_username,
        v.email as veli_email,
        v.telefon as veli_telefon,
        v.ad_soyad as veli_ad_soyad,
        r.ad_soyad as rehber_ad_soyad,
        r.brans as rehber_brans,
        'rehber' as talep_tipi
      FROM ogrenci_talepleri ot
      INNER JOIN users v ON ot.veli_id = v.id
      LEFT JOIN users r ON ot.rehber_ogretmen_id = r.id
      WHERE ot.durum IN ('beklemede', 'onaylandi', 'reddedildi')
    `);
    
    // Ä°ki listeyi birleÅtir
    const talepler = [...sinavTalepleri, ...rehberTalepleri].sort((a, b) => {
      // Ãnce duruma gÃķre sÄąrala
      const durumOrder = { 'beklemede': 1, 'onaylandi': 2, 'reddedildi': 3 };
      const durumDiff = durumOrder[a.durum] - durumOrder[b.durum];
      if (durumDiff !== 0) return durumDiff;
      
      // Sonra tarihe gÃķre sÄąrala (en yeni en Ãžstte)
      return new Date(b.talep_tarihi || b.created_at) - new Date(a.talep_tarihi || a.created_at);
    });
    
    res.render('kurum/talepler', {
      talepler: talepler,
      user: { username: req.session.username, type: req.session.userType },
      error: req.session.error,
      success: req.session.success
    });
    
    req.session.error = null;
    req.session.success = null;
  } catch (error) {
    console.error('Talep listesi hatasÄą:', error);
    res.status(500).send('Bir hata oluÅtu!');
  }
});

// Kurum - Talep YÃķnetimi (Alias - /kurum/talepler ile aynÄą)
app.get('/kurum/talep-yonetimi', requireAuth, async (req, res) => {
  if (req.session.userType !== 'kurum_yonetici') {
    return res.status(403).send('Bu sayfaya eriÅim yetkiniz yok!');
  }
  
  try {
    const talepler = await dbAll(`
      SELECT 
        st.*,
        s.ad as sinav_adi,
        s.fiyat,
        s.tarih as sinav_tarihi,
        s.sinif,
        s.ders,
        u.username as veli_username,
        u.email as veli_email,
        u.telefon as veli_telefon,
        u.ad_soyad as veli_ad_soyad
      FROM sinav_talepleri st
      INNER JOIN sinavlar s ON st.sinav_id = s.id
      INNER JOIN users u ON st.veli_id = u.id
      ORDER BY 
        CASE st.durum
          WHEN 'beklemede' THEN 1
          WHEN 'onaylandi' THEN 2
          WHEN 'reddedildi' THEN 3
        END,
        st.talep_tarihi DESC
    `);
    
    res.render('kurum/talepler', {
      talepler: talepler,
      user: { username: req.session.username, type: req.session.userType },
      error: req.session.error,
      success: req.session.success
    });
    
    req.session.error = null;
    req.session.success = null;
  } catch (error) {
    console.error('Talep listesi hatasÄą:', error);
    res.status(500).send('Bir hata oluÅtu!');
  }
});

// Kurum - Talep YanÄątla (Onayla/Reddet)
app.post('/kurum/talep-yanitla', requireAuth, async (req, res) => {
  if (req.session.userType !== 'kurum_yonetici') {
    return res.status(403).json({ success: false, message: 'Yetkiniz yok!' });
  }
  
  try {
    const { talep_id, durum, yanit, talep_tipi } = req.body;
    
    if (!talep_id || !durum || !['onaylandi', 'reddedildi'].includes(durum)) {
      return res.json({ success: false, message: 'GeÃ§ersiz parametreler!' });
    }
    
    // Talep tipine gÃķre farklÄą tablolardan gÃžncelle
    if (talep_tipi === 'rehber') {
      // Rehber ÃķÄretmen talebi
      await dbRun(
        `UPDATE ogrenci_talepleri 
         SET durum = ?, mesaj = ?
         WHERE id = ?`,
        [durum, yanit || '', talep_id]
      );
      
      // Talep bilgilerini al
      const talep = await dbGet(`
        SELECT 
          ot.*,
          ot.ad_soyad as ogrenci_adi,
          v.ad_soyad as veli_ad_soyad,
          v.telefon as veli_telefon,
          r.ad_soyad as rehber_ad_soyad
        FROM ogrenci_talepleri ot
        INNER JOIN users v ON ot.veli_id = v.id
        LEFT JOIN users r ON ot.rehber_ogretmen_id = r.id
        WHERE ot.id = ?
      `, [talep_id]);
      
      // WhatsApp bildirimi gÃķnder
      if (talep && talep.veli_telefon) {
        const mesaj = durum === 'onaylandi' 
          ? `â REHBER ÃÄRETMEN TALEBÄ°NÄ°Z ONAYLANDI!\n\n` +
            `Merhaba ${talep.veli_ad_soyad || 'DeÄerli Velimiz'},\n\n` +
            `ðĻâðŦ ÃÄrenci: ${talep.ogrenci_adi}\n` +
            `ð Rehber: ${talep.rehber_ad_soyad || 'Rehber ÃÄretmen'}\n` +
            `â Durum: OnaylandÄą\n\n` +
            (yanit ? `ðŽ Kurum YanÄątÄą: ${yanit}\n\n` : '') +
            `Rehber ÃķÄretmen yetkisi aktif hale getirilmiÅtir.`
          : `â REHBER ÃÄRETMEN TALEBÄ°NÄ°Z REDDEDÄ°LDÄ°\n\n` +
            `Merhaba ${talep.veli_ad_soyad || 'DeÄerli Velimiz'},\n\n` +
            `ðĻâðŦ ÃÄrenci: ${talep.ogrenci_adi}\n` +
            `â Durum: Reddedildi\n\n` +
            (yanit ? `ðŽ Kurum YanÄątÄą: ${yanit}\n\n` : '') +
            `Daha fazla bilgi iÃ§in lÃžtfen bizimle iletiÅime geÃ§iniz.`;
        
        whatsappBildirimGonder(talep.veli_telefon, mesaj, `rehber_talep_${durum}`)
          .then(result => console.log('â WhatsApp bildirimi gÃķnderildi:', result))
          .catch(error => console.error('â WhatsApp bildirimi hatasÄą:', error));
      }
      
    } else {
      // SÄąnav talebi (eski kod)
      await dbRun(
        `UPDATE sinav_talepleri 
         SET durum = ?, yanit = ?, yanitlanma_tarihi = datetime('now')
         WHERE id = ?`,
        [durum, yanit || '', talep_id]
      );
      
      // Talep bilgilerini al (WhatsApp bildirimi iÃ§in)
      const talep = await dbGet(`
        SELECT 
          st.*,
          s.ad as sinav_adi,
          u.ad_soyad as veli_ad_soyad,
          u.telefon as veli_telefon
        FROM sinav_talepleri st
        INNER JOIN sinavlar s ON st.sinav_id = s.id
        INNER JOIN users u ON st.veli_id = u.id
        WHERE st.id = ?
      `, [talep_id]);
      
      // WhatsApp bildirimi gÃķnder (arka planda)
      if (talep && talep.veli_telefon) {
        const mesaj = durum === 'onaylandi' 
          ? `â TALEBÄ°NÄ°Z ONAYLANDI!\n\n` +
            `Merhaba ${talep.veli_ad_soyad || 'DeÄerli Velimiz'},\n\n` +
            `ð SÄąnav: ${talep.sinav_adi}\n` +
            `â Durum: OnaylandÄą\n\n` +
            (yanit ? `ðŽ Kurum YanÄątÄą: ${yanit}\n\n` : '') +
            `SÄąnav eriÅiminiz aktif hale getirilmiÅtir. Ä°yi sÄąnavlar dileriz! ð`
          : `â TALEBÄ°NÄ°Z REDDEDÄ°LDÄ°\n\n` +
            `Merhaba ${talep.veli_ad_soyad || 'DeÄerli Velimiz'},\n\n` +
            `ð SÄąnav: ${talep.sinav_adi}\n` +
            `â Durum: Reddedildi\n\n` +
            (yanit ? `ðŽ Kurum YanÄątÄą: ${yanit}\n\n` : '') +
            `Daha fazla bilgi iÃ§in lÃžtfen bizimle iletiÅime geÃ§iniz.`;
        
        whatsappBildirimGonder(talep.veli_telefon, mesaj, `talep_${durum}`)
          .then(result => console.log('â WhatsApp bildirimi gÃķnderildi:', result))
          .catch(error => console.error('â WhatsApp bildirimi hatasÄą:', error));
      }
    }
    
    res.json({ 
      success: true, 
      message: durum === 'onaylandi' ? 'Talep baÅarÄąyla onaylandÄą!' : 'Talep reddedildi.' 
    });
    
  } catch (error) {
    console.error('Talep yanÄątlama hatasÄą:', error);
    res.json({ success: false, message: 'Talep iÅlenirken bir hata oluÅtu!' });
  }
});

