        username: req.session.username, 
        type: req.session.userType,
        id: req.session.userId
      } : null
    });
  }
});

// SÄąnav Talep GÃķnderme - GiriÅ Zorunlu DeÄil
app.post('/sinav-talep-gonder', async (req, res) => {
  try {
    const { sinav_id, ad_soyad, email, telefon, password, aciklama } = req.body;
    let veli_id = req.session.userId; // EÄer giriÅ yapÄąlmÄąÅsa
    
    // SÄąnavÄą kontrol et
    const sinav = await dbGet('SELECT * FROM sinavlar WHERE id = ?', [sinav_id]);
    if (!sinav) {
      return res.json({ success: false, message: 'SÄąnav bulunamadÄą!' });
    }
    
    // DURUM 1: GiriÅ yapÄąlmamÄąÅ - Yeni hesap oluÅtur veya temp hesap kullan
    if (!veli_id) {
      // Zorunlu alanlar kontrolÃž (sadece ad_soyad ve telefon)
      if (!ad_soyad || !telefon) {
        return res.json({ 
          success: false, 
          message: 'LÃžtfen tÃžm bilgileri eksiksiz doldurun!' 
        });
      }
      
      // Email ve password yoksa, otomatik oluÅtur
      const tempEmail = email || `${telefon.replace(/\D/g, '')}@temp.com`;
      const tempPassword = password || telefon.replace(/\D/g, '').slice(-6);
      
      // E-posta daha Ãķnce kullanÄąlmÄąÅ mÄą?
      const mevcutKullanici = await dbGet('SELECT id FROM users WHERE email = ?', [tempEmail]);
      if (mevcutKullanici) {
        veli_id = mevcutKullanici.id;
      } else {
        // Åifre hash'le
        const password_hash = await bcrypt.hash(tempPassword, 10);
        
        // Username oluÅtur (telefondan)
        const username = telefon.replace(/\D/g, '') + '_' + Date.now();
        
        // Yeni veli hesabÄą oluÅtur
        const result = await dbRun(
          `INSERT INTO users (username, email, password_hash, user_type, ad_soyad, telefon, created_at) 
           VALUES (?, ?, ?, 'veli', ?, ?, datetime('now'))`,
          [username, tempEmail, password_hash, ad_soyad, telefon]
        );
        
        veli_id = result.lastID;
        
        console.log(`â Yeni veli hesabÄą oluÅturuldu: ${tempEmail} (ID: ${veli_id})`);
      }
      
      // Otomatik giriÅ yapma (session oluÅturma)
      // req.session.userId = veli_id;
      // req.session.username = username;
      // req.session.userType = 'veli';
    }
    
    // DURUM 2: Daha Ãķnce talep gÃķnderilmiÅ mi kontrol et
    const mevcutTalep = await dbGet(
      'SELECT * FROM sinav_talepleri WHERE veli_id = ? AND sinav_id = ? AND durum != "reddedildi"',
      [veli_id, sinav_id]
    );
    
    if (mevcutTalep) {
      return res.json({ success: false, message: 'Bu sÄąnav iÃ§in zaten bir talebiniz bulunmaktadÄąr!' });
    }
    
    // Talep kaydet
    await dbRun(
      `INSERT INTO sinav_talepleri (veli_id, sinav_id, durum, aciklama, talep_tarihi) 
       VALUES (?, ?, 'beklemede', ?, datetime('now'))`,
      [veli_id, sinav_id, aciklama || '']
    );
    
    // Veli bilgilerini al (WhatsApp bildirimi iÃ§in)
    const veliDetay = await dbGet('SELECT * FROM users WHERE id = ?', [veli_id]);
    
    // WhatsApp API ayarlarÄąnÄą kontrol et
    const whatsappAyarlari = await dbGet('SELECT * FROM whatsapp_ayarlari WHERE aktif = 1');
    
    if (whatsappAyarlari && whatsappAyarlari.phone_number) {
      // Bildirim mesajÄą oluÅtur
      const mesaj = talepBildirimMesaji(veliDetay, sinav);
      
      // WhatsApp bildirimi gÃķnder (arka planda, hata olsa bile kullanÄącÄąya baÅarÄąlÄą dÃķn)
      whatsappBildirimGonder(whatsappAyarlari.phone_number, mesaj, 'yeni_talep')
        .then(result => {
          console.log('â WhatsApp bildirimi sonucu:', result);
        })
        .catch(error => {
          console.error('â WhatsApp bildirimi hatasÄą (arka plan):', error);
        });
    } else {
      console.log('â ïļ  WhatsApp ayarlarÄą yapÄąlmamÄąÅ, bildirim gÃķnderilmedi');
    }
    
    res.json({ 
      success: true, 
      message: `${sinav.ad} iÃ§in talebiniz baÅarÄąyla gÃķnderildi! En kÄąsa sÃžrede deÄerlendirilecektir.`,
      yeniHesap: (ad_soyad && email) ? true : false,
      veli_id: veli_id
    });
    
  } catch (error) {
    console.error('Talep gÃķnderme hatasÄą:', error);
    res.json({ success: false, message: 'Talep gÃķnderilirken bir hata oluÅtu: ' + error.message });
  }
});

// Paket Talebi GÃķnder
app.post('/paket-talep-gonder', async (req, res) => {
  try {
    const { paket_id, ad_soyad, email, telefon, password, aciklama } = req.body;
    let veli_id = req.session.userId; // EÄer giriÅ yapÄąlmÄąÅsa
    
    // Paketi kontrol et
    const paket = await dbGet('SELECT * FROM sinav_paketleri WHERE id = ? AND aktif = 1', [paket_id]);
    if (!paket) {
      return res.json({ success: false, message: 'Paket bulunamadÄą!' });
    }
    
    // DURUM 1: GiriÅ yapÄąlmamÄąÅ - Yeni hesap oluÅtur veya temp hesap kullan
    if (!veli_id) {
      // Zorunlu alanlar kontrolÃž (sadece ad_soyad ve telefon)
      if (!ad_soyad || !telefon) {
        return res.json({ 
          success: false, 
          message: 'LÃžtfen tÃžm bilgileri eksiksiz doldurun!' 
        });
      }
      
      // Email ve password yoksa, otomatik oluÅtur
      const tempEmail = email || `${telefon.replace(/\D/g, '')}@temp.com`;
      const tempPassword = password || telefon.replace(/\D/g, '').slice(-6);
      
      // E-posta daha Ãķnce kullanÄąlmÄąÅ mÄą?
      const mevcutKullanici = await dbGet('SELECT id FROM users WHERE email = ?', [tempEmail]);
      if (mevcutKullanici) {
        veli_id = mevcutKullanici.id;
      } else {
        // Åifre hash'le
        const password_hash = await bcrypt.hash(tempPassword, 10);
        
        // Username oluÅtur (telefondan)
        const username = telefon.replace(/\D/g, '') + '_' + Date.now();
        
        // Yeni veli hesabÄą oluÅtur
        const result = await dbRun(
          `INSERT INTO users (username, email, password_hash, user_type, ad_soyad, telefon, created_at) 
           VALUES (?, ?, ?, 'veli', ?, ?, datetime('now'))`,
          [username, tempEmail, password_hash, ad_soyad, telefon]
        );
        
        veli_id = result.lastID;
        
        console.log(`â Yeni veli hesabÄą oluÅturuldu: ${tempEmail} (ID: ${veli_id})`);
      }
    }
    
    // Paket iÃ§indeki sÄąnavlarÄą al
    const paketSinavlari = await dbAll(
      'SELECT sinav_id FROM paket_sinavlari WHERE paket_id = ?',
      [paket_id]
    );
    
    if (paketSinavlari.length === 0) {
      return res.json({ success: false, message: 'Paket iÃ§inde sÄąnav bulunamadÄą!' });
    }
    
    // Her sÄąnav iÃ§in talep oluÅtur
    let olusturulanTalep = 0;
    for (const ps of paketSinavlari) {
      // Daha Ãķnce talep gÃķnderilmiÅ mi kontrol et
      const mevcutTalep = await dbGet(
        'SELECT * FROM sinav_talepleri WHERE veli_id = ? AND sinav_id = ? AND durum != "reddedildi"',
        [veli_id, ps.sinav_id]
      );
      
      if (!mevcutTalep) {
        // Talep kaydet (paket bilgisini aciklama'ya ekle)
        const paketAciklama = `[PAKET: ${paket.ad}] ${aciklama || ''}`;
        await dbRun(
          `INSERT INTO sinav_talepleri (veli_id, sinav_id, durum, aciklama, talep_tarihi) 
           VALUES (?, ?, 'beklemede', ?, datetime('now'))`,
          [veli_id, ps.sinav_id, paketAciklama]
        );
        olusturulanTalep++;
      }
    }
    
    if (olusturulanTalep === 0) {
      return res.json({ success: false, message: 'Bu paket iÃ§in zaten tÃžm sÄąnavlara talebiniz bulunmaktadÄąr!' });
    }
    
    // Veli bilgilerini al (WhatsApp bildirimi iÃ§in)
    const veliDetay = await dbGet('SELECT * FROM users WHERE id = ?', [veli_id]);
    
    // WhatsApp API ayarlarÄąnÄą kontrol et
    const whatsappAyarlari = await dbGet('SELECT * FROM whatsapp_ayarlari WHERE aktif = 1');
    
    if (whatsappAyarlari && whatsappAyarlari.phone_number) {
      // Bildirim mesajÄą oluÅtur
      const mesaj = `ðĶ YENÄ° PAKET TALEBÄ°\n\n` +
        `Merhaba,\n\n` +
        `${veliDetay.ad_soyad || veliDetay.username} adlÄą veli "${paket.ad}" paketi iÃ§in talep gÃķnderdi.\n\n` +
        `ðĶ Paket: ${paket.ad}\n` +
        `ð SÄąnÄąf: ${paket.sinif || 'BelirtilmemiÅ'}\n` +
        `ð SÄąnav SayÄąsÄą: ${paketSinavlari.length}\n` +
        `${aciklama ? `ðŽ AÃ§Äąklama: ${aciklama}\n` : ''}\n` +
        `ð Telefon: ${veliDetay.telefon || 'BelirtilmemiÅ'}\n` +
        `ð§ Email: ${veliDetay.email || 'BelirtilmemiÅ'}\n\n` +
        `LÃžtfen kurum panelinden talebi deÄerlendirin.`;
      
      // WhatsApp bildirimi gÃķnder (arka planda, hata olsa bile kullanÄącÄąya baÅarÄąlÄą dÃķn)
      whatsappBildirimGonder(whatsappAyarlari.phone_number, mesaj, 'paket_talebi')
        .then(result => {
          console.log('â WhatsApp bildirimi sonucu:', result);
        })
        .catch(error => {
          console.error('â WhatsApp bildirimi hatasÄą (arka plan):', error);
        });
    } else {
      console.log('â ïļ  WhatsApp ayarlarÄą yapÄąlmamÄąÅ, bildirim gÃķnderilmedi');
    }
    
    res.json({ 
      success: true, 
      message: `${paket.ad} paketi iÃ§in ${olusturulanTalep} sÄąnav talebi baÅarÄąyla gÃķnderildi! En kÄąsa sÃžrede deÄerlendirilecektir.`,
      yeniHesap: (ad_soyad && email) ? true : false,
      veli_id: veli_id
    });
    
  } catch (error) {
    console.error('Paket talep gÃķnderme hatasÄą:', error);
    res.json({ success: false, message: 'Talep gÃķnderilirken bir hata oluÅtu: ' + error.message });
  }
});

