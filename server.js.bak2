// Test PDF Upload Route
app.post('/test-pdf-upload', pdfUpload.single('pdfFile'), async (req, res) => {
  try {
    if (!req.file) {
      return res.status(400).json({ error: 'LÃžtfen bir PDF dosyasÄą yÃžkleyin!' });
    }

    // PDF'i oku
    const dataBuffer = fs.readFileSync(req.file.path);
    
    // PDF'i parse et
    const pdfData = await pdfParse(dataBuffer);
    
    // Text iÃ§eriÄini al
    const text = pdfData.text;
    
    // ÃÄrenci bilgilerini Ã§Äąkar (regex ile)
    const ogrenciMatch = text.match(/ÃÄrenci\s+Numara\s+SÄąnÄąf\s+([^\n]+)\s+(\d+)\s+(\w+)/);
    const puanMatch = text.match(/âž\s*([\d,]+)/);
    
    // Ders detaylarÄąnÄą Ã§Äąkar
    const dersler = [];
    const dersRegex = /(TÃžrkÃ§e|Tarih-1|CoÄrafya-1|Felsefe|Din KÃžl\. ve Ahl\. Bil\.|Fizik|Kimya|Biyoloji|TYT Fen)\s+(\d+)\s+(\d+)\s+(\d+)\s+([\d,]+)/g;
    let dersMatch;
    
    while ((dersMatch = dersRegex.exec(text)) !== null) {
      dersler.push({
        ders: dersMatch[1],
        soru: dersMatch[2],
        dogru: dersMatch[3],
        yanlis: dersMatch[4],
        net: dersMatch[5]
      });
    }
    
    const result = {
      filename: req.file.originalname,
      filepath: req.file.path,
      pageCount: pdfData.numpages,
      ogrenciBilgi: ogrenciMatch ? {
        ad: ogrenciMatch[1].trim(),
        numara: ogrenciMatch[2],
        sinif: ogrenciMatch[3]
      } : null,
      puan: puanMatch ? puanMatch[1] : null,
      dersler: dersler,
      rawText: text.substring(0, 2000) // Ä°lk 2000 karakter
    };
    
    res.json({
      success: true,
      data: result
    });
    
  } catch (error) {
    console.error('PDF parse hatasÄą:', error);
    res.status(500).json({ 
      success: false, 
      error: 'PDF parse edilirken hata oluÅtu: ' + error.message 
    });
  }
});

