    console.log(`   SÄąnav ID: ${sinavId}`);
    console.log(`   EÅleÅmiÅ SayÄąsÄą: ${eslesmisler.length}`);
    
    res.render('kurum/sinav-eslesen-kontrol', {
      user: req.session,
      sinav: sinav,
