// Kurum - Rehber ÃÄretmene Talep GÃķnder
app.post('/kurum/rehber-talep-gonder', requireAuth, async (req, res) => {
  if (req.session.userType !== 'kurum_yonetici') {
    return res.status(403).json({ success: false, message: 'Yetkiniz yok!' });
  }
  
  try {
    const { veli_id, ogrenci_id, rehber_ogretmen_id, ogrenci_no, ad_soyad, sinif, okul, mesaj, ogrenci_kaynak } = req.body;
    
    console.log('ðĨ Talep gÃķnderme isteÄi:', { veli_id, ogrenci_id, rehber_ogretmen_id, ad_soyad, ogrenci_kaynak });
    
    if (!veli_id || !rehber_ogretmen_id || !ad_soyad) {
      return res.json({ success: false, message: 'Eksik bilgiler! (veli_id, rehber_ogretmen_id, ad_soyad gerekli)' });
    }
    
    // Kurum ÃķÄrencileri iÃ§in ogrenci_id NULL olabilir
    const kullanilacakOgrenciId = (ogrenci_kaynak === 'kurum') ? null : ogrenci_id;
    
    // AynÄą talep var mÄą kontrol et (ogrenci_id varsa) - Beklemede VEYA OnaylÄą talep kontrolÃž
    if (kullanilacakOgrenciId) {
      const mevcutTalep = await dbGet(`
        SELECT id, durum FROM ogrenci_talepleri 
        WHERE ogrenci_id = ? AND rehber_ogretmen_id = ? AND durum IN ('beklemede', 'onaylandi')
      `, [kullanilacakOgrenciId, rehber_ogretmen_id]);
      
      if (mevcutTalep) {
        if (mevcutTalep.durum === 'beklemede') {
          return res.json({ success: false, message: 'Bu ÃķÄrenci iÃ§in bu rehber ÃķÄretmene zaten bekleyen bir talep var!' });
        } else {
          return res.json({ success: false, message: 'Bu ÃķÄrenci iÃ§in bu rehber ÃķÄretmene zaten onaylÄą bir talep var!' });
        }
      }
    } else {
      // Kurum ÃķÄrencileri iÃ§in ad_soyad ve veli_id ile kontrol et
      const mevcutTalep = await dbGet(`
        SELECT id, durum FROM ogrenci_talepleri 
        WHERE ad_soyad = ? AND veli_id = ? AND rehber_ogretmen_id = ? AND durum IN ('beklemede', 'onaylandi') AND ogrenci_id IS NULL
      `, [ad_soyad, veli_id, rehber_ogretmen_id]);
      
      if (mevcutTalep) {
        if (mevcutTalep.durum === 'beklemede') {
          return res.json({ success: false, message: 'Bu ÃķÄrenci iÃ§in bu rehber ÃķÄretmene zaten bekleyen bir talep var!' });
        } else {
          return res.json({ success: false, message: 'Bu ÃķÄrenci iÃ§in bu rehber ÃķÄretmene zaten onaylÄą bir talep var!' });
        }
      }
    }
    
    // Talep oluÅtur
    // rehber_id ve rehber_ogretmen_id aynÄą deÄer (kurum tarafÄąndan gÃķnderildiÄi iÃ§in)
    await dbRun(`
      INSERT INTO ogrenci_talepleri 
      (ogrenci_id, ogrenci_no, ad_soyad, sinif, okul, veli_id, rehber_id, rehber_ogretmen_id, durum, mesaj)
      VALUES (?, ?, ?, ?, ?, ?, ?, ?, 'beklemede', ?)
    `, [kullanilacakOgrenciId, ogrenci_no || '', ad_soyad, sinif || '', okul || '', veli_id, rehber_ogretmen_id, rehber_ogretmen_id, mesaj || '']);
    
    console.log('â Talep baÅarÄąyla oluÅturuldu');
    
    // Veli ve rehber bilgilerini al
    const veli = await dbGet('SELECT ad_soyad, telefon FROM users WHERE id = ?', [veli_id]);
    const rehber = await dbGet('SELECT ad_soyad, telefon FROM users WHERE id = ?', [rehber_ogretmen_id]);
    
    // WhatsApp bildirimi gÃķnder (arka planda)
    if (veli && veli.telefon) {
      const veliMesaj = `ðĐ YENÄ° REHBER ÃÄRETMEN TALEBÄ°\n\n` +
        `Merhaba ${veli.ad_soyad || 'DeÄerli Velimiz'},\n\n` +
        `Kurum tarafÄąndan sizin adÄąnÄąza rehber ÃķÄretmen yetki talebi gÃķnderilmiÅtir.\n\n` +
        `ðĪ ÃÄrenci: ${ad_soyad}\n` +
        `ðĻâðŦ Rehber: ${rehber?.ad_soyad || 'Rehber ÃÄretmen'}\n\n` +
        `Talebiniz onaylandÄąÄÄąnda rehber ÃķÄretmen ÃķÄrenciniz hakkÄąnda bilgilere eriÅebilecektir.`;
      
      whatsappBildirimGonder(veli.telefon, veliMesaj, 'rehber_talep_kurum')
        .then(result => console.log('â Veli WhatsApp bildirimi gÃķnderildi:', result))
        .catch(error => console.error('â Veli WhatsApp bildirimi hatasÄą:', error));
    }
    
    if (rehber && rehber.telefon) {
      const rehberMesaj = `ðĐ YENÄ° ÃÄRENCÄ° YETKÄ° TALEBÄ°\n\n` +
        `Merhaba ${rehber.ad_soyad || 'DeÄerli Rehber ÃÄretmenimiz'},\n\n` +
        `Kurum tarafÄąndan size yeni bir ÃķÄrenci yetki talebi gÃķnderilmiÅtir.\n\n` +
        `ðĪ ÃÄrenci: ${ad_soyad}\n` +
        `ðĻâðĐâð§ Veli: ${veli?.ad_soyad || 'Veli'}\n` +
        `${sinif ? `ð SÄąnÄąf: ${sinif}\n` : ''}` +
        `${okul ? `ðŦ Okul: ${okul}\n` : ''}` +
        `${mesaj ? `\nðŽ Mesaj: ${mesaj}\n` : ''}\n` +
        `LÃžtfen veli panelinden talebi inceleyip onaylayÄąn veya reddedin.`;
      
      whatsappBildirimGonder(rehber.telefon, rehberMesaj, 'rehber_talep_kurum')
        .then(result => console.log('â Rehber WhatsApp bildirimi gÃķnderildi:', result))
        .catch(error => console.error('â Rehber WhatsApp bildirimi hatasÄą:', error));
    }
    
    res.json({ 
      success: true, 
      message: 'Rehber ÃķÄretmene talep baÅarÄąyla gÃķnderildi!' 
    });
    
  } catch (error) {
    console.error('â Rehber talep gÃķnderme hatasÄą:', error);
    console.error('Hata detayÄą:', error.message);
    console.error('Stack trace:', error.stack);
    res.json({ 
      success: false, 
      message: `Talep gÃķnderilirken bir hata oluÅtu: ${error.message}` 
    });
  }
});

