      );
      
      return { success: true, message: 'Bildirim gÃķnderildi (simÃžlasyon - API token yok)' };
    }
    
    // Whapi.cloud API'ye istek gÃķnder
    const https = require('https');
    const url = require('url');
    
    // Telefon numarasÄąnÄą formatla (Whapi.cloud formatÄą: 905551234567@s.whatsapp.net)
    let formattedPhone = telefon.replace(/[^0-9]/g, ''); // Sadece rakamlar
    if (!formattedPhone.startsWith('90')) {
      formattedPhone = '90' + formattedPhone; // TÃžrkiye kodu ekle
    }
    formattedPhone = formattedPhone + '@s.whatsapp.net';
    
    // API URL'ini dÃžzelt
    const baseUrl = (ayarlar.api_url || 'https://gate.whapi.cloud').replace(/\/$/, '');
    const apiUrl = `${baseUrl}/messages/text`;
    
    const postData = JSON.stringify({
      to: formattedPhone,
      body: mesaj
    });
    
    console.log('ðĄ API URL:', apiUrl);
    console.log('ð Formatted Phone:', formattedPhone);
    console.log('ðĶ POST Data:', postData);
    
    const parsedUrl = url.parse(apiUrl);
    const options = {
      hostname: parsedUrl.hostname,
      port: parsedUrl.port || 443,
      path: parsedUrl.path,
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'Authorization': `Bearer ${ayarlar.api_token}`,
        'Content-Length': Buffer.byteLength(postData)
      }
    };
    
    return new Promise((resolve, reject) => {
      const req = https.request(options, (res) => {
        let data = '';
        
        res.on('data', (chunk) => {
          data += chunk;
        });
        
        res.on('end', async () => {
          console.log('â Whapi.cloud API YanÄątÄą:', res.statusCode);
          console.log('ðĶ Response:', data);
          
          if (res.statusCode === 200 || res.statusCode === 201) {
            // BaÅarÄąlÄą - Bildirim geÃ§miÅine kaydet
            await dbRun(
              `INSERT INTO bildirim_gecmisi (bildirim_tipi, alici_telefon, mesaj, durum, created_at) 
               VALUES (?, ?, ?, 'basarili', datetime('now'))`,
              [bildirimTipi, telefon, mesaj]
            );
            
            resolve({ success: true, message: 'WhatsApp bildirimi baÅarÄąyla gÃķnderildi!' });
          } else {
            // API hatasÄą
            const errorMsg = `API Error: ${res.statusCode} - ${data}`;
            console.error('â', errorMsg);
            
            await dbRun(
              `INSERT INTO bildirim_gecmisi (bildirim_tipi, alici_telefon, mesaj, durum, hata_mesaji, created_at) 
               VALUES (?, ?, ?, 'basarisiz', ?, datetime('now'))`,
              [bildirimTipi, telefon, mesaj, errorMsg]
            );
            
            resolve({ success: false, message: 'WhatsApp bildirimi gÃķnderilemedi', error: errorMsg });
          }
        });
      });
      
      req.on('error', async (error) => {
        console.error('â Whapi.cloud baÄlantÄą hatasÄą:', error);
        
        // Hata durumunu kaydet
        try {
          await dbRun(
            `INSERT INTO bildirim_gecmisi (bildirim_tipi, alici_telefon, mesaj, durum, hata_mesaji, created_at) 
             VALUES (?, ?, ?, 'basarisiz', ?, datetime('now'))`,
            [bildirimTipi, telefon, mesaj, error.message]
          );
        } catch (logError) {
          console.error('â Bildirim geÃ§miÅi kayÄąt hatasÄą:', logError);
        }
        
        resolve({ success: false, message: 'BaÄlantÄą hatasÄą', error: error.message });
      });
      
      req.write(postData);
      req.end();
    });
    
  } catch (error) {
    console.error('â WhatsApp bildirim hatasÄą:', error);
    
    // Hata durumunu kaydet
    try {
      await dbRun(
        `INSERT INTO bildirim_gecmisi (bildirim_tipi, alici_telefon, mesaj, durum, hata_mesaji, created_at) 
         VALUES (?, ?, ?, 'basarisiz', ?, datetime('now'))`,
        [bildirimTipi, telefon, mesaj, error.message]
      );
    } catch (logError) {
      console.error('â Bildirim geÃ§miÅi kayÄąt hatasÄą:', logError);
    }
    
    return { success: false, message: 'Bildirim gÃķnderilemedi', error: error.message };
  }
}

