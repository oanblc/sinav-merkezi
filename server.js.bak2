  } catch (error) {
    console.error('EÅleÅen kontrol sayfasÄą hatasÄą:', error);
    res.status(500).send('Bir hata oluÅtu!');
  }
});

// ð EÅleÅmeyi KaldÄąr
app.post('/kurum/sinav-eslestirme-kaldir', requireAuth, async (req, res) => {
  if (req.session.userType !== 'kurum_yonetici') {
    return res.status(403).json({ success: false, error: 'Yetkiniz yok!' });
  }
  
  try {
    const { sinav_id, ogrenci_id, kaynak } = req.body;
    
    console.log(`\nâ EÅLEÅMEYÄ° KALDIR`);
    console.log(`   SÄąnav ID: ${sinav_id}`);
    console.log(`   ÃÄrenci ID: ${ogrenci_id} (${kaynak})`);
    
    // pdf_path'i NULL yap ve sonuc_durumu'nu beklemede'ye Ã§ek
    const result = await new Promise((resolve, reject) => {
      db.run(`
        UPDATE sinav_katilimcilari 
        SET pdf_path = NULL, sonuc_durumu = 'beklemede'
        WHERE sinav_id = ? AND ogrenci_id = ? AND ogrenci_kaynak = ?
      `, [sinav_id, ogrenci_id, kaynak], function(err) {
        if (err) reject(err);
        else resolve({ changes: this.changes });
      });
    });
    
    console.log(`   â BaÅarÄąlÄą: ${result.changes} satÄąr gÃžncellendi`);
    
    if (result.changes === 0) {
      console.log(`   â ïļ  UYARI: HiÃ§bir satÄąr gÃžncellenmedi!`);
      return res.json({ success: false, error: 'EÅleÅme bulunamadÄą!' });
    }
    
    res.json({ success: true });
    
  } catch (error) {
    console.error('â EÅleÅme kaldÄąrma hatasÄą:', error);
    res.status(500).json({ success: false, error: error.message });
  }
});

// ð TOPLU VELÄ° HESABI OLUÅTURMA
app.post('/kurum/toplu-veli-hesap-olustur', requireAuth, async (req, res) => {
  if (req.session.userType !== 'kurum_yonetici') {
    return res.status(403).json({ success: false, error: 'Yetkiniz yok!' });
  }
  
  try {
    console.log('\nðĨ TOPLU VELÄ° HESABI OLUÅTURMA BAÅLADI');
    
    // TÃžm ÃķÄrencileri al (sadece kurum ÃķÄrencileri - tc_no olanlar)
    const ogrenciler = await dbAll(`
      SELECT id, ogrenci_adi_soyadi, tc_kimlik_no, sinif, telefon, veli_adi, veli_telefon
      FROM ogrenci_kayitlari
      WHERE tc_kimlik_no IS NOT NULL AND tc_kimlik_no != ''
      ORDER BY sinif, ogrenci_adi_soyadi
    `);
    
    console.log(`   ð ${ogrenciler.length} ÃķÄrenci bulundu`);
    
    let olusturulan = 0;
    let mevcutOlanlar = 0;
    let hatalar = 0;
    
    for (const ogrenci of ogrenciler) {
      try {
        // Kontrol et: Bu TC ile kullanÄącÄą var mÄą?
        const mevcutUser = await dbGet('SELECT id FROM users WHERE username = ?', [ogrenci.tc_kimlik_no]);
        
        if (mevcutUser) {
          mevcutOlanlar++;
          continue;
        }
        
        // Åifreyi hashle (ilk Åifre = TC)
        const hashedPassword = await bcrypt.hash(ogrenci.tc_kimlik_no, 10);
        
        // Veli hesabÄą oluÅtur
        await dbRun(`
          INSERT INTO users (username, email, password_hash, user_type, ad_soyad, telefon, password_changed)
          VALUES (?, ?, ?, 'veli', ?, ?, 0)
        `, [
          ogrenci.tc_kimlik_no, // username = TC
          `veli_${ogrenci.id}_${Date.now()}@temp.com`, // benzersiz email
          hashedPassword,
          ogrenci.veli_adi || `${ogrenci.ogrenci_adi_soyadi} Velisi`,
          ogrenci.veli_telefon || ogrenci.telefon
        ]);
        
        // Veli ID'sini al
        const veliUser = await dbGet('SELECT id FROM users WHERE username = ?', [ogrenci.tc_kimlik_no]);
        
        // ogrenciler tablosuna ekle (veli-ÃķÄrenci iliÅkisi)
        await dbRun(`
          INSERT OR IGNORE INTO ogrenciler (veli_id, ad_soyad, sinif, telefon, tc_no)
          VALUES (?, ?, ?, ?, ?)
        `, [
          veliUser.id,
          ogrenci.ogrenci_adi_soyadi,
          ogrenci.sinif,
          ogrenci.telefon,
          ogrenci.tc_kimlik_no
        ]);
        
        olusturulan++;
        
      } catch (error) {
        console.error(`   â Hata (${ogrenci.ogrenci_adi_soyadi}):`, error.message);
        hatalar++;
      }
    }
    
    console.log(`\nâ TOPLU VELÄ° HESABI OLUÅTURMA TAMAMLANDI`);
    console.log(`   â OluÅturulan: ${olusturulan}`);
    console.log(`   â ïļ  Mevcut olanlar: ${mevcutOlanlar}`);
    console.log(`   â Hatalar: ${hatalar}`);
    
    res.json({ 
      success: true, 
      olusturulan, 
      mevcutOlanlar, 
      hatalar,
      toplam: ogrenciler.length
    });
    
  } catch (error) {
    console.error('â Toplu veli hesabÄą oluÅturma hatasÄą:', error);
    res.status(500).json({ success: false, error: error.message });
  }
});

