});

// ============================================
// AKILLI EÅLEÅTÄ°RME SÄ°STEMÄ° - STRATEJÄ°LER
// ============================================

/**
 * STRATEJÄ° 1: ÃÄrenilmiÅ Pattern (En HÄązlÄą)
 * Daha Ãķnce baÅarÄąlÄą olan pattern'leri kullanÄąr
 */
async function strategy1_LearnedPattern(lines, katilimcilar, kurumId, sinavId, pdfPath) {
  console.log('   ð GeÃ§miÅ ÃķÄrenmelere bakÄąlÄąyor...');
  
  try {
    // Bu kurumun geÃ§miÅ baÅarÄąlÄą pattern'lerini al
    const learnedPattern = await dbGet(`
      SELECT name_line_number, name_position_type, success_rate, use_count
      FROM pdf_learning_patterns
      WHERE kurum_id = ? 
        AND success_rate >= 0.85
      ORDER BY use_count DESC, success_rate DESC
      LIMIT 1
    `, [kurumId]);
    
    if (!learnedPattern) {
      console.log('   âđïļ ÃÄrenilmiÅ pattern yok');
      return null;
    }
    
    console.log(`   ð ÃÄrenilmiÅ pattern: SatÄąr ${learnedPattern.name_line_number} (BaÅarÄą: ${(learnedPattern.success_rate * 100).toFixed(0)}%, KullanÄąm: ${learnedPattern.use_count}x)`);
    
    // ÃÄrenilmiÅ satÄąrdan ismi Ã§Äąkar
    const extractedName = lines[learnedPattern.name_line_number];
    
    if (!extractedName) {
      console.log('   â ïļ SatÄąr bulunamadÄą');
      return null;
    }
    
    // Ä°smi temizle
    const cleanName = cleanExtractedName(extractedName);
    
    // KatÄąlÄąmcÄąlarla eÅleÅtir
    const match = findBestMatch(cleanName, katilimcilar);
    
    if (match && match.similarity >= 0.80) {
      return {
        ogrenciId: match.ogrenci.ogrenci_id,
        ogrenciAd: match.ogrenci.ad_soyad,
        kaynak: match.ogrenci.kaynak,
        extractedName: cleanName,
        confidence: match.similarity,
        lineNumber: learnedPattern.name_line_number
      };
    }
    
    console.log('   â ÃÄrenilmiÅ pattern eÅleÅmedi');
    return null;
  } catch (error) {
    console.error('   â Strateji 1 hatasÄą:', error.message);
    return null;
  }
}

/**
 * STRATEJÄ° 2: VeritabanÄą Benzerlik TaramasÄą (Ana YÃķntem)
 * TÃžm satÄąrlarÄą tarayÄąp veritabanÄąndaki ÃķÄrencilerle karÅÄąlaÅtÄąrÄąr
 */
async function strategy2_DatabaseSimilarity(lines, katilimcilar, kurumId, sinavId) {    console.log('Database connected:', DB_PATH);
  
  let bestMatch = null;
  let bestSimilarity = 0;
  let bestLineNumber = -1;
  let bestExtractedName = '';
  
  // Ä°lk 50 satÄąrÄą tara
  for (let i = 0; i < Math.min(lines.length, 50); i++) {
    const line = lines[i];
    
    // BoÅ satÄąrlarÄą atla
    if (!line || line.length < 5) continue;
    
    // ð GELÄ°ÅMÄ°Å PARSE: SatÄąrÄą farklÄą Åekillerde parse et
    const parsedNames = [];
    
    // 1. Direkt satÄąr
    parsedNames.push({ text: line, source: 'direct' });
    
    // 2. Rakamlardan Ãķnceki kÄąsÄąm (Ãķrn: "ALÄ° OSMAN ÃÃZELÄ°08-A" â "ALÄ° OSMAN ÃÃZELÄ°")
    const beforeNumber = line.match(/^([A-ZÃÄÄ°ÃÅÃa-zÃ§ÄÄąÃķÅÃž\s]+?)(?=\d|$)/);
    if (beforeNumber && beforeNumber[1].trim().length >= 5) {
      parsedNames.push({ text: beforeNumber[1].trim(), source: 'before_number' });
    }
    
    // 3. Kelime tabanlÄą parse (birleÅik satÄąrlarÄą bÃķl)
    // "ÃÄrenciNumaraSÄąnÄąfALÄ° OSMAN ÃÃZELÄ°08-A" gibi durumlar iÃ§in
    const words = line.split(/(?=[A-ZÃÄÄ°ÃÅÃ][a-zÃ§ÄÄąÃķÅÃž])/);
    words.forEach(w => {
      const clean = cleanExtractedName(w);
      if (clean && clean.length >= 5 && clean.split(' ').length >= 2) {
        parsedNames.push({ text: w, source: 'word_split' });
      }
    });
    
    // Her parse edilmiÅ ismi test et
    for (const parsed of parsedNames) {
      // Ä°sim gibi mi kontrol et
      if (!looksLikeName(parsed.text)) continue;
      
      const cleanLine = cleanExtractedName(parsed.text);
      if (!cleanLine) continue;
      
      // Her katÄąlÄąmcÄą ile karÅÄąlaÅtÄąr
      for (const katilimci of katilimcilar) {
        const similarity = stringSimilarity(cleanLine, katilimci.ad_soyad);
        
        if (similarity > bestSimilarity) {
          bestSimilarity = similarity;
          bestMatch = katilimci;
          bestLineNumber = i;
          bestExtractedName = cleanLine;
          console.log(`   ð Yeni aday: "${cleanLine}" â "${katilimci.ad_soyad}" (${(similarity * 100).toFixed(0)}%, kaynak: ${parsed.source})`);
        }
      }
    }
  }
  
  if (bestMatch && bestSimilarity >= 0.70) { // EÅiÄi 0.70'e dÃžÅÃžrdÃžk
    console.log(`   â EÅleÅme bulundu: "${bestMatch.ad_soyad}" (Benzerlik: ${(bestSimilarity * 100).toFixed(0)}%, SatÄąr: ${bestLineNumber})`);
    
    return {
      ogrenciId: bestMatch.ogrenci_id,
      ogrenciAd: bestMatch.ad_soyad,
      kaynak: bestMatch.kaynak,
      extractedName: bestExtractedName,
      confidence: bestSimilarity,
      lineNumber: bestLineNumber
    };
  }
  
  console.log(`   â ïļ Yeterli benzerlik bulunamadÄą (En iyi: ${(bestSimilarity * 100).toFixed(0)}%)`);
  return null;
}

/**
 * STRATEJÄ° 3: Pozisyon TabanlÄą
 * PDF'deki pozisyona gÃķre isim tahmini yapar
 */
async function strategy3_PositionBased(lines, katilimcilar, kurumId, sinavId, pdfPath) {
  console.log('   ð PDF koordinatlarÄąna bakÄąlÄąyor...');
  
  // Ä°lk 15 satÄąrda, en Ã§ok kelime sayÄąsÄąna sahip satÄąrÄą bul
  const candidates = lines.slice(0, 15)
    .map((line, index) => ({
      line: line,
      index: index,
      wordCount: line.split(/\s+/).length,
      isNameLike: looksLikeName(line)
    }))
    .filter(c => c.isNameLike && c.wordCount >= 2 && c.wordCount <= 4)
    .sort((a, b) => b.wordCount - a.wordCount);
  
  for (const candidate of candidates) {
    const cleanLine = cleanExtractedName(candidate.line);
    const match = findBestMatch(cleanLine, katilimcilar);
    
    if (match && match.similarity >= 0.70) {
      console.log(`   â Pozisyon eÅleÅmesi: "${match.ogrenci.ad_soyad}"`);
      return {
        ogrenciId: match.ogrenci.ogrenci_id,
        ogrenciAd: match.ogrenci.ad_soyad,
        kaynak: match.ogrenci.kaynak,
        extractedName: cleanLine,
        confidence: match.similarity * 0.9, // Pozisyon tabanlÄą biraz daha dÃžÅÃžk gÃžven
        lineNumber: candidate.index
      };
    }
  }
  
  console.log('   â Pozisyon tabanlÄą eÅleÅme baÅarÄąsÄąz');
  return null;
}

/**
 * STRATEJÄ° 4: GeliÅmiÅ Regex Pattern'leri
 */
async function strategy4_AdvancedRegex(lines, katilimcilar, kurumId, sinavId) {
  console.log('   ðĪ Regex pattern\'leri deneniyor...');
  
  const patterns = [
    /(?:ÃÄrenci|ADI|SOYADI|Ä°SÄ°M)[:\s]+([A-ZÃÄÄ°ÃÅÃ\s]{10,40})/i,
    /(?:Ad Soyad)[:\s]+([A-ZÃÄÄ°ÃÅÃ\s]{10,40})/i,
    /^([A-ZÃÄÄ°ÃÅÃ]+\s+[A-ZÃÄÄ°ÃÅÃ]+(?:\s+[A-ZÃÄÄ°ÃÅÃ]+)?)\s+\d/,
    /\d+\s+([A-ZÃÄÄ°ÃÅÃ]+\s+[A-ZÃÄÄ°ÃÅÃ]+)/
  ];
  
  for (const pattern of patterns) {
    for (let i = 0; i < Math.min(lines.length, 30); i++) {
      const match_result = lines[i].match(pattern);
      
      if (match_result && match_result[1]) {
        const extractedName = cleanExtractedName(match_result[1]);
        const match = findBestMatch(extractedName, katilimcilar);
        
        if (match && match.similarity >= 0.75) {
          console.log(`   â Regex eÅleÅmesi: "${match.ogrenci.ad_soyad}"`);
          return {
            ogrenciId: match.ogrenci.ogrenci_id,
            ogrenciAd: match.ogrenci.ad_soyad,
            kaynak: match.ogrenci.kaynak,
            extractedName: extractedName,
            confidence: match.similarity * 0.85,
            lineNumber: i
          };
        }
      }
    }
  }
  
  console.log('   â Regex eÅleÅmesi baÅarÄąsÄąz');
  return null;
}

/**
 * STRATEJÄ° 5: Fuzzy Search (En agresif)
 */
async function strategy5_FuzzySearch(lines, katilimcilar, kurumId, sinavId) {
  console.log('   ðŦïļ Fuzzy search yapÄąlÄąyor (agresif)...');
  
  // TÃžm PDF textini birleÅtir ve her katÄąlÄąmcÄąyÄą ara
  const fullText = lines.join(' ').toUpperCase();
  
  for (const katilimci of katilimcilar) {
    const nameWords = katilimci.ad_soyad.toUpperCase().split(/\s+/);
    
    // Ä°smin tÃžm kelimeleri PDF'de var mÄą?
    const allWordsExist = nameWords.every(word => fullText.includes(word));
    
    if (allWordsExist && nameWords.length >= 2) {
      console.log(`   â Fuzzy eÅleÅme: "${katilimci.ad_soyad}" (tÃžm kelimeler bulundu)`);
      
      return {
        ogrenciId: katilimci.ogrenci_id,
        ogrenciAd: katilimci.ad_soyad,
        kaynak: katilimci.kaynak,
        extractedName: katilimci.ad_soyad,
        confidence: 0.70, // DÃžÅÃžk gÃžven
        lineNumber: -1
      };
    }
  }
  
  console.log('   â Fuzzy search baÅarÄąsÄąz');
  return null;
}

// ============================================
// AKILLI ÃÄRENME SÄ°STEMÄ° FONKSÄ°YONLARI
// ============================================

/**
 * BaÅarÄąlÄą pattern'i ÃķÄren
 */
async function learnSuccessfulPattern(kurumId, sinavId, result, strategyName) {
  try {
    console.log(`\nð ÃÄRENME: BaÅarÄąlÄą pattern kaydediliyor...`);
    
    // SÄąnav tipini al
    const sinav = await dbGet('SELECT sinav_turu FROM sinavlar WHERE id = ?', [sinavId]);
    
    // Var olan pattern'i gÃžncelle veya yeni ekle
    const existing = await dbGet(`
      SELECT id, success_rate, use_count 
      FROM pdf_learning_patterns 
      WHERE kurum_id = ? AND name_line_number = ?
    `, [kurumId, result.lineNumber]);
    
    if (existing) {
      // BaÅarÄą oranÄąnÄą gÃžncelle (moving average)
      const newSuccessRate = (existing.success_rate * existing.use_count + result.confidence) / (existing.use_count + 1);
      
      await dbRun(`
        UPDATE pdf_learning_patterns 
        SET success_rate = ?, 
            use_count = use_count + 1,
            last_used = datetime('now')
        WHERE id = ?
      `, [newSuccessRate, existing.id]);
      
      console.log(`   â Pattern gÃžncellendi (Yeni baÅarÄą: ${(newSuccessRate * 100).toFixed(0)}%)`);
    } else {
      // Yeni pattern ekle
      await dbRun(`
        INSERT INTO pdf_learning_patterns 
        (kurum_id, sinav_tipi, name_line_number, name_position_type, success_rate)
        VALUES (?, ?, ?, ?, ?)
      `, [kurumId, sinav?.sinav_turu || 'unknown', result.lineNumber, strategyName, result.confidence]);
      
      console.log(`   â Yeni pattern ÃķÄrenildi (SatÄąr: ${result.lineNumber})`);
    }
  } catch (error) {
    console.error('â ÃÄrenme hatasÄą:', error);
  }
}

/**
 * BaÅarÄąsÄązlÄąÄÄą kaydet (gelecekte analiz iÃ§in)
 */
async function logMatchingFailure(sinavId, lines, reason) {
  try {
    const attemptedNames = lines.slice(0, 10).join(' | ');
    
    await dbRun(`
      INSERT INTO matching_failures (sinav_id, attempted_name, failure_reason)
      VALUES (?, ?, ?)
    `, [sinavId, attemptedNames.substring(0, 200), reason]);
    
    console.log('   ð BaÅarÄąsÄązlÄąk kaydedildi (gelecek analiz iÃ§in)');
  } catch (error) {
    console.error('â BaÅarÄąsÄązlÄąk kayÄąt hatasÄą:', error);
  }
}

/**
 * ANA CASCADE MATCHING SÄ°STEMÄ°
 * Ãok KatmanlÄą AkÄąllÄą EÅleÅtirme - Strateji 1 baÅarÄąsÄąz olursa Strateji 2'ye geÃ§er
 */
async function intelligentCascadeMatching(pdfText, sinavId, kurumId, pdfPath) {
  console.log('\nð§  AKILLI EÅLEÅTÄ°RME BAÅLADI');
  
  try {
    // 1. SÄąnava katÄąlan ÃķÄrencileri al
    const katilimcilar = await dbAll(`
      SELECT 
        sk.ogrenci_id,
        sk.ogrenci_kaynak as kaynak,
        CASE 
          WHEN sk.ogrenci_kaynak = 'kurum' THEN ok.ogrenci_adi_soyadi
          WHEN sk.ogrenci_kaynak = 'veli' THEN o.ad_soyad
        END as ad_soyad
      FROM sinav_katilimcilari sk
      LEFT JOIN ogrenci_kayitlari ok ON sk.ogrenci_id = ok.id AND sk.ogrenci_kaynak = 'kurum'
      LEFT JOIN ogrenciler o ON sk.ogrenci_id = o.id AND sk.ogrenci_kaynak = 'veli'
      WHERE sk.sinav_id = ?
    `, [sinavId]);
    
    console.log(`ðĨ SÄąnava katÄąlan: ${katilimcilar.length} ÃķÄrenci`);
    
    if (katilimcilar.length === 0) {
      console.log('â ïļ SÄąnava katÄąlan ÃķÄrenci bulunamadÄą!');
      return null;
    }
    
    // PDF'den tÃžm satÄąrlarÄą Ã§Äąkar
    const lines = pdfText.split('\n').map(l => l.trim()).filter(l => l.length > 0);
    
    const strategies = [
      strategy1_LearnedPattern,
      strategy2_DatabaseSimilarity,
      strategy3_PositionBased,
      strategy4_AdvancedRegex,
      strategy5_FuzzySearch
    ];
    
    let result = null;
    let usedStrategy = null;
    
    // Her stratejiyi sÄąrayla dene
    for (let i = 0; i < strategies.length; i++) {
      const strategy = strategies[i];
      console.log(`\nð Strateji ${i+1}: ${strategy.name}`);
      
      try {
        result = await strategy(lines, katilimcilar, kurumId, sinavId, pdfPath);
        
        // Strateji 1 ve 2 iÃ§in daha dÃžÅÃžk eÅik, diÄerleri iÃ§in 0.75
        const minConfidence = (i === 0 || i === 1) ? 0.70 : 0.75;
        
        if (result && result.confidence >= minConfidence) {
          usedStrategy = strategy.name;
          console.log(`â Strateji ${i+1} BAÅARILI! (GÃžven: ${(result.confidence * 100).toFixed(0)}%)`);
          
          // BaÅarÄąlÄą stratejiyi ÃķÄren
          await learnSuccessfulPattern(kurumId, sinavId, result, strategy.name);
          break;
        } else {
          console.log(`â ïļ Strateji ${i+1} yeterli gÃžvende deÄil (Mevcut: ${result?.confidence ? (result.confidence * 100).toFixed(0) + '%' : 'yok'}, Gereken: ${(minConfidence * 100).toFixed(0)}%)`);
        }
      } catch (error) {
        console.error(`â Strateji ${i+1} hatasÄą:`, error.message);
      }
    }
    
    // HiÃ§bir strateji iÅe yaramadÄąysa
    if (!result || result.confidence < 0.70) {
      console.log('â TÃM STRATEJÄ°LER BAÅARISIZ - Manuel eÅleÅtirme gerekli');
      console.log(`   En iyi sonuÃ§: ${result?.confidence ? (result.confidence * 100).toFixed(0) + '%' : 'BulunamadÄą'}`);
      await logMatchingFailure(sinavId, lines, 'all_strategies_failed');
      return null;
    }
    
    return {
      ...result,
      usedStrategy: usedStrategy
    };
  } catch (error) {
    console.error('â Cascade matching hatasÄą:', error);
    return null;
  }
}

