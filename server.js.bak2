app.post('/login', loginLimiter, async (req, res) => {
  const { username, password } = req.body;
  
  try {
    const user = await dbGet('SELECT * FROM users WHERE username = ?', [username]);
    
    console.log('\nð GÄ°RÄ°Å DENEMESÄ°:');
    console.log('   KullanÄącÄą AdÄą:', username);
    console.log('Database connected:', DB_PATH);
    if (user) {
      console.log('   KullanÄącÄą Tipi:', user.user_type);
      console.log('   Hash KarÅÄąlaÅtÄąrma:', await bcrypt.compare(password, user.password_hash) ? 'BaÅarÄąlÄą' : 'BaÅarÄąsÄąz');
    }
    
    if (user && await bcrypt.compare(password, user.password_hash)) {
      req.session.userId = user.id;
      req.session.username = user.username;
      req.session.userType = user.user_type;
      
      console.log('   â GÄ°RÄ°Å BAÅARILI!');
      console.log('   Session ID:', req.session.userId);
      
      // Ä°lk giriÅ kontrolÃž (password_changed = 0 veya NULL)
      if (user.user_type === 'veli' && (user.password_changed === 0 || user.password_changed === null)) {
        console.log('   ð Ä°LK GÄ°RÄ°Å - Åifre deÄiÅtirme ekranÄąna yÃķnlendiriliyor\n');
        return res.redirect('/sifre-degistir');
      }
      
      console.log('   YÃķnlendirme:', user.user_type + ' dashboard\n');
      
      if (user.user_type === 'veli') {
        return res.redirect('/veli/dashboard');
      } else if (user.user_type === 'rehber_ogretmen') {
        return res.redirect('/rehber/dashboard');
      } else if (user.user_type === 'kurum_yonetici') {
        return res.redirect('/kurum/dashboard');
      }
    }
    
    console.log('   â GÄ°RÄ°Å BAÅARISIZ!\n');
    req.session.error = 'KullanÄącÄą adÄą veya Åifre hatalÄą!';
    res.redirect('/login');
  } catch (error) {
    console.error('Login hatasÄą:', error);
    req.session.error = 'GiriÅ sÄąrasÄąnda bir hata oluÅtu!';
    res.redirect('/login');
  }
});

// Åifre DeÄiÅtirme SayfasÄą (Ä°lk GiriÅ)
app.get('/sifre-degistir', (req, res) => {
  if (!req.session.userId) {
    return res.redirect('/login');
  }
  
  res.render('sifre-degistir', { error: req.session.error });
  req.session.error = null;
});

app.post('/sifre-degistir', async (req, res) => {
  if (!req.session.userId) {
    return res.redirect('/login');
  }
  
  const { yeni_sifre, yeni_sifre_tekrar } = req.body;
  
  try {
    // Åifre kontrolÃž
    if (yeni_sifre.length < 6) {
      req.session.error = 'Åifre en az 6 karakter olmalÄądÄąr!';
      return res.redirect('/sifre-degistir');
    }
    
    if (yeni_sifre !== yeni_sifre_tekrar) {
      req.session.error = 'Åifreler uyuÅmuyor!';
      return res.redirect('/sifre-degistir');
    }
    
    // Yeni Åifreyi hashle
    const hashedPassword = await bcrypt.hash(yeni_sifre, 10);
    
    // VeritabanÄąnÄą gÃžncelle
    await dbRun(`
      UPDATE users 
      SET password_hash = ?, password_changed = 1 
      WHERE id = ?
    `, [hashedPassword, req.session.userId]);
    
    console.log(`\nð ÅÄ°FRE DEÄÄ°ÅTÄ°RÄ°LDÄ°`);
    console.log(`   User ID: ${req.session.userId}`);
    console.log(`   â Åifre baÅarÄąyla deÄiÅtirildi\n`);
    
    req.session.success = 'Åifreniz baÅarÄąyla deÄiÅtirildi!';
    
    // KullanÄącÄą tipine gÃķre yÃķnlendir
    const user = await dbGet('SELECT user_type FROM users WHERE id = ?', [req.session.userId]);
    
    if (user.user_type === 'veli') {
      return res.redirect('/veli/dashboard');
    } else {
      return res.redirect('/');
    }
    
  } catch (error) {
    console.error('Åifre deÄiÅtirme hatasÄą:', error);
    req.session.error = 'Åifre deÄiÅtirme sÄąrasÄąnda bir hata oluÅtu!';
    res.redirect('/sifre-degistir');
  }
});

app.get('/register', (req, res) => {
