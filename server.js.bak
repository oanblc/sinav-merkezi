// WhatsApp bildirimi gĂśnder (Whapi.cloud API kullanarak)
async function whatsappBildirimGonder(telefon, mesaj, bildirimTipi = 'genel') {
  console.log('\nđą ââââââââââââââââââââââââââââââââââââââââââââââââââââ');
  console.log('đą WHATSAPP BÄ°LDÄ°RÄ°M - Whapi.cloud');
  console.log('đą ââââââââââââââââââââââââââââââââââââââââââââââââââââ');
  console.log(`đ AlÄącÄą: ${telefon}`);
  console.log(`đ Mesaj: ${mesaj}`);
  console.log(`đˇď¸  Tip: ${bildirimTipi}`);
  console.log('đą ââââââââââââââââââââââââââââââââââââââââââââââââââââ\n');
  
  try {
    // WhatsApp ayarlarÄąnÄą al
    const ayarlar = await dbGet('SELECT * FROM whatsapp_ayarlari WHERE aktif = 1');
    
    if (!ayarlar || !ayarlar.api_token) {
      console.log('â ď¸  WhatsApp API token bulunamadÄą, sadece log yazÄąlÄąyor');
      
      // Bildirim geĂ§miĹine kaydet (simĂźlasyon)
      await dbRun(
        `INSERT INTO bildirim_gecmisi (bildirim_tipi, alici_telefon, mesaj, durum, created_at) 
         VALUES (?, ?, ?, 'simulasyon', datetime('now'))`,
        [bildirimTipi, telefon, mesaj]
      );
      
      return { success: true, message: 'Bildirim gĂśnderildi (simĂźlasyon - API token yok)' };
    }
    
    // Whapi.cloud API'ye istek gĂśnder
    const https = require('https');
    const url = require('url');
    
    // Telefon numarasÄąnÄą formatla (Whapi.cloud formatÄą: 905551234567@s.whatsapp.net)
    let formattedPhone = telefon.replace(/[^0-9]/g, ''); // Sadece rakamlar
    if (!formattedPhone.startsWith('90')) {
      formattedPhone = '90' + formattedPhone; // TĂźrkiye kodu ekle
    }
    formattedPhone = formattedPhone + '@s.whatsapp.net';
    
    // API URL'ini dĂźzelt
    const baseUrl = (ayarlar.api_url || 'https://gate.whapi.cloud').replace(/\/$/, '');
    const apiUrl = `${baseUrl}/messages/text`;
    
    const postData = JSON.stringify({
      to: formattedPhone,
      body: mesaj
    });
    
    console.log('đĄ API URL:', apiUrl);
    console.log('đ Formatted Phone:', formattedPhone);
    console.log('đŚ POST Data:', postData);
    
    const parsedUrl = url.parse(apiUrl);
    const options = {
      hostname: parsedUrl.hostname,
      port: parsedUrl.port || 443,
      path: parsedUrl.path,
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'Authorization': `Bearer ${ayarlar.api_token}`,
        'Content-Length': Buffer.byteLength(postData)
      }
    };
    
    return new Promise((resolve, reject) => {
      const req = https.request(options, (res) => {
        let data = '';
        
        res.on('data', (chunk) => {
          data += chunk;
        });
        
        res.on('end', async () => {
          console.log('â Whapi.cloud API YanÄątÄą:', res.statusCode);
          console.log('đŚ Response:', data);
          
          if (res.statusCode === 200 || res.statusCode === 201) {
            // BaĹarÄąlÄą - Bildirim geĂ§miĹine kaydet
            await dbRun(
              `INSERT INTO bildirim_gecmisi (bildirim_tipi, alici_telefon, mesaj, durum, created_at) 
               VALUES (?, ?, ?, 'basarili', datetime('now'))`,
              [bildirimTipi, telefon, mesaj]
            );
            
            resolve({ success: true, message: 'WhatsApp bildirimi baĹarÄąyla gĂśnderildi!' });
          } else {
            // API hatasÄą
            const errorMsg = `API Error: ${res.statusCode} - ${data}`;
            console.error('â', errorMsg);
            
            await dbRun(
              `INSERT INTO bildirim_gecmisi (bildirim_tipi, alici_telefon, mesaj, durum, hata_mesaji, created_at) 
               VALUES (?, ?, ?, 'basarisiz', ?, datetime('now'))`,
              [bildirimTipi, telefon, mesaj, errorMsg]
            );
            
            resolve({ success: false, message: 'WhatsApp bildirimi gĂśnderilemedi', error: errorMsg });
          }
        });
      });
      
      req.on('error', async (error) => {
        console.error('â Whapi.cloud baÄlantÄą hatasÄą:', error);
        
        // Hata durumunu kaydet
        try {
          await dbRun(
            `INSERT INTO bildirim_gecmisi (bildirim_tipi, alici_telefon, mesaj, durum, hata_mesaji, created_at) 
             VALUES (?, ?, ?, 'basarisiz', ?, datetime('now'))`,
            [bildirimTipi, telefon, mesaj, error.message]
          );
        } catch (logError) {
          console.error('â Bildirim geĂ§miĹi kayÄąt hatasÄą:', logError);
        }
        
        resolve({ success: false, message: 'BaÄlantÄą hatasÄą', error: error.message });
      });
      
      req.write(postData);
      req.end();
    });
    
  } catch (error) {
    console.error('â WhatsApp bildirim hatasÄą:', error);
    
    // Hata durumunu kaydet
    try {
      await dbRun(
        `INSERT INTO bildirim_gecmisi (bildirim_tipi, alici_telefon, mesaj, durum, hata_mesaji, created_at) 
         VALUES (?, ?, ?, 'basarisiz', ?, datetime('now'))`,
        [bildirimTipi, telefon, mesaj, error.message]
      );
    } catch (logError) {
      console.error('â Bildirim geĂ§miĹi kayÄąt hatasÄą:', logError);
    }
    
    return { success: false, message: 'Bildirim gĂśnderilemedi', error: error.message };
  }
}

