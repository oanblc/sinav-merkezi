    // SÄąnav paketleri (aktif olanlar)
    const paketler = await dbAll(`
      SELECT 
        sp.*,
        COUNT(DISTINCT ps.sinav_id) as sinav_sayisi
      FROM sinav_paketleri sp
      LEFT JOIN paket_sinavlari ps ON sp.id = ps.paket_id
      WHERE sp.aktif = 1
