    }
    
    await dbRun(
      'UPDATE duyurular SET baslik = ?, icerik = ?, tarih = ?, sira = ?, aktif = ? WHERE id = ?',
      [baslik, icerik || '', tarih || new Date().toISOString().split('T')[0], sira || 0, aktif ? 1 : 0, duyuruId]
    );
    
    console.log(`\nâ DUYURU GĂNCELLENDÄ°`);
    console.log(`   ID: ${duyuruId}`);
    console.log(`   BaĹlÄąk: ${baslik}`);
    
    req.session.success = 'Duyuru baĹarÄąyla gĂźncellendi!';
    res.json({ success: true, message: 'Duyuru baĹarÄąyla gĂźncellendi!' });
  } catch (error) {
    console.error('Duyuru gĂźncelleme hatasÄą:', error);
    res.json({ success: false, message: 'Bir hata oluĹtu: ' + error.message });
  }
});

