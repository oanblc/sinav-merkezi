        SET pdf_path = ?, sonuc_durumu = 'yuklendi'
        WHERE sinav_id = ? AND ogrenci_id = ? AND ogrenci_kaynak = ?
      `, [sayfa_yolu, sinav_id, ogrenci_id, kaynak], function(err) {
        if (err) reject(err);
        else resolve({ changes: this.changes });
      });
    });
    
    console.log(`   â BaĹarÄąlÄą: ${result.changes} satÄąr gĂźncellendi`);
    
    if (result.changes === 0) {
      console.log(`   â ď¸  UYARI: HiĂ§bir satÄąr gĂźncellenmedi! WHERE koĹulu tutmadÄą.`);
    }
    
    res.json({ success: true, changes: result.changes });
    
  } catch (error) {
