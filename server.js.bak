// Kurum - SÄąnav Detay (KatÄąlÄąmcÄą YĂśnetimi)
app.get('/kurum/sinav-detay/:id', requireAuth, async (req, res) => {
  if (req.session.userType !== 'kurum_yonetici') {
    return res.status(403).send('Bu sayfaya eriĹim yetkiniz yok!');
  }
  
  // â Cache'i devre dÄąĹÄą bÄąrak - her zaman gĂźncel veri Ă§ek
  res.setHeader('Cache-Control', 'no-store, no-cache, must-revalidate, private');
  res.setHeader('Pragma', 'no-cache');
  res.setHeader('Expires', '0');
  
  try {
    const sinavId = req.params.id;
    
    // SÄąnav bilgilerini al
    const sinav = await dbGet('SELECT * FROM sinavlar WHERE id = ?', [sinavId]);
    
    if (!sinav) {
      req.session.error = 'SÄąnav bulunamadÄą!';
      return res.redirect('/kurum/sinavlar');
    }
    
    // KatÄąlÄąmcÄąlarÄą al (hem kurum hem veli kayÄątlarÄąndan)
    const kurumKatilimcilari = await dbAll(`
      SELECT 
        sk.*,
        'kurum' as kaynak,
        ok.ogrenci_adi_soyadi as ad_soyad,
        ok.sinif,
        ok.telefon,
        ok.veli_adi,
        ok.veli_telefon
      FROM sinav_katilimcilari sk
      INNER JOIN ogrenci_kayitlari ok ON sk.ogrenci_id = ok.id AND sk.ogrenci_kaynak = 'kurum'
      WHERE sk.sinav_id = ?
      ORDER BY ok.sinif, ok.ogrenci_adi_soyadi
    `, [sinavId]);
    
    const veliKatilimcilari = await dbAll(`
      SELECT 
        sk.*,
        'veli' as kaynak,
        o.ad_soyad,
        o.sinif,
        o.telefon,
        u.username as veli_adi,
        o.telefon as veli_telefon
      FROM sinav_katilimcilari sk
      INNER JOIN ogrenciler o ON sk.ogrenci_id = o.id AND sk.ogrenci_kaynak = 'veli'
      LEFT JOIN users u ON o.veli_id = u.id
      WHERE sk.sinav_id = ?
      ORDER BY o.sinif, o.ad_soyad
    `, [sinavId]);
    
    const katilimcilar = [...kurumKatilimcilari, ...veliKatilimcilari];
    
    // TĂźm ĂśÄrencileri al (hem kurum kayÄątlarÄą hem veli ĂśÄrencileri)
    const kurumOgrencileri = await dbAll(`
      SELECT 
        'kurum_' || id as unique_id,
        id as original_id,
        'kurum' as kaynak,
        ogrenci_adi_soyadi as ad_soyad,
        sinif,
        telefon,
        tc_kimlik_no as tc_no,
        veli_adi,
        veli_telefon
      FROM ogrenci_kayitlari
      ORDER BY sinif, ogrenci_adi_soyadi
    `);
    
    const veliOgrencileri = await dbAll(`
      SELECT 
        'veli_' || o.id as unique_id,
        o.id as original_id,
        'veli' as kaynak,
        o.ad_soyad,
        o.sinif,
        o.telefon,
        o.tc_no,
        u.username as veli_adi,
        o.telefon as veli_telefon
      FROM ogrenciler o
      LEFT JOIN users u ON o.veli_id = u.id
      ORDER BY o.sinif, o.ad_soyad
    `);
    
    // TC bazlÄą tekrarlarÄą temizle (Kurum kaydÄą Ăśncelikli)
    const tumOgrenciler = temizleOgrenciTekrarlari(veliOgrencileri, kurumOgrencileri);
    
    console.log(`\nđ ĂÄrenci Listesi (${tumOgrenciler.length} ĂśÄrenci):`);
    console.log(`  - Kurum kayÄątlarÄą: ${kurumOgrencileri.length}`);
    console.log(`  - Veli ĂśÄrencileri: ${veliOgrencileri.length}`);
    if (tumOgrenciler.length > 0) {
      console.log('Ä°lk 3 ĂśÄrenci ĂśrneÄi:');
      tumOgrenciler.slice(0, 3).forEach(o => {
        console.log(`  - [${o.kaynak}] ID: ${o.original_id}, Ä°sim: "${o.ad_soyad}", SÄąnÄąf: "${o.sinif}"`);
      });
    } else {
      console.log('â HiĂ§ ĂśÄrenci bulunamadÄą!');
    }
    
    // Benzersiz sÄąnÄąf listesi
    const siniflar = [...new Set(tumOgrenciler.map(o => o.sinif).filter(s => s))].sort();
    
    // EĹleĹme istatistiklerini hesapla
    // pdf_path varsa eĹleĹmiĹtir (sonuc_durumu 'yuklendi', 'tamamlandi', 'bildirildi' olabilir)
    const eslesmisKatilimcilar = katilimcilar.filter(k => k.pdf_path && k.pdf_path.trim() !== '');
    const eslesmemisKatilimcilar = katilimcilar.filter(k => !k.pdf_path || k.pdf_path.trim() === '');
    
    const istatistikler = {
      toplam: katilimcilar.length,
      eslesmis: eslesmisKatilimcilar.length,
      eslesmemis: eslesmemisKatilimcilar.length,
      oran: katilimcilar.length > 0 ? Math.round((eslesmisKatilimcilar.length / katilimcilar.length) * 100) : 0
    };
    
    console.log(`\nđ Ä°STATÄ°STÄ°KLER (SÄąnav ID: ${sinavId})`);
    console.log(`   Toplam KatÄąlÄąmcÄą: ${istatistikler.toplam}`);
    console.log(`   â EĹleĹen: ${istatistikler.eslesmis}`);
    console.log(`   â ď¸ EĹleĹmeyen: ${istatistikler.eslesmemis}`);
    console.log(`   đ BaĹarÄą OranÄą: %${istatistikler.oran}`);
    
    // Session mesajlarÄąnÄą al ve hemen temizle
    const errorMsg = req.session.error;
    const successMsg = req.session.success;
    req.session.error = null;
    req.session.success = null;
    
    res.render('kurum/sinav-detay', {
      sinav: sinav,
      katilimcilar: katilimcilar,
      eslesmisKatilimcilar: eslesmisKatilimcilar,
      eslesmemisKatilimcilar: eslesmemisKatilimcilar,
      istatistikler: istatistikler,
      tumOgrenciler: tumOgrenciler,
      siniflar: siniflar,
      user: { username: req.session.username, type: req.session.userType },
      error: errorMsg,
      success: successMsg
    });
  } catch (error) {
    console.error('SÄąnav detay hatasÄą:', error);
    res.status(500).send('Bir hata oluĹtu!');
  }
});

// đ Kurum - SÄąnav SonuĂ§larÄąnÄą Listele (YĂźklenmiĹ PDF sonuĂ§larÄąnÄą gĂśster)
app.get('/kurum/sinav-sonuclari-listele/:id', requireAuth, async (req, res) => {
  if (req.session.userType !== 'kurum_yonetici') {
    return res.status(403).json({ success: false, error: 'Yetkiniz yok!' });
  }
  
  try {
    const sinavId = req.params.id;
    
    console.log('\nđ SINAV SONUĂLARI LÄ°STELENÄ°YOR:', sinavId);
    
    // SÄąnav katÄąlÄąmcÄąlarÄąnÄą ve sonuĂ§larÄąnÄą al
    const sonuclar = await dbAll(`
      SELECT 
        sk.ogrenci_id,
        sk.ogrenci_kaynak as kaynak,
        sk.pdf_path,
        sk.sonuc_durumu,
        CASE 
          WHEN sk.ogrenci_kaynak = 'kurum' THEN ok.ogrenci_adi_soyadi
          WHEN sk.ogrenci_kaynak = 'veli' THEN o.ad_soyad
        END as ad_soyad
      FROM sinav_katilimcilari sk
      LEFT JOIN ogrenci_kayitlari ok ON sk.ogrenci_id = ok.id AND sk.ogrenci_kaynak = 'kurum'
      LEFT JOIN ogrenciler o ON sk.ogrenci_id = o.id AND sk.ogrenci_kaynak = 'veli'
      WHERE sk.sinav_id = ?
      ORDER BY sk.id
    `, [sinavId]);
    
    console.log(`   Toplam katÄąlÄąmcÄą: ${sonuclar.length}`);
    
    // SonuĂ§larÄą grupla
    let matchedCount = 0;
    let unmatchedCount = 0;
    
    const results = sonuclar.map((s, index) => {
      const eslesti = !!(s.pdf_path && s.sonuc_durumu === 'yuklendi');
      
      if (eslesti) matchedCount++;
      else unmatchedCount++;
      
      return {
        sayfaNo: index + 1,
        ogrenciId: s.ogrenci_id,
        ogrenciAdi: s.ad_soyad || 'BÄ°LÄ°NMEYEN',
        pdfYolu: s.pdf_path,
        eslesti: eslesti,
        kaynak: s.kaynak,
        sonucDurumu: s.sonuc_durumu
      };
    });
    
    console.log(`   â EĹleĹen: ${matchedCount}`);
    console.log(`   â ď¸  EĹleĹmeyen: ${unmatchedCount}`);
    
    res.json({
      success: true,
      data: {
        totalCount: sonuclar.length,
        matchedCount: matchedCount,
        unmatchedCount: unmatchedCount,
        results: results
      }
    });
    
  } catch (error) {
    console.error('â SonuĂ§ listeleme hatasÄą:', error);
    res.status(500).json({
      success: false,
      error: 'SonuĂ§lar listelenemedi: ' + error.message
    });
  }
});

// đ Kurum - SÄąnav SonuĂ§larÄąnÄą YayÄąnla/KaldÄąr
app.post('/kurum/sinav-yayinla/:id', requireAuth, async (req, res) => {
  if (req.session.userType !== 'kurum_yonetici') {
    return res.status(403).json({ success: false, message: 'Yetkiniz yok!' });
  }

  try {
    const sinavId = req.params.id;
    const { yayinla } = req.body; // true = yayÄąnla, false = yayÄąndan kaldÄąr
    
    const yeniDurum = yayinla ? 1 : 0;
    
    await dbRun('UPDATE sinavlar SET sonuclar_aciklandi = ? WHERE id = ?', [yeniDurum, sinavId]);
    
    // AyrÄąca sÄąnav durumunu da gĂźncelle (gĂśrsel uyumluluk iĂ§in)
    const sinavDurumu = yayinla ? 'SonuĂ§ aĂ§ÄąklandÄą' : 'SonuĂ§ yĂźkleniyor';
    await dbRun('UPDATE sinavlar SET sinav_durumu = ? WHERE id = ?', [sinavDurumu, sinavId]);
    
    console.log(`\nđ˘ SÄąnav ${sinavId} durumu gĂźncellendi: ${yayinla ? 'YAYINLANDI' : 'TASLAK'}`);
    
    res.json({ 
      success: true, 
      message: yayinla ? 'SÄąnav sonuĂ§larÄą baĹarÄąyla yayÄąnlandÄą! Veliler artÄąk gĂśrebilir.' : 'SÄąnav sonuĂ§larÄą yayÄąndan kaldÄąrÄąldÄą (Taslak).' 
    });
    
  } catch (error) {
    console.error('SÄąnav yayÄąnlama hatasÄą:', error);
    res.status(500).json({ success: false, message: 'Bir hata oluĹtu: ' + error.message });
  }
});

// Kurum - KatÄąlÄąmcÄą Ekle
app.post('/kurum/sinav-katilimci-ekle', requireAuth, async (req, res) => {
  if (req.session.userType !== 'kurum_yonetici') {
    return res.status(403).json({ success: false, message: 'Yetkiniz yok!' });
  }
  
  try {
    const { sinav_id, ogrenci_ids } = req.body;
    
    if (!sinav_id || !ogrenci_ids || ogrenci_ids.length === 0) {
      return res.json({ success: false, message: 'SÄąnav ID veya ĂśÄrenci seĂ§imi eksik!' });
    }
    
    let eklenenSayisi = 0;
    let mevcutSayisi = 0;
    
    for (const uniqueId of ogrenci_ids) {
      // unique_id'yi parse et (Ăśrn: "kurum_123" veya "veli_456")
      const parts = uniqueId.split('_');
      const kaynak = parts[0]; // 'kurum' veya 'veli'
      const ogrenciId = parts[1]; // gerĂ§ek ID
      
      // Zaten katÄąlÄąmcÄą mÄą kontrol et
      const mevcut = await dbGet(
        'SELECT * FROM sinav_katilimcilari WHERE sinav_id = ? AND ogrenci_id = ? AND ogrenci_kaynak = ?',
        [sinav_id, ogrenciId, kaynak]
      );
      
      if (mevcut) {
        mevcutSayisi++;
      } else {
        await dbRun(
          'INSERT INTO sinav_katilimcilari (sinav_id, ogrenci_id, ogrenci_kaynak) VALUES (?, ?, ?)',
          [sinav_id, ogrenciId, kaynak]
        );
        eklenenSayisi++;
      }
    }
    
    // KatÄąlÄąmcÄą sayÄąsÄąnÄą gĂźncelle
    const yeniSayi = await dbGet(
      'SELECT COUNT(*) as sayi FROM sinav_katilimcilari WHERE sinav_id = ?',
      [sinav_id]
    );
    await dbRun(
      'UPDATE sinavlar SET katilimci_sayisi = ? WHERE id = ?',
      [yeniSayi.sayi, sinav_id]
    );
    
    // EÄer hiĂ§bir ĂśÄrenci eklenemediyse (hepsi zaten ekliyse), uyarÄą ver
    if (eklenenSayisi === 0 && mevcutSayisi > 0) {
      return res.json({ 
        success: false, 
        message: `â ď¸ SeĂ§tiÄiniz ${mevcutSayisi} ĂśÄrenci zaten bu sÄąnava ekli! Tekrar ekleme yapÄąlamaz.` 
      });
    }
    
    // BazÄąlarÄą eklendi, bazÄąlarÄą mevcuttu
    res.json({ 
      success: true, 
      message: `â ${eklenenSayisi} ĂśÄrenci eklendi${mevcutSayisi > 0 ? `\nâ ď¸ ${mevcutSayisi} ĂśÄrenci zaten ekli olduÄu iĂ§in atlandÄą` : ''}!` 
    });
  } catch (error) {
    console.error('KatÄąlÄąmcÄą ekleme hatasÄą:', error);
    res.json({ success: false, message: 'Bir hata oluĹtu!' });
  }
});

// Kurum - KatÄąlÄąmcÄą Sil
app.post('/kurum/sinav-katilimci-sil/:id', requireAuth, async (req, res) => {
  if (req.session.userType !== 'kurum_yonetici') {
    return res.status(403).json({ success: false, message: 'Yetkiniz yok!' });
  }
  
  try {
    const katilimciId = req.params.id;
    
    // SÄąnav ID'sini al (katÄąlÄąmcÄą sayÄąsÄąnÄą gĂźncellemek iĂ§in)
    const katilimci = await dbGet('SELECT sinav_id FROM sinav_katilimcilari WHERE id = ?', [katilimciId]);
    
    if (!katilimci) {
      return res.json({ success: false, message: 'KatÄąlÄąmcÄą bulunamadÄą!' });
    }
    
    // KatÄąlÄąmcÄąyÄą sil
    await dbRun('DELETE FROM sinav_katilimcilari WHERE id = ?', [katilimciId]);
    
    // KatÄąlÄąmcÄą sayÄąsÄąnÄą gĂźncelle
    const yeniSayi = await dbGet(
      'SELECT COUNT(*) as sayi FROM sinav_katilimcilari WHERE sinav_id = ?',
      [katilimci.sinav_id]
    );
    await dbRun(
      'UPDATE sinavlar SET katilimci_sayisi = ? WHERE id = ?',
      [yeniSayi.sayi, katilimci.sinav_id]
    );
    
    res.json({ success: true, message: 'KatÄąlÄąmcÄą baĹarÄąyla Ă§ÄąkarÄąldÄą!' });
  } catch (error) {
    console.error('KatÄąlÄąmcÄą silme hatasÄą:', error);
    res.json({ success: false, message: 'Bir hata oluĹtu!' });
  }
});

