// Graceful shutdown
// Rehber - Manuel EĹleĹtirme KALDIRILDI (Sadece kurum yapabilir)

process.on('SIGINT', () => {
  db.close((err) => {
    if (err) {
      console.error('VeritabanÄą kapatma hatasÄą:', err);
    } else {
      console.log('Database connected:', DB_PATH);
    }
    process.exit(0);
  });
});













