// API - ĂÄrenci Ara (Autocomplete iĂ§in - SonuĂ§ yĂźklerken manuel eĹleĹtirmede kullanÄąlacak)
app.get('/api/ogrenci-ara', requireAuth, async (req, res) => {
  if (req.session.userType !== 'kurum_yonetici') {
    return res.status(403).json({ success: false, message: 'Yetkiniz yok!' });
  }
  
  try {
    const { q, sinav_id } = req.query;
    
    if (!q || q.length < 2) {
      return res.json([]);
    }
    
    // SÄąnÄąfa kayÄątlÄą ĂśÄrencileri ara
    let query = `
      SELECT 
        ok.id,
        ok.ogrenci_adi_soyadi,
        ok.sinif,
        ok.telefon,
        ok.veli_adi,
        ok.veli_telefon
      FROM ogrenci_kayitlari ok
      WHERE ok.ogrenci_adi_soyadi LIKE ?
    `;
    
    const params = [`%${q}%`];
    
    // EÄer sinav_id verilmiĹse, sÄąnava katÄąlÄąmcÄą olarak eklenenlerden filtrele
    if (sinav_id) {
      query += ` AND ok.id IN (SELECT ogrenci_id FROM sinav_katilimcilari WHERE sinav_id = ?)`;
      params.push(sinav_id);
    }
    
    query += ` ORDER BY ok.ogrenci_adi_soyadi LIMIT 10`;
    
    const sonuclar = await dbAll(query, params);
    
    res.json(sonuclar);
  } catch (error) {
    console.error('ĂÄrenci arama hatasÄą:', error);
    res.json([]);
  }
});

// đ YENÄ° SÄ°STEM: Basit SonuĂ§ YĂźkleme SayfasÄą
app.get('/kurum/sinav-sonuc-yukle-yeni/:id', requireAuth, async (req, res) => {
  if (req.session.userType !== 'kurum_yonetici') {
    return res.status(403).send('Yetkiniz yok!');
  }
  
  try {
    const sinavId = req.params.id;
    
    const sinav = await dbGet('SELECT * FROM sinavlar WHERE id = ?', [sinavId]);
    if (!sinav) {
      return res.status(404).send('SÄąnav bulunamadÄą!');
    }
    
    const katilimciSayisi = await dbGet(
      'SELECT COUNT(*) as count FROM sinav_katilimcilari WHERE sinav_id = ?',
      [sinavId]
    );
    
    res.render('kurum/sinav-sonuc-yukle-yeni', {
      user: req.session,
      sinav: sinav,
      katilimciSayisi: katilimciSayisi.count,
      error: req.query.error || null
    });
    
  } catch (error) {
    console.error('SonuĂ§ yĂźkleme sayfasÄą hatasÄą:', error);
    res.status(500).send('Bir hata oluĹtu!');
  }
});

// ESKÄ° SÄ°STEM: SonuĂ§ YĂźkleme SayfasÄą (AkÄąllÄą EĹleĹtirme ile)
app.get('/kurum/sinav-sonuc-yukle/:id', requireAuth, async (req, res) => {
  if (req.session.userType !== 'kurum_yonetici') {
    return res.status(403).send('Bu sayfaya eriĹim yetkiniz yok!');
  }
  
  try {
    const sinavId = req.params.id;
    
    // SÄąnav bilgilerini al
    const sinav = await dbGet('SELECT * FROM sinavlar WHERE id = ?', [sinavId]);
    
    if (!sinav) {
      req.session.error = 'SÄąnav bulunamadÄą!';
      return res.redirect('/kurum/sinavlar');
    }
    
    // KatÄąlÄąmcÄąlarÄą al (hem kurum hem veli kayÄątlarÄąndan)
    const kurumKatilimcilari = await dbAll(`
      SELECT 
        sk.*,
        'kurum' as kaynak,
        ok.ogrenci_adi_soyadi as ad_soyad,
        ok.sinif,
        ok.telefon,
        ok.veli_adi,
        ok.veli_telefon
      FROM sinav_katilimcilari sk
      INNER JOIN ogrenci_kayitlari ok ON sk.ogrenci_id = ok.id AND sk.ogrenci_kaynak = 'kurum'
      WHERE sk.sinav_id = ?
      ORDER BY ok.sinif, ok.ogrenci_adi_soyadi
    `, [sinavId]);
    
    const veliKatilimcilari = await dbAll(`
      SELECT 
        sk.*,
        'veli' as kaynak,
        o.ad_soyad,
        o.sinif,
        o.telefon,
        u.username as veli_adi,
        o.telefon as veli_telefon
      FROM sinav_katilimcilari sk
      INNER JOIN ogrenciler o ON sk.ogrenci_id = o.id AND sk.ogrenci_kaynak = 'veli'
      LEFT JOIN users u ON o.veli_id = u.id
      WHERE sk.sinav_id = ?
      ORDER BY o.sinif, o.ad_soyad
    `, [sinavId]);
    
    const katilimcilar = [...kurumKatilimcilari, ...veliKatilimcilari];
    
    if (katilimcilar.length === 0) {
      req.session.error = 'Bu sÄąnava henĂźz katÄąlÄąmcÄą eklenmemiĹ! Ănce ĂśÄrenci ekleyin.';
      return res.redirect(`/kurum/sinav-detay/${sinavId}`);
    }
    
    res.render('kurum/sinav-sonuc-yukle', {
      sinav: sinav,
      katilimcilar: katilimcilar,
      katilimciSayisi: katilimcilar.length,
      user: { username: req.session.username, type: req.session.userType },
      error: req.session.error,
      success: req.session.success
    });
    
    req.session.error = null;
    req.session.success = null;
  } catch (error) {
    console.error('SonuĂ§ yĂźkleme sayfasÄą hatasÄą:', error);
    res.status(500).send('Bir hata oluĹtu!');
  }
});

// Kurum - SonuĂ§ PDF Analiz (Ä°lk sayfayÄą analiz et, isim pattern'i bul)
// đ YENÄ° SÄ°STEM: PDF'i Sayfalara AyÄąr (Otomatik EĹleĹtirme YOK)
app.post('/kurum/sinav-sonuc-yukle-sayfalara-ayir', requireAuth, uploadLimiter, pdfUpload.single('pdfFile'), async (req, res) => {
  if (req.session.userType !== 'kurum_yonetici') {
    return res.status(403).json({ success: false, error: 'Yetkiniz yok!' });
  }
  
  try {
    if (!req.file) {
      return res.status(400).json({ success: false, error: 'PDF dosyasÄą seĂ§ilmedi!' });
    }
    
    const { sinav_id, pdfPath } = req.body;
    const isUploaded = !!req.file;
    const sourcePath = isUploaded ? req.file.path : pdfPath;
    if (!sourcePath || -not (Test-Path )) {
      return res.status(400).json({ success: false, error: 'PDF dosyasý bulunamadý!' });
    }
    
    if (!sinav_id) {
      return res.status(400).json({ success: false, error: 'SÄąnav ID eksik!' });
    }
    
    console.log('\nđ PDF SAYFALARA AYRILIYOR:', req.file.originalname);
    console.log('đ SÄąnav ID:', sinav_id);
    
    // PDF'i yĂźkle
    const pdfBytes = fs.readFileSync(req.file.path);
    const pdfDoc = await PDFDocument.load(pdfBytes);
    const totalPages = pdfDoc.getPageCount();
    
    console.log(`đ Toplam sayfa: ${totalPages}`);
    
    // Her sayfayÄą ayrÄą PDF olarak kaydet
    const sayfaYollari = [];
    
    for (let i = 0; i < totalPages; i++) {
      const singlePagePdf = await PDFDocument.create();
      const [copiedPage] = await singlePagePdf.copyPages(pdfDoc, [i]);
      singlePagePdf.addPage(copiedPage);
      const singlePageBytes = await singlePagePdf.save();
      
      // Dosya adÄą: sinav_ID_sayfa_NUMARA_timestamp.pdf
      const sayfaFileName = `sinav_${sinav_id}_sayfa_${i + 1}_${Date.now()}.pdf`;
      const sayfaYolu = path.join('uploads', 'sinav-sonuclari', sayfaFileName);
      
      // KlasĂśr yoksa oluĹtur
      const dir = path.dirname(sayfaYolu);
      if (!fs.existsSync(dir)) {
        fs.mkdirSync(dir, { recursive: true });
      }
      
      fs.writeFileSync(sayfaYolu, singlePageBytes);
      sayfaYollari.push(sayfaYolu);
      
      console.log(`   â Sayfa ${i + 1}/${totalPages} kaydedildi`);
    }
    
    // Orijinal PDF'i de kaydet
    const orijinalFileName = `sinav_${sinav_id}_orijinal_${Date.now()}.pdf`;
    const orijinalYol = path.join('uploads', 'sinav-sonuclari', orijinalFileName);
    fs.copyFileSync(req.file.path, orijinalYol);
    
    // VeritabanÄąna kaydet - sinavlar tablosuna orijinal PDF yolunu ekle
    await dbRun(
      'UPDATE sinavlar SET dosya_yolu = ?, sonuc_yuklendi = 1 WHERE id = ?',
      [orijinalYol, sinav_id]
    );
    
    // GeĂ§ici dosyayÄą sil
    fs.unlinkSync(req.file.path);
    
    console.log(`â PDF baĹarÄąyla ${totalPages} sayfaya ayrÄąldÄą!`);
    
    res.json({
      success: true,
      data: {
        sayfaSayisi: totalPages,
        sayfaYollari: sayfaYollari,
        orijinalYol: orijinalYol,
        // AkÄąllÄą eĹleĹtirme (analiz/pattern seĂ§imi) ekranÄąna yĂśnlendir
        redirectTo: `/kurum/sinav-sonuc-yukle/${sinav_id}`
      }
    });
    
  } catch (error) {
    console.error('â PDF ayÄąrma hatasÄą:', error);
    res.status(500).json({ success: false, error: error.message });
  }
});

// ESKÄ° SÄ°STEM (Yedek olarak kalÄąyor)
app.post('/kurum/sinav-sonuc-yukle-analiz', requireAuth, uploadLimiter, pdfUpload.single('pdfFile'), async (req, res) => {
  if (req.session.userType !== 'kurum_yonetici') {
    return res.status(403).json({ success: false, error: 'Yetkiniz yok!' });
  }
  
  try {
    if (!req.file) {
      return res.status(400).json({ success: false, error: 'PDF dosyasÄą seĂ§ilmedi!' });
    }
    
    const { sinav_id, pdfPath } = req.body;
    const isUploaded = !!req.file;
    const sourcePath = isUploaded ? req.file.path : pdfPath;
    if (!sourcePath || -not (Test-Path )) {
      return res.status(400).json({ success: false, error: 'PDF dosyasý bulunamadý!' });
    }
    
    if (!sinav_id) {
      return res.status(400).json({ success: false, error: 'SÄąnav ID eksik!' });
    }
    
    console.log('\nđ SINAV SONUCU ANALÄ°Z EDÄ°LÄ°YOR:', req.file.originalname);
    console.log('đ SÄąnav ID:', sinav_id);
    
    // PDF'i yĂźkle
    const pdfBytes = fs.readFileSync(req.file.path);
    const pdfDoc = await PDFDocument.load(pdfBytes);
    const totalPages = pdfDoc.getPageCount();
    
    console.log(`đ Toplam sayfa: ${totalPages}`);
    
    // Sadece ilk sayfayÄą analiz et
    const singlePagePdf = await PDFDocument.create();
    const [copiedPage] = await singlePagePdf.copyPages(pdfDoc, [0]);
    singlePagePdf.addPage(copiedPage);
    const singlePageBytes = await singlePagePdf.save();
    
    // GeĂ§ici dosya oluĹtur
    const tempFileName = `temp_analyze_sinav_${Date.now()}.pdf`;
    const tempFilePath = path.join('uploads', tempFileName);
    fs.writeFileSync(tempFilePath, singlePageBytes);
    
    // Text Ă§Äąkar - HÄ°BRÄ°T YĂNTEM
    const extractionResult = await extractTextHybrid(tempFilePath);
    const text = extractionResult.text;
    
    console.log(`đ Ä°lk sayfa text uzunluÄu: ${text.length} (YĂśntem: ${extractionResult.method})`);
    
    if (extractionResult.garbled) {
      console.log('â ď¸ Ä°lk sayfada encoding sorunu tespit edildi!');
      console.log('đĄ Manuel giriĹ Ăśnerilir.');
    }
    
    // Potansiyel isim adaylarÄąnÄą bul - YENÄ° GELÄ°ĹMÄ°Ĺ SÄ°STEM
    const lines = text.split('\n').map(l => l.trim()).filter(l => l.length > 0);
    const potansiyelIsimler = [];
    
    console.log(`đ Analiz: ${lines.length} satÄąr bulundu`);
    
    // 1. GELÄ°ĹMÄ°Ĺ FÄ°LTRELEME: Yeni looksLikeName fonksiyonunu kullan
    for (let i = 0; i < Math.min(lines.length, 80); i++) { // 80 satÄąra Ă§ÄąkardÄąk
      const line = lines[i];
      
      // Ä°sim gibi mi kontrol et (yeni fonksiyon)
      if (!looksLikeName(line)) continue;
      
      // Ä°smi temizle (yeni fonksiyon)
      const cleanLine = cleanExtractedName(line);
      if (!cleanLine || cleanLine.length < 5) continue;
      
      // Kelime sayÄąsÄą kontrolĂź
      const words = cleanLine.split(/\s+/);
      const wordCount = words.length;
      
      // GĂźven seviyesi hesapla
      let confidence = 'medium';
      
      // Sadece harf ve boĹluk + 2-3 kelime = yĂźksek gĂźven
      if (wordCount === 2 || wordCount === 3) {
        confidence = 'high';
      }
      // 4-6 kelime = dĂźĹĂźk gĂźven
      else if (wordCount > 3) {
        confidence = 'low';
      }
      
      potansiyelIsimler.push({
        text: cleanLine,
        lineNumber: i,
        confidence: confidence,
        originalLine: line // Orijinal satÄąrÄą da sakla
      });
      
      console.log(`   â Aday ${potansiyelIsimler.length}: "${cleanLine}" (SatÄąr: ${i}, GĂźven: ${confidence})`);
    }
    
    // 2. HiĂ§ isim bulunamadÄąysa, en uzun satÄąrlarÄą gĂśster (fallback)
    if (potansiyelIsimler.length === 0) {
      console.log('â ď¸ HiĂ§ isim adayÄą bulunamadÄą, en uzun satÄąrlar gĂśsteriliyor...');
      
      const longLines = lines
        .map((line, i) => ({ line, index: i, length: line.length }))
        .filter(l => l.length >= 10 && l.length <= 100)
        .sort((a, b) => b.length - a.length)
        .slice(0, 10);
      
      longLines.forEach(l => {
        potansiyelIsimler.push({
          text: l.line,
          lineNumber: l.index,
          confidence: 'low',
          originalLine: l.line
        });
      });
      
      console.log(`   â ${potansiyelIsimler.length} uzun satÄąr eklendi (fallback)`);
    }
    
    // đ§  AkÄąllÄą sistem ile ilk sayfayÄą test et
    console.log('\nđ§  AkÄąllÄą sistem ile ilk sayfa test ediliyor...');
    const testMatch = await intelligentCascadeMatching(
      text, 
      sinav_id, 
      req.session.userId, 
      tempFilePath
    );
    
    let autoSelectedPattern = null;
    let autoConfidence = 0;
    
    if (testMatch && testMatch.confidence >= 0.80) {
      autoSelectedPattern = {
        text: testMatch.extractedName,
        lineNumber: testMatch.lineNumber,
        confidence: testMatch.confidence,
        strategy: testMatch.usedStrategy,
        matchedStudent: testMatch.ogrenciAd
      };
      autoConfidence = testMatch.confidence;
      console.log(`â Otomatik pattern bulundu: "${testMatch.extractedName}" (GĂźven: ${(autoConfidence * 100).toFixed(0)}%)`);
    } else {
      console.log('â ď¸ Otomatik pattern bulunamadÄą, manuel seĂ§im gerekli');
    }
    
    // GeĂ§ici dosyalarÄą temizle
    fs.unlinkSync(tempFilePath);
    
    console.log(`â ${potansiyelIsimler.length} potansiyel isim bulundu`);
    potansiyelIsimler.forEach(p => console.log(`   - ${p.text} (satÄąr ${p.lineNumber}, gĂźven: ${p.confidence})`));
    
    res.json({
      success: true,
      data: {
        totalPages: totalPages,
        uploadPath: req.file.path,
        originalName: req.file.originalname,
        sinavId: sinav_id,
        potansiyelIsimler: potansiyelIsimler.slice(0, 15), // Ä°lk 15 aday
        ornekText: text.substring(0, 500), // KullanÄącÄąya gĂśster
        allLines: lines, // TĂźm satÄąrlarÄą da gĂśnder (frontend iĂ§in)
        autoSelectedPattern: autoSelectedPattern, // đŻ Otomatik seĂ§ilen pattern
        useAutoMode: autoConfidence >= 0.85 // %85+ gĂźven varsa direkt kullan
      }
    });
    
  } catch (error) {
    console.error('SonuĂ§ analiz hatasÄą:', error);
    
    // DosyayÄą temizle
    if (req.file && req.file.path) {
      try { fs.unlinkSync(req.file.path); } catch (e) {}
    }
    
    res.status(500).json({ 
      success: false, 
      error: 'Analiz sÄąrasÄąnda bir hata oluĹtu: ' + error.message 
    });
  }
});

// Kurum - SonuĂ§ PDF Kaydet (TĂźm sayfalarÄą iĹle, eĹleĹtir, kaydet)
app.post('/kurum/sinav-sonuc-yukle-kaydet', requireAuth, async (req, res) => {
  if (req.session.userType !== 'kurum_yonetici') {
    return res.status(403).json({ success: false, error: 'Yetkiniz yok!' });
  }
  
  try {
    const { sinav_id, pdfPath, selectedPattern, selectedLineNumber, manuelEslesmeler } = req.body;
    
    if (!sinav_id || !pdfPath) {
      return res.status(400).json({ success: false, error: 'SÄąnav ID veya PDF dosya yolu eksik!' });
    }
    
    console.log('\nđ§  AKILLI SINAV SONUĂLARI YĂKLENÄ°YOR');
    console.log('â SÄąnav ID:', sinav_id);
    console.log('â PDF Path:', pdfPath);
    console.log('đŻ Mod: AkÄąllÄą Cascade Matching (5 strateji)');
    
    const results = [];
    let matchedCount = 0;
    let unmatchedCount = 0;
    let savedCount = 0;
    let strategyStats = {};
    
    // SÄąnav bilgilerini al
    const sinav = await dbGet('SELECT * FROM sinavlar WHERE id = ?', [sinav_id]);
    
    if (!sinav) {
      return res.status(400).json({ success: false, error: 'SÄąnav bulunamadÄą!' });
    }
    
    // SonuĂ§ klasĂśrĂźnĂź oluĹtur
    const sonucKlasoru = path.join('uploads', 'sinav-sonuclari', `sinav_${sinav_id}`);
    if (!fs.existsSync(sonucKlasoru)) {
      fs.mkdirSync(sonucKlasoru, { recursive: true });
    }
    
    // PDF'i yĂźkle
    if (!fs.existsSync(pdfPath)) {
      return res.status(400).json({ success: false, error: 'PDF dosyasÄą bulunamadÄą!' });
    }
    
    const pdfBytes = fs.readFileSync(pdfPath);
    const pdfDoc = await PDFDocument.load(pdfBytes);
    const totalPages = pdfDoc.getPageCount();
    
    console.log(`đ Toplam sayfa: ${totalPages}`);
    console.log(`đ SonuĂ§ klasĂśrĂź: ${sonucKlasoru}`);
    
    // Manuel eĹleĹmeleri map'e Ă§evir (sayfa numarasÄą â ĂśÄrenci ID)
    const manuelMap = {};
    if (manuelEslesmeler && Array.isArray(manuelEslesmeler)) {
      manuelEslesmeler.forEach(m => {
        if (m.sayfaNo && m.ogrenciId) {
          manuelMap[m.sayfaNo] = m.ogrenciId;
        }
      });
      console.log(`đ ${Object.keys(manuelMap).length} manuel eĹleĹme alÄąndÄą`);
    }
    
    // Her sayfayÄą iĹle
    for (let i = 0; i < totalPages; i++) {
      try {
        const sayfaNo = i + 1;
        console.log(`\nđ Sayfa ${sayfaNo}/${totalPages} iĹleniyor...`);
        
        // Bu sayfayÄą ayrÄą bir PDF olarak oluĹtur
        const singlePagePdf = await PDFDocument.create();
        const [copiedPage] = await singlePagePdf.copyPages(pdfDoc, [i]);
        singlePagePdf.addPage(copiedPage);
        const singlePageBytes = await singlePagePdf.save();
        
        // GeĂ§ici dosya adÄą oluĹtur
        const tempFileName = `temp_sinav_page_${sayfaNo}_${Date.now()}.pdf`;
        const tempFilePath = path.join('uploads', tempFileName);
        fs.writeFileSync(tempFilePath, singlePageBytes);
        
        // Bu sayfadan text Ă§Äąkar
        const extractionResult = await extractTextHybrid(tempFilePath);
        const text = extractionResult.text;
        const isGarbled = extractionResult.garbled || false;
        
        let ogrenciId = null;
        let ogrenciAdi = 'BÄ°LÄ°NMEYEN';
        let kaynak = 'kurum';
        let usedStrategy = null;
        let confidence = 0;
        let extractedName = '';
        
        // Manuel eĹleĹme var mÄą kontrol et
        if (manuelMap[sayfaNo]) {
          // Manuel eĹleĹme var
          ogrenciId = manuelMap[sayfaNo];
          const ogrenci = await dbGet('SELECT * FROM ogrenci_kayitlari WHERE id = ?', [ogrenciId]);
          if (ogrenci) {
            ogrenciAdi = ogrenci.ogrenci_adi_soyadi;
            console.log(`â Manuel eĹleĹme: ${ogrenciAdi} (ID: ${ogrenciId})`);
            matchedCount++;
            usedStrategy = 'Manuel';
            confidence = 1.0;
          } else {
            console.log(`â ď¸ Manuel eĹleĹme geĂ§ersiz! ĂÄrenci ID ${ogrenciId} bulunamadÄą.`);
            unmatchedCount++;
          }
        } else {
          // đ§  AKILLI CASCADE MATCHING KULLAN
          const matchResult = await intelligentCascadeMatching(
            text, 
            sinav_id, 
            req.session.userId,
            tempFilePath
          );
          
          if (matchResult && matchResult.confidence >= 0.75) {
            // BaĹarÄąlÄą eĹleĹme
            ogrenciId = matchResult.ogrenciId;
            ogrenciAdi = matchResult.ogrenciAd;
            kaynak = matchResult.kaynak;
            extractedName = matchResult.extractedName;
            confidence = matchResult.confidence;
            usedStrategy = matchResult.usedStrategy;
            
            // Strateji istatistiklerini gĂźncelle
            strategyStats[usedStrategy] = (strategyStats[usedStrategy] || 0) + 1;
            
            console.log(`â AkÄąllÄą eĹleĹme: ${ogrenciAdi} (Strateji: ${usedStrategy}, GĂźven: ${(confidence * 100).toFixed(0)}%)`);
            matchedCount++;
          } else {
            // EĹleĹme baĹarÄąsÄąz
            console.log(`â TĂźm stratejiler baĹarÄąsÄąz - Manuel gerekli`);
            unmatchedCount++;
          }
        }
        
        // PDF'i kaydet
        const sanitizedName = ogrenciAdi.replace(/[^a-zA-ZĂ§ĂÄÄÄąÄ°ĂśĂĹĹĂźĂ\s]/g, '').replace(/\s+/g, '_');
        const finalFileName = ogrenciId 
          ? `${sayfaNo}_${sanitizedName}_${ogrenciId}.pdf`
          : `${sayfaNo}_BILINMEYEN_${Date.now()}.pdf`;
        
        const finalFilePath = path.join(sonucKlasoru, finalFileName);
        fs.writeFileSync(finalFilePath, singlePageBytes);
        
        console.log(`đž PDF kaydedildi: ${finalFileName}`);
        
        // VeritabanÄąna kaydet (eÄer eĹleĹme varsa)
        if (ogrenciId) {
          try {
            // sinav_katilimcilari tablosunu gĂźncelle
            await dbRun(`
              UPDATE sinav_katilimcilari 
              SET pdf_path = ?, sonuc_durumu = 'yuklendi' 
              WHERE sinav_id = ? AND ogrenci_id = ? AND ogrenci_kaynak = ?
            `, [finalFilePath, sinav_id, ogrenciId, kaynak]);
            
            savedCount++;
            console.log(`â VeritabanÄąna kaydedildi`);
          } catch (dbError) {
            console.error(`â VeritabanÄą kayÄąt hatasÄą:`, dbError);
          }
        }
        
        // SonuĂ§ listesine ekle
        results.push({
          sayfaNo: sayfaNo,
          ogrenciId: ogrenciId,
          ogrenciAdi: ogrenciAdi,
          pdfYolu: finalFilePath,
          eslesti: !!ogrenciId,
          extractedName: extractedName,
          isGarbled: isGarbled,
          strategy: usedStrategy,
          confidence: confidence
        });
        
        // GeĂ§ici dosyayÄą temizle
        fs.unlinkSync(tempFilePath);
        
      } catch (pageError) {
        console.error(`â Sayfa ${i + 1} iĹlenirken hata:`, pageError);
        results.push({
          sayfaNo: i + 1,
          ogrenciId: null,
          ogrenciAdi: 'HATA',
          pdfYolu: null,
          eslesti: false,
          error: pageError.message
        });
        unmatchedCount++;
      }
    }
    
    // SÄąnavÄą gĂźncelle (sonuc_yuklendi = 1)
    await dbRun('UPDATE sinavlar SET sonuc_yuklendi = 1 WHERE id = ?', [sinav_id]);
    
    // YĂźklenen PDF dosyasÄąnÄą temizle
    try {
      fs.unlinkSync(pdfPath);
    } catch (cleanError) {
      console.error('â ď¸ GeĂ§ici PDF temizlenemedi:', cleanError);
    }
    
    console.log('\nâ Ä°ĹLEM TAMAMLANDI!');
    console.log(`   Toplam sayfa: ${totalPages}`);
    console.log(`   EĹleĹen: ${matchedCount}`);
    console.log(`   EĹleĹmeyen: ${unmatchedCount}`);
    console.log(`   Kaydedilen: ${savedCount}`);
    console.log(`\nđ Strateji Ä°statistikleri:`);
    Object.entries(strategyStats).forEach(([strategy, count]) => {
      console.log(`   ${strategy}: ${count} sayfa`);
    });
    
    res.json({
      success: true,
      message: `${matchedCount}/${totalPages} sayfa otomatik eĹleĹtirildi (AkÄąllÄą Sistem)`,
      data: {
        totalPages: totalPages,
        matchedCount: matchedCount,
        unmatchedCount: unmatchedCount,
        savedCount: savedCount,
        strategyStats: strategyStats,
        results: results
      }
    });
    
  } catch (error) {
    console.error('â SonuĂ§ kaydetme hatasÄą:', error);
    
    res.status(500).json({ 
      success: false, 
      error: 'Kaydetme sÄąrasÄąnda bir hata oluĹtu: ' + error.message 
    });
  }
});

// Kurum - Manuel SÄąnav SonuĂ§ EĹleĹtirme
app.post('/kurum/sinav-manuel-eslestir/:id', requireAuth, async (req, res) => {
  if (req.session.userType !== 'kurum_yonetici') {
    return res.status(403).json({ success: false, message: 'Yetkiniz yok!' });
  }
  
  try {
    const sinavId = req.params.id;
    const { eslesmeler } = req.body;
    
    if (!eslesmeler || eslesmeler.length === 0) {
      return res.json({ success: false, message: 'EĹleĹtirme bilgisi eksik!' });
    }
    
    console.log(`\nđ MANUEL EĹLEĹTIRME (SÄąnav ID: ${sinavId})`);
    console.log(`   ${eslesmeler.length} adet eĹleĹtirme yapÄąlacak`);
    
    let basarili = 0;
    let hatali = 0;
    
    for (const eslesme of eslesmeler) {
      try {
        const { sayfaNo, pdfYolu, ogrenciId, kaynak } = eslesme;
        
        console.log(`   đ Sayfa ${sayfaNo}:`);
        console.log(`      - ĂÄrenci ID: ${ogrenciId}`);
        console.log(`      - Kaynak: ${kaynak}`);
        console.log(`      - PDF Yolu: ${pdfYolu}`);
        console.log(`      - Dosya var mÄą: ${pdfYolu ? fs.existsSync(pdfYolu) : 'PDF yolu boĹ'}`);
        
        // PDF dosyasÄąnÄą yeni isimle kaydet
        if (pdfYolu && fs.existsSync(pdfYolu)) {
          // ĂÄrenci bilgilerini al
          let ogrenci;
          if (kaynak === 'veli') {
            ogrenci = await dbGet('SELECT ad_soyad FROM ogrenciler WHERE id = ?', [ogrenciId]);
          } else {
            ogrenci = await dbGet('SELECT ogrenci_adi_soyadi as ad_soyad FROM ogrenci_kayitlari WHERE id = ?', [ogrenciId]);
          }
          
          if (ogrenci) {
            // Yeni dosya adÄą oluĹtur
            const sonucKlasoru = path.join('uploads', 'sinav-sonuclari', `sinav_${sinavId}`);
            if (!fs.existsSync(sonucKlasoru)) {
              fs.mkdirSync(sonucKlasoru, { recursive: true });
            }
            
            const timestamp = Date.now();
            const safeIsim = ogrenci.ad_soyad.replace(/[^a-zA-ZĂ§ĂÄÄÄąÄ°ĂśĂĹĹĂźĂ\s]/g, '').replace(/\s+/g, '_');
            const yeniDosyaAdi = `${safeIsim}_${timestamp}.pdf`;
            const yeniDosyaYolu = path.join(sonucKlasoru, yeniDosyaAdi);
            
            // DosyayÄą kopyala
            fs.copyFileSync(pdfYolu, yeniDosyaYolu);
            
            // sinav_katilimcilari tablosunu gĂźncelle
            await dbRun(`
              UPDATE sinav_katilimcilari 
              SET pdf_path = ?, sonuc_durumu = 'yuklendi'
              WHERE sinav_id = ? AND ogrenci_id = ? AND ogrenci_kaynak = ?
            `, [yeniDosyaYolu, sinavId, ogrenciId, kaynak]);
            
            console.log(`   â BaĹarÄąlÄą: ${ogrenci.ad_soyad}`);
            basarili++;
          } else {
            console.log(`   â ĂÄrenci bulunamadÄą: ${ogrenciId}`);
            hatali++;
          }
        } else {
          console.log(`   â PDF dosyasÄą bulunamadÄą: ${pdfYolu}`);
          hatali++;
        }
      } catch (error) {
        console.error(`   â EĹleĹtirme hatasÄą:`, error);
        hatali++;
      }
    }
    
    // SÄąnavÄąn sonuc_yuklendi durumunu gĂźncelle (ama henĂźz yayÄąnlanmamÄąĹ)
    await dbRun('UPDATE sinavlar SET sonuc_yuklendi = 1, sonuc_yayinlandi = 0 WHERE id = ?', [sinavId]);
    
    // â GĂNCEL Ä°STATÄ°STÄ°KLERÄ° HESAPLA
    const istatistikler = await dbGet(`
      SELECT 
        COUNT(*) as toplam,
        SUM(CASE WHEN pdf_path IS NOT NULL AND pdf_path != '' THEN 1 ELSE 0 END) as eslesmis,
        SUM(CASE WHEN pdf_path IS NULL OR pdf_path = '' THEN 1 ELSE 0 END) as eslesmemis
      FROM sinav_katilimcilari
      WHERE sinav_id = ?
    `, [sinavId]);
    
    console.log(`\nđ MANUEL EĹLEĹTIRME TAMAMLANDI:`);
    console.log(`   â BaĹarÄąlÄą: ${basarili}`);
    console.log(`   â HatalÄą: ${hatali}`);
    console.log(`\nđ GĂNCEL DURUM:`);
    console.log(`   Toplam KatÄąlÄąmcÄą: ${istatistikler.toplam}`);
    console.log(`   EĹleĹen: ${istatistikler.eslesmis}`);
    console.log(`   EĹleĹmeyen: ${istatistikler.eslesmemis}`);
    
    res.json({ 
      success: true, 
      message: `${basarili} ĂśÄrenci eĹleĹtirildi! ${hatali > 0 ? `(${hatali} hata)` : ''}`,
      matchedCount: istatistikler.eslesmis || 0,
      unmatchedCount: istatistikler.eslesmemis || 0,
      totalCount: istatistikler.toplam || 0
    });
  } catch (error) {
    console.error('â Manuel eĹleĹtirme hatasÄą:', error);
    res.json({ success: false, message: 'Bir hata oluĹtu!' });
  }
});

// đ Kurum - EĹleĹmemiĹ PDF SayfalarÄąnÄą Listele
app.get('/kurum/sinav-eslesmemis-pdfler/:id', requireAuth, async (req, res) => {
  if (req.session.userType !== 'kurum_yonetici') {
    return res.status(403).json({ success: false, error: 'Yetkiniz yok!' });
  }
  
  try {
    const sinavId = req.params.id;
    
    console.log('\nđ TĂM PDF SAYFALARI LÄ°STELENÄ°YOR (EĹleĹen + EĹleĹmeyen):', sinavId);
    
    // TĂM yĂźklenmiĹ PDF'leri al - HEM EĹLEĹEN HEM EĹLEĹMEYEN
    // pdf_path NULL olanlar = henĂźz eĹleĹmemiĹ (BÄ°LÄ°NMEYEN)
    // pdf_path dolu olanlar = eĹleĹmiĹ
    // BÄ°LÄ°NMEYEN olanlar = PDF var ama ĂśÄrenci eĹleĹmemiĹ
    const eslesmemisOgrenciler = await dbAll(`
      SELECT 
        sk.id as katilimci_id,
        sk.ogrenci_id,
        sk.ogrenci_kaynak as kaynak,
        sk.pdf_path,
        sk.sonuc_durumu,
        CASE 
          WHEN sk.ogrenci_kaynak = 'kurum' THEN ok.ogrenci_adi_soyadi
          WHEN sk.ogrenci_kaynak = 'veli' THEN o.ad_soyad
          ELSE 'BÄ°LÄ°NMEYEN'
        END as ad_soyad,
        CASE 
          WHEN sk.ogrenci_kaynak = 'kurum' THEN ok.sinif
          WHEN sk.ogrenci_kaynak = 'veli' THEN o.sinif
        END as sinif
      FROM sinav_katilimcilari sk
      LEFT JOIN ogrenci_kayitlari ok ON sk.ogrenci_id = ok.id AND sk.ogrenci_kaynak = 'kurum'
      LEFT JOIN ogrenciler o ON sk.ogrenci_id = o.id AND sk.ogrenci_kaynak = 'veli'
      WHERE sk.sinav_id = ?
      ORDER BY 
        CASE 
          WHEN sk.pdf_path IS NOT NULL AND (ok.ogrenci_adi_soyadi = 'BÄ°LÄ°NMEYEN' OR o.ad_soyad = 'BÄ°LÄ°NMEYEN' OR (ok.ogrenci_adi_soyadi IS NULL AND o.ad_soyad IS NULL)) THEN 0
          WHEN sk.pdf_path IS NULL THEN 1
          ELSE 2
        END,
        sk.id
    `, [sinavId]);
    
    // EĹleĹtirilebilir ĂśÄrencileri al (tĂźm katÄąlÄąmcÄąlar)
    const tumOgrenciler = await dbAll(`
      SELECT 
        sk.ogrenci_id,
        sk.ogrenci_kaynak as kaynak,
        CASE 
          WHEN sk.ogrenci_kaynak = 'kurum' THEN ok.ogrenci_adi_soyadi
          WHEN sk.ogrenci_kaynak = 'veli' THEN o.ad_soyad
        END as ad_soyad,
        CASE 
          WHEN sk.ogrenci_kaynak = 'kurum' THEN ok.sinif
          WHEN sk.ogrenci_kaynak = 'veli' THEN o.sinif
        END as sinif
      FROM sinav_katilimcilari sk
      LEFT JOIN ogrenci_kayitlari ok ON sk.ogrenci_id = ok.id AND sk.ogrenci_kaynak = 'kurum'
      LEFT JOIN ogrenciler o ON sk.ogrenci_id = o.id AND sk.ogrenci_kaynak = 'veli'
      WHERE sk.sinav_id = ?
      ORDER BY ad_soyad
    `, [sinavId]);
    
    // Orijinal PDF yolunu bul - eĹleĹmiĹ herhangi bir ĂśÄrencinin PDF'inden al
    let orijinalPdfYolu = null;
    
    // Ănce sinavlar tablosuna bak
    const sinav = await dbGet('SELECT dosya_yolu FROM sinavlar WHERE id = ?', [sinavId]);
    if (sinav && sinav.dosya_yolu) {
        orijinalPdfYolu = sinav.dosya_yolu;
    } else {
        // Yoksa eĹleĹmiĹ herhangi bir ĂśÄrencinin PDF'ini al
        const eslesmisOgrenci = await dbGet(
            'SELECT pdf_path FROM sinav_katilimcilari WHERE sinav_id = ? AND pdf_path IS NOT NULL LIMIT 1',
            [sinavId]
        );
        if (eslesmisOgrenci && eslesmisOgrenci.pdf_path) {
            orijinalPdfYolu = eslesmisOgrenci.pdf_path;
        }
    }
    
    console.log(`   đ EĹleĹmemiĹ: ${eslesmemisOgrenciler.length}`);
    console.log(`   đĽ Toplam ĂÄrenci: ${tumOgrenciler.length}`);
    console.log(`   đ PDF Yolu: ${orijinalPdfYolu}`);
    
    res.json({
      success: true,
      data: {
        eslesmemisPdfler: eslesmemisOgrenciler,
        tumOgrenciler: tumOgrenciler,
        orijinalPdfYolu: orijinalPdfYolu
      }
    });
    
  } catch (error) {
    console.error('â EĹleĹmemiĹ PDF listeleme hatasÄą:', error);
    res.json({ success: false, error: error.message });
  }
});

// đ Kurum - Mevcut PDF'i BaĹka ĂÄrenciye Ata
app.post('/kurum/sinav-pdf-yeniden-eslestir', requireAuth, async (req, res) => {
  if (req.session.userType !== 'kurum_yonetici') {
    return res.status(403).json({ success: false, message: 'Yetkiniz yok!' });
  }
  
  try {
    const { katilimci_id, yeni_ogrenci_id, yeni_kaynak, sinav_id } = req.body;
    
    console.log(`\nđ PDF YENÄ°DEN EĹLEĹTÄ°RÄ°LÄ°YOR`);
    console.log(`   KatÄąlÄąmcÄą ID: ${katilimci_id}`);
    console.log(`   Yeni ĂÄrenci ID: ${yeni_ogrenci_id}`);
    console.log(`   Yeni Kaynak: ${yeni_kaynak}`);
    
    // Eski katÄąlÄąmcÄąnÄąn PDF yolunu al
    const eskiKatilimci = await dbGet('SELECT pdf_path FROM sinav_katilimcilari WHERE id = ?', [katilimci_id]);
    
    if (!eskiKatilimci || !eskiKatilimci.pdf_path) {
      return res.json({ success: false, message: 'PDF bulunamadÄą!' });
    }
    
    // Yeni ĂśÄrenci bilgilerini al
    let yeniOgrenci;
    if (yeni_kaynak === 'kurum') {
      yeniOgrenci = await dbGet('SELECT ogrenci_adi_soyadi as ad_soyad FROM ogrenci_kayitlari WHERE id = ?', [yeni_ogrenci_id]);
    } else {
      yeniOgrenci = await dbGet('SELECT ad_soyad FROM ogrenciler WHERE id = ?', [yeni_ogrenci_id]);
    }
    
    if (!yeniOgrenci) {
      return res.json({ success: false, message: 'ĂÄrenci bulunamadÄą!' });
    }
    
    // Eski PDF yolunu al
    const eskiPdfPath = eskiKatilimci.pdf_path;
    
    // Yeni dosya adÄą oluĹtur
    const sinavKlasoru = path.join(__dirname, 'uploads', 'sinav-sonuclari', `sinav_${sinav_id}`);
    const guvenliIsim = yeniOgrenci.ad_soyad.replace(/[^a-zA-Z0-9ÄĂźĹĂśĂ§Ä°ÄĂĹĂĂ\s]/g, '').replace(/\s+/g, '_');
    const timestamp = Date.now();
    const yeniDosyaAdi = `${guvenliIsim}_${timestamp}.pdf`;
    const yeniDosyaYolu = path.join(sinavKlasoru, yeniDosyaAdi);
    
    // DosyayÄą kopyala/taĹÄą
    const eskiTamYol = path.join(__dirname, eskiPdfPath);
    if (fs.existsSync(eskiTamYol)) {
      fs.copyFileSync(eskiTamYol, yeniDosyaYolu);
    }
    
    // VeritabanÄąnÄą gĂźncelle
    const relativePath = path.join('uploads', 'sinav-sonuclari', `sinav_${sinav_id}`, yeniDosyaAdi);
    
    // Yeni ĂśÄrenci iĂ§in kayÄąt oluĹtur/gĂźncelle
    await dbRun(`
      UPDATE sinav_katilimcilari 
      SET pdf_path = ?, sonuc_durumu = 'yuklendi'
      WHERE sinav_id = ? AND ogrenci_id = ? AND ogrenci_kaynak = ?
    `, [relativePath, sinav_id, yeni_ogrenci_id, yeni_kaynak]);
    
    // Eski kaydÄą temizle (PDF'i kaldÄąr)
    await dbRun(`
      UPDATE sinav_katilimcilari 
      SET pdf_path = NULL, sonuc_durumu = 'bekleniyor'
      WHERE id = ?
    `, [katilimci_id]);
    
    // Eski dosyayÄą sil
    if (fs.existsSync(eskiTamYol)) {
      fs.unlinkSync(eskiTamYol);
    }
    
    console.log(`   â PDF baĹarÄąyla "${yeniOgrenci.ad_soyad}" iĂ§in atandÄą`);
    
    res.json({ 
      success: true, 
      message: `â PDF baĹarÄąyla "${yeniOgrenci.ad_soyad}" ile eĹleĹtirildi!`
    });
    
  } catch (error) {
    console.error('â PDF yeniden eĹleĹtirme hatasÄą:', error);
    res.json({ success: false, message: 'Bir hata oluĹtu: ' + error.message });
  }
});

// đ¤ Kurum - Tek ĂÄrenci Ä°Ă§in PDF EĹleĹtir
app.post('/kurum/sinav-tek-ogrenci-eslestir', requireAuth, upload.single('pdf'), async (req, res) => {
  if (req.session.userType !== 'kurum_yonetici') {
    return res.status(403).json({ success: false, message: 'Yetkiniz yok!' });
  }
  
  try {
    const { sinav_id, ogrenci_id, kaynak } = req.body;
    const pdfFile = req.file;
    
    if (!pdfFile) {
      return res.json({ success: false, message: 'PDF dosyasÄą yĂźklenmedi!' });
    }
    
    console.log(`\nđ¤ TEK ĂÄRENCÄ° EĹLEĹTÄ°RME`);
    console.log(`   SÄąnav ID: ${sinav_id}`);
    console.log(`   ĂÄrenci ID: ${ogrenci_id}`);
    console.log(`   Kaynak: ${kaynak}`);
    console.log(`   PDF: ${pdfFile.filename}`);
    
    // ĂÄrenci bilgilerini al
    let ogrenci;
    if (kaynak === 'kurum') {
      ogrenci = await dbGet('SELECT ogrenci_adi_soyadi as ad_soyad FROM ogrenci_kayitlari WHERE id = ?', [ogrenci_id]);
    } else {
      ogrenci = await dbGet('SELECT ad_soyad FROM ogrenciler WHERE id = ?', [ogrenci_id]);
    }
    
    if (!ogrenci) {
      return res.json({ success: false, message: 'ĂÄrenci bulunamadÄą!' });
    }
    
    // SÄąnav klasĂśrĂźnĂź oluĹtur
    const sinavKlasoru = path.join(__dirname, 'uploads', 'sinav-sonuclari', `sinav_${sinav_id}`);
    if (!fs.existsSync(sinavKlasoru)) {
      fs.mkdirSync(sinavKlasoru, { recursive: true });
    }
    
    // Dosya adÄąnÄą oluĹtur
    const guvenliIsim = ogrenci.ad_soyad.replace(/[^a-zA-Z0-9ÄĂźĹĂśĂ§Ä°ÄĂĹĂĂ\s]/g, '').replace(/\s+/g, '_');
    const timestamp = Date.now();
    const yeniDosyaAdi = `${guvenliIsim}_${timestamp}.pdf`;
    const yeniDosyaYolu = path.join(sinavKlasoru, yeniDosyaAdi);
    
    // DosyayÄą taĹÄą
    fs.copyFileSync(pdfFile.path, yeniDosyaYolu);
    fs.unlinkSync(pdfFile.path); // GeĂ§ici dosyayÄą sil
    
    // VeritabanÄąnÄą gĂźncelle
    const relativePath = path.join('uploads', 'sinav-sonuclari', `sinav_${sinav_id}`, yeniDosyaAdi);
    await dbRun(`
      UPDATE sinav_katilimcilari 
      SET pdf_path = ?, sonuc_durumu = 'yuklendi'
      WHERE sinav_id = ? AND ogrenci_id = ? AND ogrenci_kaynak = ?
    `, [relativePath, sinav_id, ogrenci_id, kaynak]);
    
    // SÄąnavÄąn sonuc_yuklendi durumunu gĂźncelle
    await dbRun('UPDATE sinavlar SET sonuc_yuklendi = 1 WHERE id = ?', [sinav_id]);
    
    console.log(`   â BaĹarÄąlÄą: ${ogrenci.ad_soyad} iĂ§in PDF eĹleĹtirildi`);
    
    res.json({ 
      success: true, 
      message: `â ${ogrenci.ad_soyad} iĂ§in sonuĂ§ baĹarÄąyla eĹleĹtirildi!`
    });
    
  } catch (error) {
    console.error('â Tek ĂśÄrenci eĹleĹtirme hatasÄą:', error);
    res.json({ success: false, message: 'Bir hata oluĹtu: ' + error.message });
  }
});

// đ˘ Kurum - SÄąnav SonuĂ§larÄąnÄą YayÄąnla (Velilere gĂśrĂźnĂźr hale getir)
app.post('/kurum/sinav-sonuclari-yayinla/:id', requireAuth, async (req, res) => {
  if (req.session.userType !== 'kurum_yonetici') {
    return res.status(403).json({ success: false, message: 'Yetkiniz yok!' });
  }
  
  try {
    const sinavId = req.params.id;
    
    console.log('\nđ˘ SINAV SONUĂLARI YAYINLANIYOR:', sinavId);
    
    // SÄąnav bilgilerini al
    const sinav = await dbGet('SELECT * FROM sinavlar WHERE id = ?', [sinavId]);
    
    if (!sinav) {
      return res.json({ success: false, message: 'SÄąnav bulunamadÄą!' });
    }
    
    if (!sinav.sonuc_yuklendi) {
      return res.json({ success: false, message: 'HenĂźz sonuĂ§ yĂźklenmemiĹ!' });
    }
    
    if (sinav.sonuc_yayinlandi) {
      return res.json({ success: false, message: 'SonuĂ§lar zaten yayÄąnlanmÄąĹ!' });
    }
    
    // EĹleĹmiĹ sonuĂ§ sayÄąsÄąnÄą kontrol et
    const eslesmisler = await dbAll(`
      SELECT COUNT(*) as sayi 
      FROM sinav_katilimcilari 
      WHERE sinav_id = ? AND pdf_path IS NOT NULL
    `, [sinavId]);
    
    const eslesmeSayisi = eslesmisler[0]?.sayi || 0;
    
    if (eslesmeSayisi === 0) {
      return res.json({ success: false, message: 'HiĂ§ eĹleĹmiĹ sonuĂ§ yok! LĂźtfen Ăśnce eĹleĹtirme yapÄąn.' });
    }
    
    // SÄąnavÄą yayÄąnla
    await dbRun('UPDATE sinavlar SET sonuc_yayinlandi = 1 WHERE id = ?', [sinavId]);
    
    console.log(`   â YayÄąnlandÄą: ${eslesmeSayisi} sonuĂ§ velilere gĂśrĂźnĂźr hale geldi`);
    
    res.json({ 
      success: true, 
      message: `â SonuĂ§lar yayÄąnlandÄą! ${eslesmeSayisi} ĂśÄrencinin velisi artÄąk sonuĂ§larÄą gĂśrebilir.`
    });
    
  } catch (error) {
    console.error('â YayÄąnlama hatasÄą:', error);
    res.json({ success: false, message: 'Bir hata oluĹtu: ' + error.message });
  }
});

// Kurum - SÄąnav SonuĂ§ WhatsApp Bildirim GĂśnder
app.post('/kurum/sinav-sonuc-whatsapp-gonder/:id', requireAuth, async (req, res) => {
  if (req.session.userType !== 'kurum_yonetici') {
    return res.status(403).json({ success: false, message: 'Yetkiniz yok!' });
  }
  
  try {
    const sinavId = req.params.id;
    
    // SÄąnav bilgilerini al
    const sinav = await dbGet('SELECT * FROM sinavlar WHERE id = ?', [sinavId]);
    
    if (!sinav) {
      return res.json({ success: false, message: 'SÄąnav bulunamadÄą!' });
    }
    
    // Sonucu yĂźklenmiĹ katÄąlÄąmcÄąlarÄą al (hem kurum hem veli ĂśÄrencileri)
    const kurumKatilimcilari = await dbAll(`
      SELECT 
        sk.*,
        ok.ogrenci_adi_soyadi as ogrenci_adi,
        ok.veli_adi,
        ok.veli_telefon,
        ok.telefon as ogrenci_telefon,
        'kurum' as kaynak
      FROM sinav_katilimcilari sk
      INNER JOIN ogrenci_kayitlari ok ON sk.ogrenci_id = ok.id AND sk.ogrenci_kaynak = 'kurum'
      WHERE sk.sinav_id = ? AND sk.sonuc_durumu IN ('yuklendi', 'bildirildi') AND sk.pdf_path IS NOT NULL
    `, [sinavId]);
    
    const veliKatilimcilari = await dbAll(`
      SELECT 
        sk.*,
        o.ad_soyad as ogrenci_adi,
        u.ad_soyad as veli_adi,
        u.telefon as veli_telefon,
        o.telefon as ogrenci_telefon,
        'veli' as kaynak
      FROM sinav_katilimcilari sk
      INNER JOIN ogrenciler o ON sk.ogrenci_id = o.id AND sk.ogrenci_kaynak = 'veli'
      LEFT JOIN users u ON o.veli_id = u.id
      WHERE sk.sinav_id = ? AND sk.sonuc_durumu IN ('yuklendi', 'bildirildi') AND sk.pdf_path IS NOT NULL
    `, [sinavId]);
    
    const katilimcilar = [...kurumKatilimcilari, ...veliKatilimcilari];
    
    if (katilimcilar.length === 0) {
      return res.json({ success: false, message: 'Sonucu yĂźklenmiĹ ĂśÄrenci bulunamadÄą!' });
    }
    
    console.log(`\nđą WHATSAPP BÄ°LDÄ°RÄ°MLERÄ° GĂNDERÄ°LÄ°YOR`);
    console.log(`   SÄąnav: ${sinav.ad}`);
    console.log(`   Toplam katÄąlÄąmcÄą: ${katilimcilar.length}\n`);
    
    let basarili = 0;
    let basarisiz = 0;
    
    // Her ĂśÄrenci iĂ§in veli telefonuna bildirim gĂśnder
    for (const katilimci of katilimcilar) {
      // Veli telefonu Ăśncelikli, yoksa ĂśÄrenci telefonu
      const telefon = katilimci.veli_telefon || katilimci.ogrenci_telefon;
      
      console.log(`   đ ${katilimci.ogrenci_adi} (Veli: ${katilimci.veli_adi || 'Bilinmiyor'}) â ${telefon || 'TELEFON YOK'}`);
      
      if (!telefon) {
        console.log(`   â ď¸ ${katilimci.ogrenci_adi} - Telefon numarasÄą yok!`);
        basarisiz++;
        continue;
      }
      
      // WhatsApp mesajÄąnÄą oluĹtur
      const mesaj = `đ SÄąnav Sonucu AĂ§ÄąklandÄą

SayÄąn ${katilimci.veli_adi || 'Veli'},

${katilimci.ogrenci_adi} ĂśÄrencinizin sÄąnav sonucu aĂ§ÄąklanmÄąĹtÄąr.

đ SÄąnav: ${sinav.ad}
đ Tarih: ${new Date(sinav.tarih).toLocaleDateString('tr-TR')}

đĽ Sonucu gĂśrĂźntĂźlemek iĂ§in sisteme giriĹ yapÄąn:
đ ${req.protocol}://${req.get('host')}/login

âââââââââââââââââ
đŤ SÄąnav Merkezi`;
      
      // WhatsApp gĂśnder
      const result = await whatsappBildirimGonder(
        telefon,
        mesaj,
        'sinav_sonuc'
      );
      
      if (result.success) {
        console.log(`   â ${katilimci.ogrenci_adi} - ${telefon}`);
        basarili++;
        
        // Bildirim durumunu gĂźncelle
        await dbRun(
          'UPDATE sinav_katilimcilari SET sonuc_durumu = ?, whatsapp_gonderim_tarihi = datetime("now") WHERE id = ?',
          ['bildirildi', katilimci.id]
        );
      } else {
        console.log(`   â ${katilimci.ogrenci_adi} - ${telefon} - ${result.message}`);
        basarisiz++;
      }
      
      // API rate limit iĂ§in kĂźĂ§Ăźk gecikme
      await new Promise(resolve => setTimeout(resolve, 500));
    }
    
    console.log(`\nâ Bildirim gĂśnderimi tamamlandÄą!`);
    console.log(`   BaĹarÄąlÄą: ${basarili}`);
    console.log(`   BaĹarÄąsÄąz: ${basarisiz}`);
    
    res.json({ 
      success: true, 
      message: `${basarili} bildirim gĂśnderildi, ${basarisiz} baĹarÄąsÄąz.`,
      basarili: basarili,
      basarisiz: basarisiz
    });
    
  } catch (error) {
    console.error('WhatsApp bildirim hatasÄą:', error);
    res.json({ success: false, message: 'Bildirim gĂśnderilirken bir hata oluĹtu!' });
  }
});

// Veli - SÄąnav SonuĂ§larÄą
app.get('/veli/sinav-sonuclari', requireAuth, requireRole('veli'), async (req, res) => {
  try {
    console.log(`\nđ SINAV SONUĂLARI (Veli ID: ${req.session.userId}, Username: ${req.session.username})`);
    
    // 1. Veli'nin kendi eklediÄi ĂśÄrenciler (ogrenciler tablosu)
    const veliOgrencileri = await dbAll('SELECT * FROM ogrenciler WHERE veli_id = ?', [req.session.userId]);
    console.log(`   Veli ekledi: ${veliOgrencileri.length} ĂśÄrenci`);
    
    // 2. Kurum tarafÄąndan eklenen ĂśÄrenciler (TC eĹleĹmesi ile)
    const kurumOgrencileri = await dbAll(`
      SELECT 
        id,
        ogrenci_adi_soyadi as ad_soyad,
        sinif,
        tc_kimlik_no as tc_no,
        telefon,
        'kurum' as kaynak
      FROM ogrenci_kayitlari
      WHERE REPLACE(CAST(tc_kimlik_no AS TEXT), '.0', '') = ?
    `, [req.session.username]);
    console.log(`   Kurum ekledi: ${kurumOgrencileri.length} ĂśÄrenci (TC eĹleĹtirme)`);
    
    // 3. Ä°ki listeyi birleĹtir
    const ogrenciler = [...veliOgrencileri, ...kurumOgrencileri];
    console.log(`   đ TOPLAM: ${ogrenciler.length} ĂśÄrenci`);
    
    if (ogrenciler.length === 0) {
      return res.render('veli/sinav-sonuclari', {
        user: { username: req.session.username, type: req.session.userType },
        sonuclar: [],
        ogrenciler: [],
        error: 'HenĂźz ĂśÄrenci kaydÄąnÄąz bulunmuyor.',
        success: req.session.success
      });
    }
    
    // Veli'nin kendi eklediÄi ĂśÄrencilerin sonuĂ§larÄą (ogrenciler tablosu)
    const veliSonuclari = await dbAll(`
      SELECT 
        sk.id,
        sk.sinav_id,
        sk.ogrenci_id,
        sk.pdf_path,
        sk.sonuc_durumu,
        sk.pdf_goruldu,
        sk.pdf_gorunme_tarihi,
        sk.pdf_indirilme_sayisi,
        'veli' as kaynak,
        s.ad as sinav_adi,
        s.tarih as sinav_tarihi,
        s.sinif,
        s.ders,
        s.sinav_durumu,
        o.ad_soyad as ogrenci_adi_soyadi,
        o.sinif as ogrenci_sinif
      FROM sinav_katilimcilari sk
      INNER JOIN sinavlar s ON sk.sinav_id = s.id
      INNER JOIN ogrenciler o ON sk.ogrenci_id = o.id
      WHERE sk.ogrenci_kaynak = 'veli'
        AND o.veli_id = ?
        AND s.sonuc_yayinlandi = 1
        AND sk.pdf_path IS NOT NULL
    `, [req.session.userId]);
    
    console.log(`   â Veli ekledi: ${veliSonuclari.length} sonuĂ§`);
    
    // Kurum tarafÄąndan eklenen ĂśÄrencilerin sonuĂ§larÄą (ogrenci_kayitlari tablosu)
    const kurumSonuclari = await dbAll(`
      SELECT 
        sk.id,
        sk.sinav_id,
        sk.ogrenci_id,
        sk.pdf_path,
        sk.sonuc_durumu,
        sk.pdf_goruldu,
        sk.pdf_gorunme_tarihi,
        sk.pdf_indirilme_sayisi,
        'kurum' as kaynak,
        s.ad as sinav_adi,
        s.tarih as sinav_tarihi,
        s.sinif,
        s.ders,
        s.sinav_durumu,
        ok.ogrenci_adi_soyadi,
        ok.sinif as ogrenci_sinif
      FROM sinav_katilimcilari sk
      INNER JOIN sinavlar s ON sk.sinav_id = s.id
      INNER JOIN ogrenci_kayitlari ok ON sk.ogrenci_id = ok.id
      WHERE sk.ogrenci_kaynak = 'kurum'
        AND REPLACE(CAST(ok.tc_kimlik_no AS TEXT), '.0', '') = (SELECT username FROM users WHERE id = ?)
        AND s.sonuc_yayinlandi = 1
        AND sk.pdf_path IS NOT NULL
    `, [req.session.userId]);
    
    console.log(`   â Kurum ekledi: ${kurumSonuclari.length} sonuĂ§`);
    
    // Ä°ki kaynaÄÄą birleĹtir
    const sonuclar = [...veliSonuclari, ...kurumSonuclari].sort((a, b) => {
      return new Date(b.sinav_tarihi) - new Date(a.sinav_tarihi);
    });
    
    console.log(`   đ Toplam: ${sonuclar.length} sonuĂ§`);
    
    res.render('veli/sinav-sonuclari', {
      user: { username: req.session.username, type: req.session.userType },
      sonuclar: sonuclar,
      ogrenciler: ogrenciler,
      error: req.session.error,
      success: req.session.success
    });
    
    req.session.error = null;
    req.session.success = null;
  } catch (error) {
    console.error('SÄąnav sonuĂ§larÄą hatasÄą:', error);
    req.session.error = 'SÄąnav sonuĂ§larÄą yĂźklenirken bir hata oluĹtu!';
    res.redirect('/veli/dashboard');
  }
});

// Veli - SÄąnav SonuĂ§ PDF Ä°ndir
app.get('/veli/sinav-sonuc-indir/:katilimciId', requireAuth, requireRole('veli'), async (req, res) => {
  try {
    const katilimciId = req.params.katilimciId;
    
    // Ănce ogrenci_kaynak'a bak
    const katilimciBilgi = await dbGet('SELECT ogrenci_kaynak, ogrenci_id, pdf_path FROM sinav_katilimcilari WHERE id = ?', [katilimciId]);
    
    if (!katilimciBilgi) {
      return res.status(404).send('SonuĂ§ bulunamadÄą!');
    }
    
    let yetkiVar = false;
    
    // Kaynak'a gĂśre yetki kontrolĂź
    if (katilimciBilgi.ogrenci_kaynak === 'veli') {
      // Veli'nin kendi eklediÄi ĂśÄrenci
      const ogrenci = await dbGet('SELECT veli_id FROM ogrenciler WHERE id = ?', [katilimciBilgi.ogrenci_id]);
      yetkiVar = ogrenci && ogrenci.veli_id === req.session.userId;
    } else {
      // Kurum ekledi, veli telefonuyla kontrol
      const user = await dbGet('SELECT telefon FROM users WHERE id = ?', [req.session.userId]);
      const ogrenci = await dbGet('SELECT veli_telefon FROM ogrenci_kayitlari WHERE id = ?', [katilimciBilgi.ogrenci_id]);
      yetkiVar = ogrenci && user && user.telefon === ogrenci.veli_telefon;
    }
    
    if (!yetkiVar) {
      return res.status(403).send('Bu sonuca eriĹim yetkiniz yok!');
    }
    
    // PDF var mÄą kontrol et
    if (!katilimciBilgi.pdf_path || !fs.existsSync(katilimciBilgi.pdf_path)) {
      return res.status(404).send('PDF dosyasÄą bulunamadÄą!');
    }
    
    // PDF indirme kaydÄąnÄą gĂźncelle
    const simdi = new Date().toISOString();
    await dbRun(`
      UPDATE sinav_katilimcilari 
      SET 
        pdf_goruldu = 1,
        pdf_gorunme_tarihi = ?,
        pdf_indirilme_sayisi = COALESCE(pdf_indirilme_sayisi, 0) + 1
      WHERE id = ?
    `, [simdi, katilimciId]);
    
    console.log(`\nđĽ PDF Ä°NDÄ°RME KAYDI`);
    console.log(`   KatÄąlÄąmcÄą ID: ${katilimciId}`);
    console.log(`   Tarih: ${simdi}`);
    console.log(`   Veli ID: ${req.session.userId}`);
    
    // PDF'i indir
    res.download(katilimciBilgi.pdf_path, path.basename(katilimciBilgi.pdf_path), (err) => {
      if (err) {
        console.error('PDF indirme hatasÄą:', err);
        res.status(500).send('PDF indirilemedi!');
      }
    });
    
  } catch (error) {
    console.error('PDF indirme hatasÄą:', error);
    res.status(500).send('Bir hata oluĹtu!');
  }
});

// Veli Profil
app.get('/veli/profil', requireAuth, requireRole('veli'), async (req, res) => {
  try {
    const kullanici = await dbGet('SELECT * FROM users WHERE id = ?', [req.session.userId]);
    
    // Talep edilen sÄąnavlarÄą getir
    const talepEdilenSinavlar = await dbAll(`
      SELECT 
        s.*,
        st.durum,
        st.talep_tarihi,
        st.yanitlanma_tarihi,
        st.yanit,
        COUNT(DISTINCT o.id) as ogrenci_sayisi
      FROM sinav_talepleri st
      INNER JOIN sinavlar s ON st.sinav_id = s.id
      LEFT JOIN ogrenciler o ON o.veli_id = ?
      WHERE st.veli_id = ?
      GROUP BY s.id, st.id
      ORDER BY st.talep_tarihi DESC
    `, [req.session.userId, req.session.userId]);
    
    // Login hatalarÄąnÄą filtrele - sadece profil ile ilgili hatalarÄą gĂśster
    let error = req.session.error;
    if (error && (error.includes('KullanÄącÄą adÄą veya Ĺifre') || error.includes('Ĺifre hatalÄą'))) {
      error = null; // Login hatalarÄąnÄą gĂśsterme
    }
    
    res.render('veli_profil', {
      user: { username: req.session.username, type: req.session.userType },
      kullanici: kullanici,
      talepEdilenSinavlar: talepEdilenSinavlar,
      error: error,
      success: req.session.success
    });
    req.session.error = null;
    req.session.success = null;
  } catch (error) {
    console.error('Profil hatasÄą:', error);
    req.session.error = 'Profil yĂźklenirken bir hata oluĹtu!';
    res.redirect('/veli/dashboard');
  }
});

// Veli Profil GĂźncelleme
app.post('/veli/profil', requireAuth, requireRole('veli'), async (req, res) => {
  try {
    const { ad_soyad, telefon, current_password, new_password } = req.body;
    
    if (!ad_soyad) {
      req.session.error = 'Ad Soyad alanÄą zorunludur';
      res.redirect('/veli/profil');
      return;
    }
    
    // Ĺifre deÄiĹtirme kontrolĂź
    if (new_password && new_password.trim() !== '') {
      if (!current_password || current_password.trim() === '') {
        req.session.error = 'Ĺifre deÄiĹtirmek iĂ§in mevcut Ĺifrenizi girmelisiniz!';
        res.redirect('/veli/profil');
        return;
      }
      
      if (new_password.length < 6) {
        req.session.error = 'Yeni Ĺifre en az 6 karakter olmalÄądÄąr!';
        res.redirect('/veli/profil');
        return;
      }
      
      // Mevcut Ĺifreyi kontrol et
      const kullanici = await dbGet('SELECT password_hash FROM users WHERE id = ?', [req.session.userId]);
      const sifreDogruMu = await bcrypt.compare(current_password, kullanici.password_hash);
      
      if (!sifreDogruMu) {
        req.session.error = 'Mevcut Ĺifreniz yanlÄąĹ!';
        res.redirect('/veli/profil');
        return;
      }
      
      // Yeni Ĺifreyi hashle
      const yeniSifreHash = await bcrypt.hash(new_password, 10);
      
      // Profil ve Ĺifreyi gĂźncelle
      await dbRun(
        'UPDATE users SET ad_soyad = ?, telefon = ?, password_hash = ? WHERE id = ?',
        [ad_soyad, telefon, yeniSifreHash, req.session.userId]
      );
      
      console.log(`â Veli Ĺifre deÄiĹtirdi: User ID ${req.session.userId}`);
      req.session.success = 'Profil bilgileriniz ve Ĺifreniz baĹarÄąyla gĂźncellendi!';
    } else {
      // Sadece profil bilgilerini gĂźncelle
      await dbRun(
        'UPDATE users SET ad_soyad = ?, telefon = ? WHERE id = ?',
        [ad_soyad, telefon, req.session.userId]
      );
      
      req.session.success = 'Profil bilgileriniz baĹarÄąyla gĂźncellendi!';
    }
    
    res.redirect('/veli/profil');
  } catch (error) {
    console.error('Profil gĂźncelleme hatasÄą:', error);
    req.session.error = 'Profil gĂźncellenirken bir hata oluĹtu!';
    res.redirect('/veli/profil');
  }
});

