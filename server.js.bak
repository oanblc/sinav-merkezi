// Veli - ĂÄrenci Ekle (POST)
app.post('/veli/ogrenci-ekle', requireAuth, requireRole('veli'), async (req, res) => {
  try {
    const { ad_soyad, tc_no, telefon, okul, sinif } = req.body;
    
    console.log('ĂÄrenci ekleme isteÄi:', { ad_soyad, tc_no, telefon, okul, sinif, veli_id: req.session.userId });
    
    if (!ad_soyad || !okul || !sinif) {
      req.session.error = 'ĂÄrenci adÄą soyadÄą, okul ve sÄąnÄąf zorunludur!';
      res.redirect('/veli/ogrenci-ekle');
      return;
    }
    
    // ĂÄrenci numarasÄą oluĹtur
    const ogrenciNo = await generateOgrenciNo();
    
    // ĂÄrenci ekle
    const result = await dbRun(
      'INSERT INTO ogrenciler (ad_soyad, tc_no, telefon, okul, sinif, veli_id, ogrenci_no) VALUES (?, ?, ?, ?, ?, ?, ?)',
      [ad_soyad, tc_no, telefon, okul, sinif, req.session.userId, ogrenciNo]
    );
    
    console.log('ĂÄrenci eklendi! ID:', result.lastID, 'ĂÄrenci No:', ogrenciNo);
    
    req.session.success = `${ad_soyad} baĹarÄąyla eklendi! ĂÄrenci No: ${ogrenciNo}`;
    res.redirect('/veli/dashboard');
  } catch (error) {
    console.error('ĂÄrenci ekleme hatasÄą:', error);
    req.session.error = 'ĂÄrenci eklenirken bir hata oluĹtu: ' + error.message;
    res.redirect('/veli/ogrenci-ekle');
  }
});

// Veli - ĂÄrenci DĂźzenle (GET)
app.get('/veli/ogrenci-duzenle/:id', requireAuth, requireRole('veli'), async (req, res) => {
  try {
    const ogrenci = await dbGet('SELECT * FROM ogrenciler WHERE id = ? AND veli_id = ?', [req.params.id, req.session.userId]);
    
    if (!ogrenci) {
      req.session.error = 'ĂÄrenci bulunamadÄą!';
      res.redirect('/veli/dashboard');
      return;
    }
    
    // Bu ĂśÄrenciye yetki verilmiĹ rehber ĂśÄretmenleri getir
    const rehberOgretmenler = await dbAll(`
      SELECT 
        t.id as talep_id, 
        t.created_at, 
        t.sonuc_goruntuleme_aktif,
        u.id as ogretmen_id, 
        u.ad_soyad, 
        u.kurum, 
        u.brans, 
        u.telefon
      FROM ogrenci_talepleri t
      INNER JOIN users u ON t.rehber_ogretmen_id = u.id
      WHERE t.ogrenci_id = ? AND t.durum = 'onaylandi'
      ORDER BY t.created_at DESC
    `, [req.params.id]);
    
    res.render('veli_ogrenci_duzenle', {
      user: { username: req.session.username, type: req.session.userType },
      ogrenci: ogrenci,
      rehberOgretmenler: rehberOgretmenler,
      error: req.session.error,
      success: req.session.success
    });
    req.session.error = null;
    req.session.success = null;
  } catch (error) {
    console.error('ĂÄrenci dĂźzenle sayfasÄą hatasÄą:', error);
    req.session.error = 'Sayfa yĂźklenirken bir hata oluĹtu!';
    res.redirect('/veli/dashboard');
  }
});

