  `);
  
  // Eksik kolonlarÄą ekle (ALTER TABLE)
  db.run(`ALTER TABLE ogrenci_talepleri ADD COLUMN rehber_ogretmen_id INTEGER`, (err) => {
    if (err && !err.message.includes('duplicate column name')) {
      console.log('â ď¸ rehber_ogretmen_id kolonu zaten var veya hata:', err.message);
    } else if (!err) {
      console.log('â ogrenci_talepleri.rehber_ogretmen_id kolonu eklendi');
    }
  });
  
  db.run(`ALTER TABLE ogrenci_talepleri ADD COLUMN ogrenci_id INTEGER`, (err) => {
    if (err && !err.message.includes('duplicate column name')) {
      console.log('â ď¸ ogrenci_id kolonu zaten var veya hata:', err.message);
    } else if (!err) {
      console.log('â ogrenci_talepleri.ogrenci_id kolonu eklendi');
    }
  });
  
  db.run(`ALTER TABLE sinav_sonuclari_pdf ADD COLUMN pdf_isim TEXT`, (err) => {
    if (err && !err.message.includes('duplicate column')) {
      // SĂźtun zaten var, sorun yok
    }
  });
  
  db.run(`ALTER TABLE sinav_sonuclari_pdf ADD COLUMN sayfa_no INTEGER`, (err) => {
    if (err && !err.message.includes('duplicate column')) {
      // SĂźtun zaten var, sorun yok
    }
  });
  
  // SÄąnav paketlerine fiyat kolonu ekle
  db.run(`ALTER TABLE sinav_paketleri ADD COLUMN fiyat REAL DEFAULT 0`, (err) => {
    if (err && !err.message.includes('duplicate column')) {
      console.log('â ď¸ sinav_paketleri.fiyat kolonu zaten var veya hata:', err.message);
    } else if (!err) {
      console.log('â sinav_paketleri.fiyat kolonu eklendi');
    }
  });
});

// VeritabanÄą yardÄąmcÄą fonksiyonlarÄą (Promise wrapper)
// ĂÄrenci NumarasÄą OluĹturma Fonksiyonu
async function generateOgrenciNo() {
  const yil = new Date().getFullYear();
  
  // Bu yÄąl eklenen son ĂśÄrenci numarasÄąnÄą bul
  const sonOgrenci = await dbGet(
    `SELECT ogrenci_no FROM ogrenciler 
     WHERE ogrenci_no LIKE ? 
     ORDER BY ogrenci_no DESC LIMIT 1`,
    [`${yil}%`]
  );
  
  let sira = 1;
  if (sonOgrenci && sonOgrenci.ogrenci_no) {
    // Son 4 haneyi al ve 1 artÄąr
    const sonSira = parseInt(sonOgrenci.ogrenci_no.substring(4));
    sira = sonSira + 1;
  }
  
  // YÄąl + 4 haneli sÄąra numarasÄą
  const ogrenciNo = `${yil}${sira.toString().padStart(4, '0')}`;
  return ogrenciNo;
}

function dbGet(query, params = []) {
  return new Promise((resolve, reject) => {
    db.get(query, params, (err, row) => {
      if (err) reject(err);
      else resolve(row);
    });
  });
}

function dbAll(query, params = []) {
  return new Promise((resolve, reject) => {
    db.all(query, params, (err, rows) => {
      if (err) reject(err);
      else resolve(rows);
    });
  });
}

function dbRun(query, params = []) {
  return new Promise((resolve, reject) => {
    db.run(query, params, function(err) {
      if (err) reject(err);
      else resolve({ lastID: this.lastID, changes: this.changes });
    });
  });
}

/**
 * TC bazlÄą ĂśÄrenci tekrarlarÄąnÄą temizler
 * AynÄą TC'ye sahip ĂśÄrenciler varsa, kurum kaydÄąnÄą Ăśncelikli tutar
 * @param {Array} veliOgrencileri - Veli tarafÄąndan eklenen ĂśÄrenciler
 * @param {Array} kurumOgrencileri - Kurum tarafÄąndan eklenen ĂśÄrenciler
 * @returns {Array} TemizlenmiĹ ĂśÄrenci listesi
 */
function temizleOgrenciTekrarlari(veliOgrencileri = [], kurumOgrencileri = []) {
  const tcMap = new Map();
  const tcSizOgrenciler = [];
  let tekrarSayisi = 0;
  
  // Ănce kurum ĂśÄrencilerini ekle (Ăśncelikli)
  kurumOgrencileri.forEach(ogr => {
    const tc = ogr.tc_no ? String(ogr.tc_no).replace('.0', '').trim() : null;
    if (tc && tc !== '' && tc !== 'null' && tc !== 'undefined') {
      if (!tcMap.has(tc)) {
        tcMap.set(tc, ogr);
      }
    } else {
      // TC yok, direkt ekle
      tcSizOgrenciler.push(ogr);
    }
  });
  
  // Sonra veli ĂśÄrencilerini ekle (sadece TC tekrar etmeyenler)
  veliOgrencileri.forEach(ogr => {
    const tc = ogr.tc_no ? String(ogr.tc_no).replace('.0', '').trim() : null;
    if (tc && tc !== '' && tc !== 'null' && tc !== 'undefined') {
      if (!tcMap.has(tc)) {
        tcMap.set(tc, ogr);
      } else {
        tekrarSayisi++;
        console.log(`   â ď¸  Tekrar: ${ogr.ad_soyad || ogr.ogrenci_adi} (TC: ${tc}) - Kurum kaydÄą kullanÄąlÄąyor`);
      }
    } else {
      // TC yok, direkt ekle
      tcSizOgrenciler.push(ogr);
    }
  });
  
  // TĂźm ĂśÄrencileri birleĹtir ve isme gĂśre sÄąrala
  const temizlenmis = [...Array.from(tcMap.values()), ...tcSizOgrenciler];
  temizlenmis.sort((a, b) => {
    const adA = (a.ad_soyad || a.ogrenci_adi || '').toLowerCase();
    const adB = (b.ad_soyad || b.ogrenci_adi || '').toLowerCase();
    return adA.localeCompare(adB, 'tr');
  });
  
  if (tekrarSayisi > 0) {
    console.log(`   đ§š ${tekrarSayisi} tekrar temizlendi`);
  }
  
  return temizlenmis;
}

