// Test PDF Upload Route
app.post('/test-pdf-upload', pdfUpload.single('pdfFile'), async (req, res) => {
  try {
    if (!req.file) {
      return res.status(400).json({ error: 'LĂźtfen bir PDF dosyasÄą yĂźkleyin!' });
    }

    // PDF'i oku
    const dataBuffer = fs.readFileSync(req.file.path);
    
    // PDF'i parse et
    const pdfData = await pdfParse(dataBuffer);
    
    // Text iĂ§eriÄini al
    const text = pdfData.text;
    
    // ĂÄrenci bilgilerini Ă§Äąkar (regex ile)
    const ogrenciMatch = text.match(/ĂÄrenci\s+Numara\s+SÄąnÄąf\s+([^\n]+)\s+(\d+)\s+(\w+)/);
    const puanMatch = text.match(/âź\s*([\d,]+)/);
    
    // Ders detaylarÄąnÄą Ă§Äąkar
    const dersler = [];
    const dersRegex = /(TĂźrkĂ§e|Tarih-1|CoÄrafya-1|Felsefe|Din KĂźl\. ve Ahl\. Bil\.|Fizik|Kimya|Biyoloji|TYT Fen)\s+(\d+)\s+(\d+)\s+(\d+)\s+([\d,]+)/g;
    let dersMatch;
    
    while ((dersMatch = dersRegex.exec(text)) !== null) {
      dersler.push({
        ders: dersMatch[1],
        soru: dersMatch[2],
        dogru: dersMatch[3],
        yanlis: dersMatch[4],
        net: dersMatch[5]
      });
    }
    
    const result = {
      filename: req.file.originalname,
      filepath: req.file.path,
      pageCount: pdfData.numpages,
      ogrenciBilgi: ogrenciMatch ? {
        ad: ogrenciMatch[1].trim(),
        numara: ogrenciMatch[2],
        sinif: ogrenciMatch[3]
      } : null,
      puan: puanMatch ? puanMatch[1] : null,
      dersler: dersler,
      rawText: text.substring(0, 2000) // Ä°lk 2000 karakter
    };
    
    res.json({
      success: true,
      data: result
    });
    
  } catch (error) {
    console.error('PDF parse hatasÄą:', error);
    res.status(500).json({ 
      success: false, 
      error: 'PDF parse edilirken hata oluĹtu: ' + error.message 
    });
  }
});

