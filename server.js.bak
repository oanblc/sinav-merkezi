// ============================================
// GELIĹMIĹ PDF TEXT EXTRACTION
// ============================================

// Bozuk text tespit et
function isGarbledText(text) {
  if (!text || text.length === 0) return true;
  
  // 1. AynÄą karakterin 10+ kez tekrarÄą (DYBNDYBNDYBN...)
  if (text.match(/(.)\1{9,}/)) {
    console.log('   â ď¸ Tespit: Tekrarlayan karakter paterni');
    return true;
  }
  
  // 2. 2-3 karakterlik tekrar (DYBN DYBN DYBN...)
  if (text.match(/(.{2,4})\1{5,}/)) {
    console.log('   â ď¸ Tespit: Tekrarlayan string paterni');
    return true;
  }
  
  // 3. Ăok az sesli harf (encoding sorunlarÄąnda sesliler kaybolur)
  const vowelCount = (text.match(/[AEIOUĂĂIÄ°aeÄąouĂźĂś]/g) || []).length;
  const totalChars = text.replace(/\s/g, '').length;
  if (totalChars > 50 && vowelCount / totalChars < 0.15) {
    console.log(`   â ď¸ Tespit: Ăok az sesli harf (${vowelCount}/${totalChars})`);
    return true;
  }
  
  return false;
}

// Alternatif PDF okuma (Ĺimdilik devre dÄąĹÄą - gelecekte OCR eklenebilir)
async function extractTextWithAlternative(pdfPath) {
  console.log('   â ď¸ Alternatif extraction Ĺu anda desteklenmiyor');
  console.log('   đĄ PDF\'i farklÄą formatta export edin veya manuel giriĹ kullanÄąn');
  return null;
}

// Hibrit extraction: Ănce pdf-parse, bozuksa PDF.js
async function extractTextHybrid(pdfPath) {
  // 1. Ănce pdf-parse dene
  const buffer = fs.readFileSync(pdfPath);
  const data = await pdfParse(buffer);
  const text1 = data.text;
  
  // Bozuk mu kontrol et
  if (!isGarbledText(text1)) {
    console.log('   â pdf-parse baĹarÄąlÄą');
    return { text: text1, method: 'pdf-parse' };
  }
  
  console.log('   â ď¸ pdf-parse bozuk text Ăźretti');
  
  // 2. Alternatif yĂśntem dene (Ĺimdilik sadece uyarÄą)
  await extractTextWithAlternative(pdfPath);
  
  // 3. Bozuk text ile devam et ama iĹaretle
  console.log('   â ď¸ Bozuk text ile devam ediliyor - Manuel kontrol gerekli');
  return { text: text1, method: 'pdf-parse-garbled', garbled: true };
}

// ============================================
// AKILLI EĹLEĹTÄ°RME SÄ°STEMÄ° - YARDIMCI FONKSÄ°YONLAR
// ============================================

/**
 * Ä°sim gibi gĂśrĂźnĂźyor mu kontrol et
 */
function looksLikeName(line) {
  // Ănce ismi rakamlardan ayÄąr (Ăśrn: "ALÄ° OSMAN ĂĂZELÄ°08-A" â "ALÄ° OSMAN ĂĂZELÄ°")
  const cleanedLine = line.replace(/\d+[-]?[A-Z]?$/g, '').trim();
  
  const words = cleanedLine.split(/\s+/);
  const wordCount = words.length;
  
  // Kelime sayÄąsÄą kontrolĂź (daha esnek)
  if (wordCount < 2 || wordCount > 6) return false;
  
  // Uzunluk kontrolĂź (daha esnek)
  if (cleanedLine.length < 5 || cleanedLine.length > 60) return false;
  
  // TĂźrkĂ§e harfler kontrolĂź
  if (!cleanedLine.match(/^[A-ZĂÄÄ°ĂĹĂa-zĂ§ÄÄąĂśĹĂź\s]+$/)) return false;
  
  // Blacklist: BaĹlÄąk kelimeleri (daha kapsamlÄą)
  if (cleanedLine.match(/BELGESÄ°|SINAV|SONUĂ|PUAN|OKUL|DERS|NET|DOÄRU|YANLIĹ|BOĹ|SIRA|ORTALAMA|Ä°LĂE|KURUM|LÄ°SE|ORTAOKUL|DENEME|NUMARA|GENEL|DERECE|KATILIM|BAĹARI|ANALÄ°Z|CEVAP|SORU/i)) return false;
  
  // En az bir boĹluk olmalÄą (ad-soyad)
  if (!cleanedLine.includes(' ')) return false;
  
  return true;
}

/**
 * Ä°smi temizle (rakamlarÄą ve Ăśzel karakterleri kaldÄąr)
 */
function cleanExtractedName(name) {
  if (!name) return '';
  
  // 1. Ănce sondaki rakam-harf kombinasyonlarÄąnÄą temizle (08-A, 123, vs)
  let clean = name.replace(/\d+[-]?[A-Z]?$/g, '').trim();
  
  // 2. TĂźm rakamlarÄą temizle
  clean = clean.replace(/\d+/g, '');
  
  // 3. Ăzel karakterleri temizle (TĂźrkĂ§e harfler hariĂ§)
  clean = clean.replace(/[^\wĂÄÄ°ĂĹĂĂ§ÄÄąĂśĹĂź\s]/g, '');
  
  // 4. BaĹÄąndaki/sonundaki gereksiz kelimeleri temizle
  clean = clean.replace(/^(ĂÄrenci|ĂÄRENCÄ°|Ogrenci|OGRENCI|Ad|AD|AdÄą|ADI|Soyad|SOYAD|SoyadÄą|SOYADI)\s*/gi, '');
  clean = clean.replace(/\s*(Numara|NUMARA|SÄąnÄąf|SINIF|SÄąnÄąfÄą|SINIFI)$/gi, '');
  
  // 5. Fazla boĹluklarÄą temizle
  clean = clean.replace(/\s+/g, ' ').trim();
  
  // 6. BĂźyĂźk harfe Ă§evir
  clean = clean.toUpperCase();
  
  // 7. Ăok kÄąsa veya Ă§ok uzunsa geĂ§ersiz
  if (clean.length < 5 || clean.length > 50) return '';
  
  return clean;
}

/**
 * Levenshtein Distance hesapla
 */
function levenshteinDistance(str1, str2) {
  const matrix = [];
  
  for (let i = 0; i <= str2.length; i++) {
    matrix[i] = [i];
  }
  
  for (let j = 0; j <= str1.length; j++) {
    matrix[0][j] = j;
  }
  
  for (let i = 1; i <= str2.length; i++) {
    for (let j = 1; j <= str1.length; j++) {
      if (str2.charAt(i - 1) === str1.charAt(j - 1)) {
        matrix[i][j] = matrix[i - 1][j - 1];
      } else {
        matrix[i][j] = Math.min(
          matrix[i - 1][j - 1] + 1, // substitution
          matrix[i][j - 1] + 1,     // insertion
          matrix[i - 1][j] + 1      // deletion
        );
      }
    }
  }
  
  return matrix[str2.length][str1.length];
}

/**
 * String benzerliÄi hesapla (0-1 arasÄą, 1 = tam eĹleĹme)
 */
function stringSimilarity(str1, str2) {
  if (!str1 || !str2) return 0;
  
  const s1 = str1.toUpperCase().trim();
  const s2 = str2.toUpperCase().trim();
  
  if (s1 === s2) return 1.0;
  
  const longer = s1.length > s2.length ? s1 : s2;
  const shorter = s1.length > s2.length ? s2 : s1;
  
  if (longer.length === 0) return 1.0;
  
  const editDistance = levenshteinDistance(longer, shorter);
  return (longer.length - editDistance) / longer.length;
}

/**
 * En iyi eĹleĹmeyi bul
 */
function findBestMatch(extractedName, katilimcilar) {
  if (!extractedName || !katilimcilar || katilimcilar.length === 0) {
    return null;
  }
  
  let bestMatch = null;
  let bestSimilarity = 0;
  
  for (const katilimci of katilimcilar) {
    if (!katilimci.ad_soyad) continue;
    
    const similarity = stringSimilarity(extractedName, katilimci.ad_soyad);
    
    if (similarity > bestSimilarity) {
      bestSimilarity = similarity;
      bestMatch = katilimci;
    }
  }
  
  return bestMatch && bestSimilarity >= 0.65 ? { ogrenci: bestMatch, similarity: bestSimilarity } : null;
}

// ============================================
// MULTER CONFIGURATION (PDF & Excel Upload)
// ============================================

// PDF Upload Storage
const pdfStorage = multer.diskStorage({
  destination: function (req, file, cb) {
    const uploadDir = './uploads/';
    if (!fs.existsSync(uploadDir)) {
      fs.mkdirSync(uploadDir, { recursive: true });
    }
    cb(null, uploadDir);
  },
  filename: function (req, file, cb) {
    cb(null, Date.now() + '-' + file.originalname);
  }
});

const pdfUpload = multer({ 
  storage: pdfStorage,
  limits: {
    fileSize: 50 * 1024 * 1024 // 50MB limit
  },
  fileFilter: (req, file, cb) => {
    if (file.mimetype === 'application/pdf') {
      cb(null, true);
    } else {
      cb(new Error('Sadece PDF dosyasÄą yĂźkleyebilirsiniz!'), false);
    }
  }
});

