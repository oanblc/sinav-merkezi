// Kurum - Duyuru YĂśnetimi SayfasÄą
app.get('/kurum/duyurular', requireAuth, async (req, res) => {
  if (req.session.userType !== 'kurum_yonetici') {
    return res.status(403).send('Bu sayfaya eriĹim yetkiniz yok!');
  }
  
  try {
    const duyurular = await dbAll('SELECT * FROM duyurular ORDER BY sira ASC, tarih DESC');
    
    res.render('kurum/duyurular', {
      duyurular: duyurular,
      user: { username: req.session.username, type: req.session.userType },
      error: req.session.error,
      success: req.session.success
    });
    
    req.session.error = null;
    req.session.success = null;
  } catch (error) {
    console.error('Duyuru yĂśnetimi hatasÄą:', error);
    res.status(500).send('Bir hata oluĹtu!');
  }
});

// Kurum - Duyuru Ekle (POST)
app.post('/kurum/duyuru-ekle', requireAuth, async (req, res) => {
  if (req.session.userType !== 'kurum_yonetici') {
    return res.status(403).json({ success: false, message: 'Yetkisiz eriĹim!' });
  }
  
  try {
    const { baslik, icerik, tarih, sira, aktif } = req.body;
    
    if (!baslik) {
      return res.json({ success: false, message: 'BaĹlÄąk zorunludur!' });
    }
    
    await dbRun(
      'INSERT INTO duyurular (baslik, icerik, tarih, sira, aktif) VALUES (?, ?, ?, ?, ?)',
      [baslik, icerik || '', tarih || new Date().toISOString().split('T')[0], sira || 0, aktif ? 1 : 0]
    );
    
    console.log(`\nâ YENÄ° DUYURU EKLENDÄ°`);
    console.log(`   BaĹlÄąk: ${baslik}`);
    
    req.session.success = 'Duyuru baĹarÄąyla eklendi!';
    res.json({ success: true, message: 'Duyuru baĹarÄąyla eklendi!' });
  } catch (error) {
    console.error('Duyuru ekleme hatasÄą:', error);
    res.json({ success: false, message: 'Bir hata oluĹtu: ' + error.message });
  }
});

// Kurum - Duyuru GĂźncelle (POST)
app.post('/kurum/duyuru-guncelle/:id', requireAuth, async (req, res) => {
  if (req.session.userType !== 'kurum_yonetici') {
