      console.log('â Yetki kontrolĂź baĹarÄąsÄąz');
      return res.json({ success: false, message: 'Yetkiniz yok!' });
    }
    
    // Talebi sil (yetkiyi kaldÄąr)
    await dbRun('DELETE FROM ogrenci_talepleri WHERE id = ?', [talepId]);
    console.log('â Yetki baĹarÄąyla kaldÄąrÄąldÄą');
    
    res.json({ success: true, message: 'Rehber ĂśÄretmen yetkisi kaldÄąrÄąldÄą!' });
  } catch (error) {
