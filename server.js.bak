  }
});

// Kurum - Excel Import
app.post('/kurum/ogrenci-import-excel', requireAuth, upload.single('excelFile'), async (req, res) => {
  if (req.session.userType !== 'kurum_yonetici') {
    return res.status(403).json({ success: false, message: 'Yetkiniz yok!' });
  }
  
  try {
    if (!req.file) {
      return res.json({ success: false, message: 'Excel dosyasÄą seĂ§ilmedi!' });
    }
    
    const xlsx = require('xlsx');
    const workbook = xlsx.readFile(req.file.path);
    const sheetName = workbook.SheetNames[0];
    const sheet = workbook.Sheets[sheetName];
    const data = xlsx.utils.sheet_to_json(sheet);
    
    console.log('\nđĽ EXCEL IMPORT BAĹLADI');
    console.log(`đ Toplam satÄąr: ${data.length}`);
    
    if (data.length > 0) {
      console.log('đ Excel baĹlÄąklarÄą:', Object.keys(data[0]));
      console.log('đ Ä°lk satÄąr ĂśrneÄi:', data[0]);
    }
    
    let eklenenSayisi = 0;
    let hataliSayisi = 0;
    
    for (const row of data) {
      try {
        // TĂźm olasÄą baĹlÄąk varyasyonlarÄąnÄą dene (boĹluklar, bĂźyĂźk/kĂźĂ§Ăźk harf)
        const keys = Object.keys(row);
        
        // SÄąnÄąf bilgisini bul
        const sinifKey = keys.find(k => 
          k.includes('SINIF') || k.includes('SÄąnÄąf') || k.includes('sÄąnÄąf') || k === 'sinif'
        );
        const sinif = sinifKey ? row[sinifKey] : '';
        
        // ĂÄrenci adÄąnÄą bul
        const isimKey = keys.find(k => 
          k.includes('ADI') || k.includes('SOYADI') || k.includes('AdÄą') || k.includes('SoyadÄą') || k === 'ogrenci_adi_soyadi'
        );
        const ogrenciAdi = isimKey ? row[isimKey] : '';
        
        if (!ogrenciAdi || !sinif) {
          console.log(`â ď¸ Eksik veri: SÄąnÄąf="${sinif}" (key: ${sinifKey}), Ä°sim="${ogrenciAdi}" (key: ${isimKey})`);
          console.log(`   SatÄąr:`, row);
          hataliSayisi++;
          continue;
        }
        
        // DiÄer alanlarÄą da dinamik bul
        const telefonKey = keys.find(k => k.includes('TELEFON') && !k.includes('VELÄ°'));
        const tcKey = keys.find(k => k.includes('T.C') || k.includes('TC') || k.includes('KÄ°MLÄ°K'));
        const veliAdiKey = keys.find(k => k.includes('VELÄ°') && (k.includes('ADI') || k === 'ĂÄRENCÄ° VELÄ°'));
        const veliTelKey = keys.find(k => k.includes('VELÄ°') && k.includes('TELEFON'));
        const tutarKey = keys.find(k => k.includes('TUTAR'));
        const odemeDurumKey = keys.find(k => k.includes('ĂDEME') && k.includes('DURUM'));
        const odemeTurKey = keys.find(k => k.includes('ĂDEME') && k.includes('TĂR'));
        const edesisKey = keys.find(k => k.includes('EDESIS') || k.includes('EDEĹÄ°S') || k.includes('KAYDI'));
        const taksitKey = keys.find(k => k.includes('TAKSÄ°T') || k.includes('TAKSIT'));
        
        await dbRun(
          `INSERT INTO ogrenci_kayitlari (
            sinif, ogrenci_adi_soyadi, telefon, tc_kimlik_no,
            veli_adi, veli_telefon, tutar, odeme_durumu,
            odeme_turu, edessis_kaydi, taksit
          ) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)`,
          [
            sinif,
            ogrenciAdi,
            telefonKey ? row[telefonKey] : '',
            tcKey ? row[tcKey] : '',
            veliAdiKey ? row[veliAdiKey] : '',
            veliTelKey ? row[veliTelKey] : '',
            tutarKey ? row[tutarKey] : '',
            odemeDurumKey ? row[odemeDurumKey] : 'BEKLÄ°YOR',
            odemeTurKey ? row[odemeTurKey] : '',
            edesisKey ? row[edesisKey] : '',
            taksitKey ? row[taksitKey] : ''
          ]
        );
        eklenenSayisi++;
      } catch (error) {
        console.error('â SatÄąr ekleme hatasÄą:', error.message);
        hataliSayisi++;
      }
    }
    
    console.log(`\nâ Excel import tamamlandÄą: ${eklenenSayisi} eklendi, ${hataliSayisi} hata\n`);
    
    // YĂźklenen dosyayÄą sil
    fs.unlinkSync(req.file.path);
    
    res.json({ 
      success: true, 
      message: `${eklenenSayisi} kayÄąt eklendi. ${hataliSayisi > 0 ? hataliSayisi + ' kayÄąt hatasÄą.' : ''}` 
    });
  } catch (error) {
    console.error('Excel import hatasÄą:', error);
    res.json({ success: false, message: 'Excel iĂ§eri aktarÄąlÄąrken bir hata oluĹtu: ' + error.message });
  }
});

// Kurum - Excel Ĺablon Ä°ndir
app.get('/kurum/ogrenci-sablon-indir', requireAuth, async (req, res) => {
  if (req.session.userType !== 'kurum_yonetici') {
    return res.status(403).send('Yetkiniz yok!');
  }
  
  try {
    const xlsx = require('xlsx');
    
    // Ĺablon veri: BaĹlÄąklar + GerĂ§ek veri ĂśrneÄi
    const sablonData = [
      {
        'ĂÄRENCI SINIF BÄ°LGÄ°SÄ°': '5',
        'ĂÄRENCI ADI SOYADI': 'Onur KapÄącÄąoÄlu',
        'TELEFON KAYDI': 'YapÄąldÄą',
        'T.C KÄ°MLÄ°K NO': '14983254220',
        'ĂÄRENCÄ° VELÄ°': 'Edip KapÄącÄąoÄlu',
        'VELÄ° TELEFON': '05365052512',
        'TUTAR': '5000',
        'ĂDEME DURUMU': 'YapÄąldÄą',
        'ĂDEME TĂRĂ': 'Nakit',
        'EDESIS KAYDI': '',
        'TAKSÄ°T': ''
      },
      {
        'ĂÄRENCI SINIF BÄ°LGÄ°SÄ°': '3',
        'ĂÄRENCI ADI SOYADI': 'Ărnek ĂÄrenci 2',
        'TELEFON KAYDI': '',
        'T.C KÄ°MLÄ°K NO': '12345678901',
        'ĂÄRENCÄ° VELÄ°': 'Ărnek Veli 2',
        'VELÄ° TELEFON': '05321234567',
        'TUTAR': '4000',
        'ĂDEME DURUMU': 'Bekliyor',
        'ĂDEME TĂRĂ': '',
        'EDESIS KAYDI': '',
        'TAKSÄ°T': '2'
      }
    ];
    
    const worksheet = xlsx.utils.json_to_sheet(sablonData);
    
    // SĂźtun geniĹliklerini ayarla
    worksheet['!cols'] = [
      { wch: 22 }, // ĂÄRENCI SINIF BÄ°LGÄ°SÄ°
      { wch: 25 }, // ĂÄRENCI ADI SOYADI
      { wch: 15 }, // TELEFON KAYDI
      { wch: 15 }, // T.C KÄ°MLÄ°K NO
      { wch: 20 }, // ĂÄRENCÄ° VELÄ°
      { wch: 15 }, // VELÄ° TELEFON
      { wch: 12 }, // TUTAR
      { wch: 15 }, // ĂDEME DURUMU
      { wch: 12 }, // ĂDEME TĂRĂ
      { wch: 15 }, // EDESIS KAYDI
      { wch: 10 }  // TAKSÄ°T
    ];
    
    const workbook = xlsx.utils.book_new();
    xlsx.utils.book_append_sheet(workbook, worksheet, 'ĂÄrenci KayÄąt Ĺablonu');
    
    const buffer = xlsx.write(workbook, { type: 'buffer', bookType: 'xlsx' });
    
    res.setHeader('Content-Disposition', 'attachment; filename=ogrenci-kayit-sablonu.xlsx');
    res.setHeader('Content-Type', 'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet');
    res.send(buffer);
  } catch (error) {
    console.error('Excel Ĺablon oluĹturma hatasÄą:', error);
    res.status(500).send('Ĺablon oluĹturulurken bir hata oluĹtu!');
  }
});

// Kurum - Excel Export
app.get('/kurum/ogrenci-export-excel', requireAuth, async (req, res) => {
  if (req.session.userType !== 'kurum_yonetici') {
    return res.status(403).send('Yetkiniz yok!');
  }
  
  try {
    const xlsx = require('xlsx');
    const ogrenciler = await dbAll('SELECT * FROM ogrenci_kayitlari ORDER BY sinif, ogrenci_adi_soyadi');
    
    // Excel iĂ§in veri formatla
    const excelData = ogrenciler.map(o => ({
      'ĂÄRENCI SINIF BÄ°LGÄ°SÄ°': o.sinif,
      'ĂÄRENCI ADI SOYADI': o.ogrenci_adi_soyadi,
      'TELEFON KAYDI': o.telefon || '',
      'T.C KÄ°MLÄ°K NO': o.tc_kimlik_no || '',
      'ĂÄRENCÄ° VELÄ°': o.veli_adi || '',
      'VELÄ° TELEFON': o.veli_telefon || '',
      'TUTAR': o.tutar || '',
      'ĂDEME DURUMU': o.odeme_durumu || '',
      'ĂDEME TĂRĂ': o.odeme_turu || '',
      'EDESIS KAYDI': o.edessis_kaydi || '',
      'TAKSÄ°T': o.taksit || ''
    }));
    
    const worksheet = xlsx.utils.json_to_sheet(excelData);
    const workbook = xlsx.utils.book_new();
    xlsx.utils.book_append_sheet(workbook, worksheet, 'ĂÄrenci KayÄątlarÄą');
    
    const buffer = xlsx.write(workbook, { type: 'buffer', bookType: 'xlsx' });
    
    res.setHeader('Content-Disposition', 'attachment; filename=ogrenci-kayitlari.xlsx');
    res.setHeader('Content-Type', 'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet');
    res.send(buffer);
  } catch (error) {
    console.error('Excel export hatasÄą:', error);
    res.status(500).send('Excel dÄąĹarÄą aktarÄąlÄąrken bir hata oluĹtu!');
  }
});

