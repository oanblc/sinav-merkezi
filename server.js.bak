// Kurum - Rehber ĂÄretmene Talep GĂśnder
app.post('/kurum/rehber-talep-gonder', requireAuth, async (req, res) => {
  if (req.session.userType !== 'kurum_yonetici') {
    return res.status(403).json({ success: false, message: 'Yetkiniz yok!' });
  }
  
  try {
    const { veli_id, ogrenci_id, rehber_ogretmen_id, ogrenci_no, ad_soyad, sinif, okul, mesaj, ogrenci_kaynak } = req.body;
    
    console.log('đĽ Talep gĂśnderme isteÄi:', { veli_id, ogrenci_id, rehber_ogretmen_id, ad_soyad, ogrenci_kaynak });
    
    if (!veli_id || !rehber_ogretmen_id || !ad_soyad) {
      return res.json({ success: false, message: 'Eksik bilgiler! (veli_id, rehber_ogretmen_id, ad_soyad gerekli)' });
    }
    
    // Kurum ĂśÄrencileri iĂ§in ogrenci_id NULL olabilir
    const kullanilacakOgrenciId = (ogrenci_kaynak === 'kurum') ? null : ogrenci_id;
    
    // AynÄą talep var mÄą kontrol et (ogrenci_id varsa) - Beklemede VEYA OnaylÄą talep kontrolĂź
    if (kullanilacakOgrenciId) {
      const mevcutTalep = await dbGet(`
        SELECT id, durum FROM ogrenci_talepleri 
        WHERE ogrenci_id = ? AND rehber_ogretmen_id = ? AND durum IN ('beklemede', 'onaylandi')
      `, [kullanilacakOgrenciId, rehber_ogretmen_id]);
      
      if (mevcutTalep) {
        if (mevcutTalep.durum === 'beklemede') {
          return res.json({ success: false, message: 'Bu ĂśÄrenci iĂ§in bu rehber ĂśÄretmene zaten bekleyen bir talep var!' });
        } else {
          return res.json({ success: false, message: 'Bu ĂśÄrenci iĂ§in bu rehber ĂśÄretmene zaten onaylÄą bir talep var!' });
        }
      }
    } else {
      // Kurum ĂśÄrencileri iĂ§in ad_soyad ve veli_id ile kontrol et
      const mevcutTalep = await dbGet(`
        SELECT id, durum FROM ogrenci_talepleri 
        WHERE ad_soyad = ? AND veli_id = ? AND rehber_ogretmen_id = ? AND durum IN ('beklemede', 'onaylandi') AND ogrenci_id IS NULL
      `, [ad_soyad, veli_id, rehber_ogretmen_id]);
      
      if (mevcutTalep) {
        if (mevcutTalep.durum === 'beklemede') {
          return res.json({ success: false, message: 'Bu ĂśÄrenci iĂ§in bu rehber ĂśÄretmene zaten bekleyen bir talep var!' });
        } else {
          return res.json({ success: false, message: 'Bu ĂśÄrenci iĂ§in bu rehber ĂśÄretmene zaten onaylÄą bir talep var!' });
        }
      }
    }
    
    // Talep oluĹtur
    // rehber_id ve rehber_ogretmen_id aynÄą deÄer (kurum tarafÄąndan gĂśnderildiÄi iĂ§in)
    await dbRun(`
      INSERT INTO ogrenci_talepleri 
      (ogrenci_id, ogrenci_no, ad_soyad, sinif, okul, veli_id, rehber_id, rehber_ogretmen_id, durum, mesaj)
      VALUES (?, ?, ?, ?, ?, ?, ?, ?, 'beklemede', ?)
    `, [kullanilacakOgrenciId, ogrenci_no || '', ad_soyad, sinif || '', okul || '', veli_id, rehber_ogretmen_id, rehber_ogretmen_id, mesaj || '']);
    
    console.log('â Talep baĹarÄąyla oluĹturuldu');
    
    // Veli ve rehber bilgilerini al
    const veli = await dbGet('SELECT ad_soyad, telefon FROM users WHERE id = ?', [veli_id]);
    const rehber = await dbGet('SELECT ad_soyad, telefon FROM users WHERE id = ?', [rehber_ogretmen_id]);
    
    // WhatsApp bildirimi gĂśnder (arka planda)
    if (veli && veli.telefon) {
      const veliMesaj = `đŠ YENÄ° REHBER ĂÄRETMEN TALEBÄ°\n\n` +
        `Merhaba ${veli.ad_soyad || 'DeÄerli Velimiz'},\n\n` +
        `Kurum tarafÄąndan sizin adÄąnÄąza rehber ĂśÄretmen yetki talebi gĂśnderilmiĹtir.\n\n` +
        `đ¤ ĂÄrenci: ${ad_soyad}\n` +
        `đ¨âđŤ Rehber: ${rehber?.ad_soyad || 'Rehber ĂÄretmen'}\n\n` +
        `Talebiniz onaylandÄąÄÄąnda rehber ĂśÄretmen ĂśÄrenciniz hakkÄąnda bilgilere eriĹebilecektir.`;
      
      whatsappBildirimGonder(veli.telefon, veliMesaj, 'rehber_talep_kurum')
        .then(result => console.log('â Veli WhatsApp bildirimi gĂśnderildi:', result))
        .catch(error => console.error('â Veli WhatsApp bildirimi hatasÄą:', error));
    }
    
    if (rehber && rehber.telefon) {
      const rehberMesaj = `đŠ YENÄ° ĂÄRENCÄ° YETKÄ° TALEBÄ°\n\n` +
        `Merhaba ${rehber.ad_soyad || 'DeÄerli Rehber ĂÄretmenimiz'},\n\n` +
        `Kurum tarafÄąndan size yeni bir ĂśÄrenci yetki talebi gĂśnderilmiĹtir.\n\n` +
        `đ¤ ĂÄrenci: ${ad_soyad}\n` +
        `đ¨âđŠâđ§ Veli: ${veli?.ad_soyad || 'Veli'}\n` +
        `${sinif ? `đ SÄąnÄąf: ${sinif}\n` : ''}` +
        `${okul ? `đŤ Okul: ${okul}\n` : ''}` +
        `${mesaj ? `\nđŹ Mesaj: ${mesaj}\n` : ''}\n` +
        `LĂźtfen veli panelinden talebi inceleyip onaylayÄąn veya reddedin.`;
      
      whatsappBildirimGonder(rehber.telefon, rehberMesaj, 'rehber_talep_kurum')
        .then(result => console.log('â Rehber WhatsApp bildirimi gĂśnderildi:', result))
        .catch(error => console.error('â Rehber WhatsApp bildirimi hatasÄą:', error));
    }
    
    res.json({ 
      success: true, 
      message: 'Rehber ĂśÄretmene talep baĹarÄąyla gĂśnderildi!' 
    });
    
  } catch (error) {
    console.error('â Rehber talep gĂśnderme hatasÄą:', error);
    console.error('Hata detayÄą:', error.message);
    console.error('Stack trace:', error.stack);
    res.json({ 
      success: false, 
      message: `Talep gĂśnderilirken bir hata oluĹtu: ${error.message}` 
    });
  }
});

