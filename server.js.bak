        type: req.session.userType,
        id: req.session.userId
      } : null
    });
  }
});

// SÄąnav Talep GĂśnderme - GiriĹ Zorunlu DeÄil
app.post('/sinav-talep-gonder', async (req, res) => {
  try {
    const { sinav_id, ad_soyad, email, telefon, password, aciklama } = req.body;
    let veli_id = req.session.userId; // EÄer giriĹ yapÄąlmÄąĹsa
    
    // SÄąnavÄą kontrol et
    const sinav = await dbGet('SELECT * FROM sinavlar WHERE id = ?', [sinav_id]);
    if (!sinav) {
      return res.json({ success: false, message: 'SÄąnav bulunamadÄą!' });
    }
    
    // DURUM 1: GiriĹ yapÄąlmamÄąĹ - Yeni hesap oluĹtur veya temp hesap kullan
    if (!veli_id) {
      // Zorunlu alanlar kontrolĂź (sadece ad_soyad ve telefon)
      if (!ad_soyad || !telefon) {
        return res.json({ 
          success: false, 
          message: 'LĂźtfen tĂźm bilgileri eksiksiz doldurun!' 
        });
      }
      
      // Email ve password yoksa, otomatik oluĹtur
      const tempEmail = email || `${telefon.replace(/\D/g, '')}@temp.com`;
      const tempPassword = password || telefon.replace(/\D/g, '').slice(-6);
      
      // E-posta daha Ăśnce kullanÄąlmÄąĹ mÄą?
      const mevcutKullanici = await dbGet('SELECT id FROM users WHERE email = ?', [tempEmail]);
      if (mevcutKullanici) {
        veli_id = mevcutKullanici.id;
      } else {
        // Ĺifre hash'le
        const password_hash = await bcrypt.hash(tempPassword, 10);
        
        // Username oluĹtur (telefondan)
        const username = telefon.replace(/\D/g, '') + '_' + Date.now();
        
        // Yeni veli hesabÄą oluĹtur
        const result = await dbRun(
          `INSERT INTO users (username, email, password_hash, user_type, ad_soyad, telefon, created_at) 
           VALUES (?, ?, ?, 'veli', ?, ?, datetime('now'))`,
          [username, tempEmail, password_hash, ad_soyad, telefon]
        );
        
        veli_id = result.lastID;
        
        console.log(`â Yeni veli hesabÄą oluĹturuldu: ${tempEmail} (ID: ${veli_id})`);
      }
      
      // Otomatik giriĹ yapma (session oluĹturma)
      // req.session.userId = veli_id;
      // req.session.username = username;
      // req.session.userType = 'veli';
    }
    
    // DURUM 2: Daha Ăśnce talep gĂśnderilmiĹ mi kontrol et
    const mevcutTalep = await dbGet(
      'SELECT * FROM sinav_talepleri WHERE veli_id = ? AND sinav_id = ? AND durum != "reddedildi"',
      [veli_id, sinav_id]
    );
    
    if (mevcutTalep) {
      return res.json({ success: false, message: 'Bu sÄąnav iĂ§in zaten bir talebiniz bulunmaktadÄąr!' });
    }
    
    // Talep kaydet
    await dbRun(
      `INSERT INTO sinav_talepleri (veli_id, sinav_id, durum, aciklama, talep_tarihi) 
       VALUES (?, ?, 'beklemede', ?, datetime('now'))`,
      [veli_id, sinav_id, aciklama || '']
    );
    
    // Veli bilgilerini al (WhatsApp bildirimi iĂ§in)
    const veliDetay = await dbGet('SELECT * FROM users WHERE id = ?', [veli_id]);
    
    // WhatsApp API ayarlarÄąnÄą kontrol et
    const whatsappAyarlari = await dbGet('SELECT * FROM whatsapp_ayarlari WHERE aktif = 1');
    
    if (whatsappAyarlari && whatsappAyarlari.phone_number) {
      // Bildirim mesajÄą oluĹtur
      const mesaj = talepBildirimMesaji(veliDetay, sinav);
      
      // WhatsApp bildirimi gĂśnder (arka planda, hata olsa bile kullanÄącÄąya baĹarÄąlÄą dĂśn)
      whatsappBildirimGonder(whatsappAyarlari.phone_number, mesaj, 'yeni_talep')
        .then(result => {
          console.log('â WhatsApp bildirimi sonucu:', result);
        })
        .catch(error => {
          console.error('â WhatsApp bildirimi hatasÄą (arka plan):', error);
        });
    } else {
      console.log('â ď¸  WhatsApp ayarlarÄą yapÄąlmamÄąĹ, bildirim gĂśnderilmedi');
    }
    
    res.json({ 
      success: true, 
      message: `${sinav.ad} iĂ§in talebiniz baĹarÄąyla gĂśnderildi! En kÄąsa sĂźrede deÄerlendirilecektir.`,
      yeniHesap: (ad_soyad && email) ? true : false,
      veli_id: veli_id
    });
    
  } catch (error) {
    console.error('Talep gĂśnderme hatasÄą:', error);
    res.json({ success: false, message: 'Talep gĂśnderilirken bir hata oluĹtu: ' + error.message });
  }
});

// Paket Talebi GĂśnder
app.post('/paket-talep-gonder', async (req, res) => {
  try {
    const { paket_id, ad_soyad, email, telefon, password, aciklama } = req.body;
    let veli_id = req.session.userId; // EÄer giriĹ yapÄąlmÄąĹsa
    
    // Paketi kontrol et
    const paket = await dbGet('SELECT * FROM sinav_paketleri WHERE id = ? AND aktif = 1', [paket_id]);
    if (!paket) {
      return res.json({ success: false, message: 'Paket bulunamadÄą!' });
    }
    
    // DURUM 1: GiriĹ yapÄąlmamÄąĹ - Yeni hesap oluĹtur veya temp hesap kullan
    if (!veli_id) {
      // Zorunlu alanlar kontrolĂź (sadece ad_soyad ve telefon)
      if (!ad_soyad || !telefon) {
        return res.json({ 
          success: false, 
          message: 'LĂźtfen tĂźm bilgileri eksiksiz doldurun!' 
        });
      }
      
      // Email ve password yoksa, otomatik oluĹtur
      const tempEmail = email || `${telefon.replace(/\D/g, '')}@temp.com`;
      const tempPassword = password || telefon.replace(/\D/g, '').slice(-6);
      
      // E-posta daha Ăśnce kullanÄąlmÄąĹ mÄą?
      const mevcutKullanici = await dbGet('SELECT id FROM users WHERE email = ?', [tempEmail]);
      if (mevcutKullanici) {
        veli_id = mevcutKullanici.id;
      } else {
        // Ĺifre hash'le
        const password_hash = await bcrypt.hash(tempPassword, 10);
        
        // Username oluĹtur (telefondan)
        const username = telefon.replace(/\D/g, '') + '_' + Date.now();
        
        // Yeni veli hesabÄą oluĹtur
        const result = await dbRun(
          `INSERT INTO users (username, email, password_hash, user_type, ad_soyad, telefon, created_at) 
           VALUES (?, ?, ?, 'veli', ?, ?, datetime('now'))`,
          [username, tempEmail, password_hash, ad_soyad, telefon]
        );
        
        veli_id = result.lastID;
        
        console.log(`â Yeni veli hesabÄą oluĹturuldu: ${tempEmail} (ID: ${veli_id})`);
      }
    }
    
    // Paket iĂ§indeki sÄąnavlarÄą al
    const paketSinavlari = await dbAll(
      'SELECT sinav_id FROM paket_sinavlari WHERE paket_id = ?',
      [paket_id]
    );
    
    if (paketSinavlari.length === 0) {
      return res.json({ success: false, message: 'Paket iĂ§inde sÄąnav bulunamadÄą!' });
    }
    
    // Her sÄąnav iĂ§in talep oluĹtur
    let olusturulanTalep = 0;
    for (const ps of paketSinavlari) {
      // Daha Ăśnce talep gĂśnderilmiĹ mi kontrol et
      const mevcutTalep = await dbGet(
        'SELECT * FROM sinav_talepleri WHERE veli_id = ? AND sinav_id = ? AND durum != "reddedildi"',
        [veli_id, ps.sinav_id]
      );
      
      if (!mevcutTalep) {
        // Talep kaydet (paket bilgisini aciklama'ya ekle)
        const paketAciklama = `[PAKET: ${paket.ad}] ${aciklama || ''}`;
        await dbRun(
          `INSERT INTO sinav_talepleri (veli_id, sinav_id, durum, aciklama, talep_tarihi) 
           VALUES (?, ?, 'beklemede', ?, datetime('now'))`,
          [veli_id, ps.sinav_id, paketAciklama]
        );
        olusturulanTalep++;
      }
    }
    
    if (olusturulanTalep === 0) {
      return res.json({ success: false, message: 'Bu paket iĂ§in zaten tĂźm sÄąnavlara talebiniz bulunmaktadÄąr!' });
    }
    
    // Veli bilgilerini al (WhatsApp bildirimi iĂ§in)
    const veliDetay = await dbGet('SELECT * FROM users WHERE id = ?', [veli_id]);
    
    // WhatsApp API ayarlarÄąnÄą kontrol et
    const whatsappAyarlari = await dbGet('SELECT * FROM whatsapp_ayarlari WHERE aktif = 1');
    
    if (whatsappAyarlari && whatsappAyarlari.phone_number) {
      // Bildirim mesajÄą oluĹtur
      const mesaj = `đŚ YENÄ° PAKET TALEBÄ°\n\n` +
        `Merhaba,\n\n` +
        `${veliDetay.ad_soyad || veliDetay.username} adlÄą veli "${paket.ad}" paketi iĂ§in talep gĂśnderdi.\n\n` +
        `đŚ Paket: ${paket.ad}\n` +
        `đ SÄąnÄąf: ${paket.sinif || 'BelirtilmemiĹ'}\n` +
        `đ SÄąnav SayÄąsÄą: ${paketSinavlari.length}\n` +
        `${aciklama ? `đŹ AĂ§Äąklama: ${aciklama}\n` : ''}\n` +
        `đ Telefon: ${veliDetay.telefon || 'BelirtilmemiĹ'}\n` +
        `đ§ Email: ${veliDetay.email || 'BelirtilmemiĹ'}\n\n` +
        `LĂźtfen kurum panelinden talebi deÄerlendirin.`;
      
      // WhatsApp bildirimi gĂśnder (arka planda, hata olsa bile kullanÄącÄąya baĹarÄąlÄą dĂśn)
      whatsappBildirimGonder(whatsappAyarlari.phone_number, mesaj, 'paket_talebi')
        .then(result => {
          console.log('â WhatsApp bildirimi sonucu:', result);
        })
        .catch(error => {
          console.error('â WhatsApp bildirimi hatasÄą (arka plan):', error);
        });
    } else {
      console.log('â ď¸  WhatsApp ayarlarÄą yapÄąlmamÄąĹ, bildirim gĂśnderilmedi');
    }
    
    res.json({ 
      success: true, 
      message: `${paket.ad} paketi iĂ§in ${olusturulanTalep} sÄąnav talebi baĹarÄąyla gĂśnderildi! En kÄąsa sĂźrede deÄerlendirilecektir.`,
      yeniHesap: (ad_soyad && email) ? true : false,
      veli_id: veli_id
    });
    
  } catch (error) {
    console.error('Paket talep gĂśnderme hatasÄą:', error);
    res.json({ success: false, message: 'Talep gĂśnderilirken bir hata oluĹtu: ' + error.message });
  }
});

