<%- include('partials/header-dashboard', { title: 'Sınav Sonuçları - ' + ogrenci.ad_soyad + ' - Sınav Merkezi', user: user }) %>

<div class="row">
    <div class="col-12">
        <h2 class="mb-4">
            <i class="bi bi-clipboard-data"></i> <%= ogrenci.ad_soyad %> - Sınav Sonuçları
        </h2>
        <a href="/veli/dashboard" class="btn btn-secondary mb-3">
            <i class="bi bi-arrow-left"></i> Geri Dön
        </a>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <% if (sinav_sonuclari && Object.keys(sinav_sonuclari).length > 0) { %>
            <% Object.keys(sinav_sonuclari).forEach(function(sinavId) { 
                const sinavData = sinav_sonuclari[sinavId];
            %>
            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="mb-0">
                        <i class="bi bi-file-earmark-text"></i> <%= sinavData.sinav.ad %>
                        <small class="text-muted">(<%= new Date(sinavData.sinav.tarih).toLocaleDateString('tr-TR') %>)</small>
                    </h5>
                </div>
                <div class="card-body">
                    <% sinavData.sonuclar.forEach(function(sonuc) { 
                        // Backend'de parse edilmiş veri geliyor
                        let veri = sonuc.sonuc_verisi_parsed || {};
                    %>
                    <div class="mb-3">
                        <h6>Sayfa <%= sonuc.sayfa_no %></h6>
                        <div class="table-responsive">
                            <table class="table table-bordered table-sm">
                                <% if (Object.keys(veri).length > 0) { %>
                                <thead>
                                    <tr>
                                        <% Object.keys(veri).forEach(function(key) { %>
                                        <th><%= key %></th>
                                        <% }); %>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <% Object.values(veri).forEach(function(value) { %>
                                        <td><%= value %></td>
                                        <% }); %>
                                    </tr>
                                </tbody>
                                <% } else { %>
                                <tbody>
                                    <tr>
                                        <td colspan="100%" class="text-center text-muted">Veri bulunamadı</td>
                                    </tr>
                                </tbody>
                                <% } %>
                            </table>
                        </div>
                    </div>
                    <% }); %>
                </div>
            </div>
            <% }); %>
        <% } else { %>
            <div class="alert alert-info">
                <i class="bi bi-info-circle"></i> Bu öğrenci için henüz sınav sonucu bulunmamaktadır.
            </div>
        <% } %>
    </div>
</div>

<%- include('partials/footer-dashboard') %>
