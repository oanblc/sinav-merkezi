<%- include('partials/header', {title: 'Hakkımızda', user: typeof user !== 'undefined' ? user : null}) %>

<%- include('partials/common-styles') %>

<style>
    /* Breadcrumb */
    .breadcrumb-container {
        background: #f8f9fa;
        padding: 16px 0;
        margin-bottom: 30px;
        border-bottom: 1px solid #e0e0e0;
    }
    
    .breadcrumb {
        display: flex;
        align-items: center;
        gap: 8px;
        list-style: none;
        padding: 0;
        margin: 0;
        flex-wrap: wrap;
    }
    
    .breadcrumb-item {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 1rem;
    }
    
    .breadcrumb-item a {
        color: var(--primary);
        text-decoration: none;
        transition: all 0.2s ease;
        display: flex;
        align-items: center;
        gap: 6px;
    }
    
    .breadcrumb-item a:hover {
        color: var(--primary-dark);
        text-decoration: underline;
    }
    
    .breadcrumb-item a i {
        font-size: 1rem;
    }
    
    .breadcrumb-separator {
        color: #999;
        font-size: 0.875rem;
    }
    
    .breadcrumb-item.active {
        color: #666;
        font-weight: 500;
    }
    
    /* Hero Section */
    .about-hero {
        background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%);
        color: white;
        padding: clamp(50px, 10vw, 80px) 0;
        margin-bottom: clamp(30px, 6vw, 60px);
        text-align: center;
    }

    .about-hero h1 {
        font-size: clamp(1.5rem, 4vw, 2.5rem);
        font-weight: 800;
        margin-bottom: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 12px;
        flex-wrap: wrap;
    }

    .about-hero h1 i {
        font-size: clamp(1.4rem, 3.5vw, 2.2rem);
    }

    .about-hero p {
        font-size: clamp(0.95rem, 2vw, 1.2rem);
        opacity: 0.95;
        max-width: 700px;
        margin: 0 auto;
        padding: 0 20px;
    }
    
    /* Content Section */
    .about-section {
        padding: clamp(30px, 6vw, 60px) 0;
    }

    .about-section h2 {
        font-size: clamp(1.4rem, 3vw, 2rem);
        font-weight: 700;
        color: var(--primary);
        margin-bottom: clamp(16px, 3vw, 24px);
        display: flex;
        align-items: center;
        gap: 10px;
        flex-wrap: wrap;
    }

    .about-section h2 i {
        font-size: clamp(1.5rem, 3vw, 2.2rem);
    }

    .about-section p {
        font-size: clamp(0.95rem, 2vw, 1.1rem);
        line-height: 1.8;
        color: #666;
        margin-bottom: 20px;
    }
    
    /* Feature Cards */
    .feature-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
        gap: clamp(16px, 3vw, 30px);
        margin-top: clamp(24px, 4vw, 40px);
    }

    .feature-card {
        background: white;
        padding: clamp(20px, 4vw, 32px);
        border-radius: 16px;
        box-shadow: 0 2px 12px rgba(0,0,0,0.06);
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        border: 1px solid #e8ecf0;
    }

    .feature-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 12px 32px rgba(0,59,120,0.12);
        border-color: var(--primary);
    }

    .feature-icon {
        width: clamp(50px, 8vw, 70px);
        height: clamp(50px, 8vw, 70px);
        background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%);
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 16px;
    }

    .feature-icon i {
        font-size: clamp(1.5rem, 3vw, 2rem);
        color: white;
    }

    .feature-card h3 {
        font-size: clamp(1.1rem, 2.5vw, 1.3rem);
        font-weight: 700;
        color: var(--text);
        margin-bottom: 10px;
    }

    .feature-card p {
        font-size: clamp(0.9rem, 1.8vw, 1rem);
        color: #666;
        line-height: 1.7;
        margin: 0;
    }
    
    /* Stats Section */
    .stats-section {
        background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%);
        color: white;
        padding: clamp(40px, 6vw, 60px) 0;
        margin: clamp(30px, 6vw, 60px) 0;
    }

    .stats-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
        gap: clamp(20px, 4vw, 40px);
        text-align: center;
    }

    .stat-item {
        padding: clamp(10px, 2vw, 20px);
    }

    .stat-number {
        font-size: clamp(2rem, 5vw, 3rem);
        font-weight: 900;
        display: block;
        margin-bottom: 6px;
    }

    .stat-label {
        font-size: clamp(0.85rem, 2vw, 1.1rem);
        opacity: 0.9;
        font-weight: 500;
    }
    
    /* Team Section */
    .team-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: clamp(16px, 3vw, 30px);
        margin-top: clamp(24px, 4vw, 40px);
    }

    .team-card {
        background: white;
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 2px 12px rgba(0,0,0,0.06);
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        text-align: center;
        border: 1px solid #e8ecf0;
    }

    .team-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 12px 32px rgba(0,59,120,0.12);
    }

    .team-image {
        width: 100%;
        height: clamp(160px, 25vw, 220px);
        background: linear-gradient(135deg, #e8ecf0 0%, #f8f9fa 100%);
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .team-image i {
        font-size: clamp(3rem, 6vw, 4.5rem);
        color: var(--primary);
        opacity: 0.3;
    }

    .team-info {
        padding: clamp(16px, 3vw, 24px);
    }

    .team-info h4 {
        font-size: clamp(1rem, 2.2vw, 1.2rem);
        font-weight: 700;
        color: var(--text);
        margin-bottom: 6px;
    }

    .team-info p {
        font-size: clamp(0.85rem, 1.8vw, 0.95rem);
        color: #666;
        margin: 0;
    }
    
    /* Vision Mission */
    .vision-mission {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: clamp(20px, 4vw, 40px);
        margin-top: clamp(24px, 4vw, 40px);
    }

    .vm-card {
        background: white;
        padding: clamp(24px, 4vw, 40px);
        border-radius: 16px;
        box-shadow: 0 2px 12px rgba(0,0,0,0.06);
        border-left: 4px solid var(--primary);
    }

    .vm-card h3 {
        font-size: clamp(1.2rem, 2.5vw, 1.5rem);
        font-weight: 700;
        color: var(--primary);
        margin-bottom: 14px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .vm-card h3 i {
        font-size: clamp(1.4rem, 2.5vw, 1.8rem);
    }

    .vm-card p {
        font-size: clamp(0.9rem, 2vw, 1.05rem);
        line-height: 1.8;
        color: #666;
        margin: 0;
    }

    /* Responsive */
    @media (max-width: 768px) {
        .breadcrumb-container {
            padding: 12px 0;
            margin-bottom: 20px;
        }

        .feature-grid {
            grid-template-columns: 1fr;
        }

        .team-grid {
            grid-template-columns: repeat(2, 1fr);
        }

        .vision-mission {
            grid-template-columns: 1fr;
        }
    }

    @media (max-width: 480px) {
        .team-grid {
            grid-template-columns: 1fr;
        }

        .stats-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }
</style>

