<%- include('partials/header', {title: 'Ana Sayfa', user: typeof user !== 'undefined' ? user : null}) %>

<%- include('partials/common-styles') %>
<%- include('partials/index-styles') %>

<!-- Hero Section -->
<section class="hero-section">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-8">
                <div class="hero-content">
                    <h1 class="hero-title">Türkiye'nin Simülasyon Sınav Merkezi</h1>
                    <p class="hero-subtitle">
                        30 yıllık eğitim tecrübesiyle, gerçek sınav ortamında öğrencilerimizi geleceğe hazırlıyoruz.
                        LGS, YKS ve tüm sınavlar için profesyonel deneme sınavları.
                    </p>
                    <div class="mt-4">
                        <a href="/register" class="btn btn-secondary btn-lg me-3">
                            <i class="bi bi-person-plus me-2"></i>Hemen Kayıt Ol
                        </a>
                        <a href="/sinav-paketleri" class="btn btn-outline-light btn-lg">
                            <i class="bi bi-book me-2"></i>Sınav Paketleri
                        </a>
                    </div>
                    <div class="hero-stats">
                        <div class="hero-stat">
                            <span class="hero-stat-number"><%= istatistikler.ogrenci %></span>
                            <span class="hero-stat-label">Aktif Öğrenci</span>
                        </div>
                        <div class="hero-stat">
                            <span class="hero-stat-number"><%= istatistikler.sinav %></span>
                            <span class="hero-stat-label">Yapılan Sınav</span>
                        </div>
                        <div class="hero-stat">
                            <span class="hero-stat-number">30+</span>
                            <span class="hero-stat-label">Yıllık Tecrübe</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Sınav Paketleri -->
<section id="sinavlar" class="section bg-light">
    <div class="container">
        <div class="section-header">
            <h2 class="section-title">Sınav Paketleri</h2>
            <p class="section-subtitle">Size özel hazırlanmış sınav paketlerimiz</p>
            <a href="/sinav-paketleri" class="btn btn-primary mt-3">
                <i class="bi bi-arrow-right-circle me-2"></i>Tümünü Gör
            </a>
        </div>
        
        <% if ((satinAlinabilirSinavlar && satinAlinabilirSinavlar.length > 0) || (typeof sinavPaketleri !== 'undefined' && sinavPaketleri && sinavPaketleri.length > 0)) { %>
        <!-- Sınavlar ve Paketler Grid -->
        <div class="row g-4">
            <% if (typeof sinavPaketleri !== 'undefined' && sinavPaketleri && sinavPaketleri.length > 0) { %>
                <% sinavPaketleri.forEach(function(paket, paketIndex) { %>
                    <div class="col-lg-4 col-md-6">
                        <div class="pricing-card <%= paketIndex === 0 ? 'featured' : '' %>" style="border: 2px solid #06b6d4;">
                            <% if (paketIndex === 0) { %>
                            <div class="pricing-badge" style="background: linear-gradient(135deg, #06b6d4 0%, #3b82f6 100%);">
                                <i class="bi bi-star-fill"></i> Paket
                            </div>
                            <% } %>
                            
                            <div class="pricing-header">
                                <h3 class="pricing-title"><%= paket.ad %></h3>
                                <p class="pricing-subtitle">
                                    <%= paket.aciklama ? (paket.aciklama.length > 80 ? paket.aciklama.substring(0, 80) + '...' : paket.aciklama) : 'Sınav paketi' %>
                                </p>
                            </div>
                            
                            <div class="pricing-price">
                                <span class="price-amount" style="font-size: 1.5rem;"><%= paket.sinav_sayisi || 0 %></span>
                                <span class="price-currency" style="font-size: 1rem;">Sınav</span>
                                <% if (paket.sinif) { %>
                                <div class="price-info">
                                    <i class="bi bi-person-workspace"></i> <%= paket.sinif %>
                                </div>
                                <% } %>
                            </div>
                            
                            <div class="pricing-actions">
                                <a href="/sinav-paketleri" class="pricing-btn primary">
                                    <i class="bi bi-arrow-right-circle"></i>
                                    <span>Detayları Gör</span>
                                </a>
                            </div>
                        </div>
                    </div>
                <% }); %>
            <% } %>
            
            <% if (satinAlinabilirSinavlar && satinAlinabilirSinavlar.length > 0) { %>
                <% satinAlinabilirSinavlar.forEach(function(sinav, sinavIndex) { %>
                    <div class="col-lg-4 col-md-6">
                        <div class="pricing-card <%= sinavIndex === 0 ? 'featured' : '' %>">
                            <% if (sinavIndex === 0) { %>
                            <div class="pricing-badge">
                                <i class="bi bi-star-fill"></i> En Popüler
                            </div>
                            <% } %>
                            
                            <div class="pricing-header">
                                <h3 class="pricing-title"><%= sinav.ad %></h3>
                                <p class="pricing-subtitle">
                                    <%= sinav.aciklama ? (sinav.aciklama.length > 80 ? sinav.aciklama.substring(0, 80) + '...' : sinav.aciklama) : '' %>
                                </p>
                            </div>
                            
                            <div class="pricing-price">
                                <span class="price-amount"><%= sinav.fiyat %></span>
                                <span class="price-currency">₺</span>
                                <% if (sinav.sinif) { %>
                                <div class="price-info">
                                    <i class="bi bi-person-workspace"></i> <%= sinav.sinif %>
                                </div>
                                <% } %>
                                <% if (sinav.ders) { %>
                                <div class="price-info">
                                    <i class="bi bi-book"></i> <%= sinav.ders %>
                                </div>
                                <% } %>
                            </div>
                            
                            <% 
                                // Backend'de parse edilmiş ozellikler geliyor
                                let ozellikler = sinav.ozellikler_parsed || [];
                                if (ozellikler && ozellikler.length > 0) {
                            %>
                            <ul class="pricing-features">
                                <% ozellikler.forEach(function(ozellik) { %>
                                <li>
                                    <i class="bi bi-check-circle-fill"></i>
                                    <span><%= ozellik %></span>
                                </li>
                                <% }); %>
                            </ul>
                            <% } %>
                            
                            <div class="pricing-actions">
                                <a href="/sinav-paketleri" class="pricing-btn primary">
                                    <i class="bi bi-send"></i>
                                    <span>Talep Gönder</span>
                                </a>
                                <a href="/sinav-paketleri" class="pricing-btn secondary">
                                    <i class="bi bi-eye"></i>
                                    <span>Tümünü Gör</span>
                                </a>
                            </div>
                        </div>
                    </div>
                    <% }); %>
                </div>
        <% } else { %>
            <div class="empty-state">
                <i class="bi bi-box-seam"></i>
                <h5>Henüz satın alınabilecek sınav paketi bulunmamaktadır.</h5>
            </div>
        <% } %>
    </div>
</section>

<!-- Özellikler -->
<section class="section">
    <div class="container">
        <div class="section-header">
            <h2 class="section-title">Neden Biz?</h2>
            <p class="section-subtitle">Gerçek sınav deneyimi için profesyonel çözümler</p>
        </div>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="info-card">
                    <div class="info-card-icon">
                        <i class="bi bi-check-circle-fill"></i>
                    </div>
                    <h3 class="info-card-title">Gerçek Sınav Ortamı</h3>
                    <p class="info-card-text">
                        MEB & ÖSYM standartlarında, gerçek sınav koşullarıyla birebir aynı ortamda sınavlar.
                        Giriş belgesinden güvenliğe her detay gerçek gibi.
                    </p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="info-card">
                    <div class="info-card-icon">
                        <i class="bi bi-graph-up-arrow"></i>
                    </div>
                    <h3 class="info-card-title">Detaylı Analizler</h3>
                    <p class="info-card-text">
                        Sınav sonrası detaylı karneler, net analizleri ve branş bazlı performans raporları.
                        Eksiklerinizi görerek başarınızı artırın.
                    </p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="info-card">
                    <div class="info-card-icon">
                        <i class="bi bi-people-fill"></i>
                    </div>
                    <h3 class="info-card-title">Deneyimli Kadro</h3>
                    <p class="info-card-text">
                        30 yıllık eğitim tecrübesi, profesyonel gözetmenler ve uzman ekibimizle
                        yanınızdayız.
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Duyurular -->
<section id="duyurular" class="section bg-light">
    <div class="container">
        <div class="section-header">
            <h2 class="section-title">Duyurular</h2>
            <p class="section-subtitle">En son haberler ve önemli duyurular</p>
            <a href="/duyurular" class="btn btn-primary mt-3">
                <i class="bi bi-arrow-right-circle me-2"></i>Tümünü Gör
            </a>
        </div>
        <div class="row g-3">
            <% if (duyurular && duyurular.length > 0) { %>
                <% duyurular.forEach(function(duyuru) { %>
                <div class="col-12">
                    <div class="content-card" style="overflow: visible;">
                        <div class="content-card-body" style="padding: 24px; display: flex; justify-content: space-between; align-items: center;">
                            <div style="flex: 1;">
                                <h5 class="content-card-title mb-2" style="font-size: 1.2rem;"><%= duyuru.baslik %></h5>
                                <p class="content-card-text mb-0">
                                    <%= duyuru.icerik %>
                                </p>
                            </div>
                            <% if (duyuru.tarih) { %>
                            <div class="content-card-meta ms-3" style="white-space: nowrap;">
                                <span><i class="bi bi-calendar-event"></i> <%= new Date(duyuru.tarih).toLocaleDateString('tr-TR') %></span>
                            </div>
                            <% } %>
                        </div>
                    </div>
                </div>
                <% }); %>
            <% } else { %>
                <div class="col-12">
                    <div class="empty-state">
                        <i class="bi bi-megaphone"></i>
                        <h5>Henüz duyuru bulunmamaktadır.</h5>
                    </div>
                </div>
            <% } %>
        </div>
    </div>
</section>

<!-- CTA Section -->
<section class="cta-section">
    <div class="container">
        <div class="cta-content">
            <h2 class="cta-title">Başarınız İçin Yanınızdayız</h2>
            <p class="cta-text">
                Hemen kaydolun ve gerçek sınav deneyimini yaşayın.
                30 yıllık tecrübemizle öğrencilerimizi başarıya taşıyoruz.
            </p>
            <a href="/register" class="btn btn-secondary btn-lg me-3">
                <i class="bi bi-person-plus me-2"></i>Ücretsiz Kayıt Ol
            </a>
            <a href="/login" class="btn btn-outline-light btn-lg">
                <i class="bi bi-box-arrow-in-right me-2"></i>Giriş Yap
            </a>
        </div>
    </div>
</section>

<%- include('partials/footer') %>

<script>
    // Exam Category Tab Navigation
    document.addEventListener('DOMContentLoaded', function() {
        const categoryBtns = document.querySelectorAll('.exam-category-btn');
        const categoryContents = document.querySelectorAll('.exam-category-content');
        
        categoryBtns.forEach(btn => {
            btn.addEventListener('click', function() {
                const category = this.getAttribute('data-category');
                
                // Remove active class from all buttons
                categoryBtns.forEach(b => b.classList.remove('active'));
                // Add active class to clicked button
                this.classList.add('active');
                
                // Hide all contents
                categoryContents.forEach(content => content.classList.remove('active'));
                // Show selected content
                const selectedContent = document.querySelector(`.exam-category-content[data-category="${category}"]`);
                if (selectedContent) {
                    selectedContent.classList.add('active');
                }
            });
        });
    });

    // Smooth scrolling for anchor links
    document.querySelectorAll('a[href^="#"]').forEach(anchor => {
        anchor.addEventListener('click', function (e) {
            e.preventDefault();
            const target = document.querySelector(this.getAttribute('href'));
            if (target) {
                target.scrollIntoView({
                    behavior: 'smooth',
                    block: 'start'
                });
            }
        });
    });
</script>
