<%- include('partials/header', {title: 'Cevap Anahtarları', user: typeof user !== 'undefined' ? user : null}) %>

<%- include('partials/common-styles') %>

<style>
    /* Breadcrumb */
    .breadcrumb-container {
        background: #f8f9fa;
        padding: 16px 0;
        border-bottom: 1px solid #e0e0e0;
    }
    
    .breadcrumb {
        display: flex;
        align-items: center;
        gap: 8px;
        list-style: none;
        padding: 0;
        margin: 0;
        flex-wrap: wrap;
    }
    
    .breadcrumb-item {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 1rem;
    }
    
    .breadcrumb-item a {
        color: var(--primary);
        text-decoration: none;
        transition: all 0.2s ease;
        display: flex;
        align-items: center;
        gap: 6px;
    }
    
    .breadcrumb-item a:hover {
        color: var(--primary-dark);
        text-decoration: underline;
    }
    
    .breadcrumb-item a i {
        font-size: 1rem;
    }
    
    .breadcrumb-separator {
        color: #999;
        font-size: 0.875rem;
    }
    
    .breadcrumb-item.active {
        color: #666;
        font-weight: 500;
    }
    
    /* Page Header */
    .page-header {
        background: transparent;
        padding: 30px 0 20px;
        margin-bottom: 30px;
    }
    
    .page-header h1 {
        font-size: 2rem;
        font-weight: 800;
        margin-bottom: 6px;
        color: #1e293b;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .page-header h1 i {
        color: #003b78;
        font-size: 1.75rem;
    }

    .page-header p {
        font-size: 1rem;
        color: #64748b;
        margin: 0;
    }
    
    /* Class Filter Tabs */
    .class-filter {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        justify-content: center;
        margin-bottom: 40px;
        padding: 0;
    }
    
    .class-btn {
        background: white;
        border: 2px solid #e8ecf0;
        border-radius: 16px;
        padding: 16px 32px;
        font-size: 1rem;
        font-weight: 600;
        color: var(--text);
        text-decoration: none;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        display: flex;
        align-items: center;
        gap: 10px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.04);
    }
    
    .class-btn i {
        font-size: 1.25rem;
        transition: transform 0.3s ease;
    }
    
    .class-btn:hover {
        background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%);
        color: white;
        border-color: var(--primary);
        transform: translateY(-2px);
        box-shadow: 0 8px 24px rgba(0, 59, 120, 0.2);
    }
    
    .class-btn:hover i {
        transform: scale(1.1);
    }
    
    .class-btn.active {
        background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%);
        color: white;
        border-color: var(--primary);
        box-shadow: 0 8px 24px rgba(0, 59, 120, 0.25);
    }
    
    /* Answer Container */
    .answer-container {
        margin-bottom: 40px;
    }
    
    .answer-header {
        background: white;
        padding: 20px;
        border-radius: 8px 8px 0 0;
        border: 1px solid #e0e0e0;
        border-bottom: none;
    }
    
    .answer-header h3 {
        font-size: 1.25rem;
        font-weight: 700;
        color: var(--primary);
        margin: 0;
        display: flex;
        align-items: center;
        gap: 10px;
    }
    
    .answer-header i {
        font-size: 1.5rem;
    }
    
    /* Answer List Styles */
    .answer-list {
        background: white;
        border: 1px solid #e0e0e0;
        border-radius: 0 0 8px 8px;
    }
    
    .answer-item {
        padding: 20px;
        margin-bottom: 12px;
        background: #f8f9fa;
        border-radius: 8px;
        border: 1px solid #e8e8e8;
        transition: all 0.2s ease;
    }
    
    .answer-item:last-child {
        margin-bottom: 0;
    }
    
    .answer-item:hover {
        background: #e9ecef;
        border-color: var(--primary);
        box-shadow: 0 2px 8px rgba(0,0,0,0.08);
    }
    
    /* Row 1: Number, Type, Name, Status */
    .answer-row-1 {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        margin-bottom: 12px;
    }
    
    .answer-left {
        display: flex;
        align-items: center;
        gap: 12px;
        flex: 1;
    }
    
    .answer-number {
        background: var(--primary);
        color: white;
        width: 28px;
        height: 28px;
        border-radius: 6px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: 0.875rem;
        flex-shrink: 0;
    }
    
    .answer-type {
        display: inline-block;
        background: var(--primary);
        color: white;
        padding: 4px 10px;
        border-radius: 4px;
        font-weight: 600;
        font-size: 0.75rem;
        flex-shrink: 0;
    }
    
    .answer-name {
        font-size: 1rem;
        font-weight: 600;
        color: var(--text);
        margin: 0;
    }
    
    /* Row 2: Date and Actions */
    .answer-row-2 {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        flex-wrap: wrap;
    }
    
    .answer-date {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 0.875rem;
        flex: 1;
    }
    
    .answer-date i {
        color: var(--primary);
        font-size: 1rem;
    }
    
    .answer-date-label {
        color: #999;
        font-size: 0.875rem;
    }
    
    .answer-date-value {
        color: var(--text);
        font-weight: 600;
    }
    
    .status-badge {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 6px 12px;
        border-radius: 6px;
        font-weight: 600;
        font-size: 0.875rem;
        white-space: nowrap;
    }
    
    .status-published {
        background: #d4edda;
        color: #155724;
    }
    
    .status-pending {
        background: #fff3cd;
        color: #856404;
    }
    
    .answer-actions {
        display: flex;
        align-items: center;
        gap: 8px;
        flex-shrink: 0;
    }
    
    .action-btn {
        background: var(--secondary);
        color: white;
        border: none;
        padding: 6px 12px;
        border-radius: 6px;
        font-weight: 600;
        font-size: 0.875rem;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        transition: all 0.2s ease;
        white-space: nowrap;
    }
    
    .action-btn:hover {
        background: #e67e22;
        color: white;
        transform: translateY(-1px);
        box-shadow: 0 4px 12px rgba(243, 156, 18, 0.3);
    }
    
    .action-btn i {
        font-size: 0.875rem;
    }
    
    .action-btn.success {
        background: #27ae60;
    }
    
    .action-btn.success:hover {
        background: #229954;
    }
    
    /* Empty State */
    .empty-state {
        text-align: center;
        padding: 60px 20px;
        background: white;
        border: 1px solid #e0e0e0;
        border-radius: 0 0 8px 8px;
        color: #999;
    }
    
    .empty-state i {
        font-size: 3rem;
        margin-bottom: 16px;
        opacity: 0.4;
        color: #999;
    }
    
    .empty-state h5 {
        color: #666;
        font-weight: 600;
        margin-bottom: 8px;
    }
    
    .empty-state p {
        color: #999;
        font-size: 1rem;
    }
    
    /* Compact Filter Bar */
    .filter-bar {
        background: white;
        border-radius: 50px;
        padding: 8px 16px;
        margin-bottom: 24px;
        box-shadow: 0 2px 12px rgba(0,0,0,0.06);
        border: 1px solid #e8ecf0;
        display: flex;
        align-items: center;
        gap: 10px;
        flex-wrap: wrap;
    }

    .filter-bar .filter-input {
        flex: 1;
        min-width: 120px;
        position: relative;
    }

    .filter-bar .form-control,
    .filter-bar .form-select {
        border: none;
        border-radius: 25px;
        padding: 10px 16px 10px 38px;
        font-size: 0.875rem;
        background: #f8fafc;
        height: 42px;
        width: 100%;
    }

    .filter-bar .form-control:focus,
    .filter-bar .form-select:focus {
        background: #f0f4ff;
        box-shadow: none;
        outline: none;
    }

    .filter-bar .filter-icon {
        position: absolute;
        left: 14px;
        top: 50%;
        transform: translateY(-50%);
        color: var(--primary);
        font-size: 1rem;
        pointer-events: none;
        z-index: 1;
    }

    .filter-bar .btn-clear {
        background: none;
        border: none;
        color: #94a3b8;
        padding: 8px 12px;
        border-radius: 20px;
        font-size: 0.875rem;
        cursor: pointer;
        display: none;
    }

    .filter-bar .btn-clear:hover {
        color: var(--primary);
        background: #f0f4ff;
    }

    .filter-bar.has-filters {
        border-color: var(--primary);
    }

    .filter-bar.has-filters .btn-clear {
        display: flex;
        align-items: center;
        gap: 4px;
    }

    /* Responsive */
    @media (max-width: 768px) {
        .filter-bar {
            border-radius: 16px;
            padding: 10px;
        }

        .filter-bar .filter-input {
            flex: 1 1 calc(50% - 5px);
            min-width: unset;
        }

        .filter-bar .filter-input:first-child {
            flex: 1 1 100%;
        }

        .filter-bar .form-control,
        .filter-bar .form-select {
            height: 40px;
            font-size: 0.875rem;
        }

        .filter-bar .btn-clear {
            flex: 1 1 100%;
            justify-content: center;
        }
    }
    
    @media (max-width: 768px) {
        .breadcrumb-container {
            padding: 12px 0;
        }
        
        .breadcrumb {
            font-size: 0.875rem;
        }
        
        .breadcrumb-item a i {
            font-size: 0.875rem;
        }
        
        .page-header {
            padding: 20px 0 15px;
        }
        
        .page-header h1 {
            font-size: 1.5rem;
            gap: 8px;
        }
        
        .page-header h1 i {
            font-size: 1.5rem;
        }
        
        .page-header p {
            font-size: 0.875rem;
        }
        
        .class-filter {
            gap: 8px;
        }
        
        .class-btn {
            padding: 12px 20px;
            font-size: 0.875rem;
            border-radius: 12px;
        }
        
        .class-btn i {
            font-size: 1rem;
        }
        
        .answer-header {
            padding: 16px;
        }
        
        .answer-header h3 {
            font-size: 1.125rem;
        }
        
        .answer-item {
            padding: 16px;
        }
        
        .answer-row-1 {
            flex-wrap: wrap;
        }
        
        .answer-left {
            flex-wrap: wrap;
        }
        
        .answer-name {
            font-size: 1rem;
        }
        
        .answer-row-2 {
            flex-direction: column;
            align-items: flex-start;
            gap: 12px;
        }
        
        .answer-date {
            width: 100%;
        }
        
        .answer-actions {
            width: 100%;
            justify-content: flex-start;
        }
        
        .status-badge {
            font-size: 0.75rem;
            padding: 5px 10px;
        }
        
        .action-btn {
            font-size: 0.75rem;
            padding: 5px 10px;
        }
    }
</style>

<!-- Breadcrumb -->
<div class="breadcrumb-container">
    <div class="container">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item">
                    <a href="/">
                        <i class="bi bi-house-door"></i>
                        Ana Sayfa
                    </a>
                </li>
                <li class="breadcrumb-separator">
                    <i class="bi bi-chevron-right"></i>
                </li>
                <li class="breadcrumb-item active" aria-current="page">
                    Cevap Anahtarları
                </li>
            </ol>
        </nav>
    </div>
</div>

<!-- Page Header -->
<div class="page-header">
    <div class="container">
        <h1>
            <i class="bi bi-file-earmark-text"></i>
            Cevap Anahtarları
        </h1>
        <p>Sınav cevap anahtarlarını ve sonuçlarınızı görüntüleyin</p>
    </div>
</div>

<!-- Main Content -->
<div class="container" style="margin-bottom: 60px;">
    
    <!-- Kompakt Filtre Cubugu -->
    <div class="filter-bar" id="filterBar">
        <div class="filter-input" style="flex: 2; min-width: 150px;">
            <i class="bi bi-search filter-icon"></i>
            <input type="text" id="aramaInput" class="form-control" placeholder="Cevap anahtarı ara...">
        </div>

        <div class="filter-input" style="flex: 1; min-width: 110px;">
            <i class="bi bi-mortarboard filter-icon"></i>
            <select id="sinifFilter" class="form-select">
                <option value="">Sınıf</option>
                <option value="1">1</option>
                <option value="2">2</option>
                <option value="3">3</option>
                <option value="4">4</option>
                <option value="5">5</option>
                <option value="6">6</option>
                <option value="7">7</option>
                <option value="8">8</option>
                <option value="9">9</option>
                <option value="10">10</option>
                <option value="11">11</option>
                <option value="12">12</option>
                <option value="Mezun">Mezun</option>
            </select>
        </div>

        <div class="filter-input" style="flex: 1; min-width: 130px;">
            <i class="bi bi-calendar-event filter-icon"></i>
            <input type="date" id="sinavTarih" class="form-control">
        </div>

        <button class="btn-clear" onclick="filtreleriTemizle()" id="clearBtn">
            <i class="bi bi-x-circle"></i>
            Temizle
        </button>
    </div>

    <!-- Answer Keys -->
    <div class="answer-container">
        <div class="answer-header">
            <h3>
                <i class="bi bi-journal-text"></i>
                Cevap Anahtarları
            </h3>
        </div>
        
        <% if (sinavlar && sinavlar.length > 0) { %>
        <div class="answer-list">
            <% sinavlar.forEach(function(sinav, index) { 
                const sinavTarihi = new Date(sinav.tarih);
                // Sınıf numarasını çıkar (örn: "10. Sınıf" -> "10")
                const sinifNumara = sinav.sinif ? sinav.sinif.match(/\d+/) : null;
            %>
            <div class="answer-item" 
                 data-sinif="<%= sinifNumara ? sinifNumara[0] : '' %>" 
                 data-tarih="<%= sinav.tarih %>" 
                 data-ad="<%= sinav.ad.toLowerCase() %>">
                <!-- Row 1: Name, Class, Status -->
                <div class="answer-row-1">
                    <div class="answer-left">
                        <span class="answer-name"><%= sinav.ad %></span>
                        <% if (sinav.sinif) { 
                            // Sınıf numarasını formatla
                            const sinifText = sinav.sinif.includes('Sınıf') || sinav.sinif.includes('Mezun') 
                                ? sinav.sinif 
                                : sinav.sinif + '. Sınıf';
                        %>
                        <span class="answer-type"><%= sinifText %></span>
                        <% } %>
                    </div>
                    
                    <% if (sinav.sinav_durumu) { %>
                    <span class="status-badge status-published">
                        <i class="bi bi-check-circle-fill"></i>
                        <%= sinav.sinav_durumu %>
                    </span>
                    <% } %>
                </div>
                
                <!-- Row 2: Date and Action Buttons -->
                <div class="answer-row-2">
                    <div class="answer-date">
                        <i class="bi bi-calendar-event"></i>
                        <span class="answer-date-label">Sınav Tarihi:</span>
                        <span class="answer-date-value">
                            <%= sinavTarihi.toLocaleDateString('tr-TR', { day: 'numeric', month: 'long', year: 'numeric' }) %>
                        </span>
                    </div>
                    
                    <div class="answer-actions">
                        <a href="/<%= sinav.cevap_anahtari_pdf %>" target="_blank" class="action-btn">
                            <i class="bi bi-file-earmark-text"></i>
                            Cevap Anahtarı
                        </a>
                    </div>
                </div>
            </div>
            <% }); %>
        </div>
        <% } else { %>
        <div class="empty-state">
            <i class="bi bi-file-earmark-x"></i>
            <h5>Henüz cevap anahtarı yayınlanmamıştır.</h5>
            <p>Cevap anahtarları sınav sonrasında burada yayınlanacaktır.</p>
        </div>
        <% } %>
    </div>
</div>

<%- include('partials/footer') %>

<script>
    // Filtreleme fonksiyonu
    function filtrele() {
        const sinifFilter = document.getElementById('sinifFilter').value;
        const sinavTarih = document.getElementById('sinavTarih').value;
        const aramaText = document.getElementById('aramaInput').value.toLowerCase().trim();

        const items = document.querySelectorAll('.answer-item');
        const filterBar = document.getElementById('filterBar');
        let gorunenSayisi = 0;

        // Filtre aktif mi kontrol et
        const hasFilters = sinifFilter || sinavTarih || aramaText;
        if (hasFilters) {
            filterBar.classList.add('has-filters');
        } else {
            filterBar.classList.remove('has-filters');
        }
        
        items.forEach(item => {
            const itemSinif = item.dataset.sinif;
            const itemTarih = item.dataset.tarih;
            const itemAd = item.dataset.ad;
            
            // Sınıf filtresi
            let sinifEslesti = true;
            if (sinifFilter) {
                sinifEslesti = itemSinif === sinifFilter || 
                              (sinifFilter === 'Mezun' && itemSinif.includes('Mezun'));
            }
            
            // Tarih filtresi (tam eşleşme)
            let tarihEslesti = true;
            if (sinavTarih && itemTarih) {
                tarihEslesti = itemTarih === sinavTarih;
            }
            
            // Arama filtresi
            let aramaEslesti = true;
            if (aramaText) {
                aramaEslesti = itemAd.includes(aramaText);
            }
            
            // Tüm filtreler eşleşti mi?
            if (sinifEslesti && tarihEslesti && aramaEslesti) {
                item.style.display = 'block';
                gorunenSayisi++;
            } else {
                item.style.display = 'none';
            }
        });
        
        // Hiç sonuç yoksa boş state göster
        const answerList = document.querySelector('.answer-list');
        const emptyState = document.querySelector('.empty-state');
        
        if (gorunenSayisi === 0 && answerList) {
            answerList.style.display = 'none';
            if (emptyState) {
                emptyState.style.display = 'block';
                emptyState.querySelector('h5').textContent = 'Filtreye uygun cevap anahtarı bulunamadı.';
            }
        } else if (answerList) {
            answerList.style.display = 'block';
            if (emptyState) {
                emptyState.style.display = 'none';
            }
        }
    }
    
    // Filtreleri temizle
    function filtreleriTemizle() {
        document.getElementById('sinifFilter').value = '';
        document.getElementById('sinavTarih').value = '';
        document.getElementById('aramaInput').value = '';
        filtrele();
    }
    
    // Event listener'lar
    document.getElementById('sinifFilter').addEventListener('change', filtrele);
    document.getElementById('sinavTarih').addEventListener('change', filtrele);
    document.getElementById('aramaInput').addEventListener('input', filtrele);
    
    // Smooth scroll
    document.querySelectorAll('a[href^="#"]').forEach(anchor => {
        anchor.addEventListener('click', function (e) {
            e.preventDefault();
            const target = document.querySelector(this.getAttribute('href'));
            if (target) {
                target.scrollIntoView({
                    behavior: 'smooth',
                    block: 'start'
                });
            }
        });
    });
</script>

