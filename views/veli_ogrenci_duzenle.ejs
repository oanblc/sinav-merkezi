<%- include('partials/header-dashboard', { title: 'Öğrenci Düzenle - Sınav Merkezi', user: user }) %>
<%- include('partials/veli-panel-styles') %>

<style>
    /* Sayfa Header - Turuncu tema */
    .vp-edit-header {
        background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);
        color: white;
        padding: clamp(16px, 4vw, 24px) 0;
        margin: -20px -12px clamp(16px, 4vw, 24px);
        border-radius: 0 0 var(--vp-radius-lg) var(--vp-radius-lg);
    }

    .vp-edit-header h2 {
        font-size: clamp(1.1rem, 4vw, 1.4rem);
        font-weight: 700;
        margin-bottom: 4px;
    }

    .vp-edit-header p {
        font-size: clamp(0.85rem, 3vw, 0.95rem);
        opacity: 0.9;
        margin: 0;
    }

    /* Ogrenci No Karti */
    .vp-student-no-card {
        background: linear-gradient(135deg, #dbeafe 0%, #bfdbfe 100%);
        border: 2px solid #93c5fd;
        border-radius: var(--vp-radius);
        padding: clamp(12px, 3vw, 16px);
        margin-bottom: 16px;
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .vp-student-no-card i {
        font-size: clamp(1.5rem, 5vw, 2rem);
        color: #1e40af;
    }

    .vp-student-no-card .label {
        font-weight: 700;
        color: #1e40af;
        font-size: clamp(0.75rem, 2.8vw, 0.85rem);
    }

    .vp-student-no-card .value {
        font-size: clamp(1rem, 4vw, 1.3rem);
        font-weight: 800;
        color: #1e40af;
        font-family: monospace;
    }

    /* Rehber Ogretmen Karti */
    .vp-teacher-card {
        background: white;
        border: 1px solid var(--vp-border);
        border-radius: var(--vp-radius);
        padding: clamp(12px, 3vw, 16px);
        margin-bottom: 12px;
    }

    .vp-teacher-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 8px;
        margin-bottom: 8px;
    }

    .vp-teacher-name {
        font-weight: 700;
        color: var(--vp-text);
        font-size: clamp(0.9rem, 3.2vw, 1rem);
    }

    .vp-teacher-branch {
        color: #3b82f6;
        font-weight: 600;
        font-size: clamp(0.75rem, 2.8vw, 0.85rem);
    }

    .vp-teacher-info {
        font-size: clamp(0.75rem, 2.8vw, 0.85rem);
        color: var(--vp-text-muted);
        margin-bottom: 10px;
    }

    /* Yetki Durumu Kutusu */
    .vp-permission-box {
        padding: 10px;
        border-radius: 8px;
        font-size: clamp(0.75rem, 2.8vw, 0.85rem);
    }

    .vp-permission-active {
        background: #f0fdf4;
        border: 2px solid #86efac;
    }

    .vp-permission-inactive {
        background: #fef2f2;
        border: 2px solid #fecaca;
    }

    /* Info Box Sari */
    .vp-info-yellow {
        background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%);
        border: 2px solid #fbbf24;
        border-radius: var(--vp-radius);
        padding: clamp(14px, 3vw, 20px);
        margin-bottom: 16px;
    }

    .vp-info-yellow h5 {
        color: #92400e;
        font-weight: 700;
        font-size: clamp(0.9rem, 3.2vw, 1rem);
        margin-bottom: 8px;
    }

    .vp-info-yellow p {
        color: #92400e;
        margin: 0;
        font-size: clamp(0.8rem, 3vw, 0.9rem);
    }

    /* Mor Header */
    .vp-purple-header {
        background: linear-gradient(135deg, #003b78 0%, #2563eb 100%);
        color: white;
        padding: clamp(14px, 3vw, 20px);
        border-radius: var(--vp-radius) var(--vp-radius) 0 0;
    }

    .vp-purple-header h5 {
        font-weight: 700;
        margin: 0;
        font-size: clamp(0.9rem, 3.2vw, 1rem);
    }
</style>

<!-- Page Header -->
<div class="vp-edit-header">
    <div class="container">
        <h2><i class="bi bi-pencil-square"></i> Öğrenci Düzenle</h2>
        <p>Öğrenci bilgilerini güncelleyin</p>
    </div>
</div>

<div class="container">
    <% if (error) { %>
    <div class="alert alert-danger alert-dismissible fade show" role="alert" style="border-radius: var(--vp-radius); font-size: 0.875rem;">
        <i class="bi bi-exclamation-triangle"></i> <%= error %>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
    <% } %>

    <% if (success) { %>
    <div class="alert alert-success alert-dismissible fade show" role="alert" style="border-radius: var(--vp-radius); font-size: 0.875rem;">
        <i class="bi bi-check-circle"></i> <%= success %>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
    <% } %>

    <div class="row">
        <!-- Mobilde bilgi kartlari uste cikar -->
        <div class="col-lg-4 order-lg-2 mb-4">
            <!-- Rehber Ogretmenler -->
            <div class="vp-card" style="padding: 0; overflow: hidden;">
                <div class="vp-purple-header">
                    <h5><i class="bi bi-people-fill"></i> Rehber Öğretmenler</h5>
                </div>
                <div style="padding: clamp(14px, 3vw, 20px);">
                    <% if (rehberOgretmenler && rehberOgretmenler.length > 0) { %>
                        <% rehberOgretmenler.forEach(function(ogretmen) { %>
                        <div class="vp-teacher-card" id="ogretmen-<%= ogretmen.talep_id %>">
                            <div class="vp-teacher-header">
                                <div>
                                    <div class="vp-teacher-name"><%= ogretmen.ad_soyad %></div>
                                    <div class="vp-teacher-branch">
                                        <i class="bi bi-bookmark-fill"></i> <%= ogretmen.brans %>
                                    </div>
                                </div>
                                <button onclick="yetkiKaldir(<%= ogretmen.talep_id %>)"
                                        class="vp-btn vp-btn-danger vp-btn-sm" style="padding: 6px 10px;">
                                    <i class="bi bi-x-circle"></i>
                                </button>
                            </div>
                            <div class="vp-teacher-info">
                                <div><i class="bi bi-building"></i> <%= ogretmen.kurum %></div>
                                <% if (ogretmen.telefon) { %>
                                <div><i class="bi bi-telephone"></i> <%= ogretmen.telefon %></div>
                                <% } %>
                            </div>

                            <!-- Yetki Durumu -->
                            <div class="vp-permission-box <%= ogretmen.sonuc_goruntuleme_aktif == 1 ? 'vp-permission-active' : 'vp-permission-inactive' %>">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <i class="bi bi-<%= ogretmen.sonuc_goruntuleme_aktif == 1 ? 'eye-fill' : 'eye-slash-fill' %>"
                                           style="color: <%= ogretmen.sonuc_goruntuleme_aktif == 1 ? '#16a34a' : '#dc2626' %>"></i>
                                        <strong style="color: <%= ogretmen.sonuc_goruntuleme_aktif == 1 ? '#16a34a' : '#dc2626' %>;">
                                            Sonuçlar <%= ogretmen.sonuc_goruntuleme_aktif == 1 ? 'Aktif' : 'Pasif' %>
                                        </strong>
                                    </div>
                                </div>
                                <div style="font-size: 0.75rem; color: #64748b; margin-top: 4px;">
                                    Kurum yöneticisi tarafından yönetilir
                                </div>
                            </div>
                        </div>
                        <% }); %>
                    <% } else { %>
                        <div class="text-center" style="padding: 24px 12px; color: #94a3b8;">
                            <i class="bi bi-person-x" style="font-size: 2.5rem; margin-bottom: 8px; display: block;"></i>
                            <div style="font-weight: 600; font-size: 0.875rem;">Henüz rehber öğretmen yok</div>
                        </div>
                    <% } %>
                </div>
            </div>

            <div class="vp-info-yellow">
                <h5><i class="bi bi-exclamation-triangle-fill"></i> Dikkat</h5>
                <p>Öğrenci bilgilerini güncelledikten sonra sınav sonuçları etkilenmeyecektir.</p>
            </div>
        </div>

        <!-- Form -->
        <div class="col-lg-8 order-lg-1">
            <!-- Ogrenci No -->
            <% if (ogrenci.ogrenci_no) { %>
            <div class="vp-student-no-card">
                <i class="bi bi-person-badge"></i>
                <div>
                    <div class="label">Öğrenci Numarası</div>
                    <div class="value"><%= ogrenci.ogrenci_no %></div>
                </div>
            </div>
            <% } %>

            <div class="vp-card">
                <form method="POST" action="/veli/ogrenci-duzenle/<%= ogrenci.id %>">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="vp-form-group">
                                <label><i class="bi bi-person"></i> Öğrenci Adı Soyadı *</label>
                                <input type="text" name="ad_soyad" class="vp-form-control"
                                       value="<%= ogrenci.ad_soyad %>" placeholder="Orn: Ahmet Yilmaz" required>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="vp-form-group">
                                <label><i class="bi bi-card-text"></i> T.C. Kimlik No</label>
                                <input type="text" name="tc_no" class="vp-form-control"
                                       value="<%= ogrenci.tc_no || '' %>" placeholder="11 haneli TC No" maxlength="11">
                                <small style="color: var(--vp-text-muted); font-size: 0.75rem;">Opsiyonel</small>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="vp-form-group">
                                <label><i class="bi bi-phone"></i> Öğrenci Cep Telefonu</label>
                                <input type="tel" name="telefon" class="vp-form-control"
                                       value="<%= ogrenci.telefon || '' %>" placeholder="0555 555 55 55">
                                <small style="color: var(--vp-text-muted); font-size: 0.75rem;">Opsiyonel</small>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="vp-form-group">
                                <label><i class="bi bi-building"></i> Okul / Mezun Bilgisi *</label>
                                <input type="text" name="okul" class="vp-form-control"
                                       value="<%= ogrenci.okul || '' %>" placeholder="Orn: Ataturk Lisesi" required>
                            </div>
                        </div>

                        <div class="col-12">
                            <div class="vp-form-group">
                                <label><i class="bi bi-book"></i> Sınıf *</label>
                                <select name="sinif" class="vp-form-control" required>
                                    <option value="">Seçiniz...</option>
                                    <option value="9. Sinif" <%= ogrenci.sinif === '9. Sınıf' || ogrenci.sinif === '9. Sinif' ? 'selected' : '' %>>9. Sınıf</option>
                                    <option value="10. Sinif" <%= ogrenci.sinif === '10. Sınıf' || ogrenci.sinif === '10. Sinif' ? 'selected' : '' %>>10. Sınıf</option>
                                    <option value="11. Sinif" <%= ogrenci.sinif === '11. Sınıf' || ogrenci.sinif === '11. Sinif' ? 'selected' : '' %>>11. Sınıf</option>
                                    <option value="12. Sinif" <%= ogrenci.sinif === '12. Sınıf' || ogrenci.sinif === '12. Sinif' ? 'selected' : '' %>>12. Sınıf</option>
                                    <option value="Mezun" <%= ogrenci.sinif === 'Mezun' ? 'selected' : '' %>>Mezun</option>
                                </select>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex gap-2 flex-wrap mt-3">
                        <button type="submit" class="vp-btn vp-btn-warning flex-grow-1">
                            <i class="bi bi-check-circle"></i> Degisiklikleri Kaydet
                        </button>
                        <a href="/veli/dashboard" class="vp-btn vp-btn-secondary">
                            <i class="bi bi-arrow-left"></i> Iptal
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Onay Modali -->
<div class="modal fade" id="confirmModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border: none; border-radius: var(--vp-radius-lg); overflow: hidden;">
            <div class="modal-body text-center" style="padding: clamp(24px, 6vw, 48px) clamp(16px, 4vw, 32px);">
                <div style="width: 60px; height: 60px; background: var(--vp-danger);
                            border-radius: 50%; margin: 0 auto 16px; display: flex; align-items: center; justify-content: center;">
                    <i class="bi bi-exclamation-triangle" style="font-size: 2rem; color: white;"></i>
                </div>

                <h4 style="font-weight: 700; color: var(--vp-text); margin-bottom: 12px; font-size: clamp(1rem, 4vw, 1.2rem);">Yetkiyi Kaldir</h4>
                <p id="confirmMessage" style="color: var(--vp-text-muted); font-size: clamp(0.85rem, 3vw, 1rem); margin-bottom: 20px;">
                    Bu rehber öğretmenin yetkisini kaldirmak istediginize emin misiniz?
                </p>

                <div class="d-flex gap-2 justify-content-center flex-wrap">
                    <button type="button" class="vp-btn vp-btn-secondary" data-bs-dismiss="modal">Iptal</button>
                    <button type="button" class="vp-btn vp-btn-danger" id="confirmButton">Yetkiyi Kaldir</button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Basari Modali -->
<div class="modal fade" id="successModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border: none; border-radius: var(--vp-radius-lg); overflow: hidden;">
            <div class="modal-body text-center" style="padding: clamp(24px, 6vw, 48px) clamp(16px, 4vw, 32px);">
                <div style="width: 60px; height: 60px; background: var(--vp-success);
                            border-radius: 50%; margin: 0 auto 16px; display: flex; align-items: center; justify-content: center;">
                    <i class="bi bi-check-lg" style="font-size: 2rem; color: white;"></i>
                </div>

                <h4 style="font-weight: 700; color: var(--vp-text); margin-bottom: 12px; font-size: clamp(1rem, 4vw, 1.2rem);">Işlem Başarılı!</h4>
                <p id="successMessage" style="color: var(--vp-text-muted); font-size: clamp(0.85rem, 3vw, 1rem); margin-bottom: 20px;">
                    Rehber öğretmen yetkisi kaldirildi!
                </p>

                <button type="button" class="vp-btn vp-btn-success" data-bs-dismiss="modal">Tamam</button>
            </div>
        </div>
    </div>
</div>

<script>
let currentTalepId = null;

function yetkiKaldir(talepId) {
    currentTalepId = talepId;
    const confirmModalEl = document.getElementById('confirmModal');
    const confirmModal = new bootstrap.Modal(confirmModalEl);
    confirmModal.show();
}

document.addEventListener('DOMContentLoaded', function() {
    const confirmButton = document.getElementById('confirmButton');
    if (confirmButton) {
        confirmButton.addEventListener('click', function() {
            if (currentTalepId) {
                const confirmModalEl = document.getElementById('confirmModal');
                const confirmModal = bootstrap.Modal.getInstance(confirmModalEl);
                if (confirmModal) {
                    confirmModal.hide();
                }
                yetkiKaldirOnay(currentTalepId);
            }
        });
    }
});

function yetkiKaldirOnay(talepId) {
    fetch('/veli/rehber-yetki-kaldir/' + talepId, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' }
    })
    .then(res => res.json())
    .then(data => {
        if (data.success) {
            const ogretmenDiv = document.getElementById('ogretmen-' + talepId);
            if (ogretmenDiv) {
                ogretmenDiv.style.transition = 'all 0.3s ease';
                ogretmenDiv.style.opacity = '0';
                setTimeout(() => {
                    ogretmenDiv.remove();
                    const container = document.querySelector('.vp-purple-header').parentElement.querySelector('div:last-child');
                    if (container && container.querySelectorAll('.vp-teacher-card').length === 0) {
                        location.reload();
                    }
                }, 300);
            }

            const successMessageEl = document.getElementById('successMessage');
            const successModalEl = document.getElementById('successModal');
            if (successMessageEl && successModalEl) {
                successMessageEl.textContent = data.message;
                const modal = new bootstrap.Modal(successModalEl);
                modal.show();
            }
        } else {
            alert(data.message || 'Bir hata olustu!');
        }
    })
    .catch(error => {
        alert('Baglanti hatasi: ' + error.message);
    });
}
</script>

<%- include('partials/footer-dashboard') %>
