<%- include('../partials/header-dashboard', { title: 'Sınav Sonuçları - Veli Paneli', user: user, activePage: 'sonuclar' }) %>
<%- include('../partials/veli-panel-styles') %>

<style>
    /* Indigo tema header */
    .vp-sonuc-header {
        background: linear-gradient(135deg, #6366f1 0%, #4f46e5 100%);
        color: white;
        padding: clamp(16px, 4vw, 24px) 0;
        margin: -20px -12px clamp(16px, 4vw, 24px);
        border-radius: 0 0 var(--vp-radius-lg) var(--vp-radius-lg);
    }

    .vp-sonuc-header h2 {
        font-size: clamp(1.1rem, 4vw, 1.4rem);
        font-weight: 700;
        margin-bottom: 4px;
    }

    .vp-sonuc-header p {
        font-size: clamp(0.8rem, 3vw, 0.9rem);
        opacity: 0.9;
        margin: 0;
    }

    /* Filtre Alani */
    .vp-filter-box {
        background: white;
        border-radius: var(--vp-radius);
        padding: clamp(12px, 3vw, 16px);
        margin-bottom: 16px;
        border: 1px solid var(--vp-border);
    }

    .vp-filter-box label {
        font-weight: 600;
        font-size: clamp(0.75rem, 2.8vw, 0.85rem);
        color: var(--vp-text);
        margin-bottom: 6px;
        display: block;
    }

    .vp-filter-box select {
        width: 100%;
        padding: 10px 12px;
        border: 2px solid var(--vp-border);
        border-radius: var(--vp-radius);
        font-size: clamp(0.85rem, 3vw, 0.95rem);
        background: white;
        color: var(--vp-text);
    }

    .vp-filter-box select:focus {
        border-color: var(--vp-primary);
        outline: none;
    }

    /* Sonuc Karti */
    .vp-sonuc-card {
        background: white;
        border-radius: var(--vp-radius);
        padding: clamp(14px, 3vw, 20px);
        margin-bottom: 12px;
        border: 1px solid var(--vp-border);
        border-left: 4px solid #6366f1;
    }

    .vp-ogrenci-tag {
        display: inline-flex;
        align-items: center;
        padding: 6px 12px;
        background: #f1f5f9;
        border-radius: 20px;
        font-weight: 600;
        font-size: clamp(0.75rem, 2.8vw, 0.85rem);
        color: #475569;
        margin-bottom: 10px;
    }

    .vp-ogrenci-tag i {
        margin-right: 6px;
        color: #6366f1;
    }

    .vp-sinav-title {
        font-weight: 700;
        color: var(--vp-text);
        font-size: clamp(0.95rem, 3.5vw, 1.1rem);
        margin-bottom: 6px;
    }

    .vp-sinav-meta {
        font-size: clamp(0.75rem, 2.8vw, 0.85rem);
        color: var(--vp-text-muted);
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
    }

    .vp-sinav-meta span {
        display: flex;
        align-items: center;
        gap: 4px;
    }

    /* Durum Badge */
    .vp-durum-box {
        margin-top: 12px;
        padding-top: 12px;
        border-top: 1px solid var(--vp-border);
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
    }

    .vp-durum-yuklendi {
        background: #dbeafe;
        color: #1e40af;
    }

    .vp-durum-bildirildi {
        background: #d1fae5;
        color: #065f46;
    }

    .vp-durum-incelendi {
        background: #dcfce7;
        color: #166534;
    }

    /* PDF Indir Butonu */
    .vp-pdf-btn {
        background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);
        color: white;
        border: none;
        padding: 10px 16px;
        border-radius: var(--vp-radius);
        font-weight: 600;
        font-size: clamp(0.8rem, 3vw, 0.9rem);
        display: inline-flex;
        align-items: center;
        gap: 6px;
        text-decoration: none;
        min-height: 44px;
    }

    .vp-pdf-btn:hover {
        color: white;
        transform: scale(1.02);
    }

    /* Mobil: Kart dikey duzende */
    @media (max-width: 576px) {
        .vp-durum-box {
            flex-direction: column;
            align-items: stretch;
        }
        .vp-pdf-btn {
            width: 100%;
            justify-content: center;
        }
    }
</style>

<!-- Page Header -->
<div class="vp-sonuc-header">
    <div class="container">
        <h2><i class="bi bi-file-earmark-text"></i> Sınav Sonuçları</h2>
        <p>Öğrencilerinizin sınav sonuçlarını görüntüleyiniz</p>
    </div>
</div>

<div class="container">
    <% if (error) { %>
    <div class="alert alert-danger alert-dismissible fade show" role="alert" style="border-radius: var(--vp-radius); font-size: 0.875rem;">
        <i class="bi bi-exclamation-triangle"></i> <%= error %>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
    <% } %>

    <% if (success) { %>
    <div class="alert alert-success alert-dismissible fade show" role="alert" style="border-radius: var(--vp-radius); font-size: 0.875rem;">
        <i class="bi bi-check-circle"></i> <%= success %>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
    <% } %>

    <% if (sonuclar.length === 0) { %>
        <div class="vp-empty">
            <i class="bi bi-inbox"></i>
            <h4>Henüz sonuç yok</h4>
            <p>Öğrencilerinizin sınav sonuçları açıklandığında buradan görüntüleyebileceksiniz.</p>
        </div>
    <% } else { %>
        <!-- Filtreler -->
        <div class="vp-filter-box">
            <div class="row g-3">
                <div class="col-12 col-md-4">
                    <label>Öğrenci</label>
                    <select id="ogrenciFiltre">
                        <option value="">Tüm Öğrenciler</option>
                        <%
                        const uniqueOgrenciler = [...new Set(sonuclar.map(s => s.ogrenci_adi_soyadi))];
                        uniqueOgrenciler.forEach(o => {
                        %>
                            <option value="<%= o %>"><%= o %></option>
                        <% }) %>
                    </select>
                </div>
                <div class="col-12 col-md-4">
                    <label>Sınav</label>
                    <select id="sinavFiltre">
                        <option value="">Tüm Sınavlar</option>
                        <%
                        const uniqueSinavlar = [...new Set(sonuclar.map(s => s.sinav_adi))];
                        uniqueSinavlar.forEach(s => {
                        %>
                            <option value="<%= s %>"><%= s %></option>
                        <% }) %>
                    </select>
                </div>
                <div class="col-12 col-md-4">
                    <label>Durum</label>
                    <select id="durumFiltre">
                        <option value="">Tüm Durumlar</option>
                        <option value="yuklendi">Yüklendi</option>
                        <option value="bildirildi">Bildirildi</option>
                    </select>
                </div>
            </div>
        </div>

        <!-- Sonuc Listesi -->
        <div id="sonucListesi">
            <% sonuclar.forEach(sonuc => { %>
            <div class="vp-sonuc-card"
                 data-ogrenci="<%= sonuc.ogrenci_adi_soyadi %>"
                 data-sinav="<%= sonuc.sinav_adi %>"
                 data-durum="<%= sonuc.sonuc_durumu %>">

                <div class="vp-ogrenci-tag">
                    <i class="bi bi-person-fill"></i>
                    <%= sonuc.ogrenci_adi_soyadi %>
                    <% if (sonuc.ogrenci_sinif) { %>
                        <span style="margin-left: 6px; opacity: 0.7;">(<%= sonuc.ogrenci_sinif %>)</span>
                    <% } %>
                </div>

                <div class="vp-sinav-title">
                    <i class="bi bi-journal-text" style="color: #6366f1;"></i>
                    <%= sonuc.sinav_adi %>
                </div>

                <div class="vp-sinav-meta">
                    <span>
                        <i class="bi bi-calendar3"></i>
                        <%= new Date(sonuc.sinav_tarihi).toLocaleDateString('tr-TR') %>
                    </span>
                    <% if (sonuc.sinif) { %>
                    <span>
                        <i class="bi bi-mortarboard"></i>
                        <%= sonuc.sinif %>
                    </span>
                    <% } %>
                    <% if (sonuc.ders) { %>
                    <span>
                        <i class="bi bi-book"></i>
                        <%= sonuc.ders %>
                    </span>
                    <% } %>
                </div>

                <div class="vp-durum-box">
                    <div>
                        <% if (sonuc.pdf_goruldu) { %>
                            <span class="vp-badge vp-durum-incelendi">
                                <i class="bi bi-eye-fill"></i> Incelendi
                            </span>
                            <div class="vp-sinav-meta" style="margin-top: 4px;">
                                <span>
                                    <i class="bi bi-clock"></i>
                                    <%= new Date(sonuc.pdf_gorunme_tarihi).toLocaleString('tr-TR', {
                                        day: '2-digit',
                                        month: '2-digit',
                                        year: 'numeric',
                                        hour: '2-digit',
                                        minute: '2-digit'
                                    }) %>
                                </span>
                                <% if (sonuc.pdf_indirilme_sayisi > 1) { %>
                                <span>
                                    <i class="bi bi-download"></i> <%= sonuc.pdf_indirilme_sayisi %> kez
                                </span>
                                <% } %>
                            </div>
                        <% } else if (sonuc.sonuc_durumu === 'bildirildi') { %>
                            <span class="vp-badge vp-durum-bildirildi">
                                <i class="bi bi-check-circle"></i> Bildirildi
                            </span>
                        <% } else { %>
                            <span class="vp-badge vp-durum-yuklendi">
                                <i class="bi bi-upload"></i> Yüklendi
                            </span>
                        <% } %>
                    </div>

                    <% if (sonuc.pdf_path) { %>
                        <a href="/veli/sinav-sonuc-indir/<%= sonuc.id %>" class="vp-pdf-btn">
                            <i class="bi bi-file-pdf"></i>
                            PDF Indir
                        </a>
                    <% } else { %>
                        <span style="color: var(--vp-text-muted); font-size: 0.75rem;">PDF hazırlanıyor...</span>
                    <% } %>
                </div>
            </div>
            <% }) %>
        </div>

        <div id="noResultsMessage" class="alert alert-info" style="display: none; border-radius: var(--vp-radius);">
            <i class="bi bi-info-circle"></i> Seçilen filtrelere uygun sonuç bulunamadı.
        </div>
    <% } %>

    <!-- Geri Butonu -->
    <div class="mt-4">
        <a href="/veli/dashboard" class="vp-btn vp-btn-secondary">
            <i class="bi bi-arrow-left"></i> Dashboard
        </a>
    </div>
</div>

<script>
document.getElementById('ogrenciFiltre')?.addEventListener('change', filterResults);
document.getElementById('sinavFiltre')?.addEventListener('change', filterResults);
document.getElementById('durumFiltre')?.addEventListener('change', filterResults);

function filterResults() {
    const ogrenciFiltre = document.getElementById('ogrenciFiltre')?.value.toLowerCase() || '';
    const sinavFiltre = document.getElementById('sinavFiltre')?.value.toLowerCase() || '';
    const durumFiltre = document.getElementById('durumFiltre')?.value.toLowerCase() || '';

    const cards = document.querySelectorAll('.vp-sonuc-card');
    let visibleCount = 0;

    cards.forEach(card => {
        const ogrenci = card.dataset.ogrenci.toLowerCase();
        const sinav = card.dataset.sinav.toLowerCase();
        const durum = card.dataset.durum.toLowerCase();

        const ogrenciMatch = !ogrenciFiltre || ogrenci.includes(ogrenciFiltre);
        const sinavMatch = !sinavFiltre || sinav.includes(sinavFiltre);
        const durumMatch = !durumFiltre || durum === durumFiltre;

        if (ogrenciMatch && sinavMatch && durumMatch) {
            card.style.display = 'block';
            visibleCount++;
        } else {
            card.style.display = 'none';
        }
    });

    const noResultsMsg = document.getElementById('noResultsMessage');
    if (noResultsMsg) {
        noResultsMsg.style.display = visibleCount === 0 ? 'block' : 'none';
    }
}
</script>

<%- include('../partials/footer-dashboard', { user: user, activePage: 'sonuclar' }) %>
