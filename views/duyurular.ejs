<%- include('partials/header', {title: 'Duyurular', user: typeof user !== 'undefined' ? user : null}) %>

<%- include('partials/common-styles') %>

<style>
    /* Breadcrumb */
    .breadcrumb-container {
        background: #f8f9fa;
        padding: 16px 0;
        border-bottom: 1px solid #e0e0e0;
    }
    
    .breadcrumb {
        display: flex;
        align-items: center;
        gap: 8px;
        list-style: none;
        padding: 0;
        margin: 0;
        flex-wrap: wrap;
    }
    
    .breadcrumb-item {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 1rem;
    }
    
    .breadcrumb-item a {
        color: var(--primary);
        text-decoration: none;
        transition: all 0.2s ease;
        display: flex;
        align-items: center;
        gap: 6px;
    }
    
    .breadcrumb-item a:hover {
        color: var(--primary-dark);
        text-decoration: underline;
    }
    
    .breadcrumb-item a i {
        font-size: 1rem;
    }
    
    .breadcrumb-separator {
        color: #999;
        font-size: 0.875rem;
    }
    
    .breadcrumb-item.active {
        color: #666;
        font-weight: 500;
    }
    
    /* Page Header */
    .page-header {
        background: transparent;
        padding: 30px 0 20px;
        margin-bottom: 30px;
    }
    
    .page-header h1 {
        font-size: 2rem;
        font-weight: 800;
        margin-bottom: 6px;
        color: #1e293b;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .page-header h1 i {
        color: #003b78;
        font-size: 1.75rem;
    }

    .page-header p {
        font-size: 1rem;
        color: #64748b;
        margin: 0;
    }
    
    /* Duyuru Card - Modern Compact */
    .content-card {
        background: white;
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 2px 12px rgba(0,0,0,0.06);
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        border: 1px solid #e8ecf0;
        position: relative;
    }

    .content-card::before {
        content: '';
        position: absolute;
        left: 0;
        top: 0;
        bottom: 0;
        width: 4px;
        background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%);
        opacity: 0;
        transition: opacity 0.3s ease;
    }

    .content-card:hover {
        transform: translateY(-3px);
        box-shadow: 0 8px 24px rgba(0,59,120,0.12);
        border-color: var(--primary);
    }

    .content-card:hover::before {
        opacity: 1;
    }

    .content-card-body {
        padding: clamp(16px, 3vw, 24px);
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 16px;
    }

    .content-card-title {
        font-size: clamp(1rem, 2.5vw, 1.15rem);
        font-weight: 700;
        color: var(--primary);
        margin-bottom: 8px;
        line-height: 1.4;
    }

    .content-card-text {
        color: #666;
        line-height: 1.6;
        margin: 0;
        font-size: clamp(0.9rem, 2vw, 0.95rem);
    }

    .content-card-meta {
        display: flex;
        align-items: center;
        gap: 6px;
        color: #666;
        font-size: 0.875rem;
        white-space: nowrap;
        background: #f8fafc;
        padding: 8px 14px;
        border-radius: 20px;
        flex-shrink: 0;
    }

    .content-card-meta i {
        color: var(--primary);
        font-size: 0.875rem;
    }
    
    /* Empty State */
    .empty-state {
        text-align: center;
        padding: 60px 20px;
        background: white;
        border-radius: 10px;
        color: #999;
        box-shadow: 0 2px 8px rgba(0,0,0,0.08);
    }
    
    .empty-state i {
        font-size: 3rem;
        margin-bottom: 16px;
        opacity: 0.4;
        color: #999;
    }
    
    .empty-state h5 {
        color: #666;
        font-weight: 600;
        margin-bottom: 8px;
    }
    
    .empty-state p {
        color: #999;
        font-size: 1rem;
    }
    
    /* Responsive */
    @media (max-width: 768px) {
        .breadcrumb-container {
            padding: 12px 0;
            margin-bottom: 20px;
        }

        .breadcrumb {
            font-size: 0.875rem;
        }

        .breadcrumb-item a i {
            font-size: 0.875rem;
        }

        .page-header {
            padding: 16px 0 12px;
            margin-bottom: 20px;
        }

        .page-header h1 {
            font-size: 1.5rem;
            gap: 8px;
        }

        .page-header h1 i {
            font-size: 1.25rem;
        }

        .page-header p {
            font-size: 0.875rem;
        }

        .content-card {
            border-radius: 12px;
        }

        .content-card::before {
            display: none;
        }

        .content-card-body {
            flex-direction: column;
            align-items: flex-start;
            gap: 12px;
            padding: 16px;
        }

        .content-card-meta {
            align-self: flex-start;
            padding: 6px 12px;
            font-size: 0.75rem;
        }
    }

    @media (max-width: 480px) {
        .page-header h1 {
            font-size: 1.25rem;
        }

        .content-card-body {
            padding: 14px;
        }
    }
</style>

<!-- Breadcrumb -->
<div class="breadcrumb-container">
    <div class="container">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item">
                    <a href="/">
                        <i class="bi bi-house-door"></i>
                        Ana Sayfa
                    </a>
                </li>
                <li class="breadcrumb-separator">
                    <i class="bi bi-chevron-right"></i>
                </li>
                <li class="breadcrumb-item active" aria-current="page">
                    Duyurular
                </li>
            </ol>
        </nav>
    </div>
</div>

<!-- Page Header -->
<div class="page-header">
    <div class="container">
        <h1>
            <i class="bi bi-megaphone"></i>
            Duyurular
        </h1>
        <p>En son haberler ve önemli duyurular</p>
    </div>
</div>

<!-- Main Content -->
<div class="container" style="margin-bottom: 60px;">
    <div class="row g-3">
        <% if (duyurular && duyurular.length > 0) { %>
            <% duyurular.forEach(function(duyuru) { %>
            <div class="col-12">
                <div class="content-card">
                    <div class="content-card-body">
                        <div style="flex: 1;">
                            <h5 class="content-card-title"><%= duyuru.baslik %></h5>
                            <p class="content-card-text">
                                <%= duyuru.icerik %>
                            </p>
                        </div>
                        <% if (duyuru.tarih) { %>
                        <div class="content-card-meta ms-3">
                            <span><i class="bi bi-calendar-event"></i> <%= new Date(duyuru.tarih).toLocaleDateString('tr-TR') %></span>
                        </div>
                        <% } %>
                    </div>
                </div>
            </div>
            <% }); %>
        <% } else { %>
            <div class="col-12">
                <div class="empty-state">
                    <i class="bi bi-megaphone"></i>
                    <h5>Henüz duyuru bulunmamaktadır.</h5>
                    <p>Yeni duyurular eklendiğinde burada görünecektir.</p>
                </div>
            </div>
        <% } %>
    </div>
</div>

<%- include('partials/footer') %>

<script>
    // Smooth scroll
    document.querySelectorAll('a[href^="#"]').forEach(anchor => {
        anchor.addEventListener('click', function (e) {
            e.preventDefault();
            const target = document.querySelector(this.getAttribute('href'));
            if (target) {
                target.scrollIntoView({
                    behavior: 'smooth',
                    block: 'start'
                });
            }
        });
    });
</script>

