<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PayTR Entegrasyon - Sınav Merkezi</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <style>
        :root {
            --paytr-primary: #1a1aff;
            --paytr-secondary: #00d4ff;
        }
        
        body {
            background: linear-gradient(135deg, #f0f9ff 0%, #e0f2fe 100%);
            min-height: 100vh;
            padding: 40px 0;
        }
        
        .paytr-container {
            max-width: 900px;
            margin: 0 auto;
        }
        
        .paytr-header {
            background: linear-gradient(135deg, var(--paytr-primary) 0%, var(--paytr-secondary) 100%);
            color: white;
            border-radius: 24px 24px 0 0;
            padding: 40px;
            text-align: center;
        }
        
        .paytr-logo {
            font-size: 3rem;
            font-weight: 800;
            margin-bottom: 16px;
        }
        
        .paytr-body {
            background: white;
            border-radius: 0 0 24px 24px;
            padding: 40px;
            box-shadow: 0 8px 32px rgba(0,0,0,0.08);
        }
        
        .form-label {
            font-weight: 600;
            color: #1e293b;
            margin-bottom: 8px;
        }
        
        .form-control, .form-select {
            border-radius: 12px;
            border: 2px solid #e2e8f0;
            padding: 12px 16px;
        }
        
        .form-control:focus, .form-select:focus {
            border-color: var(--paytr-primary);
            box-shadow: 0 0 0 4px rgba(26, 26, 255, 0.1);
        }
        
        .form-check-input:checked {
            background-color: var(--paytr-primary);
            border-color: var(--paytr-primary);
        }
        
        .btn-paytr {
            background: linear-gradient(135deg, var(--paytr-primary) 0%, var(--paytr-secondary) 100%);
            border: none;
            color: white;
            padding: 14px 32px;
            border-radius: 12px;
            font-weight: 600;
            font-size: 1.1rem;
            transition: all 0.3s ease;
        }
        
        .btn-paytr:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 24px rgba(26, 26, 255, 0.4);
            color: white;
        }
        
        .info-box {
            background: linear-gradient(135deg, #dbeafe 0%, #bfdbfe 100%);
            border: 2px solid #93c5fd;
            border-radius: 16px;
            padding: 24px;
            margin-bottom: 24px;
        }
        
        .info-box h5 {
            color: #1e40af;
            font-weight: 700;
            margin-bottom: 12px;
        }
        
        .info-box ul {
            margin-bottom: 0;
            padding-left: 20px;
        }
        
        .info-box li {
            color: #1e40af;
            margin-bottom: 8px;
        }
        
        .status-badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 8px 16px;
            border-radius: 20px;
            font-weight: 600;
            font-size: 0.9rem;
        }
        
        .status-badge.active {
            background: #dcfce7;
            color: #15803d;
        }
        
        .status-badge.inactive {
            background: #fee2e2;
            color: #991b1b;
        }
    </style>
</head>
<body>

<div class="paytr-container">
    <!-- Header -->
    <div class="paytr-header">
        <div class="paytr-logo">
            <i class="bi bi-credit-card-2-front"></i> PayTR
        </div>
        <h2 style="font-weight: 700; margin-bottom: 8px;">Ödeme Entegrasyonu</h2>
        <p style="opacity: 0.9; margin: 0;">Güvenli online ödeme altyapınızı yönetin</p>
    </div>
    
    <!-- Body -->
    <div class="paytr-body">
        <!-- Alerts -->
        <% if (error) { %>
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle"></i> <%= error %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
        <% } %>
        
        <% if (success) { %>
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle"></i> <%= success %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
        <% } %>
        
        <!-- Durum -->
        <div class="mb-4 text-center">
            <% if (ayarlar && ayarlar.aktif) { %>
                <span class="status-badge active">
                    <i class="bi bi-check-circle-fill"></i> PayTR Aktif
                </span>
                <% if (ayarlar.test_mode) { %>
                    <span class="status-badge" style="background: #fef3c7; color: #92400e; margin-left: 8px;">
                        <i class="bi bi-flask"></i> Test Modu
                    </span>
                <% } else { %>
                    <span class="status-badge" style="background: #d1fae5; color: #065f46; margin-left: 8px;">
                        <i class="bi bi-shield-check"></i> Canlı Mod
                    </span>
                <% } %>
            <% } else { %>
                <span class="status-badge inactive">
                    <i class="bi bi-x-circle-fill"></i> PayTR Pasif
                </span>
            <% } %>
        </div>
        
        <!-- Bilgilendirme -->
        <div class="info-box">
            <h5><i class="bi bi-info-circle-fill"></i> PayTR Nasıl Alınır?</h5>
            <ul>
                <li><strong>1.</strong> <a href="https://www.paytr.com" target="_blank">www.paytr.com</a> adresinden üye olun</li>
                <li><strong>2.</strong> Üye işyeri başvurusu yapın</li>
                <li><strong>3.</strong> Onay aldıktan sonra panel → Entegrasyon → API Bilgileri bölümünden:<br>
                    <code>Merchant ID</code>, <code>Merchant Key</code>, <code>Merchant Salt</code> bilgilerini alın
                </li>
                <li><strong>4.</strong> Bu bilgileri aşağıdaki forma girin</li>
                <li><strong>5.</strong> Test modunda test edin, sonra canlı moda geçin</li>
            </ul>
            <p style="margin-top: 16px; margin-bottom: 0;">
                <i class="bi bi-book"></i> <strong>Dokümantasyon:</strong> 
                <a href="https://dev.paytr.com" target="_blank">dev.paytr.com</a>
            </p>
        </div>
        
        <!-- Form -->
        <form method="POST" action="/paytr-entegrasyon">
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label">
                        <i class="bi bi-key"></i> Merchant ID *
                    </label>
                    <input type="text" name="merchant_id" class="form-control" 
                           value="<%= ayarlar.merchant_id || '' %>" 
                           placeholder="Örn: 123456" required>
                    <small class="text-muted">PayTR panelinden alın</small>
                </div>
                
                <div class="col-md-6 mb-3">
                    <label class="form-label">
                        <i class="bi bi-shield-lock"></i> Merchant Key *
                    </label>
                    <input type="text" name="merchant_key" class="form-control" 
                           value="<%= ayarlar.merchant_key || '' %>" 
                           placeholder="Örn: abcd1234efgh5678" required>
                    <small class="text-muted">PayTR panelinden alın</small>
                </div>
                
                <div class="col-12 mb-3">
                    <label class="form-label">
                        <i class="bi bi-asterisk"></i> Merchant Salt *
                    </label>
                    <input type="text" name="merchant_salt" class="form-control" 
                           value="<%= ayarlar.merchant_salt || '' %>" 
                           placeholder="Örn: ijkl9012mnop3456" required>
                    <small class="text-muted">PayTR panelinden alın</small>
                </div>
                
                <div class="col-md-6 mb-3">
                    <div class="form-check form-switch" style="padding-left: 3rem;">
                        <input class="form-check-input" type="checkbox" id="test_mode" name="test_mode" value="1"
                               <%= (ayarlar.test_mode === 1 || ayarlar.test_mode === undefined) ? 'checked' : '' %>
                               style="width: 3rem; height: 1.5rem;">
                        <label class="form-check-label" for="test_mode" style="margin-left: 8px;">
                            <i class="bi bi-flask"></i> <strong>Test Modu</strong>
                        </label>
                    </div>
                    <small class="text-muted d-block" style="padding-left: 3rem;">
                        Test modunda gerçek ödeme alınmaz
                    </small>
                </div>
                
                <div class="col-md-6 mb-3">
                    <div class="form-check form-switch" style="padding-left: 3rem;">
                        <input class="form-check-input" type="checkbox" id="aktif" name="aktif" value="1"
                               <%= ayarlar.aktif ? 'checked' : '' %>
                               style="width: 3rem; height: 1.5rem;">
                        <label class="form-check-label" for="aktif" style="margin-left: 8px;">
                            <i class="bi bi-power"></i> <strong>PayTR Aktif</strong>
                        </label>
                    </div>
                    <small class="text-muted d-block" style="padding-left: 3rem;">
                        Pasifse demo ödeme kullanılır
                    </small>
                </div>
            </div>
            
            <hr style="margin: 32px 0;">
            
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-paytr flex-grow-1">
                    <i class="bi bi-save"></i> Ayarları Kaydet
                </button>
                <a href="/" class="btn btn-outline-secondary" style="padding: 14px 32px; border-radius: 12px; font-weight: 600;">
                    <i class="bi bi-arrow-left"></i> Geri
                </a>
            </div>
        </form>
        
        <!-- Footer Bilgi -->
        <div class="mt-4 p-3" style="background: #f8fafc; border-radius: 12px;">
            <p style="margin: 0; color: #64748b; font-size: 0.9rem;">
                <i class="bi bi-shield-check"></i> <strong>Güvenlik:</strong> 
                Bu bilgiler güvenli şekilde şifrelenerek saklanır. Hiçbir zaman 3. şahıslarla paylaşılmaz.
            </p>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

