<%- include('partials/header-dashboard', { title: 'Öğrenci Talepleri - Sınav Merkezi', user: user }) %>
<%- include('partials/veli-panel-styles') %>

<style>
    /* Turuncu tema header */
    .vp-talepler-header {
        background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);
        color: white;
        padding: clamp(16px, 4vw, 24px) 0;
        margin: -20px -12px clamp(16px, 4vw, 24px);
        border-radius: 0 0 var(--vp-radius-lg) var(--vp-radius-lg);
    }

    .vp-talepler-header h2 {
        font-size: clamp(1.1rem, 4vw, 1.4rem);
        font-weight: 700;
        margin-bottom: 4px;
    }

    .vp-talepler-header p {
        font-size: clamp(0.8rem, 3vw, 0.9rem);
        opacity: 0.9;
        margin: 0;
    }

    /* Talep Karti */
    .vp-talep-card {
        background: white;
        border-radius: var(--vp-radius);
        padding: clamp(14px, 3vw, 20px);
        margin-bottom: 12px;
        border: 1px solid var(--vp-border);
    }

    .vp-talep-avatar {
        width: clamp(44px, 10vw, 52px);
        height: clamp(44px, 10vw, 52px);
        background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);
        border-radius: var(--vp-radius);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: clamp(1.1rem, 4vw, 1.4rem);
        font-weight: 700;
        color: white;
        flex-shrink: 0;
    }

    .vp-talep-title {
        font-weight: 700;
        color: var(--vp-text);
        font-size: clamp(0.95rem, 3.5vw, 1.05rem);
        margin-bottom: 4px;
    }

    .vp-talep-meta {
        font-size: clamp(0.75rem, 2.8vw, 0.85rem);
        color: var(--vp-text-muted);
        margin-bottom: 8px;
    }

    .vp-talep-badges {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
        margin-bottom: 8px;
    }

    /* Talep Aksiyon Butonlari */
    .vp-talep-actions {
        display: flex;
        gap: 8px;
        margin-top: 12px;
        padding-top: 12px;
        border-top: 1px solid var(--vp-border);
    }

    .vp-talep-actions form {
        flex: 1;
    }

    .vp-talep-actions .vp-btn {
        width: 100%;
        justify-content: center;
    }

    /* Desktop: Aksiyon butonlari sagda */
    @media (min-width: 768px) {
        .vp-talep-card {
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .vp-talep-actions {
            margin-top: 0;
            padding-top: 0;
            border-top: none;
            flex: 0 0 auto;
        }

        .vp-talep-actions form {
            flex: none;
        }

        .vp-talep-actions .vp-btn {
            width: auto;
        }
    }
</style>

<!-- Page Header -->
<div class="vp-talepler-header">
    <div class="container">
        <h2><i class="bi bi-bell-fill"></i> Ogrenci Talepleri</h2>
        <p>Rehber ogretmenlerden gelen ekleme taleplerini goruntuleyiniz</p>
    </div>
</div>

<div class="container">
    <% if (error) { %>
    <div class="alert alert-danger alert-dismissible fade show" role="alert" style="border-radius: var(--vp-radius); font-size: 0.9rem;">
        <i class="bi bi-exclamation-triangle"></i> <%= error %>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
    <% } %>

    <% if (success) { %>
    <div class="alert alert-success alert-dismissible fade show" role="alert" style="border-radius: var(--vp-radius); font-size: 0.9rem;">
        <i class="bi bi-check-circle"></i> <%= success %>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
    <% } %>

    <% if (talepler && talepler.length > 0) { %>
        <% talepler.forEach(function(talep) { %>
        <div class="vp-talep-card">
            <div class="d-flex align-items-start gap-3 flex-grow-1" style="min-width: 0;">
                <div class="vp-talep-avatar">
                    <%= talep.ogrenci_adi ? talep.ogrenci_adi.charAt(0).toUpperCase() : 'O' %>
                </div>
                <div class="flex-grow-1" style="min-width: 0;">
                    <div class="vp-talep-title"><%= talep.ogrenci_adi || 'Ogrenci' %></div>

                    <div class="vp-talep-badges">
                        <% if (talep.ogrenci_no) { %>
                            <span class="vp-badge vp-badge-primary"><i class="bi bi-hash"></i> <%= talep.ogrenci_no %></span>
                        <% } %>
                        <% if (talep.sinif) { %>
                            <span class="vp-badge vp-badge-info"><i class="bi bi-book"></i> <%= talep.sinif %></span>
                        <% } %>
                        <% if (talep.okul) { %>
                            <span class="vp-badge vp-badge-secondary"><i class="bi bi-building"></i> <%= talep.okul %></span>
                        <% } %>
                    </div>

                    <div class="vp-talep-meta">
                        <strong>Rehber:</strong> <%= talep.rehber_adi || 'Belirtilmemis' %>
                        <% if (talep.kurum) { %> - <%= talep.kurum %><% } %>
                    </div>

                    <div class="vp-talep-meta">
                        <i class="bi bi-clock"></i>
                        <%= new Date(talep.created_at).toLocaleDateString('tr-TR', { day: '2-digit', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit' }) %>
                    </div>
                </div>
            </div>

            <div class="vp-talep-actions">
                <form method="POST" action="/veli/talep/<%= talep.id %>/onayla">
                    <button type="submit" class="vp-btn vp-btn-success">
                        <i class="bi bi-check-circle"></i> Onayla
                    </button>
                </form>
                <form method="POST" action="/veli/talep/<%= talep.id %>/reddet">
                    <button type="submit" class="vp-btn vp-btn-danger">
                        <i class="bi bi-x-circle"></i> Reddet
                    </button>
                </form>
            </div>
        </div>
        <% }); %>
    <% } else { %>
        <div class="vp-empty">
            <i class="bi bi-inbox"></i>
            <h4>Bekleyen Talep Yok</h4>
            <p>Su anda bekleyen ogrenci ekleme talebiniz bulunmamaktadir.</p>
        </div>
    <% } %>

    <!-- Geri Butonu -->
    <div class="mt-4">
        <a href="/veli/dashboard" class="vp-btn vp-btn-secondary">
            <i class="bi bi-arrow-left"></i> Dashboard
        </a>
    </div>
</div>

<%- include('partials/footer-dashboard') %>
