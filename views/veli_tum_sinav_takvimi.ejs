<%- include('partials/header-dashboard', { title: 'Sınav Takvimi - Sınav Merkezi', user: user, activePage: 'takvim' }) %>
<%- include('partials/veli-panel-styles') %>

<style>
    /* Mor tema header */
    .vp-calendar-header {
        background: linear-gradient(135deg, #8b5cf6 0%, #7c3aed 100%);
        color: white;
        padding: clamp(16px, 4vw, 24px) 0;
        margin: -20px -12px clamp(16px, 4vw, 24px);
        border-radius: 0 0 var(--vp-radius-lg) var(--vp-radius-lg);
    }

    .vp-calendar-header h2 {
        font-size: clamp(1.1rem, 4vw, 1.4rem);
        font-weight: 700;
        margin-bottom: 4px;
    }

    .vp-calendar-header p {
        font-size: clamp(0.8rem, 3vw, 0.9rem);
        opacity: 0.9;
        margin: 0;
    }

    /* Istatistik Kartlari */
    .vp-stat-card {
        border-radius: var(--vp-radius);
        padding: clamp(14px, 3vw, 20px);
        text-align: center;
        color: white;
    }

    .vp-stat-card .number {
        font-size: clamp(1.6rem, 6vw, 2.2rem);
        font-weight: 800;
        line-height: 1;
    }

    .vp-stat-card .label {
        font-size: clamp(0.7rem, 2.5vw, 0.85rem);
        opacity: 0.9;
        margin-top: 4px;
    }

    /* Sinav Kartlari */
    .vp-exam-card {
        background: white;
        border-radius: var(--vp-radius);
        padding: clamp(12px, 3vw, 16px);
        margin-bottom: 12px;
        border: 1px solid var(--vp-border);
    }

    .vp-exam-date-box {
        background: linear-gradient(135deg, #8b5cf6 0%, #7c3aed 100%);
        color: white;
        border-radius: var(--vp-radius);
        padding: clamp(10px, 2.5vw, 14px);
        text-align: center;
        min-width: clamp(56px, 14vw, 70px);
        flex-shrink: 0;
    }

    .vp-exam-date-box .day {
        font-size: clamp(1.4rem, 5vw, 1.8rem);
        font-weight: 800;
        line-height: 1;
    }

    .vp-exam-date-box .month {
        font-size: clamp(0.7rem, 2.5vw, 0.8rem);
        opacity: 0.9;
        text-transform: uppercase;
    }

    .vp-exam-title {
        font-weight: 700;
        color: var(--vp-text);
        font-size: clamp(0.9rem, 3.2vw, 1rem);
        margin-bottom: 4px;
    }

    .vp-exam-details {
        font-size: clamp(0.75rem, 2.8vw, 0.85rem);
        color: var(--vp-text-muted);
    }

    /* Ogrenci Badge */
    .vp-student-badge {
        background: linear-gradient(135deg, #06b6d4 0%, #3b82f6 100%);
        color: white;
        padding: 4px 10px;
        border-radius: 8px;
        font-weight: 600;
        font-size: clamp(0.7rem, 2.5vw, 0.8rem);
        white-space: nowrap;
    }

    /* Mor Header icin */
    .vp-purple-section {
        background: linear-gradient(135deg, #8b5cf6 0%, #7c3aed 100%);
        color: white;
        padding: clamp(12px, 3vw, 16px);
        border-radius: var(--vp-radius) var(--vp-radius) 0 0;
        margin: -1px -1px 0 -1px;
    }

    .vp-purple-section h5 {
        font-weight: 700;
        margin: 0;
        font-size: clamp(0.9rem, 3.2vw, 1rem);
    }

    /* Mobil: Sinav karti dikey duzende */
    @media (max-width: 576px) {
        .vp-exam-card .d-flex {
            flex-direction: column;
            align-items: flex-start !important;
        }
        .vp-exam-date-box {
            width: 100%;
            margin-bottom: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
        }
        .vp-exam-date-box .day,
        .vp-exam-date-box .month {
            display: inline;
        }
    }
</style>

<!-- Page Header -->
<div class="vp-calendar-header">
    <div class="container">
        <h2><i class="bi bi-calendar-event"></i> Sinav Takvimi</h2>
        <p>Tum ogrencilerinizin yaklasan sinavlari</p>
    </div>
</div>

<div class="container">
    <% if (error) { %>
    <div class="alert alert-danger alert-dismissible fade show" role="alert" style="border-radius: var(--vp-radius); font-size: 0.9rem;">
        <i class="bi bi-exclamation-triangle"></i> <%= error %>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
    <% } %>

    <% if (success) { %>
    <div class="alert alert-success alert-dismissible fade show" role="alert" style="border-radius: var(--vp-radius); font-size: 0.9rem;">
        <i class="bi bi-check-circle"></i> <%= success %>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
    <% } %>

    <!-- Istatistikler -->
    <div class="row g-3 mb-4">
        <div class="col-4">
            <div class="vp-stat-card" style="background: linear-gradient(135deg, #06b6d4 0%, #3b82f6 100%);">
                <div class="number"><%= ogrenciler.length %></div>
                <div class="label">Ogrenci</div>
            </div>
        </div>
        <div class="col-4">
            <div class="vp-stat-card" style="background: linear-gradient(135deg, #8b5cf6 0%, #7c3aed 100%);">
                <div class="number"><%= tumTakvim.length %></div>
                <div class="label">Sinav</div>
            </div>
        </div>
        <div class="col-4">
            <div class="vp-stat-card" style="background: linear-gradient(135deg, #10b981 0%, #059669 100%);">
                <div class="number">
                    <%= tumTakvim.filter(s => {
                        const tarih = new Date(s.tarih);
                        const bugun = new Date();
                        const gunFarki = Math.ceil((tarih - bugun) / (1000 * 60 * 60 * 24));
                        return gunFarki >= 0 && gunFarki <= 7;
                    }).length %>
                </div>
                <div class="label">Bu Hafta</div>
            </div>
        </div>
    </div>

    <!-- Sinav Listesi -->
    <div class="vp-card" style="padding: 0; overflow: hidden;">
        <div class="vp-purple-section">
            <h5><i class="bi bi-calendar-check"></i> Yaklasan Sinavlar</h5>
        </div>

        <div style="padding: clamp(12px, 3vw, 16px);">
            <% if (tumTakvim && tumTakvim.length > 0) { %>
                <% tumTakvim.forEach(function(sinav) {
                    const tarih = new Date(sinav.tarih);
                    const gun = tarih.getDate();
                    const ay = tarih.toLocaleDateString('tr-TR', { month: 'short' });
                    const tamTarih = tarih.toLocaleDateString('tr-TR');
                    const bugun = new Date();
                    const gunFarki = Math.ceil((tarih - bugun) / (1000 * 60 * 60 * 24));

                    let durumText = '';
                    let durumClass = '';
                    if (gunFarki < 0) {
                        durumText = 'Gecti';
                        durumClass = 'vp-badge-secondary';
                    } else if (gunFarki === 0) {
                        durumText = 'Bugun!';
                        durumClass = 'vp-badge-danger';
                    } else if (gunFarki <= 7) {
                        durumText = gunFarki + ' gun';
                        durumClass = 'vp-badge-warning';
                    } else {
                        durumText = gunFarki + ' gun';
                        durumClass = 'vp-badge-success';
                    }
                %>
                <div class="vp-exam-card">
                    <div class="d-flex align-items-center gap-3">
                        <div class="vp-exam-date-box">
                            <div class="day"><%= gun %></div>
                            <div class="month"><%= ay %></div>
                        </div>

                        <div class="flex-grow-1" style="min-width: 0;">
                            <div class="d-flex align-items-center gap-2 flex-wrap mb-1">
                                <span class="vp-student-badge">
                                    <i class="bi bi-person"></i> <%= sinav.ogrenci_ad_soyad %>
                                    <% if (sinav.ogrenci_no) { %>(<%= sinav.ogrenci_no %>)<% } %>
                                </span>
                                <span class="vp-badge <%= durumClass %>"><%= durumText %></span>
                            </div>
                            <div class="vp-exam-title"><%= sinav.sinav_adi || 'Sinav' %></div>
                            <div class="vp-exam-details">
                                <i class="bi bi-calendar3"></i> <%= tamTarih %>
                                <% if (sinav.saat) { %>
                                    | <i class="bi bi-clock"></i> <%= sinav.saat %>
                                <% } %>
                                <% if (sinav.yer) { %>
                                    | <i class="bi bi-geo-alt"></i> <%= sinav.yer %>
                                <% } %>
                            </div>
                        </div>
                    </div>

                    <% if (sinav.aciklama) { %>
                    <div class="vp-exam-details" style="margin-top: 8px; padding-top: 8px; border-top: 1px solid var(--vp-border);">
                        <i class="bi bi-info-circle"></i> <%= sinav.aciklama %>
                    </div>
                    <% } %>
                </div>
                <% }); %>
            <% } else { %>
                <div class="vp-empty" style="margin: 0;">
                    <i class="bi bi-calendar-x"></i>
                    <h4>Henuz Sinav Yok</h4>
                    <p>Ogrencileriniz icin henuz planlanmis bir sinav bulunmamaktadir.</p>
                </div>
            <% } %>
        </div>
    </div>

    <!-- Geri Butonu -->
    <div class="mt-4">
        <a href="/veli/dashboard" class="vp-btn vp-btn-secondary">
            <i class="bi bi-arrow-left"></i> Geri
        </a>
    </div>
</div>

<%- include('partials/footer-dashboard', { user: user, activePage: 'takvim' }) %>
