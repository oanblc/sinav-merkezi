    <!-- PWA Service Worker -->
    <% if (typeof user !== 'undefined' && user && (user.type === 'veli' || user.type === 'rehber_ogretmen')) { %>
    <script>
        if ('serviceWorker' in navigator) {
            window.addEventListener('load', () => {
                navigator.serviceWorker.register('/service-worker.js')
                    .then(reg => console.log('✅ Service Worker kayıtlı'))
                    .catch(err => console.log('❌ Service Worker hatası:', err));
            });
        }
        
        // PWA Install prompt
        let deferredPrompt;
        window.addEventListener('beforeinstallprompt', (e) => {
            e.preventDefault();
            deferredPrompt = e;
            
            // Kullanıcıya yükleme öner (opsiyonel banner göster)
            console.log('📱 PWA yüklenebilir!');
        });
    </script>
