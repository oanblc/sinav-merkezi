<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof title !== 'undefined' ? title : 'Adana Sınav Kulübü' %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
</head>
<body>
    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-light">
        <div class="container">
            <a class="navbar-brand" href="/">
                <i class="bi bi-mortarboard-fill"></i>
                <span>Adana Sınav Kulübü</span>
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto align-items-center">
                    <li class="nav-item">
                        <a class="nav-link" href="/">Ana Sayfa</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/sinav-takvimi">Sınav Takvimi</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/sinav-paketleri">Sınav Paketleri</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/cevap-anahtarlari">Cevap Anahtarları</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/duyurular">Duyurular</a>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" id="kurumsalDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                            Kurumsal
                        </a>
                        <ul class="dropdown-menu" aria-labelledby="kurumsalDropdown">
                            <li><a class="dropdown-item" href="/hakkimizda"><i class="bi bi-info-circle me-2"></i>Hakkımızda</a></li>
                            <li><a class="dropdown-item" href="/iletisim"><i class="bi bi-telephone me-2"></i>İletişim</a></li>
                            <li><a class="dropdown-item" href="/sinav-merkezleri"><i class="bi bi-geo-alt me-2"></i>Sınav Merkezleri</a></li>
                        </ul>
                    </li>
                    <% if (typeof user !== 'undefined' && user) { %>
                        <%
                            // Kullanıcı tipine göre dashboard URL'i belirle
                            let dashboardUrl = '/';
                            if (user.type === 'veli') {
                                dashboardUrl = '/veli/dashboard';
                            } else if (user.type === 'rehber_ogretmen') {
                                dashboardUrl = '/rehber/dashboard';
                            } else if (user.type === 'kurum_yonetici' || user.type === 'kurum' || user.type === 'kurum_admin') {
                                dashboardUrl = '/kurum/dashboard';
                            }
                        %>
                        <li class="nav-item">
                            <a class="nav-link" href="<%= dashboardUrl %>" style="color: var(--primary) !important; font-weight: 600;">
                                <i class="bi bi-person-circle"></i> <%= user.username %>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="btn btn-outline-primary btn-sm" href="/logout">Çıkış</a>
                        </li>
                    <% } else { %>
                        <li class="nav-item">
                            <a class="btn btn-primary ms-3" href="/login">
                                <i class="bi bi-box-arrow-in-right"></i> Giriş Yap
                            </a>
                        </li>
                    <% } %>
                </ul>
            </div>
        </div>
    </nav>

