<style>
    :root {
        /* ===== Ana renk: Mavi ve türevleri (kararlı palet) ===== */
        --primary: #003b78;        /* lacivert - marka */
        --primary-light: #0056b3;
        --primary-dark: #002752;
        --primary-50:  #eff6ff;
        --primary-100: #dbeafe;
        --primary-300: #93c5fd;
        --primary-500: #3b82f6;    /* canlı mavi - vurgular */
        --primary-600: #2563eb;
        --accent: #06b6d4;         /* cyan - bilgi/aksan (mavi türevi) */
        --gradient-primary: linear-gradient(135deg, #003b78 0%, #2563eb 100%);

        /* ===== Semantik (sadece anlam için: durum/rozet/uyarı) ===== */
        --success: #10b981;
        --warning: #f59e0b;
        --danger:  #ef4444;

        /* ===== Nötr (slate) ===== */
        --text: #1e293b;
        --text-muted: #64748b;
        --border: #e2e8f0;
        --bg-soft: #f8fafc;

        --secondary: #f39c12;
        --bg-light: #f8f9fa;
        --shadow: 0 2px 8px rgba(0,0,0,0.08);
        --shadow-lg: 0 8px 24px rgba(0,0,0,0.12);
        --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);

        /* ===== Tipografi Ölçeği (ortak düzen) ===== */
        --fs-2xs: 0.625rem;  /* 10px - rozet/etiket */
        --fs-xs:  0.75rem;   /* 12px - küçük not */
        --fs-sm:  0.875rem;  /* 14px - ikincil metin */
        --fs-base:1rem;      /* 16px - gövde */
        --fs-md:  1.125rem;  /* 18px - vurgulu metin */
        --fs-lg:  1.25rem;   /* 20px - kart başlığı */
        --fs-xl:  1.5rem;    /* 24px - alt başlık */
        --fs-2xl: 2rem;      /* 32px - sayfa başlığı */
        --fs-3xl: 2.5rem;    /* 40px - hero */
        --fs-4xl: 3rem;      /* 48px - büyük hero */
    }

    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        color: var(--text);
        line-height: 1.6;
        background: #f5f7fa;
        overflow-x: hidden;
        font-size: var(--fs-base);
        -webkit-text-size-adjust: 100%; /* mobil otomatik metin büyütmeyi engelle */
    }

    /* Temel başlık ölçeği (inline override yoksa geçerli) */
    h1 { font-size: var(--fs-2xl); }
    h2 { font-size: var(--fs-xl); }
    h3 { font-size: var(--fs-lg); }
    h4 { font-size: var(--fs-md); }
    h5 { font-size: var(--fs-base); }
    h6 { font-size: var(--fs-sm); }
    small, .text-small { font-size: var(--fs-sm); }

    /* ========================================
       NAVBAR - Full Responsive
       ======================================== */
    .navbar {
        background: white;
        box-shadow: var(--shadow);
        padding: clamp(10px, 2vw, 16px) 0;
        position: sticky;
        top: 0;
        z-index: 1030;
    }

    .navbar-brand {
        font-weight: 800;
        font-size: clamp(0.95rem, 2.2vw, 1.2rem);
        color: var(--primary) !important;
        display: flex;
        align-items: center;
        gap: clamp(5px, 1.2vw, 8px);
    }

    .navbar-brand i {
        font-size: clamp(1.05rem, 2.6vw, 1.4rem);
    }

    .navbar-brand span {
        white-space: nowrap;
    }

    .nav-link {
        color: var(--text) !important;
        font-weight: 500;
        padding: clamp(5px, 1vw, 7px) clamp(8px, 1.1vw, 13px) !important;
        transition: var(--transition);
        border-radius: 8px;
        font-size: clamp(0.82rem, 1.4vw, 0.94rem);
        white-space: nowrap;
    }

    .nav-link:hover {
        color: var(--primary) !important;
        background: rgba(0, 59, 120, 0.05);
    }

    /* Navbar Toggler */
    .navbar-toggler {
        border: 2px solid var(--primary);
        padding: 6px 10px;
        border-radius: 8px;
    }

    .navbar-toggler:focus {
        box-shadow: 0 0 0 3px rgba(0, 59, 120, 0.25);
    }

    .navbar-toggler-icon {
        background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 30 30'%3e%3cpath stroke='%23003b78' stroke-linecap='round' stroke-miterlimit='10' stroke-width='2' d='M4 7h22M4 15h22M4 23h22'/%3e%3c/svg%3e");
    }

    /* Dropdown Menu */
    .dropdown-menu {
        border: none;
        box-shadow: 0 4px 16px rgba(0,0,0,0.1);
        border-radius: 12px;
        padding: 8px 0;
        margin-top: 8px;
    }

    .dropdown-item {
        padding: clamp(8px, 1.5vw, 10px) clamp(14px, 2vw, 20px);
        color: var(--text);
        font-weight: 500;
        transition: var(--transition);
        display: flex;
        align-items: center;
        font-size: clamp(0.85rem, 1.8vw, 1rem);
    }

    .dropdown-item:hover {
        background: rgba(0, 59, 120, 0.05);
        color: var(--primary);
    }

    .dropdown-item i {
        color: var(--primary);
        font-size: 1rem;
    }

    .dropdown-divider {
        margin: 8px 0;
        border-color: #e8ecf0;
    }

    /* ========================================
       BUTTONS - Full Responsive
       ======================================== */
    .btn-primary {
        background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%);
        border: none;
        padding: clamp(8px, 1.5vw, 10px) clamp(16px, 3vw, 24px);
        font-weight: 600;
        border-radius: 8px;
        transition: var(--transition);
        font-size: clamp(0.85rem, 1.8vw, 1rem);
    }

    .btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: var(--shadow-lg);
        background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%);
    }

    .btn-secondary {
        background: var(--secondary);
        border: none;
        padding: clamp(8px, 1.5vw, 10px) clamp(16px, 3vw, 24px);
        font-weight: 600;
        border-radius: 8px;
        transition: var(--transition);
        font-size: clamp(0.85rem, 1.8vw, 1rem);
        color: white;
    }

    .btn-secondary:hover {
        transform: translateY(-2px);
        box-shadow: var(--shadow-lg);
        background: #e67e22;
        color: white;
    }

    .btn-outline-light {
        border: 2px solid rgba(255,255,255,0.8);
        color: white;
        padding: clamp(8px, 1.5vw, 10px) clamp(16px, 3vw, 24px);
        font-weight: 600;
        border-radius: 8px;
        transition: var(--transition);
        font-size: clamp(0.85rem, 1.8vw, 1rem);
    }

    .btn-outline-light:hover {
        background: white;
        color: var(--primary);
        transform: translateY(-2px);
    }

    .btn-outline-primary {
        border: 2px solid var(--primary);
        color: var(--primary);
        padding: clamp(6px, 1.2vw, 8px) clamp(12px, 2vw, 16px);
        font-weight: 600;
        border-radius: 8px;
        transition: var(--transition);
        font-size: clamp(0.8rem, 1.6vw, 0.9rem);
    }

    .btn-outline-primary:hover {
        background: var(--primary);
        color: white;
    }

    /* ========================================
       FOOTER in Common Styles
       ======================================== */
    footer {
        background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
        color: white;
        padding: clamp(25px, 5vw, 40px) 0 clamp(15px, 3vw, 20px);
        margin-top: clamp(40px, 6vw, 60px);
    }

    footer h5 {
        font-weight: 700;
        margin-bottom: clamp(12px, 2.5vw, 20px);
        color: white;
        font-size: clamp(1rem, 2.5vw, 1.25rem);
    }

    footer a {
        color: rgba(255,255,255,0.8);
        text-decoration: none;
        transition: var(--transition);
        display: block;
        margin-bottom: 8px;
        font-size: clamp(0.85rem, 1.8vw, 0.95rem);
    }

    footer a:hover {
        color: white;
        padding-left: 5px;
    }

    .social-links {
        display: flex;
        gap: 10px;
        margin-top: 15px;
        flex-wrap: wrap;
    }

    .social-links a {
        width: clamp(35px, 5vw, 40px);
        height: clamp(35px, 5vw, 40px);
        border-radius: 50%;
        background: rgba(255,255,255,0.1);
        display: flex;
        align-items: center;
        justify-content: center;
        transition: var(--transition);
        padding: 0;
        margin: 0;
    }

    .social-links a:hover {
        background: var(--primary);
        transform: translateY(-3px);
        padding: 0;
    }

    .footer-bottom {
        border-top: 1px solid rgba(255,255,255,0.1);
        margin-top: clamp(20px, 4vw, 30px);
        padding-top: clamp(15px, 3vw, 20px);
        text-align: center;
        color: rgba(255,255,255,0.6);
        font-size: clamp(0.8rem, 1.6vw, 0.9rem);
    }

    /* ========================================
       NAVBAR MOBILE BREAKPOINTS
       ======================================== */
    @media (max-width: 991px) {
        .navbar-collapse {
            background: white;
            padding: 15px;
            border-radius: 12px;
            margin-top: 15px;
            box-shadow: 0 4px 20px rgba(0,0,0,0.1);
        }

        .navbar-nav {
            gap: 5px;
        }

        .navbar-nav .nav-link {
            padding: 12px 16px !important;
            border-radius: 8px;
        }

        .navbar-nav .nav-link:hover {
            background: rgba(0, 59, 120, 0.08);
        }

        .navbar-nav .btn {
            margin-top: 10px;
            width: 100%;
            text-align: center;
        }

        .navbar-nav .btn-primary {
            margin-left: 0 !important;
        }

        .dropdown-menu {
            border: none;
            box-shadow: none;
            background: rgba(0, 59, 120, 0.03);
            border-radius: 8px;
            margin-top: 5px;
            padding: 5px 0;
        }

        .dropdown-item {
            padding: 10px 20px;
        }
    }

    @media (max-width: 767px) {
        .navbar-brand span {
            font-size: clamp(0.95rem, 4vw, 1.2rem);
        }

        .navbar-brand i {
            font-size: clamp(1.2rem, 5vw, 1.5rem);
        }
    }

    @media (max-width: 480px) {
        .navbar {
            padding: 8px 0;
        }

        .navbar-brand {
            gap: 6px;
        }

        .navbar-brand span {
            max-width: 150px;
            overflow: hidden;
            text-overflow: ellipsis;
        }
    }

    /* ========================================
       FOOTER MOBILE BREAKPOINTS
       ======================================== */
    @media (max-width: 767px) {
        footer {
            text-align: center;
        }

        footer .row > div {
            margin-bottom: 25px;
        }

        .social-links {
            justify-content: center;
        }

        footer div[style*="flex-direction: column"] {
            align-items: center;
        }
    }

    /* Breadcrumb (tum sayfalarda ortak) */
    .breadcrumb-container {
        background: #f8f9fa;
        padding: 16px 0;
        border-bottom: 1px solid #e0e0e0;
    }
    .breadcrumb {
        display: flex; align-items: center; gap: 8px;
        list-style: none; padding: 0; margin: 0; flex-wrap: wrap;
    }
    .breadcrumb-item { display: flex; align-items: center; gap: 8px; font-size: 1rem; }
    .breadcrumb-item a {
        color: var(--primary); text-decoration: none; transition: all 0.2s ease;
        display: flex; align-items: center; gap: 6px;
    }
    .breadcrumb-item a:hover { color: var(--primary-dark); text-decoration: underline; }
    .breadcrumb-item a i { font-size: 1rem; }
    .breadcrumb-separator { color: #999; font-size: 0.875rem; }
    .breadcrumb-item.active { color: #666; font-weight: 500; }
</style>
