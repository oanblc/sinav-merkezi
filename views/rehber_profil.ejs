<%- include('partials/header-dashboard', { title: 'Profilim - Sınav Merkezi', user: user }) %>

<style>
    .page-header {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 40px 0;
        margin: -30px -15px 40px;
        border-radius: 0 0 24px 24px;
        box-shadow: 0 8px 32px rgba(102, 126, 234, 0.3);
    }
    
    .profile-card {
        background: white;
        border-radius: 24px;
        box-shadow: 0 8px 32px rgba(0,0,0,0.08);
        overflow: hidden;
        margin-bottom: 30px;
    }
    
    .profile-header {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        padding: 40px;
        text-align: center;
        color: white;
    }
    
    .profile-avatar {
        width: 120px;
        height: 120px;
        background: white;
        border-radius: 24px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 20px;
        font-size: 3rem;
        font-weight: 800;
        color: #667eea;
        box-shadow: 0 8px 24px rgba(0,0,0,0.1);
    }
    
    .profile-body {
        padding: 40px;
    }
    
    .form-label {
        font-weight: 600;
        color: #1e293b;
        margin-bottom: 12px;
        font-size: 0.95rem;
    }
    
    .form-control-modern {
        border: 2px solid #e8ecf0;
        border-radius: 12px;
        padding: 14px 20px;
        font-size: 1rem;
        transition: all 0.3s ease;
    }
    
    .form-control-modern:focus {
        border-color: #667eea;
        box-shadow: 0 0 0 4px rgba(102, 126, 234, 0.1);
        outline: none;
    }
    
    .input-icon {
        position: absolute;
        left: 20px;
        top: 50%;
        transform: translateY(-50%);
        color: #64748b;
        font-size: 1.1rem;
    }
    
    .input-with-icon {
        padding-left: 50px !important;
    }
    
    .btn-update {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border: none;
        padding: 14px 40px;
        border-radius: 12px;
        font-weight: 600;
        font-size: 1.1rem;
        color: white;
        transition: all 0.3s ease;
    }
    
    .btn-update:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 24px rgba(102, 126, 234, 0.4);
        color: white;
    }
    
    .info-card {
        background: linear-gradient(135deg, #ecfdf5 0%, #d1fae5 100%);
        border: 2px solid #a7f3d0;
        border-radius: 16px;
        padding: 24px;
    }
    
    .stat-mini {
        background: white;
        border-radius: 12px;
        padding: 20px;
        text-align: center;
        box-shadow: 0 2px 8px rgba(0,0,0,0.05);
    }
    
    .stat-mini h3 {
        font-size: 2rem;
        font-weight: 800;
        color: #667eea;
        margin: 0;
    }
    
    .stat-mini p {
        margin: 8px 0 0;
        color: #64748b;
        font-size: 0.9rem;
    }
</style>

<!-- Page Header -->
<div class="page-header">
    <div class="container">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <h1 style="font-weight: 800; margin-bottom: 8px;">
                    <i class="bi bi-person-circle"></i> Profilim
                </h1>
                <p style="opacity: 0.9; margin: 0;">Kişisel bilgilerinizi görüntüleyin ve güncelleyin</p>
            </div>
            <a href="/rehber/dashboard" class="btn btn-light btn-lg" style="border-radius: 12px; font-weight: 600;">
                <i class="bi bi-arrow-left"></i> Dashboard
            </a>
        </div>
    </div>
</div>

<% if (error) { %>
<div class="alert alert-danger alert-dismissible fade show" role="alert" style="border-radius: 12px;">
    <i class="bi bi-exclamation-triangle"></i> <%= error %>
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
</div>
<% } %>

<% if (success) { %>
<div class="alert alert-success alert-dismissible fade show" role="alert" style="border-radius: 12px;">
    <i class="bi bi-check-circle"></i> <%= success %>
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
</div>
<% } %>

<div class="row">
    <!-- Profil Kartı -->
    <div class="col-lg-8">
        <div class="profile-card">
            <div class="profile-header">
                <div class="profile-avatar">
                    <% if (kullanici.ad_soyad) { %>
                        <%= kullanici.ad_soyad.split(' ').map(n => n.charAt(0)).join('').toUpperCase() %>
                    <% } else { %>
                        <%= kullanici.username.charAt(0).toUpperCase() %>
                    <% } %>
                </div>
                <h3 style="font-weight: 700; margin-bottom: 8px;">
                    <%= kullanici.ad_soyad || kullanici.username %>
                </h3>
                <p style="opacity: 0.9; margin: 0;">
                    <i class="bi bi-briefcase"></i> Rehber Öğretmen
                </p>
            </div>
            
            <div class="profile-body">
                <form method="POST" action="/rehber/profil">
                    <div class="row">
                        <div class="col-md-6 mb-4">
                            <label class="form-label">
                                <i class="bi bi-person"></i> Ad Soyad <span class="text-danger">*</span>
                            </label>
                            <div class="position-relative">
                                <i class="input-icon bi bi-person-fill"></i>
                                <input type="text" name="ad_soyad" class="form-control form-control-modern input-with-icon" 
                                       value="<%= kullanici.ad_soyad || '' %>" placeholder="Adınız Soyadınız" required>
                            </div>
                        </div>

                        <div class="col-md-6 mb-4">
                            <label class="form-label">
                                <i class="bi bi-building"></i> Kurum <span class="text-danger">*</span>
                            </label>
                            <div class="position-relative">
                                <i class="input-icon bi bi-building-fill"></i>
                                <input type="text" name="kurum" class="form-control form-control-modern input-with-icon" 
                                       value="<%= kullanici.kurum || '' %>" placeholder="Çalıştığınız kurum" required>
                            </div>
                        </div>

                        <div class="col-md-6 mb-4">
                            <label class="form-label">
                                <i class="bi bi-telephone"></i> Telefon <span class="text-danger">*</span>
                            </label>
                            <div class="position-relative">
                                <i class="input-icon bi bi-telephone-fill"></i>
                                <input type="tel" name="telefon" class="form-control form-control-modern input-with-icon" 
                                       value="<%= kullanici.telefon || '' %>" placeholder="0555 555 55 55" required>
                            </div>
                        </div>

                        <div class="col-md-6 mb-4">
                            <label class="form-label">
                                <i class="bi bi-book"></i> Branş (Öğretmenlik Alanı) <span class="text-danger">*</span>
                            </label>
                            <div class="position-relative">
                                <i class="input-icon bi bi-book-fill"></i>
                                <select name="brans" class="form-control form-control-modern input-with-icon" required>
                                    <option value="">Seçiniz</option>
                                    <option value="Rehber Öğretmen" <%= kullanici.brans === 'Rehber Öğretmen' ? 'selected' : '' %>>Rehber Öğretmen</option>
                                    <option value="Matematik" <%= kullanici.brans === 'Matematik' ? 'selected' : '' %>>Matematik</option>
                                    <option value="Fizik" <%= kullanici.brans === 'Fizik' ? 'selected' : '' %>>Fizik</option>
                                    <option value="Kimya" <%= kullanici.brans === 'Kimya' ? 'selected' : '' %>>Kimya</option>
                                    <option value="Biyoloji" <%= kullanici.brans === 'Biyoloji' ? 'selected' : '' %>>Biyoloji</option>
                                    <option value="Türk Dili ve Edebiyatı" <%= kullanici.brans === 'Türk Dili ve Edebiyatı' ? 'selected' : '' %>>Türk Dili ve Edebiyatı</option>
                                    <option value="İngilizce" <%= kullanici.brans === 'İngilizce' ? 'selected' : '' %>>İngilizce</option>
                                    <option value="Tarih" <%= kullanici.brans === 'Tarih' ? 'selected' : '' %>>Tarih</option>
                                    <option value="Coğrafya" <%= kullanici.brans === 'Coğrafya' ? 'selected' : '' %>>Coğrafya</option>
                                    <option value="Felsefe" <%= kullanici.brans === 'Felsefe' ? 'selected' : '' %>>Felsefe</option>
                                    <option value="Din Kültürü ve Ahlak Bilgisi" <%= kullanici.brans === 'Din Kültürü ve Ahlak Bilgisi' ? 'selected' : '' %>>Din Kültürü ve Ahlak Bilgisi</option>
                                    <option value="Görsel Sanatlar" <%= kullanici.brans === 'Görsel Sanatlar' ? 'selected' : '' %>>Görsel Sanatlar</option>
                                    <option value="Müzik" <%= kullanici.brans === 'Müzik' ? 'selected' : '' %>>Müzik</option>
                                    <option value="Beden Eğitimi" <%= kullanici.brans === 'Beden Eğitimi' ? 'selected' : '' %>>Beden Eğitimi</option>
                                    <option value="Bilişim Teknolojileri" <%= kullanici.brans === 'Bilişim Teknolojileri' ? 'selected' : '' %>>Bilişim Teknolojileri</option>
                                </select>
                            </div>
                        </div>

                        <div class="col-md-6 mb-4">
                            <label class="form-label">
                                <i class="bi bi-envelope"></i> E-posta
                            </label>
                            <div class="position-relative">
                                <i class="input-icon bi bi-envelope-fill"></i>
                                <input type="email" class="form-control form-control-modern input-with-icon" 
                                       value="<%= kullanici.email %>" disabled style="background: #f8fafc;">
                            </div>
                            <small class="text-muted">E-posta değiştirilemez</small>
                        </div>

                        <div class="col-md-6 mb-4">
                            <label class="form-label">
                                <i class="bi bi-mortarboard"></i> Mezuniyet
                            </label>
                            <div class="position-relative">
                                <i class="input-icon bi bi-mortarboard-fill"></i>
                                <input type="text" name="mezuniyet" class="form-control form-control-modern input-with-icon" 
                                       value="<%= kullanici.mezuniyet || '' %>" placeholder="Örn: Ankara Üniversitesi">
                            </div>
                        </div>
                    </div>

                    <div class="d-flex gap-3 mt-4">
                        <button type="submit" class="btn btn-update flex-grow-1">
                            <i class="bi bi-check-circle"></i> Profili Güncelle
                        </button>
                        <a href="/rehber/dashboard" class="btn btn-outline-secondary" style="padding: 14px 32px; border-radius: 12px; font-weight: 600;">
                            İptal
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Yan Bilgiler -->
    <div class="col-lg-4">
        <div class="info-card mb-4">
            <h5 style="color: #065f46; font-weight: 700; margin-bottom: 16px;">
                <i class="bi bi-info-circle-fill"></i> Hesap Bilgileri
            </h5>
            <div style="color: #047857;">
                <p style="margin-bottom: 12px;">
                    <strong>Kullanıcı Adı:</strong><br>
                    <span style="font-size: 1.1rem; font-weight: 600;"><%= kullanici.username %></span>
                </p>
                <p style="margin-bottom: 12px;">
                    <strong>Hesap Türü:</strong><br>
                    <span class="badge bg-success" style="font-size: 0.9rem;">Rehber Öğretmen</span>
                </p>
                <% if (kullanici.brans) { %>
                <p style="margin-bottom: 12px;">
                    <strong>Branş:</strong><br>
                    <span class="badge bg-primary" style="font-size: 0.9rem;"><%= kullanici.brans %></span>
                </p>
                <% } %>
                <p style="margin: 0;">
                    <strong>Kayıt Tarihi:</strong><br>
                    <%= new Date(kullanici.created_at).toLocaleDateString('tr-TR') %>
                </p>
            </div>
        </div>
        
        <div class="alert alert-warning" style="border-radius: 12px; border: 2px solid #fbbf24;">
            <strong><i class="bi bi-exclamation-triangle"></i> Önemli!</strong><br>
            <small>
                <span class="text-danger">*</span> ile işaretli alanlar zorunludur. 
                Öğrenci ekleyebilmek için tüm zorunlu alanları doldurmalısınız (Ad Soyad, Kurum, Telefon, Branş).
            </small>
        </div>

        <div class="row g-3">
            <div class="col-12">
                <div class="stat-mini">
                    <i class="bi bi-calendar-check" style="font-size: 2rem; color: #667eea; margin-bottom: 8px;"></i>
                    <h3><%= Math.floor((new Date() - new Date(kullanici.created_at)) / (1000 * 60 * 60 * 24)) %></h3>
                    <p>Gün Sistemde</p>
                </div>
            </div>
        </div>

    </div>
</div>

<%- include('partials/footer-dashboard') %>

