<%- include('partials/header-dashboard', { title: 'Veli Paneli - Sınav Merkezi', user: user, activePage: 'dashboard' }) %>
<%- include('partials/veli-panel-styles') %>

<style>
    /* Dashboard Header - Mobil Oncelikli */
    .vp-dashboard-header {
        background: linear-gradient(135deg, var(--vp-primary) 0%, var(--vp-primary-light) 100%);
        color: white;
        padding: clamp(16px, 4vw, 24px) 0;
        margin: -20px -12px clamp(16px, 4vw, 24px);
        border-radius: 0 0 var(--vp-radius-lg) var(--vp-radius-lg);
    }

    .vp-dashboard-header h2 {
        font-size: clamp(1.1rem, 4vw, 1.4rem);
        font-weight: 700;
        margin-bottom: 4px;
    }

    .vp-dashboard-header p {
        font-size: clamp(0.85rem, 3vw, 0.95rem);
        opacity: 0.9;
        margin: 0;
    }

    /* Ogrenci Karti - Mobil Oncelikli */
    .vp-student-card {
        background: white;
        border-radius: var(--vp-radius-lg);
        padding: clamp(14px, 3vw, 20px);
        margin-bottom: 12px;
        box-shadow: var(--vp-shadow-md);
        border: 1px solid var(--vp-border);
    }

    .vp-student-avatar {
        width: clamp(44px, 10vw, 52px);
        height: clamp(44px, 10vw, 52px);
        background: linear-gradient(135deg, var(--vp-primary) 0%, var(--vp-primary-light) 100%);
        border-radius: var(--vp-radius-md);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: clamp(1.1rem, 4vw, 1.4rem);
        font-weight: 700;
        color: white;
        flex-shrink: 0;
    }

    .vp-student-info {
        flex: 1;
        min-width: 0;
    }

    .vp-student-name {
        font-weight: 700;
        color: var(--vp-text);
        font-size: clamp(0.95rem, 3.5vw, 1.05rem);
        margin-bottom: 4px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .vp-student-meta {
        font-size: clamp(0.75rem, 2.8vw, 0.85rem);
        color: var(--vp-text-muted);
    }

    /* Aksiyon Butonlari - 48px touch target */
    .vp-student-actions {
        display: flex;
        gap: 8px;
        margin-top: 12px;
        padding-top: 12px;
        border-top: 1px solid var(--vp-border);
    }

    .vp-student-actions .vp-btn {
        flex: 1;
        justify-content: center;
    }

    /* Desktop: Butonlar yatay hizada */
    @media (min-width: 576px) {
        .vp-student-card {
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .vp-student-actions {
            margin-top: 0;
            padding-top: 0;
            border-top: none;
            flex: 0 0 auto;
            margin-left: auto;
        }

        .vp-student-actions .vp-btn {
            flex: none;
        }
    }
</style>

<!-- Dashboard Header -->
<div class="vp-dashboard-header">
    <div class="container">
        <h2><i class="bi bi-house-heart-fill"></i> Veli Paneli</h2>
        <p><%= ogrenciler.length %> Ogrenci</p>
    </div>
</div>

<div class="container">
    <!-- Hizli Erisim Butonlari -->
    <div class="row g-3 mb-4">
        <div class="col-6">
            <a href="/veli/tum-sinav-takvimi" class="vp-quick-action" style="--action-color: #8b5cf6;">
                <i class="bi bi-calendar-event"></i>
                <span>Sinav Takvimi</span>
            </a>
        </div>
        <div class="col-6">
            <a href="/veli/sinav-sonuclari" class="vp-quick-action" style="--action-color: #10b981;">
                <i class="bi bi-file-earmark-text-fill"></i>
                <span>Sinav Sonuclari</span>
            </a>
        </div>
    </div>

    <!-- Ogrenciler Bolumu -->
    <div class="vp-section-title">
        <i class="bi bi-people"></i>
        <span>Ogrencilerim</span>
    </div>

    <% if (ogrenciler && ogrenciler.length > 0) { %>
        <% ogrenciler.forEach(function(ogrenci) { %>
        <div class="vp-student-card">
            <div class="d-flex align-items-center gap-3 flex-grow-1" style="min-width: 0;">
                <div class="vp-student-avatar">
                    <%= ogrenci.ad_soyad.charAt(0).toUpperCase() %>
                </div>
                <div class="vp-student-info">
                    <div class="vp-student-name"><%= ogrenci.ad_soyad %></div>
                    <div class="vp-student-meta">
                        <% if (ogrenci.sinif) { %>
                            <span class="vp-badge vp-badge-primary"><i class="bi bi-book"></i> <%= ogrenci.sinif %></span>
                        <% } %>
                        <% if (ogrenci.tc_no) { %>
                            <span class="vp-badge vp-badge-info"><i class="bi bi-card-text"></i> TC: <%= ogrenci.tc_no.substring(0,3) %>***</span>
                        <% } %>
                    </div>
                </div>
            </div>
            <div class="vp-student-actions">
                <a href="/veli/ogrenci-duzenle/<%= ogrenci.id %>" class="vp-btn vp-btn-warning vp-btn-sm">
                    <i class="bi bi-pencil-square"></i>
                    <span class="d-none d-sm-inline">Duzenle</span>
                </a>
                <button type="button" class="vp-btn vp-btn-danger vp-btn-sm" onclick="silOnayi(<%= ogrenci.id %>, '<%= ogrenci.ad_soyad %>')">
                    <i class="bi bi-trash3"></i>
                    <span class="d-none d-sm-inline">Sil</span>
                </button>
            </div>
        </div>
        <% }); %>
    <% } else { %>
        <div class="vp-empty">
            <i class="bi bi-person-x"></i>
            <h4>Henuz Ogrenci Yok</h4>
            <p>Henuz kayitli ogrenci bulunmamaktadir. Asagidaki butonla ogrenci ekleyebilirsiniz.</p>
            <a href="/veli/ogrenci-ekle" class="vp-btn vp-btn-success">
                <i class="bi bi-person-plus-fill"></i> Ilk Ogrenciyi Ekle
            </a>
        </div>
    <% } %>
</div>

<!-- Silme Onay Modal -->
<div class="modal fade" id="silModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border-radius: var(--vp-radius-lg); border: none;">
            <div class="modal-header" style="background: var(--vp-danger); color: white; border: none; border-radius: var(--vp-radius-lg) var(--vp-radius-lg) 0 0;">
                <h5 class="modal-title"><i class="bi bi-exclamation-triangle"></i> Ogrenci Sil</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" style="padding: 24px;">
                <p style="font-size: 1rem;" id="silMesaj"></p>
                <p style="color: var(--vp-text-muted); font-size: 0.9rem;">Bu islem geri alinamaz!</p>
            </div>
            <div class="modal-footer" style="border: none; gap: 8px;">
                <button type="button" class="vp-btn vp-btn-secondary" data-bs-dismiss="modal">Iptal</button>
                <form id="silForm" method="POST" style="display: inline;">
                    <button type="submit" class="vp-btn vp-btn-danger">
                        <i class="bi bi-trash-fill"></i> Evet, Sil
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
function silOnayi(ogrenciId, ogrenciAd) {
    document.getElementById('silMesaj').textContent = ogrenciAd + ' ogrencisini silmek istediginizden emin misiniz?';
    document.getElementById('silForm').action = '/veli/ogrenci-sil/' + ogrenciId;
    const modal = new bootstrap.Modal(document.getElementById('silModal'));
    modal.show();
}
</script>

<%- include('partials/footer-dashboard', { user: user, activePage: 'dashboard' }) %>
