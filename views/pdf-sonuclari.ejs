<%- include('partials/header-dashboard', { title: 'PDF Sınav Sonuçları - ' + ogrenci.ad_soyad + ' - Sınav Merkezi', user: user }) %>

<div class="row mb-4">
    <div class="col-12">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <h2>
                    <i class="bi bi-file-earmark-pdf"></i> PDF Sınav Sonuçları
                </h2>
                <p class="text-muted mb-0">
                    <i class="bi bi-person-circle"></i> Öğrenci: <strong><%= ogrenci.ad_soyad %></strong>
                </p>
            </div>
            <a href="/veli/dashboard" class="btn btn-secondary">
                <i class="bi bi-arrow-left"></i> Geri Dön
            </a>
        </div>
    </div>
</div>

<% if (pdf_sonuclari && pdf_sonuclari.length > 0) { %>
<div class="row">
    <% pdf_sonuclari.forEach(function(sonuc, index) { %>
    <div class="col-md-6 mb-4">
        <div class="card h-100 shadow-sm">
            <div class="card-header bg-danger text-white">
                <h5 class="mb-0">
                    <i class="bi bi-file-pdf"></i> <%= sonuc.sinav_adi %>
                </h5>
            </div>
            <div class="card-body">
                <div class="row mb-3">
                    <div class="col-6">
                        <p class="mb-2">
                            <strong><i class="bi bi-calendar3"></i> Sınav Tarihi:</strong><br>
                            <span class="text-muted"><%= new Date(sonuc.sinav_tarihi).toLocaleDateString('tr-TR') %></span>
                        </p>
                    </div>
                    <div class="col-6">
                        <p class="mb-2">
                            <strong><i class="bi bi-clock"></i> Yüklenme:</strong><br>
                            <span class="text-muted"><%= new Date(sonuc.created_at).toLocaleDateString('tr-TR') %></span>
                        </p>
                    </div>
                </div>

                <% if (sonuc.sinav_turu) { %>
                <div class="mb-3">
                    <span class="badge bg-primary"><%= sonuc.sinav_turu %></span>
                </div>
                <% } %>

                <div class="mb-3">
                    <div class="row">
                        <% if (sonuc.numara) { %>
                        <div class="col-6">
                            <p class="mb-2">
                                <strong>📋 Numara:</strong><br>
                                <%= sonuc.numara %>
                            </p>
                        </div>
                        <% } %>
                        <% if (sonuc.sinif) { %>
                        <div class="col-6">
                            <p class="mb-2">
                                <strong>🎓 Sınıf:</strong><br>
                                <%= sonuc.sinif %>
                            </p>
                        </div>
                        <% } %>
                    </div>
                </div>

                <% if (sonuc.puan) { %>
                <div class="alert alert-success mb-3">
                    <h4 class="mb-0">
                        <i class="bi bi-trophy-fill"></i> Puan: <strong><%= sonuc.puan %></strong>
                    </h4>
                </div>
                <% } %>
            </div>
            <div class="card-footer bg-light">
                <button class="btn btn-primary btn-sm w-100" onclick="pdfGoster('<%= sonuc.pdf_path %>')">
                    <i class="bi bi-file-pdf"></i> PDF'i Görüntüle
                </button>
            </div>
        </div>
    </div>
    <% }); %>
</div>
<% } else { %>
<div class="row">
    <div class="col-12">
        <div class="alert alert-info">
            <i class="bi bi-info-circle"></i> Bu öğrenci için henüz PDF sınav sonucu yüklenmemiş.
        </div>
    </div>
</div>
<% } %>

<!-- PDF Modal -->
<div class="modal fade" id="pdfModal" tabindex="-1">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">PDF Görüntüleyici</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div id="pdfViewer" style="width: 100%; height: 70vh;">
                    <iframe id="pdfIframe" style="width: 100%; height: 100%; border: none;"></iframe>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Kapat</button>
            </div>
        </div>
    </div>
</div>

<script>
function pdfGoster(pdfPath) {
    // PDF yolunu temizle ve göreceli yol oluştur
    const cleanPath = pdfPath.replace(/\\/g, '/');
    const pdfUrl = '/' + cleanPath;
    
    // Modal'ı göster
    const modal = new bootstrap.Modal(document.getElementById('pdfModal'));
    document.getElementById('pdfIframe').src = pdfUrl;
    modal.show();
}

// Modal kapandığında iframe'i temizle
document.getElementById('pdfModal').addEventListener('hidden.bs.modal', function () {
    document.getElementById('pdfIframe').src = '';
});
</script>

<%- include('partials/footer-dashboard') %>
