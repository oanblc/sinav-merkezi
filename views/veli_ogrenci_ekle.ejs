<%- include('partials/header-dashboard', { title: 'Öğrenci Ekle - Sınav Merkezi', user: user }) %>

<style>
    .page-header {
        background: linear-gradient(135deg, #10b981 0%, #059669 100%);
        color: white;
        padding: 40px 0;
        margin: -30px -15px 40px;
        border-radius: 0 0 24px 24px;
        box-shadow: 0 8px 32px rgba(16, 185, 129, 0.3);
    }
    
    .form-card {
        background: white;
        border-radius: 24px;
        box-shadow: 0 8px 32px rgba(0,0,0,0.08);
        overflow: hidden;
    }
    
    .form-body {
        padding: 40px;
    }
    
    .form-label {
        font-weight: 600;
        color: #1e293b;
        margin-bottom: 12px;
        font-size: 0.95rem;
    }
    
    .form-control-modern {
        border: 2px solid #e8ecf0;
        border-radius: 12px;
        padding: 14px 20px;
        font-size: 1rem;
        transition: all 0.3s ease;
    }
    
    .form-control-modern:focus {
        border-color: #10b981;
        box-shadow: 0 0 0 4px rgba(16, 185, 129, 0.1);
        outline: none;
    }
    
    .btn-submit {
        background: linear-gradient(135deg, #10b981 0%, #059669 100%);
        border: none;
        padding: 14px 40px;
        border-radius: 12px;
        font-weight: 600;
        font-size: 1.1rem;
        color: white;
        transition: all 0.3s ease;
    }
    
    .btn-submit:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 24px rgba(16, 185, 129, 0.4);
        color: white;
    }
    
    .info-card {
        background: linear-gradient(135deg, #dbeafe 0%, #bfdbfe 100%);
        border: 2px solid #93c5fd;
        border-radius: 16px;
        padding: 24px;
        margin-bottom: 20px;
    }
</style>

<!-- Page Header -->
<div class="page-header">
    <div class="container">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <h1 style="font-weight: 800; margin-bottom: 8px;">
                    <i class="bi bi-person-plus-fill"></i> Öğrenci Ekle
                </h1>
                <p style="opacity: 0.9; margin: 0;">Öğrencinizin bilgilerini girerek sisteme ekleyin</p>
            </div>
            <a href="/veli/dashboard" class="btn btn-light btn-lg" style="border-radius: 12px; font-weight: 600;">
                <i class="bi bi-arrow-left"></i> İptal
            </a>
        </div>
    </div>
</div>

<% if (error) { %>
<div class="alert alert-danger alert-dismissible fade show" role="alert" style="border-radius: 12px;">
    <i class="bi bi-exclamation-triangle"></i> <%= error %>
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
</div>
<% } %>

<% if (success) { %>
<div class="alert alert-success alert-dismissible fade show" role="alert" style="border-radius: 12px;">
    <i class="bi bi-check-circle"></i> <%= success %>
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
</div>
<% } %>

<div class="row">
    <!-- Form -->
    <div class="col-lg-8">
        <div class="form-card">
            <div class="form-body">
                <form method="POST" action="/veli/ogrenci-ekle">
                    <div class="row">
                        <div class="col-md-6 mb-4">
                            <label class="form-label">
                                <i class="bi bi-person"></i> Öğrenci Adı Soyadı <span class="text-danger">*</span>
                            </label>
                            <input type="text" name="ad_soyad" class="form-control form-control-modern" 
                                   placeholder="Örn: Ahmet Yılmaz" required>
                        </div>

                        <div class="col-md-6 mb-4">
                            <label class="form-label">
                                <i class="bi bi-card-text"></i> T.C. Kimlik No
                            </label>
                            <input type="text" name="tc_no" class="form-control form-control-modern" 
                                   placeholder="11 haneli TC No" maxlength="11">
                            <small class="text-muted">Opsiyonel</small>
                        </div>

                        <div class="col-md-6 mb-4">
                            <label class="form-label">
                                <i class="bi bi-phone"></i> Öğrenci Cep Telefonu
                            </label>
                            <input type="tel" name="telefon" class="form-control form-control-modern" 
                                   placeholder="0555 555 55 55">
                            <small class="text-muted">Opsiyonel</small>
                        </div>

                        <div class="col-md-6 mb-4">
                            <label class="form-label">
                                <i class="bi bi-building"></i> Okul / Mezun Bilgisi <span class="text-danger">*</span>
                            </label>
                            <input type="text" name="okul" class="form-control form-control-modern" 
                                   placeholder="Örn: Atatürk Lisesi" required>
                        </div>

                        <div class="col-md-12 mb-4">
                            <label class="form-label">
                                <i class="bi bi-book"></i> Sınıf <span class="text-danger">*</span>
                            </label>
                            <select name="sinif" class="form-control form-control-modern" required>
                                <option value="">Seçiniz...</option>
                                <option value="9. Sınıf">9. Sınıf</option>
                                <option value="10. Sınıf">10. Sınıf</option>
                                <option value="11. Sınıf">11. Sınıf</option>
                                <option value="12. Sınıf">12. Sınıf</option>
                                <option value="Mezun">Mezun</option>
                            </select>
                        </div>
                    </div>

                    <div class="d-flex gap-3 mt-4">
                        <button type="submit" class="btn btn-submit flex-grow-1">
                            <i class="bi bi-check-circle"></i> Öğrenci Ekle
                        </button>
                        <a href="/veli/dashboard" class="btn btn-outline-secondary" style="padding: 14px 32px; border-radius: 12px; font-weight: 600;">
                            İptal
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Bilgi Kartı -->
    <div class="col-lg-4">
        <div class="info-card">
            <h5 style="color: #1e40af; font-weight: 700; margin-bottom: 16px;">
                <i class="bi bi-info-circle-fill"></i> Zorunlu Alanlar
            </h5>
            <ul style="color: #1e40af; margin: 0; padding-left: 20px;">
                <li class="mb-2"><strong>Öğrenci Adı Soyadı</strong> - Zorunlu</li>
                <li class="mb-2"><strong>Okul / Mezun Bilgisi</strong> - Zorunlu</li>
                <li class="mb-2"><strong>Sınıf</strong> - Zorunlu</li>
            </ul>
        </div>
        
        <div class="info-card" style="background: linear-gradient(135deg, #ecfdf5 0%, #d1fae5 100%); border-color: #a7f3d0;">
            <h5 style="color: #065f46; font-weight: 700; margin-bottom: 16px;">
                <i class="bi bi-lightbulb-fill"></i> Opsiyonel Alanlar
            </h5>
            <ul style="color: #047857; margin: 0; padding-left: 20px;">
                <li class="mb-2">TC Kimlik No</li>
                <li>Cep Telefonu</li>
            </ul>
        </div>
    </div>
</div>

<%- include('partials/footer-dashboard') %>
