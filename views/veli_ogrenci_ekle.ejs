<%- include('partials/header-dashboard', { title: 'Öğrenci Ekle - Sınav Merkezi', user: user }) %>
<%- include('partials/veli-panel-styles') %>

<style>
    /* Sayfa Header - Yesil tema */
    .vp-add-header {
        background: linear-gradient(135deg, #003b78 0%, #2563eb 100%);
        color: white;
        padding: clamp(16px, 4vw, 24px) 0;
        margin: -20px -12px clamp(16px, 4vw, 24px);
        border-radius: 0 0 var(--vp-radius-lg) var(--vp-radius-lg);
    }

    .vp-add-header h2 {
        font-size: clamp(1.1rem, 4vw, 1.4rem);
        font-weight: 700;
        margin-bottom: 4px;
    }

    .vp-add-header p {
        font-size: clamp(0.85rem, 3vw, 0.95rem);
        opacity: 0.9;
        margin: 0;
    }

    /* Info Box Yesil */
    .vp-info-green {
        background: linear-gradient(135deg, #ecfdf5 0%, #d1fae5 100%);
        border: 2px solid #a7f3d0;
        border-radius: var(--vp-radius);
        padding: clamp(14px, 3vw, 20px);
        margin-bottom: 16px;
    }

    .vp-info-green h5 {
        color: #065f46;
        font-weight: 700;
        font-size: clamp(0.9rem, 3.2vw, 1rem);
        margin-bottom: 12px;
    }

    .vp-info-green ul {
        color: #047857;
        margin: 0;
        padding-left: 20px;
        font-size: clamp(0.8rem, 3vw, 0.9rem);
    }

    .vp-info-green li {
        margin-bottom: 6px;
    }

    /* Info Box Mavi */
    .vp-info-blue {
        background: linear-gradient(135deg, #dbeafe 0%, #bfdbfe 100%);
        border: 2px solid #93c5fd;
        border-radius: var(--vp-radius);
        padding: clamp(14px, 3vw, 20px);
        margin-bottom: 16px;
    }

    .vp-info-blue h5 {
        color: #1e40af;
        font-weight: 700;
        font-size: clamp(0.9rem, 3.2vw, 1rem);
        margin-bottom: 12px;
    }

    .vp-info-blue ul {
        color: #1e40af;
        margin: 0;
        padding-left: 20px;
        font-size: clamp(0.8rem, 3vw, 0.9rem);
    }

    .vp-info-blue li {
        margin-bottom: 6px;
    }
</style>

<!-- Page Header -->
<div class="vp-add-header">
    <div class="container">
        <h2><i class="bi bi-person-plus-fill"></i> Öğrenci Ekle</h2>
        <p>Öğrenci bilgilerini girerek sisteme ekleyin</p>
    </div>
</div>

<div class="container">
    <% if (error) { %>
    <div class="alert alert-danger alert-dismissible fade show" role="alert" style="border-radius: var(--vp-radius); font-size: 0.875rem;">
        <i class="bi bi-exclamation-triangle"></i> <%= error %>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
    <% } %>

    <% if (success) { %>
    <div class="alert alert-success alert-dismissible fade show" role="alert" style="border-radius: var(--vp-radius); font-size: 0.875rem;">
        <i class="bi bi-check-circle"></i> <%= success %>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
    <% } %>

    <div class="row">
        <!-- Mobilde info kartlari uste cikar -->
        <div class="col-lg-4 order-lg-2 mb-4">
            <div class="vp-info-blue">
                <h5><i class="bi bi-info-circle-fill"></i> Zorunlu Alanlar</h5>
                <ul>
                    <li><strong>Ad Soyad</strong> - Zorunlu</li>
                    <li><strong>Okul / Mezun</strong> - Zorunlu</li>
                    <li><strong>Sınıf</strong> - Zorunlu</li>
                </ul>
            </div>

            <div class="vp-info-green">
                <h5><i class="bi bi-lightbulb-fill"></i> Opsiyonel Alanlar</h5>
                <ul>
                    <li>TC Kimlik No</li>
                    <li>Cep Telefonu</li>
                </ul>
            </div>
        </div>

        <!-- Form -->
        <div class="col-lg-8 order-lg-1">
            <div class="vp-card">
                <form method="POST" action="/veli/ogrenci-ekle">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="vp-form-group">
                                <label><i class="bi bi-person"></i> Öğrenci Adı Soyadı *</label>
                                <input type="text" name="ad_soyad" class="vp-form-control"
                                       placeholder="Orn: Ahmet Yilmaz" required>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="vp-form-group">
                                <label><i class="bi bi-card-text"></i> T.C. Kimlik No</label>
                                <input type="text" name="tc_no" class="vp-form-control"
                                       placeholder="11 haneli TC No" maxlength="11">
                                <small style="color: var(--vp-text-muted); font-size: 0.75rem;">Opsiyonel</small>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="vp-form-group">
                                <label><i class="bi bi-phone"></i> Öğrenci Cep Telefonu</label>
                                <input type="tel" name="telefon" class="vp-form-control"
                                       placeholder="0555 555 55 55">
                                <small style="color: var(--vp-text-muted); font-size: 0.75rem;">Opsiyonel</small>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="vp-form-group">
                                <label><i class="bi bi-building"></i> Okul / Mezun Bilgisi *</label>
                                <input type="text" name="okul" class="vp-form-control"
                                       placeholder="Orn: Ataturk Lisesi" required>
                            </div>
                        </div>

                        <div class="col-12">
                            <div class="vp-form-group">
                                <label><i class="bi bi-book"></i> Sınıf *</label>
                                <select name="sinif" class="vp-form-control" required>
                                    <option value="">Seçiniz...</option>
                                    <option value="9. Sinif">9. Sınıf</option>
                                    <option value="10. Sinif">10. Sınıf</option>
                                    <option value="11. Sinif">11. Sınıf</option>
                                    <option value="12. Sinif">12. Sınıf</option>
                                    <option value="Mezun">Mezun</option>
                                </select>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex gap-2 flex-wrap mt-3">
                        <button type="submit" class="vp-btn vp-btn-success flex-grow-1">
                            <i class="bi bi-check-circle"></i> Öğrenci Ekle
                        </button>
                        <a href="/veli/dashboard" class="vp-btn vp-btn-secondary">
                            <i class="bi bi-arrow-left"></i> Iptal
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<%- include('partials/footer-dashboard') %>
