        </div>
        
        <!-- PDF Önizleme Modalı -->
        <div class="modal fade" id="pdfOnizlemeModal" tabindex="-1">
            <div class="modal-dialog modal-fullscreen">
                <div class="modal-content">
                    <div class="modal-header bg-primary text-white">
                        <h5 class="modal-title">
                            <i class="bi bi-eye-fill"></i> PDF Önizleme
                        </h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body p-0">
                        <iframe id="pdfOnizlemeIframe" style="width: 100%; height: 100%; border: none;"></iframe>
                    </div>
                </div>
            </div>
        </div>
        `;
        
        // Eski modalı temizle
        const oldModal = document.getElementById('kalanOgrenciModal');
        if (oldModal) oldModal.remove();
        const oldPreview = document.getElementById('pdfOnizlemeModal');
        if (oldPreview) oldPreview.remove();
        
        // Yeni modalı ekle
        document.body.insertAdjacentHTML('beforeend', modalHTML);
        
        // Modalı göster
        new bootstrap.Modal(document.getElementById('kalanOgrenciModal')).show();
        
    } catch (error) {
        console.error('PDF listeleme hatası:', error);
        alert('❌ Bir hata oluştu!');
    }
}

// PDF önizle (mevcut PDF dosyasını aç)
function pdfOnizleVeEslestir(pdfIndex) {
    const pdf = window.eslesmemisPdfler[pdfIndex];
    
    if (!pdf.pdf_path) {
        alert('❌ PDF dosyası bulunamadı!');
        return;
    }
    
    // PDF önizlemesini aç
    const pdfUrl = `/${pdf.pdf_path.replace(/\\/g, '/')}`;
    document.getElementById('pdfOnizlemeIframe').src = pdfUrl;
    
    // Önizleme modalını aç
    new bootstrap.Modal(document.getElementById('pdfOnizlemeModal')).show();
}

// PDF'i seçilen öğrenciye ata
// Yeni eşleşmeyen modal için fonksiyonlar
function yukleCurrentPdf() {
    const pdf = window.eslesmemisPdfler[window.currentPdfIndex];
    const infoDiv = document.getElementById('pdfBilgi');
    
    // PDF yolu varsa göster (BİLİNMEYEN olanların da PDF'i var!)
    if (pdf && pdf.pdf_path && pdf.pdf_path.trim() !== '') {
        const pdfUrl = `/${pdf.pdf_path.replace(/\\/g, '/')}`;
        document.getElementById('pdfOnizleme').src = pdfUrl;
        
        // Bilgilendirme
        if (infoDiv) {
            infoDiv.innerHTML = `
                <div class="alert alert-warning mb-0" style="font-size: 0.9rem; padding: 8px 12px;">
                    <i class="bi bi-exclamation-triangle"></i> 
                    <strong>Eşleşmemiş PDF</strong> - 
                    Bu sayfa "${pdf.ad_soyad}" olarak işaretlenmiş. 
                    Sağ taraftan doğru öğrenciyi seçin.
                </div>
            `;
        }
    } 
    // PDF yolu yoksa orijinal PDF'i göster
    else if (window.orijinalPdfYolu) {
        const orijinalUrl = `/${window.orijinalPdfYolu.replace(/\\/g, '/')}`;
        document.getElementById('pdfOnizleme').src = orijinalUrl;
        
        if (infoDiv) {
            infoDiv.innerHTML = `
                <div class="alert alert-info mb-0" style="font-size: 0.9rem; padding: 8px 12px;">
                    <i class="bi bi-info-circle"></i> 
                    <strong>Orijinal PDF</strong> - 
                    "${pdf.ad_soyad}" için henüz sayfa ataması yok. 
                    Sağ taraftan öğrenci seçin.
                </div>
            `;
        }
    } 
    // Hiç PDF yoksa
    else {
        document.getElementById('pdfOnizleme').srcdoc = `
            <html>
                <body style="display: flex; align-items: center; justify-content: center; height: 100vh; margin: 0; font-family: Arial; background: #f8f9fa;">
                    <div style="text-align: center; padding: 40px;">
                        <div style="font-size: 4rem; color: #f59e0b; margin-bottom: 20px;">⚠️</div>
                        <h3 style="color: #333; margin-bottom: 10px;">PDF Bulunamadı</h3>
                        <p style="color: #666;">Bu sınav için henüz PDF yüklenmemiş.</p>
                    </div>
                </body>
            </html>
        `;
        if (infoDiv) infoDiv.innerHTML = '';
    }
    
    document.getElementById('currentPdfIndex').textContent = window.currentPdfIndex + 1;
    
    // Buton durumları
    document.getElementById('prevBtn').disabled = window.currentPdfIndex === 0;
    document.getElementById('nextBtn').disabled = window.currentPdfIndex === window.eslesmemisPdfler.length - 1;
}

function oncekiPdf() {
    if (window.currentPdfIndex > 0) {
        window.currentPdfIndex--;
        yukleCurrentPdf();
    }
}

function sonrakiPdf() {
    if (window.currentPdfIndex < window.eslesmemisPdfler.length - 1) {
        window.currentPdfIndex++;
        yukleCurrentPdf();
    }
}

async function ogrenciSec(ogrenciIndex) {
    const ogr = window.tumOgrenciler[ogrenciIndex];
    const pdf = window.eslesmemisPdfler[window.currentPdfIndex];
    
    if (!confirm(`Bu PDF'i "${ogr.ad_soyad}" ile eşleştirmek istediğinize emin misiniz?`)) {
        return;
    }
    
    try {
        const response = await fetch('/kurum/sinav-pdf-yeniden-eslestir', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                katilimci_id: pdf.katilimci_id,
                yeni_ogrenci_id: ogr.ogrenci_id,
                yeni_kaynak: ogr.kaynak,
                sinav_id: <%= sinav.id %>
            })
        });
        
        const data = await response.json();
        
        if (data.success) {
            alert('✅ ' + data.message);
            
            // Bu PDF'i listeden çıkar
            window.eslesmemisPdfler.splice(window.currentPdfIndex, 1);
            
            if (window.eslesmemisPdfler.length === 0) {
                alert('🎉 Tüm PDF\'ler eşleştirildi!');
                location.reload();
                return;
            }
            
            // Sonraki PDF'e geç (veya öncekine)
            if (window.currentPdfIndex >= window.eslesmemisPdfler.length) {
                window.currentPdfIndex = window.eslesmemisPdfler.length - 1;
            }
            
            yukleCurrentPdf();
        } else {
            alert('❌ ' + (data.message || 'Eşleştirme başarısız!'));
        }
    } catch (error) {
        console.error('Hata:', error);
        alert('❌ Bir hata oluştu!');
    }
}

async function pdfEslestir(pdfIndex) {
    const pdf = window.eslesmemisPdfler[pdfIndex];
    const dropdown = document.getElementById(`ogrenci-select-${pdfIndex}`);
    const seciliDeger = dropdown.value;
    
    if (!seciliDeger) {
        alert('❌ Lütfen bir öğrenci seçin!');
        return;
    }
    
    const [yeniOgrenciId, yeniKaynak] = seciliDeger.split('|');
    const ogrenciAd = dropdown.options[dropdown.selectedIndex].text;
    
    if (!confirm(`Bu PDF'i "${ogrenciAd}" ile eşleştirmek istediğinize emin misiniz?`)) {
        return;
    }
    
    try {
        const response = await fetch('/kurum/sinav-pdf-yeniden-eslestir', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                katilimci_id: pdf.katilimci_id,
                yeni_ogrenci_id: yeniOgrenciId,
                yeni_kaynak: yeniKaynak,
                sinav_id: <%= sinav.id %>
            })
        });
        
        const data = await response.json();
        
        if (data.success) {
            // Kartı yeşil yap
            const card = document.getElementById(`pdf-card-${pdfIndex}`);
            card.innerHTML = `
                <div class="card h-100" style="background: linear-gradient(135deg, #d1fae5 0%, #a7f3d0 100%); border: 2px solid #48bb78;">
                    <div class="card-body text-center">
                        <i class="bi bi-check-circle-fill text-success" style="font-size: 3rem;"></i>
                        <h6 class="mt-3 mb-1">${ogrenciAd}</h6>
                        <span class="badge bg-success">✅ Eşleştirildi</span>
                    </div>
                </div>
            `;
            
            alert('✅ ' + data.message);
            
            // 1.5 saniye sonra sayfayı yenile
            setTimeout(() => location.reload(), 1500);
        } else {
            alert('❌ ' + (data.message || 'Eşleştirme başarısız!'));
        }
    } catch (error) {
        console.error('Eşleştirme hatası:', error);
        alert('❌ Bir hata oluştu!');
    }
}

// Tek öğrenci eşleştir
async function tekOgrenciEslestir(index, ogrenciId, kaynak, ogrenciAd) {
    const fileInput = document.getElementById(`pdf-${index}`);
    const file = fileInput.files[0];
    
    if (!file) {
        alert('❌ Lütfen PDF dosyası seçin!');
        return;
    }
    
    if (!confirm(`"${ogrenciAd}" için PDF eşleştiriliyor. Onaylıyor musunuz?`)) {
        return;
    }
    
    const formData = new FormData();
    formData.append('sinav_id', <%= sinav.id %>);
    formData.append('ogrenci_id', ogrenciId);
    formData.append('kaynak', kaynak);
    formData.append('pdf', file);
    
    try {
        const response = await fetch('/kurum/sinav-tek-ogrenci-eslestir', {
            method: 'POST',
            body: formData
        });
        
        const data = await response.json();
        
        if (data.success) {
            // Kartı yeşil yap ve başarılı işaretle
            const card = document.getElementById(`ogr-card-${index}`);
            card.style.background = 'linear-gradient(135deg, #d1fae5 0%, #a7f3d0 100%)';
            card.innerHTML = `
                <div class="card-body text-center">
                    <i class="bi bi-check-circle-fill text-success" style="font-size: 2rem;"></i>
                    <h6 class="mt-2 mb-0">${ogrenciAd}</h6>
                    <small class="text-success">✅ Başarıyla eşleştirildi!</small>
                </div>
            `;
            
            // 1.5 saniye sonra sayfayı yenile
            setTimeout(() => {
                location.reload();
            }, 1500);
        } else {
            alert('❌ ' + (data.message || 'Eşleştirme başarısız!'));
        }
    } catch (error) {
        console.error('Eşleştirme hatası:', error);
        alert('❌ Bir hata oluştu!');
    }
}
</script>

