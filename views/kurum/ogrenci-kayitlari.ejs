            body: JSON.stringify(data)
        });
        const result = await response.json();
        
        bootstrap.Modal.getInstance(document.getElementById('editModal')).hide();
        
        if (result.success) {
            document.getElementById('successMessage').textContent = result.message;
            new bootstrap.Modal(document.getElementById('successModal')).show();
        } else {
            alert('❌ ' + result.message);
        }
    } catch (error) {
        console.error('Güncelleme hatası:', error);
        alert('❌ Güncelleme sırasında bir hata oluştu!');
    }
});

document.getElementById('importForm').addEventListener('submit', async function(e) {
    e.preventDefault();
    const formData = new FormData(this);
    
    try {
        const response = await fetch('/kurum/ogrenci-import-excel', {
            method: 'POST',
            body: formData
        });
        const result = await response.json();
        
        bootstrap.Modal.getInstance(document.getElementById('importModal')).hide();
        
        if (result.success) {
            document.getElementById('successMessage').textContent = result.message;
            new bootstrap.Modal(document.getElementById('successModal')).show();
        } else {
            alert('❌ ' + result.message);
        }
    } catch (error) {
        console.error('Import hatası:', error);
        alert('❌ Excel yüklenirken bir hata oluştu!');
    }
});

// Tümünü Sil Form
document.getElementById('deleteAllForm').addEventListener('submit', async function(e) {
    e.preventDefault();
    
    const onayKodu = document.getElementById('onayKodu').value.trim();
    
    // Son bir kez daha onay iste
    if (!confirm('⚠️ SON ONAY: TÜM kayıtlar silinecek! Emin misiniz?')) {
        return;
    }
    
    try {
        const response = await fetch('/kurum/ogrenci-kayitlari-tumunu-sil', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ onayKodu: onayKodu })
        });
        const result = await response.json();
        
        bootstrap.Modal.getInstance(document.getElementById('deleteAllModal')).hide();
        
        if (result.success) {
            document.getElementById('successMessage').textContent = result.message;
            const successModal = new bootstrap.Modal(document.getElementById('successModal'));
            successModal.show();
        } else {
            alert('❌ ' + result.message);
        }
    } catch (error) {
        console.error('Toplu silme hatası:', error);
        alert('❌ Silme işlemi sırasında bir hata oluştu!');
    }
});

