                    </div>
                    
                    <div style="background: white; border-radius: 12px; padding: 20px; margin-bottom: 16px;">
                        <div style="margin-bottom: 16px;">
                            <label style="font-size: 0.85rem; color: #64748b; font-weight: 600; display: block; margin-bottom: 4px;">
                                <i class="bi bi-person-badge"></i> Kullanıcı Adı
                            </label>
                            <div style="display: flex; align-items: center; gap: 8px;">
                                <input type="text" value="${data.username}" readonly class="form-control" id="copyUsername" style="background: #f8fafc; border: 2px solid #e8ecf0; font-weight: 600; font-size: 1.1rem;">
                                <button class="btn btn-outline-primary" onclick="copyToClipboard('${data.username}', 'Kullanıcı adı')" style="white-space: nowrap;">
