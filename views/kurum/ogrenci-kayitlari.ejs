// Toplu veli hesabi olustur
async function topluVeliHesapOlustur() {
    if (!confirm('TUM OGRENCILER ICIN VELI HESABI OLUSTURULACAK!\n\n' +
                 'Her ogrencinin TC Kimlik No ile veli hesabi olusturulacak.\n' +
                 'Ilk sifre = TC Kimlik No\n\n' +
                 'Devam etmek istiyor musunuz?')) {
        return;
    }

    const btn = event.target;
    const originalText = btn.innerHTML;
    btn.disabled = true;
    btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span> Olusturuluyor...';

    try {
        const result = await apiCall('/kurum/toplu-veli-hesap-olustur', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' }
        });

        if (!result) {
            btn.disabled = false;
            btn.innerHTML = originalText;
            return;
        }

        if (result.success) {
            let mesaj = 'TOPLU VELI HESABI OLUSTURMA TAMAMLANDI!\n\n';
            mesaj += 'Toplam Ogrenci: ' + result.toplam + '\n';
            mesaj += 'Olusturulan Hesap: ' + result.olusturulan + '\n';
            mesaj += 'Zaten Mevcut: ' + result.mevcutOlanlar + '\n';
            mesaj += 'Hata: ' + result.hatalar + '\n\n';
            mesaj += 'Giris Bilgileri:\n';
            mesaj += 'Kullanici Adi: Ogrenci TC\n';
            mesaj += 'Ilk Sifre: Ogrenci TC';

            alert(mesaj);

        } else {
            alert('Hata: ' + (result.error || 'Islem basarisiz!'));
        }

    } catch (error) {
        console.error('Hata:', error);
        alert('Istek sirasinda hata olustu!');
    } finally {
        btn.disabled = false;
        btn.innerHTML = originalText;
    }
}

