    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header" style="background: linear-gradient(135deg, #06b6d4 0%, #0891b2 100%); color: white;">
                <h5 class="modal-title">
                    <i class="bi bi-pencil-square"></i> Öğrenci Bilgilerini Düzenle
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="editForm">
                    <input type="hidden" id="edit_id" name="id">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Sınıf *</label>
                            <select class="form-select" id="edit_sinif" name="sinif" required>
                                <option value="">Seçiniz</option>
                                <option value="1">1</option>
                                <option value="2">2</option>
                                <option value="3">3</option>
                                <option value="4">4</option>
                                <option value="5">5</option>
                                <option value="6">6</option>
                                <option value="7">7</option>
                                <option value="8">8</option>
                                <option value="9">9</option>
                                <option value="10">10</option>
                                <option value="11">11</option>
                                <option value="12">12</option>
                                <option value="Mezun">Mezun</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Öğrenci Adı Soyadı *</label>
                            <input type="text" class="form-control" id="edit_ogrenci_adi_soyadi" name="ogrenci_adi_soyadi" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Telefon</label>
                            <input type="text" class="form-control" id="edit_telefon" name="telefon">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">T.C. Kimlik No</label>
                            <input type="text" class="form-control" id="edit_tc_kimlik_no" name="tc_kimlik_no">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Veli Adı</label>
                            <input type="text" class="form-control" id="edit_veli_adi" name="veli_adi">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Veli Telefon</label>
                            <input type="text" class="form-control" id="edit_veli_telefon" name="veli_telefon">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Tutar</label>
                            <input type="text" class="form-control" id="edit_tutar" name="tutar">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Ödeme Durumu</label>
                            <select class="form-select" id="edit_odeme_durumu" name="odeme_durumu">
                                <option value="BEKLİYOR">BEKLİYOR</option>
                                <option value="YAPILDI">YAPILDI</option>
                                <option value="HAVALE">HAVALE</option>
                                <option value="ÜCRETSİZ">ÜCRETSİZ</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Ödeme Türü</label>
                            <input type="text" class="form-control" id="edit_odeme_turu" name="odeme_turu">
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Edesis Kaydı</label>
                            <input type="text" class="form-control" id="edit_edessis_kaydi" name="edessis_kaydi">
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Taksit</label>
                            <select class="form-select" id="edit_taksit" name="taksit">
                                <option value="">Seçiniz</option>
                                <option value="1">1</option>
                                <option value="2">2</option>
                                <option value="3">3</option>
                                <option value="4">4</option>
                                <option value="5">5</option>
                                <option value="6">6</option>
                            </select>
