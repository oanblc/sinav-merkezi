function formatPara(n){ return Number(n||0).toLocaleString('tr-TR'); }

let odemeGecmisiModalRef = null;
async function showOdemeGecmisi(ogrenciId){
    document.getElementById('og_ogrenciId').value = ogrenciId;
    document.getElementById('og_liste').innerHTML = '<div class="text-center py-4 text-muted">Yükleniyor...</div>';
    document.getElementById('odemeEkleForm').reset();
    if(!odemeGecmisiModalRef) odemeGecmisiModalRef = new bootstrap.Modal(document.getElementById('odemeGecmisiModal'));
    odemeGecmisiModalRef.show();
    await loadOdemeGecmisi(ogrenciId);
}

async function loadOdemeGecmisi(ogrenciId){
    const data = await apiCall('/kurum/odeme-gecmisi/' + ogrenciId);
    if(!data || !data.success){
        document.getElementById('og_liste').innerHTML = '<div class="alert alert-danger">' + ((data && data.message) || 'Hata') + '</div>';
        return;
    }
    document.getElementById('og_ogrenciAd').textContent = '— ' + data.ogrenci.ad;
    document.getElementById('og_tutar').textContent = formatPara(data.ozet.tutar) + ' ₺';
    document.getElementById('og_odenen').textContent = formatPara(data.ozet.odenen) + ' ₺';
    const kalan = data.ozet.kalan;
    document.getElementById('og_kalan').textContent = formatPara(kalan) + ' ₺';
    const kalanBox = document.getElementById('og_kalanBox');
    const kalanVal = document.getElementById('og_kalan');
    if(kalan > 0){ kalanBox.style.background = '#fef2f2'; kalanVal.style.color = '#dc2626'; }
    else { kalanBox.style.background = '#ecfdf5'; kalanVal.style.color = '#059669'; }

    if(!data.odemeler.length){
        document.getElementById('og_liste').innerHTML = '<div class="text-center py-4 text-muted"><i class="bi bi-inbox" style="font-size:2rem;"></i><br>Henüz ödeme kaydı yok.</div>';
        return;
    }
    let html = '<div class="table-responsive"><table class="table table-sm align-middle">';
    html += '<thead><tr><th>#</th><th>Tarih</th><th>Tutar</th><th>Açıklama</th><th></th></tr></thead><tbody>';
    data.odemeler.forEach((o, i) => {
        const tarih = o.odeme_tarihi ? o.odeme_tarihi : (o.created_at ? String(o.created_at).substring(0,10) : '-');
        html += '<tr>'
            + '<td>' + (i+1) + '</td>'
            + '<td>' + tarih + '</td>'
            + '<td><strong style="color:#059669;">' + formatPara(o.tutar) + ' ₺</strong></td>'
            + '<td>' + (o.aciklama ? o.aciklama.replace(/</g,'&lt;') : '-') + '</td>'
            + '<td class="text-end"><button class="btn btn-sm btn-outline-danger" onclick="deleteOdeme(' + o.id + ', ' + ogrenciId + ')"><i class="bi bi-trash"></i></button></td>'
            + '</tr>';
    });
    html += '</tbody></table></div>';
    document.getElementById('og_liste').innerHTML = html;
}

document.getElementById('odemeEkleForm').addEventListener('submit', async function(e){
    e.preventDefault();
    const ogrenciId = document.getElementById('og_ogrenciId').value;
    const tutar = document.getElementById('og_tutarInput').value;
    const odeme_tarihi = document.getElementById('og_tarihInput').value;
    const aciklama = document.getElementById('og_aciklamaInput').value;
    if(paraToNumber(tutar) <= 0){ alert('Geçerli bir tutar girin!'); return; }

    const data = await apiCall('/kurum/odeme-ekle', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: new URLSearchParams({ ogrenci_id: ogrenciId, tutar, odeme_tarihi, aciklama })
    });
    if(data && data.success){
        document.getElementById('odemeEkleForm').reset();
        await loadOdemeGecmisi(ogrenciId);
        odemeKayitDegisti = true;
    } else if(data){
        alert(data.message || 'Ödeme eklenemedi');
    }
});

async function deleteOdeme(pid, ogrenciId){
    if(!confirm('Bu ödeme kaydını silmek istediğinize emin misiniz?')) return;
    const data = await apiCall('/kurum/odeme-sil/' + pid, { method: 'POST' });
    if(data && data.success){
        await loadOdemeGecmisi(ogrenciId);
        odemeKayitDegisti = true;
    } else if(data){
        alert(data.message || 'Silinemedi');
    }
}

