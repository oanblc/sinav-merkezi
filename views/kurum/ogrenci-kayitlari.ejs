// TR para formatini sayiya cevir ("4.000 TRY" -> 4000, "5.000,50" -> 5000.50)
function paraToNumber(v){
    if(v===null||v===undefined) return 0;
    let s=String(v).replace(/[^0-9.,]/g,'').trim();
    if(!s) return 0;
    if(s.includes(',')) s=s.replace(/\./g,'').replace(',', '.');
    else s=s.replace(/\.(?=\d{3}(\D|$))/g,'');
    const n=parseFloat(s); return isNaN(n)?0:n;
}

// Kalan tutari canli hesapla + odeme durumunu otomatik oner (add / edit)
function hesaplaKalan(prefix){
    const tutar = paraToNumber(document.getElementById(prefix + '_tutar').value);
    const odenen = paraToNumber(document.getElementById(prefix + '_odenen_tutar').value);
    const kalan = tutar - odenen;
    const kalanInput = document.getElementById(prefix + '_kalan');
    if (kalanInput) {
        kalanInput.value = tutar > 0 ? kalan.toLocaleString('tr-TR') + ' ₺' : '';
        kalanInput.style.color = kalan > 0 ? '#dc2626' : '#059669';
    }
    // Odeme durumunu otomatik oner (kullanici elle degistirebilir)
    const durumSelect = document.getElementById(prefix + '_odeme_durumu');
    if (durumSelect && tutar > 0) {
        if (odenen <= 0) durumSelect.value = 'BEKLİYOR';
        else if (odenen >= tutar) durumSelect.value = 'YAPILDI';
        else durumSelect.value = 'KISMEN ÖDENDİ';
    }
}

