// Modal functions
function showAddModal() {
    document.getElementById('addForm').reset();
    new bootstrap.Modal(document.getElementById('addModal')).show();
}

function showImportModal() {
    document.getElementById('importForm').reset();
    new bootstrap.Modal(document.getElementById('importModal')).show();
}

function showDeleteAllModal() {
    document.getElementById('deleteAllForm').reset();
    document.getElementById('onayKodu').value = '';
    new bootstrap.Modal(document.getElementById('deleteAllModal')).show();
}

function editOgrenci(ogr) {
    document.getElementById('edit_id').value = ogr.id;
    document.getElementById('edit_sinif').value = ogr.sinif || '';
    document.getElementById('edit_ogrenci_adi_soyadi').value = ogr.ogrenci_adi_soyadi || '';
    document.getElementById('edit_telefon').value = ogr.telefon || '';
    // TC kimlik formatını temizle (.0 ile biten)
    let tcNo = ogr.tc_kimlik_no || '';
    if (tcNo && tcNo.toString().endsWith('.0')) {
        tcNo = tcNo.toString().replace('.0', '');
    }
    document.getElementById('edit_tc_kimlik_no').value = tcNo;
    document.getElementById('edit_veli_adi').value = ogr.veli_adi || '';
    // Veli telefon formatını temizle (.0 ile biten)
    let veliTel = ogr.veli_telefon || '';
    if (veliTel && veliTel.toString().endsWith('.0')) {
        veliTel = veliTel.toString().replace('.0', '');
    }
    document.getElementById('edit_veli_telefon').value = veliTel;
    document.getElementById('edit_tutar').value = ogr.tutar || '';
    document.getElementById('edit_odeme_durumu').value = ogr.odeme_durumu || 'BEKLİYOR';
    document.getElementById('edit_odeme_turu').value = ogr.odeme_turu || '';
    document.getElementById('edit_edessis_kaydi').value = ogr.edessis_kaydi || '';
    document.getElementById('edit_taksit').value = ogr.taksit || '';
    
    new bootstrap.Modal(document.getElementById('editModal')).show();
}

async function deleteOgrenci(id, ad) {
    if (!confirm(`"${ad}" adlı öğrenciyi silmek istediğinize emin misiniz?`)) return;
    
    try {
        const response = await fetch(`/kurum/ogrenci-kayit-sil/${id}`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' }
        });
        const data = await response.json();
        
        if (data.success) {
            location.reload();
        } else {
            alert('❌ ' + data.message);
        }
    } catch (error) {
        console.error('Silme hatası:', error);
        alert('❌ Silme sırasında bir hata oluştu!');
    }
}

// Form submissions
document.getElementById('addForm').addEventListener('submit', async function(e) {
    e.preventDefault();
    const formData = new FormData(this);
    const data = Object.fromEntries(formData);
    
    try {
        const response = await fetch('/kurum/ogrenci-kayit-ekle', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data)
        });
        const result = await response.json();
        
        bootstrap.Modal.getInstance(document.getElementById('addModal')).hide();
        
        if (result.success) {
            document.getElementById('successMessage').textContent = result.message;
            new bootstrap.Modal(document.getElementById('successModal')).show();
        } else {
            alert('❌ ' + result.message);
        }
    } catch (error) {
        console.error('Ekleme hatası:', error);
        alert('❌ Kayıt eklenirken bir hata oluştu!');
    }
});

document.getElementById('editForm').addEventListener('submit', async function(e) {
    e.preventDefault();
    const formData = new FormData(this);
    const data = Object.fromEntries(formData);
    const id = document.getElementById('edit_id').value;
    
    try {
        const response = await fetch(`/kurum/ogrenci-kayit-guncelle/${id}`, {
            method: 'POST',
