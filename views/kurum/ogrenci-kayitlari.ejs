async function deleteOgrenci(id, ad) {
    if (!confirm(`"${ad}" adli ogrenciyi silmek istediginize emin misiniz?`)) return;

    try {
        const data = await apiCall(`/kurum/ogrenci-kayit-sil/${id}`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' }
        });

        if (!data) return; // Oturum hatasi, yonlendirme yapildi

        if (data.success) {
            location.reload();
        } else {
            alert('Hata: ' + data.message);
        }
    } catch (error) {
        console.error('Silme hatasi:', error);
        alert('Silme sirasinda bir hata olustu!');
    }
}

// TC duplicate kontrolu icin gecici data
let pendingFormData = null;

// Form submissions
document.getElementById('addForm').addEventListener('submit', async function(e) {
    e.preventDefault();
    const formData = new FormData(this);
    const data = Object.fromEntries(formData);

    // TC Kimlik validasyonu
    if (data.tc_kimlik_no && data.tc_kimlik_no.length > 0 && data.tc_kimlik_no.length !== 11) {
        alert('TC Kimlik No 11 haneli olmalidir!');
        return;
    }

    // Telefon temizle (bosluklar kaldirilsin)
    if (data.telefon) data.telefon = data.telefon.replace(/\s/g, '');
    if (data.veli_telefon) data.veli_telefon = data.veli_telefon.replace(/\s/g, '');

    await submitOgrenciForm(data);
});

async function submitOgrenciForm(data) {
    try {
        const result = await apiCall('/kurum/ogrenci-kayit-ekle', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data)
        });

        if (!result) return;

        // Mukerrer TC kontrolu
        if (result.duplicate) {
            pendingFormData = data;
            const info = result.mevcutOgrenci;
            document.getElementById('tcDuplicateInfo').textContent =
                info.ad_soyad + (info.sinif ? ' - Sinif: ' + info.sinif : '');
            bootstrap.Modal.getInstance(document.getElementById('addModal')).hide();
            new bootstrap.Modal(document.getElementById('tcDuplicateModal')).show();
            return;
        }

        bootstrap.Modal.getInstance(document.getElementById('addModal')).hide();

        if (result.success) {
            document.getElementById('successMessage').textContent = result.message;
            new bootstrap.Modal(document.getElementById('successModal')).show();
        } else {
            alert('Hata: ' + result.message);
        }
    } catch (error) {
        console.error('Ekleme hatasi:', error);
        alert('Kayit eklenirken bir hata olustu!');
    }
}

// TC Duplicate onay butonu
document.getElementById('tcDuplicateConfirmBtn').addEventListener('click', async function() {
    if (pendingFormData) {
        pendingFormData.tcOnaylanmis = true;
        bootstrap.Modal.getInstance(document.getElementById('tcDuplicateModal')).hide();
        await submitOgrenciForm(pendingFormData);
        pendingFormData = null;
    }
});

