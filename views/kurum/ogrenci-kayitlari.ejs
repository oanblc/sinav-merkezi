<script>
// Global API helper - oturum hatalarini yakalar
async function apiCall(url, options = {}) {
    try {
        const response = await fetch(url, options);

        // JSON parse et
        const data = await response.json();

        // Oturum hatasi kontrolu
        if (response.status === 401 || data.redirect === '/login') {
            alert('Oturum suresi doldu. Giris sayfasina yonlendiriliyorsunuz.');
            window.location.href = '/login';
            return null;
        }

        // Yetki hatasi
        if (response.status === 403) {
            alert('Bu islemi yapmaya yetkiniz yok!');
            return null;
        }

        return data;
    } catch (error) {
        // JSON parse hatasi - muhtemelen HTML dondu (oturum suresi dolmus)
        if (error instanceof SyntaxError && error.message.includes('Unexpected token')) {
            alert('Oturum suresi doldu. Giris sayfasina yonlendiriliyorsunuz.');
            window.location.href = '/login';
            return null;
        }
        throw error;
    }
}

let table;

// TC Kimlik No formatlama - sadece rakam, max 11 hane
function formatTcInput(input) {
    input.addEventListener('input', function(e) {
        let value = e.target.value.replace(/\D/g, ''); // Sadece rakamlar
        if (value.length > 11) {
            value = value.slice(0, 11);
        }
        e.target.value = value;

        // Gecerlilik kontrolu
        if (value.length > 0 && value.length < 11) {
            input.classList.add('is-invalid');
            input.classList.remove('is-valid');
        } else if (value.length === 11) {
            input.classList.remove('is-invalid');
            input.classList.add('is-valid');
        } else {
            input.classList.remove('is-invalid');
            input.classList.remove('is-valid');
        }
    });
}

// Telefon formatlama - 05XX XXX XX XX
function formatTelefonInput(input) {
    input.addEventListener('input', function(e) {
        let value = e.target.value.replace(/\D/g, ''); // Sadece rakamlar

        // Format: 05XX XXX XX XX
        if (value.length > 0) {
            let formatted = '';
            if (value.length <= 4) {
                formatted = value;
            } else if (value.length <= 7) {
                formatted = value.slice(0, 4) + ' ' + value.slice(4);
            } else if (value.length <= 9) {
                formatted = value.slice(0, 4) + ' ' + value.slice(4, 7) + ' ' + value.slice(7);
            } else {
                formatted = value.slice(0, 4) + ' ' + value.slice(4, 7) + ' ' + value.slice(7, 9) + ' ' + value.slice(9, 11);
            }
            e.target.value = formatted;
        }

        // Max 11 rakam (14 karakter formatli)
        const digits = e.target.value.replace(/\D/g, '');
        if (digits.length > 11) {
            e.target.value = digits.slice(0, 4) + ' ' + digits.slice(4, 7) + ' ' + digits.slice(7, 9) + ' ' + digits.slice(9, 11);
        }
    });
}

$(document).ready(function() {
