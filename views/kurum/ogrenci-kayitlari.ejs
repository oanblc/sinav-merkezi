                    </div>
                    <div class="d-flex gap-2 mt-4">
                        <button type="button" class="btn btn-secondary flex-grow-1" data-bs-dismiss="modal">İptal</button>
                        <button type="submit" class="btn btn-primary flex-grow-1">
                            <i class="bi bi-save"></i> Güncelle
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Excel Import Modal -->
<div class="modal fade" id="importModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header" style="background: linear-gradient(135deg, #10b981 0%, #059669 100%); color: white;">
                <h5 class="modal-title">
                    <i class="bi bi-upload"></i> Excel Dosyası Yükle
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" style="padding: 30px;">
                <div style="background: #f0fdf4; border-left: 4px solid #10b981; border-radius: 8px; padding: 16px; margin-bottom: 20px;">
                    <h6 style="color: #059669; font-weight: 700; margin-bottom: 12px;">
                        <i class="bi bi-info-circle"></i> Excel Formatı
                    </h6>
                    
                    <div style="background: #dbeafe; border-radius: 8px; padding: 12px; margin-bottom: 12px;">
                        <p style="color: #1e40af; margin: 0; font-weight: 600;">
                            💡 İlk kez yüklüyorsanız, önce <a href="/kurum/ogrenci-sablon-indir" style="color: #1d4ed8; text-decoration: underline;">Şablon İndir</a> butonuna tıklayıp örnek dosyayı indirin!
                        </p>
                    </div>
                    
                    <p style="color: #065f46; margin: 0 0 12px 0; font-size: 0.9rem;">
                        <strong>📋 Gerekli Sütunlar:</strong><br>
                        <code style="background: white; padding: 4px 8px; border-radius: 4px; font-size: 0.85rem; display: inline-block; margin-top: 6px;">
                            ÖĞRENCI SINIF BİLGİSİ, ÖĞRENCI ADI SOYADI, TELEFON KAYDI, T.C KİMLİK NO, ÖĞRENCİ VELİ, VELİ TELEFON, TUTAR, ÖDEME DURUMU, ÖDEME TÜRÜ, EDESIS KAYDI, TAKSİT
                        </code>
                    </p>
                    <p style="color: #065f46; margin: 0; font-size: 0.85rem;">
                        <strong>✅ Örnek Değerler:</strong><br>
                        • <strong>Sınıf:</strong> 1, 2, 3, ..., 12, Mezun<br>
                        • <strong>Ödeme Durumu:</strong> BEKLİYOR, YAPILDI, HAVALE, ÜCRETSİZ<br>
                        • <strong>Taksit:</strong> 1, 2, 3, 4, 5, 6 (veya boş)
                    </p>
                </div>
                <form id="importForm" enctype="multipart/form-data">
                    <div class="mb-3">
                        <label class="form-label" style="font-weight: 600;">Excel Dosyası Seç</label>
                        <input type="file" class="form-control" name="excelFile" accept=".xlsx,.xls" required>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="button" class="btn btn-secondary flex-grow-1" data-bs-dismiss="modal">İptal</button>
                        <button type="submit" class="btn btn-success flex-grow-1">
                            <i class="bi bi-upload"></i> Yükle
                        </button>
                    </div>
                </form>
