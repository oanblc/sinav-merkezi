// Hesapsız velileri kontrol et
// Toplu veli hesabı oluştur
async function topluVeliHesapOlustur() {
    if (!confirm('⚠️ TÜM ÖĞRENCİLER İÇİN VELİ HESABI OLUŞTURULACAK!\n\n' +
                 'Her öğrencinin TC Kimlik No ile veli hesabı oluşturulacak.\n' +
                 'İlk şifre = TC Kimlik No\n\n' +
                 'Devam etmek istiyor musunuz?')) {
        return;
    }
    
    const btn = event.target;
    const originalText = btn.innerHTML;
    btn.disabled = true;
    btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span> Oluşturuluyor...';
    
    try {
        const response = await fetch('/kurum/toplu-veli-hesap-olustur', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' }
        });
        
        const result = await response.json();
        
        if (result.success) {
            let mesaj = `✅ TOPLU VELİ HESABI OLUŞTURMA TAMAMLANDI!\n\n`;
            mesaj += `📊 Toplam Öğrenci: ${result.toplam}\n`;
            mesaj += `✅ Oluşturulan Hesap: ${result.olusturulan}\n`;
            mesaj += `⚠️ Zaten Mevcut: ${result.mevcutOlanlar}\n`;
            mesaj += `❌ Hata: ${result.hatalar}\n\n`;
            mesaj += `👤 Giriş Bilgileri:\n`;
            mesaj += `Kullanıcı Adı: Öğrenci TC\n`;
            mesaj += `İlk Şifre: Öğrenci TC\n`;
            mesaj += `(İlk girişte yeni şifre istenir)`;
            
            alert(mesaj);
            
        } else {
            alert('❌ Hata: ' + (result.error || 'İşlem başarısız!'));
        }
        
    } catch (error) {
        console.error('Hata:', error);
        alert('❌ İstek sırasında hata oluştu!');
    } finally {
        btn.disabled = false;
        btn.innerHTML = originalText;
    }
}

async function kontrolHesapsizVeliler() {
    const modal = new bootstrap.Modal(document.getElementById('kullaniciOlusturModal'));
    modal.show();
    
    try {
        const response = await fetch('/kurum/kontrol-hesapsiz-veliler');
        const data = await response.json();
        
        const liste = document.getElementById('hesapsizVeliListesi');
        const olusturBtn = document.getElementById('olusturBtn');
        
        if (data.success && data.veliler.length > 0) {
            liste.innerHTML = `
                <div class="alert alert-info">
                    <i class="bi bi-info-circle-fill me-2"></i>
                    <strong>${data.veliler.length} veli</strong> için sistemde hesap bulunamadı.
                </div>
                
                <div style="max-height: 400px; overflow-y: auto; margin-bottom: 20px;">
                    <table class="table table-sm table-hover">
                        <thead style="background: #f8f9fa; position: sticky; top: 0;">
                            <tr>
                                <th>Veli Adı</th>
                                <th>Telefon</th>
                                <th>Öğrenci Sayısı</th>
                            </tr>
                        </thead>
                        <tbody>
                            ${data.veliler.map(v => `
                                <tr>
                                    <td><strong>${v.veli_adi || 'Belirtilmemiş'}</strong></td>
                                    <td><i class="bi bi-phone"></i> ${v.veli_telefon}</td>
                                    <td><span class="badge bg-primary">${v.ogrenci_sayisi} öğrenci</span></td>
                                </tr>
                            `).join('')}
                        </tbody>
                    </table>
                </div>
                
                <div class="alert alert-warning">
                    <i class="bi bi-shield-check me-2"></i>
                    <strong>Oluşturulacak Hesap Bilgileri:</strong>
                    <ul class="mb-0 mt-2">
                        <li><strong>Kullanıcı Adı:</strong> Telefon numarası</li>
                        <li><strong>İlk Şifre:</strong> Veli2024!</li>
                        <li><strong>Hesap Tipi:</strong> Veli</li>
                    </ul>
                    <p class="mt-2 mb-0 small">
                        <i class="bi bi-lightbulb"></i> Velilere bu bilgileri SMS/WhatsApp ile bildirmeyi unutmayın!
                    </p>
                </div>
            `;
            olusturBtn.style.display = 'block';
            olusturBtn.innerHTML = `<i class="bi bi-check-circle"></i> ${data.veliler.length} Hesap Oluştur`;
        } else {
            liste.innerHTML = `
                <div class="alert alert-success text-center">
                    <i class="bi bi-check-circle-fill" style="font-size: 3rem;"></i>
                    <h5 class="mt-3">Tüm Velilerin Hesabı Var!</h5>
                    <p>Sistemde hesabı olmayan veli bulunamadı.</p>
                </div>
            `;
            olusturBtn.style.display = 'none';
        }
    } catch (error) {
        console.error('Kontrol hatası:', error);
        document.getElementById('hesapsizVeliListesi').innerHTML = `
            <div class="alert alert-danger">
                <i class="bi bi-exclamation-triangle"></i> Bir hata oluştu!
            </div>
        `;
    }
}

// Toplu hesap oluştur
async function topluVeliHesapOlustur() {
    if (!confirm('Seçilen veliler için hesap oluşturulsun mu?\n\nİlk şifre: Veli2024!')) return;
    
    const olusturBtn = document.getElementById('olusturBtn');
    olusturBtn.disabled = true;
    olusturBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Oluşturuluyor...';
    
    try {
        const response = await fetch('/kurum/toplu-veli-hesap-olustur', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' }
        });
        const data = await response.json();
        
        if (data.success) {
            alert(`✅ ${data.olusturulan} hesap başarıyla oluşturuldu!\n\nKullanıcı Adı: Telefon numarası\nİlk Şifre: Veli2024!`);
            bootstrap.Modal.getInstance(document.getElementById('kullaniciOlusturModal')).hide();
            location.reload();
        } else {
            alert('❌ ' + data.message);
            olusturBtn.disabled = false;
            olusturBtn.innerHTML = '<i class="bi bi-check-circle"></i> Hesap Oluştur';
        }
    } catch (error) {
        console.error('Oluşturma hatası:', error);
        alert('❌ Bir hata oluştu!');
        olusturBtn.disabled = false;
        olusturBtn.innerHTML = '<i class="bi bi-check-circle"></i> Hesap Oluştur';
    }
}
</script>

