function manuelEslestirBaslat(sayfaNo, extractedName, pdfYolu) {
    const modal = new bootstrap.Modal(document.getElementById('manuelEslestirmeModal'));
    const list = document.getElementById('manuelEslestirmeList');
    
    const fixedPdfPath = pdfYolu ? pdfYolu.replace(/\\/g, '/') : '';
    
    list.innerHTML = `
        <div class="card mb-3">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <h6 class="card-title mb-0">Sayfa ${sayfaNo}</h6>
                    ${pdfYolu ? `
                        <button class="btn btn-sm btn-outline-primary pdf-preview-btn" data-pdf="${fixedPdfPath}" data-sayfa="${sayfaNo}" title="PDF'i Görüntüle">
                            <i class="bi bi-eye"></i> PDF'i Gör
                        </button>
                    ` : ''}
                </div>
                <p class="text-muted small mb-2">
                    <i class="bi bi-file-text"></i> Çıkarılan isim: <strong>${extractedName || 'Bulunamadı'}</strong>
                </p>
                ${buildManualSelector(sayfaNo, fixedPdfPath, extractedName)}
            </div>
        </div>
    `;
    
    modal.show();
}

// Toplu Manuel Eşleştirme - 👁️ PDF Önizleme ile
function topluManuelEslestir() {
    if (!window.eslesmeyenSonuclar || window.eslesmeyenSonuclar.length === 0) {
        alert('Eşleşmeyen sonuç bulunamadı!');
        return;
    }
    
    const modal = new bootstrap.Modal(document.getElementById('manuelEslestirmeModal'));
    const list = document.getElementById('manuelEslestirmeList');
    
    let html = '';
    window.eslesmeyenSonuclar.forEach(r => {
        const fixedPdfPath = r.pdfYolu ? r.pdfYolu.replace(/\\/g, '/') : '';
        
        html += `
            <div class="card mb-3">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <h6 class="card-title mb-0">Sayfa ${r.sayfaNo}</h6>
                        ${r.pdfYolu ? `
                            <button class="btn btn-sm btn-outline-primary pdf-preview-btn" data-pdf="${fixedPdfPath}" data-sayfa="${r.sayfaNo}" title="PDF'i Görüntüle">
                                <i class="bi bi-eye"></i> PDF'i Gör
                            </button>
                        ` : ''}
                    </div>
                    <p class="text-muted small mb-2">
                        <i class="bi bi-file-text"></i> Çıkarılan isim: <strong>${r.extractedName || 'Bulunamadı'}</strong>
                    </p>
                    ${buildManualSelector(r.sayfaNo, fixedPdfPath, r.extractedName)}
                </div>
            </div>
        `;
    });
    
    list.innerHTML = html;
    modal.show();
}

// Hızlı filtreli öğrenci seçici
function buildManualSelector(sayfaNo, pdfPath, extractedName = '') {
    const placeholder = extractedName ? `Örn: ${extractedName}` : 'İsim yazın';
    return `
        <label class="form-label"><strong>Öğrenci Seç:</strong></label>
        <input type="text" class="form-control form-control-sm manuel-search mb-2" data-sayfa="${sayfaNo}" data-pdf="${pdfPath}" placeholder="${placeholder}">
        <select class="form-select manuel-select" data-sayfa="${sayfaNo}" data-pdf="${pdfPath}">
            ${katilimciOptionsHTML(extractedName)}
        </select>
        <small class="text-muted">Yazdıkça liste filtrelenir; Enter ile seçili öğrenci kaydedilir.</small>
    `;
}

function katilimciOptionsHTML(filterText = '') {
    const q = (filterText || '').toUpperCase().trim();
    let items = KATILIMCILAR.map(k => {
        const name = (k.ad_soyad || '').toUpperCase();
        let score = 0;
        if (q && name.startsWith(q)) score += 3;
        else if (q && name.includes(q)) score += 2;
        if (!q) score = 1; // default eşit ağırlık
        return { k, score };
    });
    
    if (q) {
        items = items.filter(i => i.score > 0);
    }
    
    items.sort((a, b) => b.score - a.score || a.k.ad_soyad.localeCompare(b.k.ad_soyad));
    const sliced = items.slice(0, 30);
    
    const options = sliced.map(({ k }) => `
        <option value="${k.ogrenci_id}_${k.kaynak}">${k.ad_soyad} ${k.kaynak === 'veli' ? '[Veli]' : ''}</option>
    `).join('');
    
    return `<option value="">-- Öğrenci Seçin --</option>${options}`;
}

// Arama kutusu ile dinamik filtre
document.addEventListener('input', function(e) {
    if (e.target.classList.contains('manuel-search')) {
        const wrapper = e.target.closest('.card-body');
        const select = wrapper.querySelector('.manuel-select');
        select.innerHTML = katilimciOptionsHTML(e.target.value);
    }
});

// Önceden yüklenmiş PDF ile otomatik analiz (ikinci kez yükleme yok)
async function autoAnalyzeExisting() {
  const uploadCard = document.getElementById('uploadCard');
  const progressSection = document.getElementById('progressSection');
  if (uploadCard) uploadCard.style.display = 'none';
  if (progressSection) progressSection.style.display = 'block';
  updateProgress(20, 'PDF analiz ediliyor...');
  
  try {
    const formData = new FormData();
    formData.append('sinav_id', SINAV_ID);
    formData.append('pdfPath', EXISTING_PDF);
    
    const response = await fetch('/kurum/sinav-sonuc-yukle-analiz', {
      method: 'POST',
      body: formData
    });
    
    if (!response.ok) {
      const t = await response.text();
      throw new Error('HTTP ' + response.status + ': ' + t);
    }
    
    const result = await response.json();
    if (!result.success) {
      throw new Error(result.error || 'Bilinmeyen hata');
    }
    
    analysisData = result.data;
    updateProgress(40, 'İsim seçimi...');
    
    if (result.data.useAutoMode && result.data.autoSelectedPattern) {
      selectedName = result.data.autoSelectedPattern.text;
      selectedLineNumber = result.data.autoSelectedPattern.lineNumber;
      confirmNameSelection();
    } else {
      showNameSelectionModal(result.data.potansiyelIsimler);
    }
  } catch (err) {
    console.error('Otomatik analiz hatası:', err);
    alert('Otomatik analiz başlatılamadı: ' + err.message);
    // Gerekirse yükleme kartını geri göster
    const uploadCard = document.getElementById('uploadCard');
    const progressSection = document.getElementById('progressSection');
    if (uploadCard) uploadCard.style.display = 'block';
    if (progressSection) progressSection.style.display = 'none';
  }
}

// 👁️ PDF Önizleme Göster
function showPdfPreview(pdfPath, sayfaNo) {
    console.log('👁️ PDF Önizleme açılıyor:', pdfPath);
    
    // Windows backslash'leri forward slash'e çevir
    const fixedPath = pdfPath.replace(/\\/g, '/');
    console.log('✅ Düzeltilmiş yol:', fixedPath);
    
    const modalHTML = `
        <div id="pdfPreviewModal" style="position: fixed; top: 0; left: 0; width: 100%; height: 100%; 
             background: rgba(0,0,0,0.9); z-index: 10000; display: flex; flex-direction: column;">
            <div style="background: #2c3e50; color: white; padding: 15px 20px; display: flex; justify-content: space-between; align-items: center;">
                <h5 style="margin: 0;">
                    <i class="bi bi-file-pdf"></i> Sayfa ${sayfaNo} - PDF Önizleme
                </h5>
                <button onclick="closePdfPreview()" class="btn btn-light btn-sm">
                    <i class="bi bi-x-lg"></i> Kapat
                </button>
            </div>
            <div style="flex: 1; overflow: auto; padding: 20px; display: flex; justify-content: center; align-items: center;">
                <iframe src="/${fixedPath}" style="width: 90%; height: 95%; border: 2px solid #fff; border-radius: 8px; background: white;"></iframe>
            </div>
            <div style="background: #2c3e50; color: white; padding: 10px 20px; text-align: center;">
                <small><i class="bi bi-info-circle"></i> PDF'i inceleyip öğrenci ismini belirleyin</small>
            </div>
        </div>
    `;
    
    // Modal'ı ekle
    document.body.insertAdjacentHTML('beforeend', modalHTML);
    
    // Escape tuşu ile kapat
    document.addEventListener('keydown', function escapeHandler(e) {
        if (e.key === 'Escape') {
            closePdfPreview();
            document.removeEventListener('keydown', escapeHandler);
        }
    });
}

// PDF Önizlemeyi Kapat
function closePdfPreview() {
    const modal = document.getElementById('pdfPreviewModal');
    if (modal) {
        modal.remove();
    }
}

// Manuel Eşleşmeleri Kaydet
async function saveManuelEslesmeler() {
    const selects = document.querySelectorAll('.manuel-select');
    const eslesmeler = [];
    
    console.log('💾 Manuel eşleşmeler kaydediliyor...');
    console.log('   Bulunan select sayısı:', selects.length);
    
    selects.forEach((select, index) => {
        console.log(`   Select ${index + 1}:`, {
            value: select.value,
            sayfa: select.dataset.sayfa,
            pdf: select.dataset.pdf
        });
        
        if (select.value) {
            const [ogrenciId, kaynak] = select.value.split('_');
            const eslesme = {
                sayfaNo: select.dataset.sayfa,
                pdfYolu: select.dataset.pdf,
                ogrenciId: ogrenciId,
                kaynak: kaynak
            };
            eslesmeler.push(eslesme);
            console.log('   ✅ Eşleşme eklendi:', eslesme);
        } else {
            console.log('   ⚠️ Boş select atlandı');
        }
    });
    
    if (eslesmeler.length === 0) {
        alert('❌ Lütfen en az bir eşleştirme yapın!');
        return;
    }
    
    console.log('📤 Gönderilecek eşleşmeler:', eslesmeler);
    
    try {
        const response = await fetch('/kurum/sinav-manuel-eslestir/<%= sinav.id %>', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify({ eslesmeler: eslesmeler })
        });
        
        const data = await response.json();
        
        if (data.success) {
            alert(`✅ ${data.message}\n\n📊 Güncellenen sayılar:\n✅ Eşleşen: ${data.matchedCount || 'Güncelleniyor...'}\n⚠️ Eşleşmeyen: ${data.unmatchedCount || 'Güncelleniyor...'}`);
            bootstrap.Modal.getInstance(document.getElementById('manuelEslestirmeModal')).hide();
            // Sayfayı yenile - güncel sayıları gösterecek
            location.reload();
        } else {
            alert('❌ ' + data.message);
        }
    } catch (error) {
        console.error('Hata:', error);
        alert('❌ Bir hata oluştu!');
    }
}

// WhatsApp Gönder
async function whatsappGonder() {
    if (!confirm('Tüm velilere WhatsApp bildirimi gönderilecek. Onaylıyor musunuz?')) {
        return;
    }
    
    try {
        const response = await fetch('/kurum/sinav-sonuc-whatsapp-gonder/<%= sinav.id %>', {
            method: 'POST'
        });
        
        const data = await response.json();
        
        if (data.success) {
            alert(`✅ ${data.message}`);
        } else {
            alert('❌ ' + data.message);
        }
    } catch (error) {
        console.error('Hata:', error);
        alert('❌ Bir hata oluştu!');
    }
}
