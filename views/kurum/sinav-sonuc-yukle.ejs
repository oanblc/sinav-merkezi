<%- include('../partials/header-dashboard', { title: 'Sonuç Yükle - Kurum Paneli', user: user }) %>

<!-- 🆕 Akıllı Sistem v1.1 - Gelişmiş İsim Tanıma -->
<style>
    .page-header {
        background: linear-gradient(135deg, #003b78 0%, #2563eb 100%);
        color: white;
        padding: 40px 0;
        margin: -30px -15px 40px;
        border-radius: 0 0 24px 24px;
        box-shadow: 0 8px 32px rgba(16, 185, 129, 0.3);
    }
    
    .upload-card {
        background: white;
        border-radius: 16px;
        padding: 32px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.08);
        margin-bottom: 30px;
    }
    
    .dropzone {
        border: 3px dashed #cbd5e1;
        border-radius: 16px;
        padding: 60px 20px;
        text-align: center;
        background: #f8fafc;
        cursor: pointer;
        transition: all 0.3s ease;
    }
    
    .dropzone:hover {
        border-color: #10b981;
        background: #ecfdf5;
    }
    
    .dropzone.active {
        border-color: #10b981;
        background: #d1fae5;
    }
    
    .dropzone i {
        font-size: 4rem;
        color: #94a3b8;
        margin-bottom: 16px;
    }
    
    .progress-section {
        display: none;
        background: white;
        border-radius: 16px;
        padding: 24px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.08);
        margin-top: 20px;
    }
    
    .results-section {
        display: none;
        background: white;
        border-radius: 16px;
        padding: 24px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.08);
        margin-top: 20px;
    }
    
    .result-item {
        padding: 16px;
        background: #f8fafc;
        border-radius: 12px;
        margin-bottom: 12px;
        border-left: 4px solid #e2e8f0;
    }
    
    .result-item.matched {
        border-left-color: #10b981;
        background: #ecfdf5;
    }
    
    .result-item.unmatched {
        border-left-color: #f59e0b;
        background: #fffbeb;
    }
    
    .modal-content {
        border-radius: 20px;
        border: none;
    }
    
    .modal-header {
        background: linear-gradient(135deg, #003b78 0%, #2563eb 100%);
        color: white;
        border-radius: 20px 20px 0 0;
    }
    
    .name-option {
        padding: 16px;
        background: white;
        border: 2px solid #e2e8f0;
        border-radius: 12px;
        margin-bottom: 12px;
        cursor: pointer;
        transition: all 0.2s;
    }
    
    .name-option:hover {
        border-color: #10b981;
        background: #ecfdf5;
    }
    
    .name-option.selected {
        border-color: #10b981;
        background: #d1fae5;
        font-weight: 600;
    }
    
    .confidence-badge {
        padding: 4px 12px;
        border-radius: 8px;
        font-size: 0.875rem;
        font-weight: 600;
    }
    
    .confidence-high {
        background: #d1fae5;
        color: #059669;
    }
    
    .confidence-medium {
        background: #fef3c7;
        color: #d97706;
    }
    
    .confidence-low {
        background: #fee2e2;
        color: #dc2626;
    }
</style>

<div class="container mt-4">
    <!-- Page Header -->
    <div class="page-header">
        <div class="container">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h1 class="mb-2"><i class="bi bi-upload"></i> Sonuç Yükle</h1>
                    <p class="mb-0 opacity-75">
                        <%= sinav.ad %> - <%= katilimciSayisi %> Katılımcı
                    </p>
                </div>
                <div>
                    <a href="/kurum/sinav-detay/<%= sinav.id %>" class="btn btn-light">
                        <i class="bi bi-arrow-left"></i> Geri
                    </a>
                </div>
            </div>
        </div>
    </div>

    <% if (error) { %>
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i><%= error %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    <% } %>

    <!-- Upload Card -->
    <div class="upload-card" id="uploadCard">
        <h5 class="mb-4"><i class="bi bi-file-pdf text-danger me-2"></i>Toplu Sonuç PDF'i Yükle</h5>
        
        <div class="alert alert-info">
            <i class="bi bi-info-circle-fill me-2"></i>
            <strong>Bilgilendirme:</strong> Sınava kayıtlı <strong><%= katilimciSayisi %> öğrenci</strong> var. 
            PDF'deki tüm sayfalar analiz edilecek ve öğrencilerle eşleştirilecek.
        </div>

        <form id="uploadForm" enctype="multipart/form-data">
            <div class="dropzone" id="dropzone">
                <i class="bi bi-cloud-upload"></i>
                <h5>PDF dosyasını buraya sürükleyin</h5>
                <p class="text-muted">veya tıklayarak seçin</p>
                <input type="file" id="pdfFile" name="pdfFile" accept=".pdf" hidden>
            </div>
            <div id="fileInfo" class="mt-3 p-3 bg-light rounded" style="display: none;">
                <strong>Seçilen dosya:</strong> <span id="fileName"></span>
                <button type="button" class="btn btn-sm btn-danger float-end" onclick="clearFile()">
                    <i class="bi bi-x"></i> Temizle
                </button>
            </div>
            <button type="submit" class="btn btn-success btn-lg w-100 mt-4">
                <i class="bi bi-rocket"></i> Analizi Başlat
            </button>
        </form>
    </div>

    <!-- Progress Section -->
    <div class="progress-section" id="progressSection">
        <h5 class="mb-3"><i class="bi bi-hourglass-split text-primary me-2"></i>İşleniyor...</h5>
        <div class="progress" style="height: 30px;">
            <div id="progressBar" class="progress-bar progress-bar-striped progress-bar-animated bg-success" 
                 role="progressbar" style="width: 0%">0%</div>
        </div>
        <p id="progressText" class="mt-3 text-center text-muted">PDF analiz ediliyor...</p>
    </div>

    <!-- Results Section -->
    <div class="results-section" id="resultsSection">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h5><i class="bi bi-check2-circle text-success me-2"></i>İşlem Tamamlandı</h5>
            <button class="btn btn-info" onclick="whatsappGonder()">
                <i class="bi bi-whatsapp"></i> WhatsApp Gönder
            </button>
        </div>
        
        <div class="row mb-4">
            <div class="col-md-4">
                <div class="p-4 bg-gradient rounded-3 text-center border border-success shadow-sm" style="background: linear-gradient(135deg, #d1fae5 0%, #a7f3d0 100%);">
                    <i class="bi bi-check-circle-fill text-success mb-2" style="font-size: 2rem;"></i>
                    <h1 class="text-success mb-2" id="matchedCount" style="font-size: 3rem; font-weight: 800;">0</h1>
                    <strong class="text-success">✅ Eşleşen</strong>
                </div>
            </div>
            <div class="col-md-4">
                <div class="p-4 bg-gradient rounded-3 text-center border border-warning shadow-sm" style="background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%);">
                    <i class="bi bi-exclamation-triangle-fill text-warning mb-2" style="font-size: 2rem;"></i>
                    <h1 class="text-warning mb-2" id="unmatchedCount" style="font-size: 3rem; font-weight: 800;">0</h1>
                    <strong class="text-warning">⚠️ Eşleşmeyen</strong>
                </div>
            </div>
            <div class="col-md-4">
                <div class="p-4 bg-gradient rounded-3 text-center border border-primary shadow-sm" style="background: linear-gradient(135deg, #dbeafe 0%, #bfdbfe 100%);">
                    <i class="bi bi-file-pdf-fill text-primary mb-2" style="font-size: 2rem;"></i>
                    <h1 class="text-primary mb-2" id="totalCount" style="font-size: 3rem; font-weight: 800;">0</h1>
                    <strong class="text-primary">📄 Toplam Sayfa</strong>
                </div>
            </div>
        </div>

        <div id="resultsList"></div>
    </div>
</div>

<!-- İsim Seçim Modalı -->
<div class="modal fade" id="nameSelectionModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-person-badge me-2"></i>İsim Seç</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p class="text-muted">İlk sayfadan çıkarılan potansiyel isimler. Doğru olanı seçin:</p>
                <div id="nameOptions"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">İptal</button>
                <button type="button" class="btn btn-success" onclick="confirmNameSelection()">
                    <i class="bi bi-check-lg"></i> Devam Et
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Manuel Eşleştirme Modalı -->
<div class="modal fade" id="manuelEslestirmeModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-link-45deg me-2"></i>Manuel Eşleştirme</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p class="text-muted">Eşleşmeyen sayfaları manuel olarak öğrencilerle eşleştirin:</p>
                <div id="manuelEslestirmeList"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Kapat</button>
                <button type="button" class="btn btn-success" onclick="saveManuelEslesmeler()">
                    <i class="bi bi-save"></i> Kaydet
                </button>
            </div>
        </div>
    </div>
</div>

<script>
const SINAV_ID = <%= sinav.id || 0 %>;
const KATILIMCILAR = <%- JSON.stringify(katilimcilar || []) %>;
const EXISTING_PDF = "<%- sinav.dosya_yolu ? sinav.dosya_yolu.replace(/\\/g, '/') : '' %>";
let analysisData = null;
let selectedName = null;
let selectedLineNumber = null;

// DOM hazır olunca başlat
document.addEventListener('DOMContentLoaded', function() {
  console.log('DOM hazir, event listenerlar ekleniyor...');
  
  initUploadForm();
  
  // Eğer sınav için önceden yüklenmiş PDF varsa, doğrudan analizi başlat
  if (EXISTING_PDF) {
    console.log('Önceden yüklenmiş PDF bulundu, otomatik analiz başlıyor:', EXISTING_PDF);
    autoAnalyzeExisting();
  }
});

function initUploadForm() {
    // Dropzone
    const dropzone = document.getElementById('dropzone');
    const fileInput = document.getElementById('pdfFile');
    
    if (!dropzone || !fileInput) {
        console.error('❌ Dropzone veya fileInput bulunamadı!');
        return;
    }
    
    dropzone.addEventListener('click', () => fileInput.click());

dropzone.addEventListener('dragover', (e) => {
    e.preventDefault();
    dropzone.classList.add('active');
});

dropzone.addEventListener('dragleave', () => {
    dropzone.classList.remove('active');
});

dropzone.addEventListener('drop', (e) => {
    e.preventDefault();
    dropzone.classList.remove('active');
    
    if (e.dataTransfer.files.length) {
        fileInput.files = e.dataTransfer.files;
        showFileInfo(e.dataTransfer.files[0]);
    }
});

    fileInput.addEventListener('change', (e) => {
        if (e.target.files.length) {
            showFileInfo(e.target.files[0]);
        }
    });
    
    // Form Submit - Analiz
    const uploadForm = document.getElementById('uploadForm');
    if (!uploadForm) {
        console.error('❌ uploadForm bulunamadı!');
        return;
    }
    
  uploadForm.addEventListener('submit', async function(e) {
    e.preventDefault();
    
    console.log('📋 Form submit edildi!');
    
    if (!fileInput || !fileInput.files || !fileInput.files.length) {
        alert('❌ Lütfen bir PDF dosyası seçin!');
        return;
    }
    
    console.log('📄 Dosya seçildi:', fileInput.files[0].name);
    
    const formData = new FormData();
    formData.append('pdfFile', fileInput.files[0]);
    formData.append('sinav_id', SINAV_ID);
    
    console.log('📤 FormData hazır, yükleniyor...');
    
    // UI güncelle
    const uploadCard = document.getElementById('uploadCard');
    const progressSection = document.getElementById('progressSection');
    
    if (uploadCard) uploadCard.style.display = 'none';
    if (progressSection) progressSection.style.display = 'block';
    
    updateProgress(20, 'PDF analiz ediliyor...');
    
    try {
        console.log('📤 PDF yükleniyor...', fileInput.files[0].name);
        
        const response = await fetch('/kurum/sinav-sonuc-yukle-analiz', {
            method: 'POST',
            body: formData
        });
        
        console.log('📥 Response alındı:', response.status);
        
        if (!response.ok) {
            const errorText = await response.text();
            console.error('❌ HTTP Hatası:', response.status, errorText);
            alert('❌ Sunucu hatası: ' + response.status + '\n' + errorText);
            location.reload();
            return;
        }
        
        const result = await response.json();
        console.log('📊 Sonuç:', result);
        
        if (!result.success) {
            alert('❌ ' + (result.error || 'Bilinmeyen hata!'));
            location.reload();
            return;
        }
        
        analysisData = result.data;
        updateProgress(40, 'İsim seçiliyor...');
        
        // 🧠 AKILLI SİSTEM KONTROLÜ
        if (result.data.useAutoMode && result.data.autoSelectedPattern) {
            // %85+ güven var - Otomatik devam et!
            console.log('🎯 Otomatik mod aktif:', result.data.autoSelectedPattern);
            selectedName = result.data.autoSelectedPattern.text;
            selectedLineNumber = result.data.autoSelectedPattern.lineNumber;
            
            // Kullanıcıya bilgi ver
            const autoConfirm = confirm(
                `🧠 Akıllı Sistem Otomatik Eşleştirme Buldu!\n\n` +
                `✅ Öğrenci: ${result.data.autoSelectedPattern.matchedStudent}\n` +
                `📝 Çıkarılan İsim: ${result.data.autoSelectedPattern.text}\n` +
                `🎯 Güven: ${(result.data.autoSelectedPattern.confidence * 100).toFixed(0)}%\n` +
                `🔧 Strateji: ${result.data.autoSelectedPattern.strategy}\n\n` +
                `Otomatik olarak devam edilsin mi?`
            );
            
            if (autoConfirm) {
                // Direkt işle
                confirmNameSelection();
            } else {
                // Manuel seçim iste
                showNameSelectionModal(result.data.potansiyelIsimler);
            }
        } else {
            // Otomatik bulunamadı - Manuel seçim göster
            console.log('⚠️ Otomatik eşleşme yok, manuel seçim gerekli');
            showNameSelectionModal(result.data.potansiyelIsimler);
        }
        
    } catch (error) {
        console.error('❌ Analiz hatası:', error);
        console.error('Hata detayı:', error.message);
        console.error('Stack:', error.stack);
        alert('❌ Analiz sırasında bir hata oluştu!\n\nHata: ' + error.message + '\n\nLütfen console\'u kontrol edin (F12)');
        
        // UI'ı geri getir
        const uploadCard = document.getElementById('uploadCard');
        const progressSection = document.getElementById('progressSection');
        if (uploadCard) uploadCard.style.display = 'block';
        if (progressSection) progressSection.style.display = 'none';
    }
    });
    
    console.log('Form event listener eklendi!');
}

function showFileInfo(file) {
    document.getElementById('fileName').textContent = file.name;
    document.getElementById('fileInfo').style.display = 'block';
}

function clearFile() {
    const fileInput = document.getElementById('pdfFile');
    if (fileInput) fileInput.value = '';
    document.getElementById('fileInfo').style.display = 'none';
}

// İsim Seçim Modalı
function showNameSelectionModal(names) {
    const container = document.getElementById('nameOptions');
    container.innerHTML = '';
    
    if (!names || names.length === 0) {
        // Hiç isim bulunamadı - Manuel giriş alanı göster
        container.innerHTML = `
            <div class="alert alert-warning mb-3">
                <i class="bi bi-exclamation-triangle me-2"></i>
                <strong>Otomatik isim tanıma başarısız!</strong><br>
                PDF formatı tanınmadı. Lütfen öğrenci ismini manuel olarak girin.
            </div>
            <div class="mb-3">
                <label class="form-label"><strong>Öğrenci Adı ve Soyadı:</strong></label>
                <input type="text" id="manualNameInput" class="form-control form-control-lg" 
                       placeholder="Örn: AHMET YILMAZ" 
                       style="text-transform: uppercase;"
                       onkeyup="this.value = this.value.toUpperCase()">
                <small class="text-muted">💡 İpucu: Büyük harfle, tam ad-soyad yazın</small>
            </div>
        `;
        
        // Manuel giriş için Enter tuşu desteği
        setTimeout(() => {
            document.getElementById('manualNameInput').focus();
            document.getElementById('manualNameInput').addEventListener('keypress', function(e) {
                if (e.key === 'Enter') {
                    const input = this.value.trim();
                    if (input.length >= 5) {
                        selectedName = input;
                        selectedLineNumber = -1; // Manuel giriş
                        confirmNameSelection();
                    } else {
                        alert('Lütfen en az 5 karakter girin!');
                    }
                }
            });
        }, 100);
    } else {
        names.forEach((name, index) => {
            const confidenceClass = name.confidence === 'high' ? 'confidence-high' : 
                                   name.confidence === 'medium' ? 'confidence-medium' : 'confidence-low';
            
            const div = document.createElement('div');
            div.className = 'name-option';
            div.dataset.name = name.text;
            div.dataset.lineNumber = name.lineNumber;
            div.innerHTML = `
                <div class="d-flex justify-content-between align-items-center">
                    <strong style="font-size: 1.125rem;">${name.text}</strong>
                    <span class="confidence-badge ${confidenceClass}">
                        ${name.confidence === 'high' ? 'Yüksek' : name.confidence === 'medium' ? 'Orta' : 'Düşük'} Güven
                    </span>
                </div>
                <small class="text-muted">Satır ${name.lineNumber + 1}</small>
            `;
            
            div.addEventListener('click', function() {
                document.querySelectorAll('.name-option').forEach(o => o.classList.remove('selected'));
                this.classList.add('selected');
                selectedName = this.dataset.name;
                selectedLineNumber = this.dataset.lineNumber;
            });
            
            container.appendChild(div);
        });
    }
    
    new bootstrap.Modal(document.getElementById('nameSelectionModal')).show();
}

// İsim Seçimi Onayla
async function confirmNameSelection() {
    // Eğer selectedName yoksa, manuel girişi kontrol et
    if (!selectedName) {
        const manualInput = document.getElementById('manualNameInput');
        if (manualInput) {
            const manualValue = manualInput.value.trim().toUpperCase();
            if (manualValue.length >= 5) {
                selectedName = manualValue;
                selectedLineNumber = -1; // Manuel giriş işareti
                console.log('✍️ Manuel isim girişi:', selectedName);
            } else {
                alert('❌ Lütfen geçerli bir öğrenci adı girin!\n\n💡 En az 5 karakter, büyük harfle yazın.\nÖrnek: AHMET YILMAZ');
                manualInput.focus();
                return;
            }
        } else {
            alert('❌ Lütfen bir isim seçin veya manuel olarak girin!');
            return;
        }
    }
    
    // Modalı kapat (eğer açıksa)
    const modal = document.getElementById('nameSelectionModal');
    const modalInstance = bootstrap.Modal.getInstance(modal);
    if (modalInstance) {
        modalInstance.hide();
    }
    
    updateProgress(60, '🧠 Akıllı sistem tüm sayfaları işliyor...');
    
    // Tüm sayfaları işle
    try {
        const response = await fetch('/kurum/sinav-sonuc-yukle-kaydet', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                sinav_id: SINAV_ID,
                pdfPath: analysisData.uploadPath,
                selectedPattern: selectedName,
                selectedLineNumber: selectedLineNumber,
                manuelEslesmeler: []
            })
        });
        
        const result = await response.json();
        
        if (!result.success) {
            alert('❌ ' + result.error);
            location.reload();
            return;
        }
        
        updateProgress(100, 'Tamamlandı!');
        
        // Sonuçları göster
        setTimeout(() => {
            document.getElementById('progressSection').style.display = 'none';
            showResults(result.data);
        }, 1000);
        
    } catch (error) {
        console.error('Kaydetme hatası:', error);
        alert('❌ Kaydetme sırasında bir hata oluştu!');
        location.reload();
    }
}

// Progress Güncelle
function updateProgress(percent, text) {
    const bar = document.getElementById('progressBar');
    bar.style.width = percent + '%';
    bar.textContent = percent + '%';
    document.getElementById('progressText').textContent = text;
}

// Sonuçları Göster
function showResults(data) {
    document.getElementById('resultsSection').style.display = 'block';
    
    // ✅ SAYAÇLARI GÜNCELLE
    document.getElementById('matchedCount').textContent = data.matchedCount;
    document.getElementById('unmatchedCount').textContent = data.unmatchedCount;
    document.getElementById('totalCount').textContent = data.totalPages;
    
    // 🧠 Strateji istatistiklerini göster
    if (data.strategyStats) {
        console.log('📊 Kullanılan Stratejiler:', data.strategyStats);
        // Strateji bilgisini header'a ekle
        const header = document.querySelector('.results-section h5');
        if (header) {
            let strategyInfo = '<div class="mt-3"><small class="text-muted"><strong>🧠 Akıllı Sistem:</strong> ';
            Object.entries(data.strategyStats).forEach(([strategy, count]) => {
                const shortName = strategy.replace('strategy', 'Str.').replace('_', ' ');
                strategyInfo += `${shortName}: ${count} sayfa | `;
            });
            strategyInfo = strategyInfo.slice(0, -3) + '</small></div>';
            header.insertAdjacentHTML('afterend', strategyInfo);
        }
    }
    
    const list = document.getElementById('resultsList');
    list.innerHTML = '';
    
    // ✅ EŞLEŞENLERİ ve EŞLEŞMEYENLERİ AYIR
    const eslesenler = data.results.filter(r => r.eslesti);
    const eslesmeyenler = data.results.filter(r => !r.eslesti);
    
    window.eslesmeyenSonuclar = eslesmeyenler;
    
    // ✅ EŞLEŞENLERİ GÖSTER
    if (eslesenler.length > 0) {
        const eslesenlerBaslik = document.createElement('div');
        eslesenlerBaslik.className = 'alert alert-success mb-3';
        eslesenlerBaslik.innerHTML = `
            <h6 class="mb-0">
                <i class="bi bi-check-circle-fill me-2"></i>
                ✅ Eşleşen Sonuçlar (${eslesenler.length})
            </h6>
        `;
        list.appendChild(eslesenlerBaslik);
        
        eslesenler.forEach(r => {
            const div = document.createElement('div');
            div.className = 'result-item matched';
            
            // Strateji bilgisi
            let strategyBadge = '';
            if (r.strategy) {
                const strategyColor = r.strategy.includes('Learned') ? 'primary' : 
                                     r.strategy.includes('Database') ? 'success' :
                                     r.strategy.includes('Position') ? 'info' :
                                     r.strategy.includes('Regex') ? 'warning' : 'secondary';
                const strategyShort = r.strategy.replace('strategy', 'Str.').replace(/_/g, ' ');
                strategyBadge = `<span class="badge bg-${strategyColor} ms-2" title="${r.strategy}">${strategyShort}</span>`;
            }
            
            // Güven skoru
            let confidenceBadge = '';
            if (r.confidence) {
                const confidencePercent = (r.confidence * 100).toFixed(0);
                const confidenceColor = r.confidence >= 0.90 ? 'success' : r.confidence >= 0.80 ? 'info' : 'warning';
                confidenceBadge = `<span class="badge bg-${confidenceColor} ms-1">%${confidencePercent}</span>`;
            }
            
            div.innerHTML = `
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <strong>Sayfa ${r.sayfaNo}:</strong> ${r.ogrenciAdi}
                        <span class="badge bg-success ms-2">✅ Eşleşti</span>
                        ${strategyBadge}
                        ${confidenceBadge}
                    </div>
                    <div>
                        ${r.pdfYolu ? `<a href="/${r.pdfYolu.replace(/\\\\/g, '/')}" target="_blank" class="btn btn-sm btn-success me-2"><i class="bi bi-file-pdf"></i> PDF'i Görüntüle</a>` : ''}
                    </div>
                </div>
                ${r.extractedName ? `<small class="text-muted">Çıkarılan isim: ${r.extractedName}</small>` : ''}
            `;
            list.appendChild(div);
        });
    }
    
    // ⚠️ EŞLEŞMEYENLERİ GÖSTER
    if (eslesmeyenler.length > 0) {
        const eslesmeyenlerBaslik = document.createElement('div');
        eslesmeyenlerBaslik.className = 'alert alert-warning mt-4 mb-3';
        eslesmeyenlerBaslik.innerHTML = `
            <h6 class="mb-0">
                <i class="bi bi-exclamation-triangle-fill me-2"></i>
                ⚠️ Eşleşmeyen Sonuçlar (${eslesmeyenler.length})
            </h6>
        `;
        list.appendChild(eslesmeyenlerBaslik);
        
        eslesmeyenler.forEach(r => {
            const div = document.createElement('div');
            div.className = 'result-item unmatched';
            
            div.innerHTML = `
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <strong>Sayfa ${r.sayfaNo}:</strong> ${r.ogrenciAdi}
                        <span class="badge bg-warning ms-2">⚠️ Eşleşmedi</span>
                    </div>
                    <div>
                        ${r.pdfYolu ? `<a href="/${r.pdfYolu.replace(/\\\\/g, '/')}" target="_blank" class="btn btn-sm btn-info me-2"><i class="bi bi-download"></i> İndir</a>` : ''}
                        <button class="btn btn-sm btn-warning manuel-tek-btn" data-sayfa="${r.sayfaNo}" data-isim="${r.extractedName || ''}" data-pdf="${(r.pdfYolu || '').replace(/\\\\/g, '/')}"><i class="bi bi-link-45deg"></i> Manuel Eşleştir</button>
                    </div>
                </div>
                ${r.extractedName ? `<small class="text-muted">Çıkarılan isim: ${r.extractedName}</small>` : ''}
            `;
            list.appendChild(div);
        });
        
        // Toplu eşleştirme butonu
        const toplubtn = document.createElement('div');
        toplubtn.className = 'mt-3 text-center';
        toplubtn.innerHTML = `
            <button class="btn btn-warning btn-lg" onclick="topluManuelEslestir()">
                <i class="bi bi-link-45deg"></i> Tümü İçin Manuel Eşleştirme Yap (${eslesmeyenler.length} adet)
            </button>
        `;
        list.appendChild(toplubtn);
    }
}

// Manuel Eşleştirme - Tek Sonuç (Event Delegation)
document.addEventListener('click', function(e) {
    if (e.target.closest('.manuel-tek-btn')) {
