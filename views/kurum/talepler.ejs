<%- include('../partials/header-dashboard', { title: 'Talep Yönetimi - Kurum Paneli', user: user }) %>

<style>
    :root {
        --kt-primary: #3b82f6;
        --kt-primary-light: #2563eb;
        --kt-primary-dark: #1d4ed8;
        --kt-success: #10b981;
        --kt-warning: #f59e0b;
        --kt-danger: #ef4444;
        --kt-text: #1e293b;
        --kt-text-muted: #64748b;
        --kt-border: #e2e8f0;
        --kt-bg: #f8fafc;
        --kt-card: #ffffff;
        --kt-shadow: 0 2px 8px rgba(0,0,0,0.08);
        --kt-shadow-hover: 0 4px 12px rgba(0,0,0,0.12);
        --kt-radius: 16px;
        --kt-radius-sm: 10px;
    }

    /* Page Header - Modern */
    .kt-page-header {
        background: linear-gradient(135deg, var(--kt-primary) 0%, var(--kt-primary-light) 100%);
        color: white;
        padding: 40px 0;
        margin: -30px -15px 30px;
        border-radius: 0 0 24px 24px;
        box-shadow: 0 8px 32px rgba(59, 130, 246, 0.3);
    }

    .kt-page-header h1 {
        font-size: 1.75rem;
        font-weight: 800;
        margin: 0;
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .kt-page-header p {
        font-size: 1rem;
        opacity: 0.9;
        margin: 8px 0 0 0;
    }

    .kt-header-btn {
        background: rgba(255,255,255,0.2);
        border: none;
        color: white;
        padding: 12px 20px;
        border-radius: 12px;
        font-weight: 600;
        font-size: 0.95rem;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: all 0.3s ease;
    }

    .kt-header-btn:hover {
        background: rgba(255,255,255,0.3);
        color: white;
        transform: translateY(-2px);
    }

    /* Stats Bar */
    .kt-stats-bar {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 16px;
        margin-bottom: 24px;
    }

    @media (max-width: 576px) {
        .kt-stats-bar { grid-template-columns: repeat(2, 1fr); gap: 12px; }
    }

    .kt-stat-card {
        background: var(--kt-card);
        border-radius: var(--kt-radius);
        padding: 20px 16px;
        text-align: center;
        box-shadow: var(--kt-shadow);
        border: 2px solid var(--kt-border);
        cursor: pointer;
        transition: all 0.3s ease;
    }

    .kt-stat-card:hover {
        box-shadow: var(--kt-shadow-hover);
        transform: translateY(-2px);
    }

    .kt-stat-card.active {
        border-color: var(--kt-primary);
        box-shadow: 0 4px 20px rgba(59, 130, 246, 0.2);
    }

    .kt-stat-card.active.beklemede { border-color: var(--kt-warning); box-shadow: 0 4px 20px rgba(245, 158, 11, 0.2); }
    .kt-stat-card.active.onaylandi { border-color: var(--kt-success); box-shadow: 0 4px 20px rgba(16, 185, 129, 0.2); }
    .kt-stat-card.active.reddedildi { border-color: var(--kt-danger); box-shadow: 0 4px 20px rgba(239, 68, 68, 0.2); }

    .kt-stat-number {
        font-size: 2rem;
        font-weight: 800;
        color: var(--kt-primary);
        line-height: 1;
    }

    .kt-stat-card.beklemede .kt-stat-number { color: var(--kt-warning); }
    .kt-stat-card.onaylandi .kt-stat-number { color: var(--kt-success); }
    .kt-stat-card.reddedildi .kt-stat-number { color: var(--kt-danger); }

    .kt-stat-label {
        font-size: 0.85rem;
        color: var(--kt-text-muted);
        font-weight: 600;
        margin-top: 8px;
    }

    /* Search Box */
    .kt-search-box {
        background: var(--kt-card);
        border-radius: var(--kt-radius);
        padding: 14px 20px;
        border: 2px solid var(--kt-border);
        margin-bottom: 24px;
        display: flex;
        align-items: center;
        gap: 12px;
        transition: all 0.3s ease;
    }

    .kt-search-box:focus-within {
        border-color: var(--kt-primary);
        box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.1);
    }

    .kt-search-box input {
        border: none;
        outline: none;
        width: 100%;
        font-size: 1rem;
        background: transparent;
    }

    .kt-search-box i {
        color: var(--kt-text-muted);
        font-size: 1.1rem;
    }

    /* Talep Cards */
    .kt-talep-card {
        background: var(--kt-card);
        border-radius: var(--kt-radius);
        margin-bottom: 16px;
        box-shadow: var(--kt-shadow);
        border: 1px solid var(--kt-border);
        overflow: hidden;
        transition: all 0.3s ease;
    }

    .kt-talep-card:hover {
        box-shadow: var(--kt-shadow-hover);
        transform: translateY(-2px);
    }

    /* Card Status Indicator */
    .kt-card-status {
        height: 4px;
        background: var(--kt-border);
    }

    .kt-talep-card.beklemede .kt-card-status { background: var(--kt-warning); }
    .kt-talep-card.onaylandi .kt-card-status { background: var(--kt-success); }
    .kt-talep-card.reddedildi .kt-card-status { background: var(--kt-danger); }

    .kt-card-body {
        padding: 20px;
    }

    /* Card Header */
    .kt-card-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 12px;
        margin-bottom: 12px;
    }

    .kt-talep-title {
        font-size: 1.1rem;
        font-weight: 700;
        color: var(--kt-text);
        margin: 0 0 8px 0;
        display: flex;
        align-items: center;
        gap: 10px;
        flex-wrap: wrap;
    }

    .kt-talep-title i { font-size: 1rem; }

    .kt-talep-type {
        font-size: 0.75rem;
        padding: 4px 10px;
        border-radius: 20px;
        font-weight: 600;
    }

    .kt-talep-type.sinav { background: #dbeafe; color: #2563eb; }
    .kt-talep-type.paket { background: #d1fae5; color: #059669; }
    .kt-talep-type.rehber { background: #e0e7ff; color: #4f46e5; }

    /* Status Badge */
    .kt-status-badge {
        padding: 6px 12px;
        border-radius: 20px;
        font-weight: 600;
        font-size: 0.8rem;
        white-space: nowrap;
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .kt-status-badge i { font-size: 0.85rem; }

    .kt-status-badge.beklemede { background: #fef3c7; color: #b45309; }
    .kt-status-badge.onaylandi { background: #d1fae5; color: #047857; }
    .kt-status-badge.reddedildi { background: #fee2e2; color: #b91c1c; }

    /* Meta Info */
    .kt-meta-row {
        display: flex;
        flex-wrap: wrap;
        gap: 8px 16px;
    }

    .kt-meta-item {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 0.9rem;
        color: var(--kt-text-muted);
    }

    .kt-meta-item i { font-size: 0.85rem; }
    .kt-meta-item strong { color: var(--kt-text); font-weight: 600; }

    /* Details Grid */
    .kt-details-grid {
        display: flex;
        flex-wrap: wrap;
        gap: 12px 24px;
        background: var(--kt-bg);
        border-radius: var(--kt-radius-sm);
        padding: 14px 16px;
        margin-top: 12px;
    }

    .kt-detail-item {
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .kt-detail-label {
        font-size: 0.8rem;
        color: var(--kt-text-muted);
        font-weight: 600;
    }

    .kt-detail-value {
        font-size: 0.9rem;
        color: var(--kt-text);
        font-weight: 500;
    }

    /* Aciklama Box */
    .kt-aciklama-box {
        background: #fffbeb;
        border-left: 4px solid var(--kt-warning);
        border-radius: 0 var(--kt-radius-sm) var(--kt-radius-sm) 0;
        padding: 12px 16px;
        margin-top: 12px;
    }

    .kt-aciklama-box h6 {
        font-size: 0.85rem;
        color: #92400e;
        font-weight: 600;
        margin: 0 0 6px 0;
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .kt-aciklama-box p {
        font-size: 0.9rem;
        color: #78350f;
        margin: 0;
        line-height: 1.5;
    }

    /* Yanit Box */
    .kt-yanit-box {
        background: #ecfdf5;
        border-left: 4px solid var(--kt-success);
        border-radius: 0 var(--kt-radius-sm) var(--kt-radius-sm) 0;
        padding: 12px 16px;
        margin-top: 10px;
    }

    .kt-yanit-box h6 {
        font-size: 0.85rem;
        color: #047857;
        font-weight: 600;
        margin: 0 0 6px 0;
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .kt-yanit-box p {
        font-size: 0.9rem;
        color: #065f46;
        margin: 0;
        line-height: 1.5;
    }

    /* Action Buttons */
    .kt-action-buttons {
        display: flex;
        gap: 10px;
        margin-top: 16px;
        padding-top: 16px;
        border-top: 1px solid var(--kt-border);
        justify-content: flex-end;
    }

    .kt-btn {
        padding: 10px 18px;
        border-radius: 10px;
        border: none;
        font-weight: 600;
        font-size: 0.9rem;
        cursor: pointer;
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
    }

    .kt-btn i { font-size: 0.85rem; }

    .kt-btn-success {
        background: var(--kt-success);
        color: white;
    }

    .kt-btn-success:hover {
        background: #059669;
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(16, 185, 129, 0.3);
    }

    .kt-btn-danger {
        background: var(--kt-danger);
        color: white;
    }

    .kt-btn-danger:hover {
        background: #dc2626;
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(239, 68, 68, 0.3);
    }

    /* Empty State */
    .kt-empty-state {
        text-align: center;
        padding: 60px 30px;
        background: var(--kt-card);
        border-radius: var(--kt-radius);
        border: 2px dashed var(--kt-border);
    }

    .kt-empty-icon {
        width: 80px;
        height: 80px;
        background: var(--kt-bg);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 20px;
    }

    .kt-empty-icon i {
        font-size: 2rem;
        color: var(--kt-text-muted);
    }

    .kt-empty-state h4 {
        font-size: 1.25rem;
        font-weight: 700;
        color: var(--kt-text);
        margin-bottom: 8px;
    }

    .kt-empty-state p {
        font-size: 1rem;
        color: var(--kt-text-muted);
        margin: 0;
    }

    /* Mobile */
    @media (max-width: 576px) {
        .kt-page-header { padding: 30px 0; }
        .kt-page-header h1 { font-size: 1.4rem; }
        .kt-card-header { flex-direction: column; gap: 10px; }
        .kt-status-badge { align-self: flex-start; }
        .kt-action-buttons { flex-direction: row; }
        .kt-details-grid { flex-direction: column; gap: 8px; }
        .kt-btn { padding: 12px 16px; flex: 1; }
    }
</style>

<!-- Page Header -->
<div class="kt-page-header">
    <div class="container">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
            <div>
                <h1><i class="bi bi-inbox-fill"></i> Talep Yonetimi</h1>
                <p>Gelen talepleri inceleyin, onaylayin veya reddedin</p>
            </div>
            <button class="kt-header-btn" onclick="showRehberTalepModal()">
                <i class="bi bi-person-plus-fill"></i>
                <span class="d-none d-sm-inline">Rehber Ogretmene Talep</span>
                <span class="d-sm-none">Talep</span>
            </button>
        </div>
    </div>
</div>

<div class="container">
    <!-- Stats Bar -->
    <div class="kt-stats-bar">
        <div class="kt-stat-card active" onclick="filterTalepler('hepsi', this)">
            <div class="kt-stat-number"><%= talepler.length %></div>
            <div class="kt-stat-label">Toplam</div>
        </div>
        <div class="kt-stat-card beklemede" onclick="filterTalepler('beklemede', this)">
            <div class="kt-stat-number"><%= talepler.filter(t => t.durum === 'beklemede').length %></div>
            <div class="kt-stat-label">Bekleyen</div>
        </div>
        <div class="kt-stat-card onaylandi" onclick="filterTalepler('onaylandi', this)">
            <div class="kt-stat-number"><%= talepler.filter(t => t.durum === 'onaylandi').length %></div>
            <div class="kt-stat-label">Onaylanan</div>
        </div>
        <div class="kt-stat-card reddedildi" onclick="filterTalepler('reddedildi', this)">
            <div class="kt-stat-number"><%= talepler.filter(t => t.durum === 'reddedildi').length %></div>
            <div class="kt-stat-label">Reddedilen</div>
        </div>
    </div>

    <!-- Search Box -->
    <div class="kt-search-box">
        <i class="bi bi-search"></i>
        <input type="text" id="searchInput" placeholder="Veli adi, sinav/paket adi veya telefon ile ara..." onkeyup="searchTalepler()">
    </div>

<!-- Talepler Listesi -->
    <div id="taleplerContainer">
        <% if (talepler.length === 0) { %>
            <div class="kt-empty-state">
                <div class="kt-empty-icon">
                    <i class="bi bi-inbox"></i>
                </div>
                <h4>Henuz talep bulunmamaktadir</h4>
                <p>Gelen talepler burada goruntulenecektir.</p>
            </div>
        <% } else { %>
            <% talepler.forEach(function(talep) { %>
                <div class="kt-talep-card <%= talep.durum %>" data-durum="<%= talep.durum %>" data-search="<%= (talep.veli_ad_soyad || talep.veli_username || '').toLowerCase() %> <%= (talep.sinav_adi || talep.paket_adi || '').toLowerCase() %> <%= (talep.veli_telefon || '').toLowerCase() %> <%= (talep.rehber_ad_soyad || '').toLowerCase() %>">
                    <div class="kt-card-status"></div>
                    <div class="kt-card-body">
                        <div class="kt-card-header">
                            <div>
                                <h4 class="kt-talep-title">
                                    <% if (talep.talep_tipi === 'rehber') { %>
                                        <i class="bi bi-mortarboard-fill" style="color: #6366f1;"></i>
                                        <%= talep.sinav_adi %>
                                        <span class="kt-talep-type rehber">Rehber Talebi</span>
                                    <% } else if (talep.talep_tipi === 'paket') { %>
                                        <i class="bi bi-box-seam-fill" style="color: #10b981;"></i>
                                        <%= talep.paket_adi || 'Paket' %>
                                        <span class="kt-talep-type paket">Paket Talebi</span>
                                    <% } else { %>
                                        <i class="bi bi-journal-bookmark-fill" style="color: #2563eb;"></i>
                                        <%= talep.sinav_adi %>
                                        <span class="kt-talep-type sinav">Sinav Talebi</span>
                                    <% } %>
                                </h4>
                                <div class="kt-meta-row">
                                    <span class="kt-meta-item">
                                        <i class="bi bi-person-fill"></i>
                                        <strong><%= talep.veli_ad_soyad || talep.veli_username %></strong>
                                    </span>
                                    <span class="kt-meta-item">
                                        <i class="bi bi-clock"></i>
                                        <%= new Date(talep.talep_tarihi || talep.created_at).toLocaleString('tr-TR', { day: '2-digit', month: 'short', hour: '2-digit', minute: '2-digit' }) %>
                                    </span>
                                    <% if (talep.veli_telefon) { %>
                                    <span class="kt-meta-item">
                                        <i class="bi bi-telephone-fill"></i>
                                        <%= talep.veli_telefon %>
                                    </span>
                                    <% } %>
                                </div>
                            </div>
                            <span class="kt-status-badge <%= talep.durum %>">
                                <% if (talep.durum === 'beklemede') { %>
                                    <i class="bi bi-hourglass-split"></i> Beklemede
                                <% } else if (talep.durum === 'onaylandi') { %>
                                    <i class="bi bi-check-circle-fill"></i> Onaylandi
                                <% } else { %>
                                    <i class="bi bi-x-circle-fill"></i> Reddedildi
                                <% } %>
                            </span>
                        </div>

                        <div class="kt-details-grid">
                            <div class="kt-detail-item">
                                <span class="kt-detail-label">E-posta</span>
                                <span class="kt-detail-value"><%= talep.veli_email || talep.email || 'Belirtilmedi' %></span>
                            </div>
                            <% if (talep.talep_tipi === 'sinav' && talep.sinav_tarihi) { %>
                            <div class="kt-detail-item">
                                <span class="kt-detail-label">Sinav Tarihi</span>
                                <span class="kt-detail-value"><%= new Date(talep.sinav_tarihi).toLocaleDateString('tr-TR', { day: '2-digit', month: 'long', year: 'numeric' }) %></span>
                            </div>
                            <% } %>
                            <% if (talep.fiyat) { %>
                            <div class="kt-detail-item">
                                <span class="kt-detail-label">Fiyat</span>
                                <span class="kt-detail-value" style="color: #10b981; font-weight: 700;"><%= talep.fiyat %> TL</span>
                            </div>
                            <% } %>
                            <% if (talep.sinif) { %>
                            <div class="kt-detail-item">
                                <span class="kt-detail-label">Sinif</span>
                                <span class="kt-detail-value"><%= talep.sinif %></span>
                            </div>
                            <% } %>
                            <% if (talep.talep_tipi === 'rehber' && talep.rehber_ad_soyad) { %>
                            <div class="kt-detail-item">
                                <span class="kt-detail-label">Rehber Ogretmen</span>
                                <span class="kt-detail-value"><%= talep.rehber_ad_soyad %> <%= talep.rehber_brans ? `(${talep.rehber_brans})` : '' %></span>
                            </div>
                            <% } %>
                        </div>

                        <% if (talep.aciklama || talep.mesaj) { %>
                        <div class="kt-aciklama-box">
                            <h6><i class="bi bi-chat-left-text-fill"></i> <% if (talep.talep_tipi === 'rehber') { %>Kurum Mesaji<% } else { %>Veli Aciklamasi<% } %></h6>
                            <p><%= talep.aciklama || talep.mesaj %></p>
                        </div>
                        <% } %>

                        <% if (talep.yanit) { %>
                        <div class="kt-yanit-box">
                            <h6><i class="bi bi-reply-fill"></i> Kurum Yaniti</h6>
                            <p><%= talep.yanit %></p>
                        </div>
                        <% } %>

                        <% if (talep.durum === 'beklemede') { %>
                        <div class="kt-action-buttons">
                            <button class="kt-btn kt-btn-success" data-talep-id="<%= talep.id %>" data-talep-tipi="<%= talep.talep_tipi || 'sinav' %>" data-sinav-adi="<%= (talep.sinav_adi || talep.paket_adi || '').replace(/"/g, '&quot;') %>" onclick="showYanitModalFromButton(this, 'onayla')">
                                <i class="bi bi-check-lg"></i> Onayla
                            </button>
                            <button class="kt-btn kt-btn-danger" data-talep-id="<%= talep.id %>" data-talep-tipi="<%= talep.talep_tipi || 'sinav' %>" data-sinav-adi="<%= (talep.sinav_adi || talep.paket_adi || '').replace(/"/g, '&quot;') %>" onclick="showYanitModalFromButton(this, 'reddet')">
                                <i class="bi bi-x-lg"></i> Reddet
                            </button>
                        </div>
                        <% } %>
                    </div>
                </div>
            <% }); %>
        <% } %>
    </div>
</div>

<!-- Yanıt Modal -->
<div class="modal fade" id="yanitModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border-radius: 20px; border: none;">
            <div class="modal-header" style="background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%); color: white; border-radius: 20px 20px 0 0;">
                <h5 class="modal-title" id="yanitModalTitle"></h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" style="padding: 30px;">
                <form id="yanitForm">
                    <input type="hidden" id="talepId">
                    <input type="hidden" id="talepDurum">
                    <input type="hidden" id="talepTipi">
                    
                    <div class="mb-3">
                        <label class="form-label" style="font-weight: 600;">
                            <i class="bi bi-chat-left-text"></i> Yanıt Mesajı <span class="text-muted">(İsteğe Bağlı)</span>
                        </label>
                        <textarea class="form-control" id="yanitMesaj" rows="4" 
                                  style="border-radius: 12px; border: 2px solid #e2e8f0;"
                                  placeholder="Veliye iletilecek mesajınızı yazın..."></textarea>
                        <small class="text-muted">Bu mesaj veliye WhatsApp ile gönderilecektir.</small>
                    </div>
                    
                    <div class="d-flex gap-2">
                        <button type="button" class="btn btn-secondary flex-grow-1" data-bs-dismiss="modal" style="border-radius: 12px;">
                            İptal
                        </button>
                        <button type="submit" class="btn btn-primary flex-grow-1" style="border-radius: 12px;">
                            <i class="bi bi-send"></i> Gönder
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Success Modal -->
<div class="modal fade" id="successModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border-radius: 20px; border: none; text-align: center; padding: 30px;">
            <div style="font-size: 4rem; color: #10b981; margin-bottom: 20px;">
                <i class="bi bi-check-circle-fill"></i>
            </div>
            <h4 style="font-weight: 800; color: #1e293b; margin-bottom: 16px;">İşlem Başarılı!</h4>
            <p id="successMessage" style="color: #64748b; margin-bottom: 30px;"></p>
            <button type="button" class="btn btn-primary" data-bs-dismiss="modal" style="border-radius: 12px; padding: 12px 40px;" onclick="location.reload()">
                Tamam
            </button>
        </div>
    </div>
</div>

<script>
// Global API helper - oturum hatalarini yakalar
async function apiCall(url, options = {}) {
    try {
        const response = await fetch(url, options);
        const data = await response.json();

        if (response.status === 401 || data.redirect === '/login') {
            alert('Oturum suresi doldu. Giris sayfasina yonlendiriliyorsunuz.');
            window.location.href = '/login';
            return null;
        }

        if (response.status === 403) {
            alert('Bu islemi yapmaya yetkiniz yok!');
            return null;
        }

        return data;
    } catch (error) {
        if (error instanceof SyntaxError && error.message.includes('Unexpected token')) {
            alert('Oturum suresi doldu. Giris sayfasina yonlendiriliyorsunuz.');
            window.location.href = '/login';
            return null;
        }
        throw error;
    }
}

    // Filter Talepler
    function filterTalepler(durum, clickedCard) {
        // Update active stat card
        document.querySelectorAll('.kt-stat-card').forEach(card => {
            card.classList.remove('active');
        });
        if (clickedCard) {
            clickedCard.classList.add('active');
        }

        // Filter talep cards
        const cards = document.querySelectorAll('.kt-talep-card');
        cards.forEach(card => {
            if (durum === 'hepsi' || card.dataset.durum === durum) {
                card.style.display = 'block';
            } else {
                card.style.display = 'none';
            }
        });
    }

    // Search Talepler
    function searchTalepler() {
        const searchTerm = document.getElementById('searchInput').value.toLowerCase();
        const cards = document.querySelectorAll('.kt-talep-card');

        cards.forEach(card => {
            const searchData = card.dataset.search;
            if (searchData.includes(searchTerm)) {
                card.style.display = 'block';
            } else {
                card.style.display = 'none';
            }
        });
    }
    
    // Show Yanıt Modal
    function showYanitModalFromButton(button, islem) {
        const talepId = button.getAttribute('data-talep-id');
        const sinavAdi = button.getAttribute('data-sinav-adi');
        const talepTipi = button.getAttribute('data-talep-tipi') || 'sinav';
        showYanitModal(talepId, sinavAdi, islem, talepTipi);
    }
    
    function showYanitModal(talepId, sinavAdi, islem, talepTipi = 'sinav') {
        document.getElementById('talepId').value = talepId;
        document.getElementById('talepDurum').value = islem === 'onayla' ? 'onaylandi' : 'reddedildi';
        document.getElementById('talepTipi').value = talepTipi;
        
        const modalTitle = islem === 'onayla' 
            ? '✅ Talebi Onayla' 
            : '❌ Talebi Reddet';
        
        document.getElementById('yanitModalTitle').textContent = modalTitle;
        document.getElementById('yanitMesaj').placeholder = islem === 'onayla'
            ? 'Örn: Talebiniz onaylanmıştır. Sınav erişiminiz aktif edildi.'
            : 'Örn: Üzgünüz, şu an bu sınavımız mevcut değil.';
        
        const modal = new bootstrap.Modal(document.getElementById('yanitModal'));
        modal.show();
    }
    
    // Form Submit
    document.getElementById('yanitForm').addEventListener('submit', async function(e) {
        e.preventDefault();

        const talepId = document.getElementById('talepId').value;
        const durum = document.getElementById('talepDurum').value;
        const yanit = document.getElementById('yanitMesaj').value.trim();
        const talepTipi = document.getElementById('talepTipi').value;

        try {
            const data = await apiCall('/kurum/talep-yanitla', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ talep_id: talepId, durum: durum, yanit: yanit, talep_tipi: talepTipi })
            });

            if (!data) return;

            const yanitModal = bootstrap.Modal.getInstance(document.getElementById('yanitModal'));
            yanitModal.hide();

            if (data.success) {
                document.getElementById('successMessage').textContent = data.message;
                const successModal = new bootstrap.Modal(document.getElementById('successModal'));
                successModal.show();
            } else {
                alert('Hata: ' + data.message);
            }
        } catch (error) {
            console.error('Talep yanitlama hatasi:', error);
            alert('Islem sirasinda bir hata olustu!');
        }
    });
</script>

