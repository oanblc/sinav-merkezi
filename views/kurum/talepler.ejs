<%- include('../partials/header-dashboard', { title: 'Talep Yönetimi - Kurum Paneli', user: user }) %>

<style>
    .page-header {
        background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);
        color: white;
        padding: 40px 0;
        margin: -30px -15px 40px;
        border-radius: 0 0 24px 24px;
        box-shadow: 0 8px 32px rgba(245, 158, 11, 0.3);
    }
    
    .filter-tabs {
        display: flex;
        gap: 12px;
        margin-bottom: 30px;
        flex-wrap: wrap;
    }
    
    .filter-btn {
        padding: 12px 24px;
        border-radius: 12px;
        border: 2px solid #e2e8f0;
        background: white;
        color: #64748b;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
    }
    
    .filter-btn:hover {
        border-color: #f59e0b;
        background: #fef3c7;
        color: #f59e0b;
    }
    
    .filter-btn.active {
        border-color: #f59e0b;
        background: #f59e0b;
        color: white;
        box-shadow: 0 4px 16px rgba(245, 158, 11, 0.3);
    }
    
    .talep-card {
        background: white;
        border-radius: 20px;
        padding: 24px;
        margin-bottom: 20px;
        box-shadow: 0 4px 16px rgba(0,0,0,0.08);
        transition: all 0.3s ease;
        border-left: 5px solid #e2e8f0;
    }
    
    .talep-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 32px rgba(0,0,0,0.12);
    }
    
    .talep-card.beklemede {
        border-left-color: #f59e0b;
    }
    
    .talep-card.onaylandi {
        border-left-color: #10b981;
    }
    
    .talep-card.reddedildi {
        border-left-color: #ef4444;
    }
    
    .talep-header {
        display: flex;
        justify-content: space-between;
        align-items: start;
        margin-bottom: 20px;
    }
    
    .talep-info h4 {
        font-weight: 800;
        color: #1e293b;
        margin-bottom: 8px;
    }
    
    .talep-meta {
        display: flex;
        gap: 16px;
        flex-wrap: wrap;
        margin-bottom: 16px;
    }
    
    .meta-item {
        display: flex;
        align-items: center;
        gap: 8px;
        color: #64748b;
        font-size: 0.9rem;
    }
    
    .meta-item i {
        color: #94a3b8;
    }
    
    .talep-badge {
        padding: 8px 16px;
        border-radius: 8px;
        font-weight: 600;
        font-size: 0.85rem;
        white-space: nowrap;
    }
    
    .talep-badge.beklemede {
        background: #fef3c7;
        color: #f59e0b;
    }
    
    .talep-badge.onaylandi {
        background: #d1fae5;
        color: #10b981;
    }
    
    .talep-badge.reddedildi {
        background: #fee2e2;
        color: #ef4444;
    }
    
    .talep-details {
        background: #f8fafc;
        border-radius: 12px;
        padding: 16px;
        margin-top: 16px;
    }
    
    .talep-details .row {
        margin-bottom: 12px;
    }
    
    .talep-details .row:last-child {
        margin-bottom: 0;
    }
    
    .detail-label {
        font-weight: 600;
        color: #475569;
        font-size: 0.9rem;
    }
    
    .detail-value {
        color: #1e293b;
        font-size: 0.95rem;
    }
    
    .action-buttons {
        display: flex;
        gap: 12px;
        margin-top: 16px;
    }
    
    .btn-action {
        padding: 10px 20px;
        border-radius: 10px;
        border: none;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
        gap: 8px;
    }
    
    .btn-onayla {
        background: linear-gradient(135deg, #10b981 0%, #059669 100%);
        color: white;
    }
    
    .btn-onayla:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 16px rgba(16, 185, 129, 0.3);
    }
    
    .btn-reddet {
        background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);
        color: white;
    }
    
    .btn-reddet:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 16px rgba(239, 68, 68, 0.3);
    }
    
    .empty-state {
        text-align: center;
        padding: 80px 20px;
        color: #94a3b8;
    }
    
    .empty-state i {
        font-size: 5rem;
        margin-bottom: 20px;
        opacity: 0.5;
    }
    
    .yanit-section {
        background: #fffbeb;
        border-left: 4px solid #f59e0b;
        border-radius: 8px;
        padding: 16px;
        margin-top: 16px;
    }
    
    .yanit-section h6 {
        color: #f59e0b;
        font-weight: 700;
        margin-bottom: 8px;
    }
    
    .search-box {
        background: white;
        border-radius: 12px;
        padding: 12px 20px;
        border: 2px solid #e2e8f0;
        margin-bottom: 24px;
        display: flex;
        align-items: center;
        gap: 12px;
    }
    
    .search-box input {
        border: none;
        outline: none;
        width: 100%;
        font-size: 1rem;
    }
    
    .search-box i {
        color: #94a3b8;
    }
</style>

<!-- Page Header -->
<div class="page-header">
    <div class="container">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <h1 style="font-weight: 800; margin-bottom: 8px;">
                    <i class="bi bi-inbox-fill"></i> Talep Yönetimi
                </h1>
                <p style="opacity: 0.9; margin: 0;">Gelen sınav taleplerini inceleyin, onaylayın veya reddedin</p>
            </div>
            <button class="btn btn-light" onclick="showRehberTalepModal()" style="border-radius: 12px; padding: 12px 24px; font-weight: 600;">
                <i class="bi bi-person-plus"></i> Rehber Öğretmene Talep Gönder
            </button>
        </div>
    </div>
</div>

<!-- Filter Tabs -->
<div class="filter-tabs">
    <button class="filter-btn active" onclick="filterTalepler('hepsi')">
        <i class="bi bi-inbox"></i> Tümü (<%= talepler.length %>)
    </button>
    <button class="filter-btn" onclick="filterTalepler('beklemede')">
        <i class="bi bi-clock-history"></i> Bekleyen (<%= talepler.filter(t => t.durum === 'beklemede').length %>)
    </button>
    <button class="filter-btn" onclick="filterTalepler('onaylandi')">
        <i class="bi bi-check-circle"></i> Onaylanan (<%= talepler.filter(t => t.durum === 'onaylandi').length %>)
    </button>
    <button class="filter-btn" onclick="filterTalepler('reddedildi')">
        <i class="bi bi-x-circle"></i> Reddedilen (<%= talepler.filter(t => t.durum === 'reddedildi').length %>)
    </button>
</div>

<!-- Search Box -->
<div class="search-box">
    <i class="bi bi-search"></i>
    <input type="text" id="searchInput" placeholder="Veli adı, sınav adı veya telefon ile ara..." onkeyup="searchTalepler()">
</div>

<!-- Talepler Listesi -->
<div id="taleplerContainer">
    <% if (talepler.length === 0) { %>
        <div class="empty-state">
            <i class="bi bi-inbox"></i>
            <h4>Henüz talep bulunmamaktadır</h4>
            <p>Gelen talepler burada görüntülenecektir.</p>
        </div>
    <% } else { %>
        <% talepler.forEach(function(talep) { %>
            <div class="talep-card <%= talep.durum %>" data-durum="<%= talep.durum %>" data-search="<%= (talep.veli_ad_soyad || talep.veli_username || '').toLowerCase() %> <%= (talep.sinav_adi || talep.paket_adi || '').toLowerCase() %> <%= (talep.veli_telefon || '').toLowerCase() %> <%= (talep.rehber_ad_soyad || '').toLowerCase() %>">
                <div class="talep-header">
                    <div class="talep-info">
                        <h4>
                            <% if (talep.talep_tipi === 'rehber') { %>
                                👨‍🏫 <%= talep.sinav_adi %> <span class="badge bg-info" style="font-size: 0.7rem; vertical-align: middle;">Rehber Talebi</span>
                            <% } else if (talep.talep_tipi === 'paket') { %>
                                📦 <%= talep.paket_adi || 'Paket' %> <span class="badge bg-success" style="font-size: 0.7rem; vertical-align: middle;">Paket Talebi</span>
                            <% } else { %>
                                📚 <%= talep.sinav_adi %>
                            <% } %>
                        </h4>
                        <div class="talep-meta">
                            <span class="meta-item">
                                <i class="bi bi-person-fill"></i>
                                <strong><%= talep.veli_ad_soyad || talep.veli_username %></strong>
                            </span>
                            <span class="meta-item">
                                <i class="bi bi-calendar3"></i>
                                <%= new Date(talep.talep_tarihi || talep.created_at).toLocaleString('tr-TR', { day: '2-digit', month: 'long', year: 'numeric', hour: '2-digit', minute: '2-digit' }) %>
                            </span>
                            <% if (talep.talep_tipi === 'rehber' && talep.rehber_ad_soyad) { %>
                            <span class="meta-item">
                                <i class="bi bi-mortarboard-fill"></i>
                                <%= talep.rehber_ad_soyad %> <%= talep.rehber_brans ? `(${talep.rehber_brans})` : '' %>
                            </span>
                            <% } %>
                            <% if (talep.sinif) { %>
                            <span class="meta-item">
                                <i class="bi bi-person-workspace"></i>
                                <%= talep.sinif %>
                            </span>
                            <% } %>
                            <% if (talep.ders) { %>
                            <span class="meta-item">
                                <i class="bi bi-book"></i>
                                <%= talep.ders %>
                            </span>
                            <% } %>
                        </div>
                    </div>
                    <span class="talep-badge <%= talep.durum %>">
                        <% if (talep.durum === 'beklemede') { %>
                            ⏳ Beklemede
                        <% } else if (talep.durum === 'onaylandi') { %>
                            ✅ Onaylandı
                        <% } else { %>
                            ❌ Reddedildi
                        <% } %>
                    </span>
                </div>
                
                <div class="talep-details">
                    <div class="row">
                        <div class="col-md-6">
                            <span class="detail-label">👤 Veli:</span>
                            <span class="detail-value"><%= talep.veli_ad_soyad || talep.veli_username %></span>
                        </div>
                        <div class="col-md-6">
                            <span class="detail-label">📞 Telefon:</span>
                            <span class="detail-value"><%= talep.veli_telefon || 'Belirtilmedi' %></span>
                        </div>
                    </div>
                    
                    <% if (talep.talep_tipi === 'sinav') { %>
                    <!-- SADECE SINAV TALEPLERİ İÇİN -->
                    <div class="row">
                        <div class="col-md-6">
                            <span class="detail-label">📧 E-posta:</span>
                            <span class="detail-value"><%= talep.veli_email %></span>
                        </div>
                        <div class="col-md-6">
                            <span class="detail-label">💰 Fiyat:</span>
                            <span class="detail-value"><%= talep.fiyat %> TL</span>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6">
                            <span class="detail-label">📅 Sınav Tarihi:</span>
                            <span class="detail-value"><%= new Date(talep.sinav_tarihi).toLocaleDateString('tr-TR', { day: '2-digit', month: 'long', year: 'numeric' }) %></span>
                        </div>
                        <% if (talep.yanitlanma_tarihi) { %>
                        <div class="col-md-6">
                            <span class="detail-label">📝 Yanıt Tarihi:</span>
                            <span class="detail-value"><%= new Date(talep.yanitlanma_tarihi).toLocaleDateString('tr-TR', { day: '2-digit', month: 'long', year: 'numeric' }) %></span>
                        </div>
                        <% } %>
                    </div>
                    <% } else if (talep.talep_tipi === 'paket') { %>
                    <!-- PAKET TALEPLERİ İÇİN -->
                    <div class="row">
                        <div class="col-md-6">
                            <span class="detail-label">📧 E-posta:</span>
                            <span class="detail-value"><%= talep.veli_email || talep.email || 'Belirtilmedi' %></span>
                        </div>
                        <div class="col-md-6">
                            <span class="detail-label">💰 Paket Fiyatı:</span>
                            <span class="detail-value"><%= talep.fiyat || 0 %> TL</span>
                        </div>
                    </div>
                    <% if (talep.sinif) { %>
                    <div class="row">
                        <div class="col-md-6">
                            <span class="detail-label">📚 Sınıf:</span>
                            <span class="detail-value"><%= talep.sinif %></span>
                        </div>
                    </div>
                    <% } %>
                    <% } %>
                    
                    <% if (talep.aciklama || talep.mesaj) { %>
                    <div class="row mt-3">
                        <div class="col-12">
                            <span class="detail-label">💬 <% if (talep.talep_tipi === 'rehber') { %>Kurum Mesajı<% } else { %>Veli Açıklaması<% } %>:</span>
                            <div class="detail-value" style="background: white; padding: 12px; border-radius: 8px; margin-top: 8px;">
                                <%= talep.aciklama || talep.mesaj %>
                            </div>
                        </div>
                    </div>
                    <% } %>
                </div>
                
                <% if (talep.yanit) { %>
                <div class="yanit-section">
                    <h6><i class="bi bi-reply-fill"></i> Kurum Yanıtı</h6>
                    <p style="margin: 0; color: #92400e;"><%= talep.yanit %></p>
                </div>
                <% } %>
                
                <% if (talep.durum === 'beklemede') { %>
                <div class="action-buttons">
                    <button class="btn-action btn-onayla" data-talep-id="<%= talep.id %>" data-talep-tipi="<%= talep.talep_tipi || 'sinav' %>" data-sinav-adi="<%= (talep.sinav_adi || '').replace(/"/g, '&quot;') %>" onclick="showYanitModalFromButton(this, 'onayla')">
                        <i class="bi bi-check-circle-fill"></i> Onayla
                    </button>
                    <button class="btn-action btn-reddet" data-talep-id="<%= talep.id %>" data-talep-tipi="<%= talep.talep_tipi || 'sinav' %>" data-sinav-adi="<%= (talep.sinav_adi || '').replace(/"/g, '&quot;') %>" onclick="showYanitModalFromButton(this, 'reddet')">
                        <i class="bi bi-x-circle-fill"></i> Reddet
                    </button>
                </div>
                <% } %>
            </div>
        <% }); %>
    <% } %>
</div>

<!-- Yanıt Modal -->
<div class="modal fade" id="yanitModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border-radius: 20px; border: none;">
            <div class="modal-header" style="background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%); color: white; border-radius: 20px 20px 0 0;">
                <h5 class="modal-title" id="yanitModalTitle"></h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" style="padding: 30px;">
                <form id="yanitForm">
                    <input type="hidden" id="talepId">
                    <input type="hidden" id="talepDurum">
                    <input type="hidden" id="talepTipi">
                    
                    <div class="mb-3">
                        <label class="form-label" style="font-weight: 600;">
                            <i class="bi bi-chat-left-text"></i> Yanıt Mesajı <span class="text-muted">(İsteğe Bağlı)</span>
                        </label>
                        <textarea class="form-control" id="yanitMesaj" rows="4" 
                                  style="border-radius: 12px; border: 2px solid #e2e8f0;"
                                  placeholder="Veliye iletilecek mesajınızı yazın..."></textarea>
                        <small class="text-muted">Bu mesaj veliye WhatsApp ile gönderilecektir.</small>
                    </div>
                    
                    <div class="d-flex gap-2">
                        <button type="button" class="btn btn-secondary flex-grow-1" data-bs-dismiss="modal" style="border-radius: 12px;">
                            İptal
                        </button>
                        <button type="submit" class="btn btn-primary flex-grow-1" style="border-radius: 12px;">
                            <i class="bi bi-send"></i> Gönder
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Success Modal -->
<div class="modal fade" id="successModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border-radius: 20px; border: none; text-align: center; padding: 30px;">
            <div style="font-size: 4rem; color: #10b981; margin-bottom: 20px;">
                <i class="bi bi-check-circle-fill"></i>
            </div>
            <h4 style="font-weight: 800; color: #1e293b; margin-bottom: 16px;">İşlem Başarılı!</h4>
            <p id="successMessage" style="color: #64748b; margin-bottom: 30px;"></p>
            <button type="button" class="btn btn-primary" data-bs-dismiss="modal" style="border-radius: 12px; padding: 12px 40px;" onclick="location.reload()">
                Tamam
            </button>
        </div>
    </div>
</div>

<script>
    // Filter Talepler
    function filterTalepler(durum) {
        // Update active button
        document.querySelectorAll('.filter-btn').forEach(btn => {
            btn.classList.remove('active');
        });
        event.target.closest('.filter-btn').classList.add('active');
        
        // Filter cards
        const cards = document.querySelectorAll('.talep-card');
        cards.forEach(card => {
            if (durum === 'hepsi' || card.dataset.durum === durum) {
                card.style.display = 'block';
            } else {
                card.style.display = 'none';
            }
        });
    }
    
    // Search Talepler
    function searchTalepler() {
        const searchTerm = document.getElementById('searchInput').value.toLowerCase();
        const cards = document.querySelectorAll('.talep-card');
        
        cards.forEach(card => {
            const searchData = card.dataset.search;
            if (searchData.includes(searchTerm)) {
                card.style.display = 'block';
            } else {
                card.style.display = 'none';
            }
        });
    }
    
    // Show Yanıt Modal
    function showYanitModalFromButton(button, islem) {
        const talepId = button.getAttribute('data-talep-id');
        const sinavAdi = button.getAttribute('data-sinav-adi');
        const talepTipi = button.getAttribute('data-talep-tipi') || 'sinav';
        showYanitModal(talepId, sinavAdi, islem, talepTipi);
    }
    
    function showYanitModal(talepId, sinavAdi, islem, talepTipi = 'sinav') {
        document.getElementById('talepId').value = talepId;
        document.getElementById('talepDurum').value = islem === 'onayla' ? 'onaylandi' : 'reddedildi';
        document.getElementById('talepTipi').value = talepTipi;
        
        const modalTitle = islem === 'onayla' 
            ? '✅ Talebi Onayla' 
            : '❌ Talebi Reddet';
        
        document.getElementById('yanitModalTitle').textContent = modalTitle;
        document.getElementById('yanitMesaj').placeholder = islem === 'onayla'
            ? 'Örn: Talebiniz onaylanmıştır. Sınav erişiminiz aktif edildi.'
            : 'Örn: Üzgünüz, şu an bu sınavımız mevcut değil.';
        
        const modal = new bootstrap.Modal(document.getElementById('yanitModal'));
        modal.show();
    }
    
    // Form Submit
    document.getElementById('yanitForm').addEventListener('submit', async function(e) {
        e.preventDefault();
        
        const talepId = document.getElementById('talepId').value;
        const durum = document.getElementById('talepDurum').value;
        const yanit = document.getElementById('yanitMesaj').value.trim();
        const talepTipi = document.getElementById('talepTipi').value;
        
        try {
            const response = await fetch('/kurum/talep-yanitla', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ talep_id: talepId, durum: durum, yanit: yanit, talep_tipi: talepTipi })
            });
            
            const data = await response.json();
            
            // Close yanıt modal
            const yanitModal = bootstrap.Modal.getInstance(document.getElementById('yanitModal'));
            yanitModal.hide();
            
            if (data.success) {
                // Show success modal
                document.getElementById('successMessage').textContent = data.message;
                const successModal = new bootstrap.Modal(document.getElementById('successModal'));
                successModal.show();
            } else {
                alert('❌ ' + data.message);
            }
        } catch (error) {
            console.error('Talep yanıtlama hatası:', error);
            alert('❌ İşlem sırasında bir hata oluştu!');
        }
    });
</script>

<!-- Rehber Öğretmene Talep Gönder Modal -->
<div class="modal fade" id="rehberTalepModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content" style="border-radius: 20px;">
            <div class="modal-header" style="background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%); color: white; border-radius: 20px 20px 0 0;">
                <h5 class="modal-title">
                    <i class="bi bi-person-plus"></i> Rehber Öğretmene Talep Gönder
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" style="padding: 30px;">
                <p class="text-muted mb-4">Bir öğrenci için rehber öğretmene yetki talebi gönderin.</p>
                
                <form id="rehberTalepForm">
                    <!-- Öğrenci Seçimi -->
                    <div class="mb-4">
                        <label class="form-label">
                            <i class="bi bi-mortarboard"></i> Öğrenci Seçin *
                        </label>
                        <div class="d-flex gap-2">
                            <input type="text" id="ogrenciAra" class="form-control" placeholder="🔍 Öğrenci ara (isim, okul, sınıf)..." autocomplete="off" style="border-radius: 12px;">
                            <button type="button" id="ogrenciAraBtn" class="btn btn-outline-secondary" style="border-radius: 12px;">
                                <i class="bi bi-search"></i>
                            </button>
                        </div>
                        <div id="ogrenciListesi" class="mt-3" style="max-height: 300px; overflow-y: auto; display: none;">
                            <!-- JavaScript ile doldurulacak -->
                        </div>
                        <div id="seciliOgrenciBilgi" class="mt-3" style="display: none;">
                            <div class="card" style="border-radius: 12px; border: 2px solid #3b82f6;">
                                <div class="card-body">
                                    <div class="d-flex justify-content-between align-items-start">
                                        <div>
                                            <h6 class="mb-2">
                                                <i class="bi bi-mortarboard-fill text-primary"></i> 
                                                <strong id="seciliOgrenciAdi"></strong>
                                            </h6>
                                            <div id="seciliOgrenciDetay" class="text-muted small"></div>
                                        </div>
                                        <button type="button" class="btn btn-sm btn-outline-danger" onclick="ogrenciSecimiTemizle()">
                                            <i class="bi bi-x"></i>
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Veli Bilgisi (Otomatik) -->
                    <div class="mb-4" id="veliBilgiAlani" style="display: none;">
                        <label class="form-label">
                            <i class="bi bi-person"></i> Veli Bilgisi
                        </label>
                        <div class="card" style="border-radius: 12px; background: #f8fafc;">
                            <div class="card-body">
                                <div id="veliBilgiIcerik">
                                    <!-- JavaScript ile doldurulacak -->
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Rehber Öğretmen Seçimi -->
                    <div class="mb-4">
                        <label class="form-label">
                            <i class="bi bi-person-badge"></i> Rehber Öğretmen Seçin *
                        </label>
                        <select id="rehberOgretmen" class="form-select" required style="border-radius: 12px;">
                            <option value="">Rehber öğretmen seçin...</option>
                            <!-- JavaScript ile doldurulacak -->
                        </select>
                    </div>
                    
                    <!-- Mesaj (Opsiyonel) -->
                    <div class="mb-4">
                        <label class="form-label">
                            <i class="bi bi-chat-left-text"></i> Mesaj (Opsiyonel)
                        </label>
                        <textarea id="talepMesaj" class="form-control" rows="3" placeholder="Rehber öğretmene göndermek istediğiniz mesaj..." style="border-radius: 12px;"></textarea>
                    </div>
                </form>
            </div>
            <div class="modal-footer" style="border: none; padding: 20px 30px;">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal" style="border-radius: 12px;">İptal</button>
                <button type="button" id="rehberTalepGonderBtn" class="btn btn-primary" onclick="rehberTalepGonder()" style="background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%); border: none; border-radius: 12px; font-weight: 600;">
                    <i class="bi bi-send"></i> Talep Gönder
                </button>
            </div>
        </div>
    </div>
</div>

<script>
let seciliVeliId = null;
let seciliOgrenciId = null;
let seciliOgrenci = null;
let tumOgrenciler = [];
let tumRehberler = [];

// Modal açıldığında verileri yükle
const rehberTalepModal = document.getElementById('rehberTalepModal');
if (rehberTalepModal) {
    rehberTalepModal.addEventListener('show.bs.modal', function() {
        console.log('🔔 Modal açıldı, veriler yükleniyor...');
        // Formu temizle
        seciliVeliId = null;
        seciliOgrenciId = null;
        seciliOgrenci = null;
        document.getElementById('rehberTalepForm').reset();
        document.getElementById('seciliOgrenciBilgi').style.display = 'none';
        document.getElementById('veliBilgiAlani').style.display = 'none';
        document.getElementById('ogrenciListesi').style.display = 'none';
        document.getElementById('ogrenciAra').value = '';
        
        ogrencileriYukle();
        rehberleriYukle();
    });
}

async function ogrencileriYukle() {
    try {
        console.log('📡 Öğrenci listesi yükleniyor...');
        const response = await fetch('/kurum/tum-ogrenciler-api');
        
        if (!response.ok) {
            throw new Error(`HTTP error! status: ${response.status}`);
        }
        
        const data = await response.json();
        console.log('✅ Öğrenciler yüklendi:', data.length, 'öğrenci bulundu');
        tumOgrenciler = data;
        
        // Otomatik arama kaldırıldı - kullanıcı arama yapınca sonuçlar gösterilecek
    } catch (error) {
        console.error('❌ Öğrenci yükleme hatası:', error);
        const liste = document.getElementById('ogrenciListesi');
        liste.innerHTML = '<div class="alert alert-danger">Öğrenciler yüklenirken hata oluştu: ' + error.message + '</div>';
        liste.style.display = 'block';
    }
}

async function rehberleriYukle() {
    try {
        const response = await fetch('/kurum/rehberler-api');
        const data = await response.json();
        tumRehberler = data;
        
        const select = document.getElementById('rehberOgretmen');
        select.innerHTML = '<option value="">Rehber öğretmen seçin...</option>';
        
        data.forEach(rehber => {
            const option = document.createElement('option');
            option.value = rehber.id;
            option.textContent = `${rehber.ad_soyad || rehber.username} ${rehber.brans ? `(${rehber.brans})` : ''}`;
            select.appendChild(option);
        });
    } catch (error) {
        console.error('Rehber yükleme hatası:', error);
    }
}

// Global scope'a ekle
window.ogrenciAra = function() {
    const aramaMetni = document.getElementById('ogrenciAra').value.toLowerCase().trim();
    const liste = document.getElementById('ogrenciListesi');
    
    // Eğer öğrenciler henüz yüklenmemişse bekle
    if (!tumOgrenciler || tumOgrenciler.length === 0) {
        console.log('⏳ Öğrenciler henüz yüklenmedi, bekleniyor...');
        liste.innerHTML = '<div class="alert alert-info">Öğrenciler yükleniyor, lütfen bekleyin...</div>';
        liste.style.display = 'block';
        return;
    }
    
    // Eğer arama boşsa, listeyi gizle
    if (!aramaMetni || aramaMetni.length === 0) {
        liste.style.display = 'none';
        return;
    }
    
    console.log('🔍 Arama yapılıyor:', aramaMetni, 'Toplam öğrenci:', tumOgrenciler.length);
    
    // Arama yapılıyorsa (1 karakter bile olsa) eşleşenleri göster
    // Kelimeleri ayır ve her kelimeyi ayrı ayrı ara
    const aramaKelimeleri = aramaMetni.split(/\s+/).filter(k => k.length > 0);
    
    const eslesenler = tumOgrenciler.filter(ogrenci => {
        const ad = (ogrenci.ad_soyad || '').toLowerCase();
        const okul = (ogrenci.okul || '').toLowerCase();
        const sinif = (ogrenci.sinif || '').toLowerCase();
        const tcNo = (ogrenci.tc_no || '').toLowerCase();
        
        // Tüm arama kelimelerinin eşleşmesi gerekiyor
        return aramaKelimeleri.every(kelime => {
            return ad.includes(kelime) || 
                   okul.includes(kelime) || 
                   sinif.includes(kelime) ||
                   tcNo.includes(kelime);
        });
    });
    
    console.log('✅ Eşleşen öğrenci sayısı:', eslesenler.length);
    
    if (eslesenler.length === 0) {
        liste.innerHTML = '<div class="alert alert-warning">Öğrenci bulunamadı! Farklı bir arama terimi deneyin.</div>';
        liste.style.display = 'block';
        return;
    }
    
    // Sonuç sayısını göster
    let html = `<div class="mb-2"><small class="text-muted"><strong>${eslesenler.length}</strong> öğrenci bulundu:</small></div>`;
    
    // Maksimum 30 sonuç göster
    eslesenler.slice(0, 30).forEach(ogrenci => {
        const ad = (ogrenci.ad_soyad || '').replace(/'/g, "\\'").replace(/"/g, '&quot;');
        html += `
            <div class="card mb-2" style="cursor: pointer; border-radius: 12px; transition: all 0.2s;" onmouseover="this.style.background='#f8fafc'" onmouseout="this.style.background='white'" onclick="ogrenciSec(${ogrenci.id})">
                <div class="card-body p-3">
                    <strong>${ogrenci.ad_soyad}</strong>
                    ${ogrenci.sinif ? `<span class="badge bg-primary ms-2">${ogrenci.sinif}</span>` : ''}
                    ${ogrenci.okul ? `<br><small class="text-muted">🏫 ${ogrenci.okul}</small>` : ''}
                    ${ogrenci.kaynak === 'kurum' ? `<span class="badge bg-info ms-2">Kurum</span>` : ''}
                </div>
            </div>
        `;
    });
    
    // Eğer 30'dan fazla sonuç varsa uyarı göster
    if (eslesenler.length > 30) {
        html += `<div class="alert alert-info mt-2"><small>Daha fazla sonuç için arama kriterlerinizi daraltın. (Toplam ${eslesenler.length} sonuç)</small></div>`;
    }
    
    liste.innerHTML = html;
    liste.style.display = 'block';
};

// Global scope'a ekle
window.ogrenciSec = async function(ogrenciId) {
    seciliOgrenciId = ogrenciId;
    seciliOgrenci = tumOgrenciler.find(o => o.id == ogrenciId);
    
    if (!seciliOgrenci) {
        alert('Öğrenci bulunamadı!');
        return;
    }
    
    // Öğrenci bilgisini göster
    document.getElementById('seciliOgrenciAdi').textContent = seciliOgrenci.ad_soyad;
    let detayHtml = '';
    if (seciliOgrenci.sinif) detayHtml += `<span class="badge bg-primary me-2">${seciliOgrenci.sinif}</span>`;
    if (seciliOgrenci.okul) detayHtml += `🏫 ${seciliOgrenci.okul}`;
    if (seciliOgrenci.kaynak === 'kurum') detayHtml += `<span class="badge bg-info ms-2">Kurum</span>`;
    document.getElementById('seciliOgrenciDetay').innerHTML = detayHtml || '<small class="text-muted">Detay bilgisi yok</small>';
    document.getElementById('seciliOgrenciBilgi').style.display = 'block';
    document.getElementById('ogrenciListesi').style.display = 'none';
    document.getElementById('ogrenciAra').value = '';
    
    // Veli bilgisini yükle
    if (seciliOgrenci.veli_id) {
        // Veli öğrencisi - users tablosundan veli bilgisini yükle
        await veliBilgisiniYukle(seciliOgrenci.veli_id);
    } else if (seciliOgrenci.kaynak === 'kurum' && (seciliOgrenci.veli_adi || seciliOgrenci.veli_telefon)) {
        // Kurum öğrencisi - ogrenci_kayitlari tablosundan veli bilgisini göster
        let veliHtml = `
            <div class="d-flex align-items-center">
                <div class="flex-grow-1">
                    <h6 class="mb-1">
                        <i class="bi bi-person-fill text-primary"></i> 
                        <strong>${seciliOgrenci.veli_adi || 'Veli'}</strong>
                    </h6>
        `;
        
        // Geçici telefon kontrolü (örn: "5072031028.0" gibi)
        const telefon = seciliOgrenci.veli_telefon && !seciliOgrenci.veli_telefon.includes('.0') && seciliOgrenci.veli_telefon.length > 5 
            ? seciliOgrenci.veli_telefon 
            : (seciliOgrenci.veli_telefon ? seciliOgrenci.veli_telefon.replace('.0', '') : null);
        
        if (telefon) {
            veliHtml += `<div class="small text-muted">📱 ${telefon}</div>`;
        }
        
        if (!telefon && !seciliOgrenci.veli_adi) {
            veliHtml += `<div class="small text-muted">İletişim bilgisi bulunmuyor</div>`;
        }
        
        veliHtml += `</div></div>`;
        
        document.getElementById('veliBilgiIcerik').innerHTML = veliHtml;
        document.getElementById('veliBilgiAlani').style.display = 'block';
        seciliVeliId = null; // Kurum öğrencileri için veli_id yok
    } else {
        // Veli bilgisi yok
        document.getElementById('veliBilgiIcerik').innerHTML = '<div class="alert alert-warning">Veli bilgisi bulunmuyor.</div>';
        document.getElementById('veliBilgiAlani').style.display = 'block';
        seciliVeliId = null;
    }
};

// Global scope'a ekle
window.ogrenciSecimiTemizle = function() {
    seciliVeliId = null;
    seciliOgrenciId = null;
    seciliOgrenci = null;
    document.getElementById('seciliOgrenciBilgi').style.display = 'none';
    document.getElementById('veliBilgiAlani').style.display = 'none';
    document.getElementById('ogrenciAra').value = '';
};

async function veliBilgisiniYukle(veliId) {
    try {
        const response = await fetch(`/kurum/veli-bilgi-api?veli_id=${veliId}`);
        const data = await response.json();
        
        if (!data || !data.id) {
            document.getElementById('veliBilgiIcerik').innerHTML = '<div class="alert alert-warning">Veli bilgisi bulunamadı!</div>';
            document.getElementById('veliBilgiAlani').style.display = 'block';
            return;
        }
        
        seciliVeliId = data.id;
        
        // Geçici email ve telefon kontrolü
        const email = data.email && !data.email.includes('@temp.com') ? data.email : null;
        const telefon = data.telefon && !data.telefon.includes('.0') && data.telefon.length > 5 ? data.telefon : null;
        
        let veliHtml = `
            <div class="d-flex align-items-center">
                <div class="flex-grow-1">
                    <h6 class="mb-1">
                        <i class="bi bi-person-fill text-primary"></i> 
                        <strong>${data.ad_soyad || data.username || 'Veli'}</strong>
                    </h6>
        `;
        
        if (telefon) {
            veliHtml += `<div class="small text-muted">📱 ${telefon}</div>`;
        }
        
        if (email) {
            veliHtml += `<div class="small text-muted">📧 ${email}</div>`;
        }
        
        if (!telefon && !email) {
            veliHtml += `<div class="small text-muted">İletişim bilgisi bulunmuyor</div>`;
        }
        
        veliHtml += `</div></div>`;
        
        document.getElementById('veliBilgiIcerik').innerHTML = veliHtml;
        document.getElementById('veliBilgiAlani').style.display = 'block';
    } catch (error) {
        console.error('Veli bilgisi yükleme hatası:', error);
        document.getElementById('veliBilgiIcerik').innerHTML = '<div class="alert alert-danger">Veli bilgisi yüklenirken hata oluştu!</div>';
        document.getElementById('veliBilgiAlani').style.display = 'block';
    }
}

// Global scope'a ekle
window.showRehberTalepModal = function() {
    const modal = new bootstrap.Modal(document.getElementById('rehberTalepModal'));
    modal.show();
};

async function rehberTalepGonder() {
    if (!seciliOgrenciId || !seciliOgrenci) {
        alert('❌ Lütfen bir öğrenci seçin!');
        return;
    }
    
    // Kurum öğrencileri için veli bilgisi kontrolü
    let kullanilacakVeliId = seciliVeliId;
    
    if (seciliOgrenci.kaynak === 'kurum' && !seciliOgrenci.veli_id && seciliOgrenci.veli_telefon) {
        // Kurum öğrencisi - veli_telefon ile users tablosunda veli ara
        try {
            const veliTelefon = seciliOgrenci.veli_telefon.replace('.0', '').trim();
            const response = await fetch(`/kurum/veli-bul-telefon?telefon=${encodeURIComponent(veliTelefon)}`);
            const veliData = await response.json();
            
            if (veliData && veliData.id) {
                kullanilacakVeliId = veliData.id;
                console.log('✅ Veli bulundu (telefon ile):', veliData);
            } else {
                alert('❌ Bu öğrenci için sistemde veli hesabı bulunamadı. Rehber öğretmene talep göndermek için öğrencinin veli hesabı olması gerekiyor.');
                return;
            }
        } catch (error) {
            console.error('Veli arama hatası:', error);
            alert('❌ Veli bilgisi kontrol edilirken hata oluştu!');
            return;
        }
    }
    
    if (!kullanilacakVeliId) {
        alert('❌ Veli bilgisi bulunamadı!');
        return;
    }
    
    const rehberId = document.getElementById('rehberOgretmen').value;
    if (!rehberId) {
        alert('❌ Lütfen bir rehber öğretmen seçin!');
        return;
    }
    
    const mesaj = document.getElementById('talepMesaj').value.trim();
    
    const data = {
        veli_id: kullanilacakVeliId,
        ogrenci_id: seciliOgrenciId,
        rehber_ogretmen_id: rehberId,
        ogrenci_no: seciliOgrenci.ogrenci_no || '',
        ad_soyad: seciliOgrenci.ad_soyad,
        sinif: seciliOgrenci.sinif || '',
        okul: seciliOgrenci.okul || '',
        mesaj: mesaj,
        ogrenci_kaynak: seciliOgrenci.kaynak || 'veli'
    };
    
    console.log('📤 Talep gönderiliyor:', data);
    
    // Butonu ID ile bul
    const btn = document.getElementById('rehberTalepGonderBtn');
    if (!btn) {
        console.error('❌ Talep gönder butonu bulunamadı!');
        alert('Bir hata oluştu! Lütfen sayfayı yenileyin.');
        return;
    }
    
    const btnText = btn.innerHTML;
    btn.disabled = true;
    btn.innerHTML = '<i class="bi bi-hourglass-split"></i> Gönderiliyor...';
    
    try {
        const response = await fetch('/kurum/rehber-talep-gonder', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify(data)
        });
        
        const result = await response.json();
        
        if (result.success) {
            alert('✅ ' + result.message);
            const modal = bootstrap.Modal.getInstance(document.getElementById('rehberTalepModal'));
            modal.hide();
            location.reload();
        } else {
            alert('❌ ' + result.message);
            btn.disabled = false;
            btn.innerHTML = btnText;
        }
    } catch (error) {
        console.error('Talep gönderme hatası:', error);
        alert('Bir hata oluştu!');
        btn.disabled = false;
        btn.innerHTML = btnText;
    }
}

// Event listener'ları ekle (DOM yüklendikten sonra)
document.addEventListener('DOMContentLoaded', function() {
    // Öğrenci arama input event listener'ları
    const ogrenciAraInput = document.getElementById('ogrenciAra');
    const ogrenciAraBtn = document.getElementById('ogrenciAraBtn');
    
    if (ogrenciAraInput) {
        ogrenciAraInput.addEventListener('keyup', window.ogrenciAra);
        ogrenciAraInput.addEventListener('input', window.ogrenciAra);
        ogrenciAraInput.addEventListener('focus', window.ogrenciAra);
    }
    
    if (ogrenciAraBtn) {
        ogrenciAraBtn.addEventListener('click', window.ogrenciAra);
    }
});

// Modal açıldığında da event listener'ları kontrol et
if (rehberTalepModal) {
    rehberTalepModal.addEventListener('shown.bs.modal', function() {
        // Modal tamamen açıldıktan sonra event listener'ları tekrar ekle
        const ogrenciAraInput = document.getElementById('ogrenciAra');
        const ogrenciAraBtn = document.getElementById('ogrenciAraBtn');
        
        if (ogrenciAraInput && window.ogrenciAra) {
            // Önceki listener'ları kaldır
            const newInput = ogrenciAraInput.cloneNode(true);
            ogrenciAraInput.parentNode.replaceChild(newInput, ogrenciAraInput);
            
            // Yeni listener'ları ekle
            document.getElementById('ogrenciAra').addEventListener('keyup', window.ogrenciAra);
            document.getElementById('ogrenciAra').addEventListener('input', window.ogrenciAra);
            document.getElementById('ogrenciAra').addEventListener('focus', window.ogrenciAra);
        }
        
        if (ogrenciAraBtn && window.ogrenciAra) {
            const newBtn = ogrenciAraBtn.cloneNode(true);
            ogrenciAraBtn.parentNode.replaceChild(newBtn, ogrenciAraBtn);
            document.getElementById('ogrenciAraBtn').addEventListener('click', window.ogrenciAra);
        }
    });
}
</script>

