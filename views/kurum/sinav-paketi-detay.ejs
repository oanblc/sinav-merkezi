<%- include('../partials/header-dashboard', { title: paket.ad + ' - Kurum Paneli', user: user }) %>

<style>
    .page-header {
        background: linear-gradient(135deg, #003b78 0%, #2563eb 100%);
        color: white;
        padding: 40px 0;
        margin: -30px -15px 40px;
        border-radius: 0 0 24px 24px;
        box-shadow: 0 8px 32px rgba(236, 72, 153, 0.3);
    }
    
    .info-card {
        background: white;
        border-radius: 20px;
        padding: 30px;
        box-shadow: 0 4px 16px rgba(0,0,0,0.08);
        margin-bottom: 30px;
    }
    
    .sinav-item {
        background: #f8fafc;
        border-left: 4px solid #3b82f6;
        border-radius: 12px;
        padding: 20px;
        margin-bottom: 16px;
        transition: all 0.2s;
    }
    
    .sinav-item:hover {
        background: #fdf2f8;
        transform: translateX(4px);
    }
</style>

<!-- Page Header -->
<div class="page-header">
    <div class="container">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <h1 style="font-weight: 800; margin-bottom: 8px;">
                    <i class="bi bi-box-seam"></i> <%= paket.ad %>
                </h1>
                <p style="opacity: 0.9; margin: 0;">
                    <i class="bi bi-mortarboard"></i> <%= paket.sinif %>. Sınıf
                    <% if (paket.aciklama) { %>
                    | <%= paket.aciklama %>
                    <% } %>
                </p>
            </div>
            <div class="d-flex gap-2">
                <button class="btn btn-light" onclick="ogrenciAtaModalAc()" style="border-radius: 12px; font-weight: 600;">
                    <i class="bi bi-person-plus"></i> Öğrenci Ata
                </button>
                <a href="/kurum/sinav-paketleri" class="btn btn-light" style="border-radius: 12px; font-weight: 600;">
                    <i class="bi bi-arrow-left"></i> Geri
                </a>
            </div>
        </div>
    </div>
</div>

<!-- İstatistikler -->
<div class="row g-4 mb-4">
    <div class="col-md-4">
        <div class="info-card text-center">
            <div style="font-size: 3rem; color: #3b82f6; margin-bottom: 8px;">
                <i class="bi bi-journals"></i>
            </div>
            <h3 style="font-weight: 800; color: #1e293b; margin-bottom: 4px;"><%= sinavlar.length %></h3>
            <p style="color: #64748b; margin: 0;">Toplam Sınav</p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="info-card text-center">
            <div style="font-size: 3rem; color: #10b981; margin-bottom: 8px;">
                <i class="bi bi-people"></i>
            </div>
            <h3 style="font-weight: 800; color: #1e293b; margin-bottom: 4px;"><%= ogrenciler.length %></h3>
            <p style="color: #64748b; margin: 0;">Atanan Öğrenci</p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="info-card text-center">
            <div style="font-size: 3rem; color: #3b82f6; margin-bottom: 8px;">
                <i class="bi bi-calendar-check"></i>
            </div>
            <h3 style="font-weight: 800; color: #1e293b; margin-bottom: 4px;"><%= paket.aktif ? 'Aktif' : 'Pasif' %></h3>
            <p style="color: #64748b; margin: 0;">Paket Durumu</p>
        </div>
    </div>
</div>

<!-- Sınavlar -->
<div class="info-card">
    <h4 style="font-weight: 700; color: #1e293b; margin-bottom: 24px;">
        <i class="bi bi-journals"></i> Paketteki Sınavlar (<%= sinavlar.length %>)
    </h4>
    
    <% if (sinavlar.length === 0) { %>
    <div class="alert alert-info">
        <i class="bi bi-info-circle"></i> Bu pakette henüz sınav bulunmuyor.
    </div>
    <% } else { %>
    <% sinavlar.forEach(function(sinav, index) { %>
    <div class="sinav-item">
        <div class="d-flex justify-content-between align-items-center">
            <div class="flex-grow-1">
                <h5 style="font-weight: 600; color: #1e293b; margin-bottom: 8px;">
                    <%= index + 1 %>. <%= sinav.ad %>
                </h5>
                <p style="color: #64748b; font-size: 0.875rem; margin: 0;">
                    <i class="bi bi-calendar"></i> <%= new Date(sinav.tarih).toLocaleDateString('tr-TR', { day: 'numeric', month: 'long', year: 'numeric' }) %>
                    <% if (sinav.ders) { %>
                    | <i class="bi bi-book"></i> <%= sinav.ders %>
                    <% } %>
                    <% if (sinav.katilimci_sayisi) { %>
                    | <i class="bi bi-people"></i> <%= sinav.katilimci_sayisi %> Katılımcı
                    <% } %>
                </p>
            </div>
            <div class="d-flex gap-2">
                <a href="/kurum/sinav-detay/<%= sinav.id %>" class="btn btn-primary btn-sm" style="background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%); border: none; border-radius: 10px;">
                    <i class="bi bi-eye"></i> Detay
                </a>
            </div>
        </div>
    </div>
    <% }); %>
    <% } %>
</div>

<!-- Atanan Öğrenciler -->
<div class="info-card">
    <h4 style="font-weight: 700; color: #1e293b; margin-bottom: 24px;">
        <i class="bi bi-people"></i> Atanan Öğrenciler (<%= ogrenciler.length %>)
    </h4>
    
    <% if (ogrenciler.length === 0) { %>
    <div class="alert alert-info">
        <i class="bi bi-info-circle"></i> Bu pakete henüz öğrenci atanmamış.
        <button class="btn btn-primary btn-sm ms-3" onclick="ogrenciAtaModalAc()">
            <i class="bi bi-person-plus"></i> Öğrenci Ata
        </button>
    </div>
    <% } else { %>
    <div class="table-responsive">
        <table class="table table-hover">
            <thead>
                <tr>
                    <th>Öğrenci Adı</th>
                    <th>Sınıf</th>
                    <th>Kaynak</th>
                    <th>Atama Tarihi</th>
                    <th>Durum</th>
                </tr>
            </thead>
            <tbody>
                <% ogrenciler.forEach(function(ogrenci) { %>
                <tr>
                    <td><strong><%= ogrenci.ogrenci_adi %></strong></td>
                    <td><%= ogrenci.sinif %></td>
                    <td>
                        <% if (ogrenci.ogrenci_kaynak === 'kurum') { %>
                        <span class="badge bg-primary">Kurum</span>
                        <% } else { %>
                        <span class="badge bg-success">Veli</span>
                        <% } %>
                    </td>
                    <td><%= new Date(ogrenci.atama_tarihi).toLocaleDateString('tr-TR') %></td>
                    <td>
                        <% if (ogrenci.durum === 'aktif') { %>
                        <span class="badge bg-success">Aktif</span>
                        <% } else { %>
                        <span class="badge bg-secondary">İptal</span>
                        <% } %>
                    </td>
                </tr>
                <% }); %>
            </tbody>
        </table>
    </div>
    <% } %>
</div>

<!-- Öğrenci Atama Modal -->
<div class="modal fade" id="ogrenciAtaModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content" style="border-radius: 20px;">
            <div class="modal-header" style="background: linear-gradient(135deg, #003b78 0%, #2563eb 100%); color: white; border-radius: 20px 20px 0 0;">
                <h5 class="modal-title">
                    <i class="bi bi-person-plus"></i> Pakete Öğrenci Ata
                </h5>
                <button type="button" class="btn-close btn-close-white" onclick="ogrenciAtaModalKapat()"></button>
            </div>
            <div class="modal-body">
                <p class="text-muted">Bu pakete atamak istediğiniz öğrencileri seçin. Seçilen öğrenciler paketteki tüm sınavlara otomatik olarak kaydedilecektir.</p>
                
                <!-- Filtreler -->
                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        <input type="text" id="ogrenciAra" class="form-control" placeholder="🔍 Öğrenci ara..." onkeyup="ogrenciFiltreUygula()">
                    </div>
                    <div class="col-md-6">
                        <select id="sinifFiltre" class="form-select" onchange="ogrenciFiltreUygula()">
                            <option value="">Tüm Sınıflar</option>
                            <option value="<%= paket.sinif %>" selected><%= paket.sinif %>. Sınıf (Önerilen)</option>
                            <% for (let i = 1; i <= 12; i++) { %>
                            <% if (i != paket.sinif) { %>
                            <option value="<%= i %>"><%= i %>. Sınıf</option>
                            <% } %>
                            <% } %>
                        </select>
                    </div>
                </div>
                
                <!-- Yükleniyor -->
                <div id="ogrenciYukleniyor" class="text-center py-4">
                    <div class="spinner-border text-primary" role="status"></div>
                    <p class="mt-2">Öğrenciler yükleniyor...</p>
                </div>
                
                <!-- Öğrenci Listesi -->
                <div id="ogrenciListesi" style="display: none; max-height: 400px; overflow-y: auto;">
                    <!-- JavaScript ile doldurulacak -->
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" onclick="ogrenciAtaModalKapat()">İptal</button>
                <button type="button" class="btn btn-primary" onclick="ogrencileriAta()" style="background: linear-gradient(135deg, #003b78 0%, #2563eb 100%); border: none;">
                    <i class="bi bi-check-circle"></i> Seçilenleri Ata
                </button>
            </div>
        </div>
    </div>
</div>

<script>
let tumOgrenciler = [];
let ogrenciYuklendi = false;

// Modal ac fonksiyonu
function ogrenciAtaModalAc() {
    const modal = document.getElementById('ogrenciAtaModal');
    modal.classList.add('show');
    modal.style.display = 'block';
    document.body.classList.add('modal-open');

    // Backdrop ekle
    if (!document.querySelector('.modal-backdrop')) {
        const backdrop = document.createElement('div');
        backdrop.className = 'modal-backdrop fade show';
        document.body.appendChild(backdrop);
    }

    // Ogrencileri yukle
    if (!ogrenciYuklendi) {
        ogrencileriYukle();
    }
}

// Modal kapat fonksiyonu
function ogrenciAtaModalKapat() {
    const modal = document.getElementById('ogrenciAtaModal');
    modal.classList.remove('show');
    modal.style.display = 'none';
    document.body.classList.remove('modal-open');

    // Backdrop kaldir
    const backdrop = document.querySelector('.modal-backdrop');
    if (backdrop) backdrop.remove();
}

// Ogrencileri yukle
async function ogrencileriYukle() {
    const yukleniyorDiv = document.getElementById('ogrenciYukleniyor');
    const listeDiv = document.getElementById('ogrenciListesi');

    // Loading goster
    yukleniyorDiv.style.display = 'block';
    listeDiv.style.display = 'none';

    try {
        const res = await fetch('/kurum/ogrenci-kayitlari-api');

        if (!res.ok) {
            throw new Error('API hatasi: ' + res.status);
        }

        const data = await res.json();

        tumOgrenciler = data.map(function(o) {
            return {
                id: o.id,
                ad_soyad: o.ogrenci_adi_soyadi || '',
                sinif: o.sinif || '',
                tc_no: o.tc_kimlik_no || ''
            };
        });

        ogrenciYuklendi = true;
        ogrenciListesiniGoster();

    } catch (error) {
        yukleniyorDiv.innerHTML = '<div class="alert alert-danger">Ogrenciler yuklenirken hata: ' + error.message + '</div>';
    }
}

// Listeyi goster
function ogrenciListesiniGoster() {
    const liste = document.getElementById('ogrenciListesi');
    const yukleniyorDiv = document.getElementById('ogrenciYukleniyor');

    if (tumOgrenciler.length === 0) {
        liste.innerHTML = '<div class="alert alert-info">Henuz ogrenci kaydi bulunmuyor.</div>';
        liste.style.display = 'block';
        yukleniyorDiv.style.display = 'none';
        return;
    }

    let html = '';
    for (let i = 0; i < tumOgrenciler.length; i++) {
        const ogrenci = tumOgrenciler[i];
        const ad = ogrenci.ad_soyad || '-';
        const sinif = ogrenci.sinif || '-';
        const adLower = ad.toLowerCase();

        html += '<div class="form-check p-3 mb-2" style="background: #f8fafc; border-radius: 12px;" data-sinif="' + sinif + '" data-ad="' + adLower + '">';
        html += '<input class="form-check-input" type="checkbox" value="' + ogrenci.id + '_kurum" id="ogr_' + ogrenci.id + '">';
        html += '<label class="form-check-label flex-grow-1" for="ogr_' + ogrenci.id + '" style="cursor: pointer;">';
        html += '<strong>' + ad + '</strong>';
        html += '<span class="badge bg-primary ms-2">Kurum</span>';
        html += '<span class="badge bg-secondary ms-1">' + sinif + '</span>';
        html += '</label></div>';
    }

    liste.innerHTML = html;
    liste.style.display = 'block';
    yukleniyorDiv.style.display = 'none';

    ogrenciFiltreUygula();
}

// Filtre uygula
function ogrenciFiltreUygula() {
    const aramaInput = document.getElementById('ogrenciAra');
    const sinifSelect = document.getElementById('sinifFiltre');

    const aramaMetni = aramaInput ? aramaInput.value.toLowerCase() : '';
    const sinifFiltre = sinifSelect ? sinifSelect.value : '';

    const items = document.querySelectorAll('#ogrenciListesi .form-check');
    for (let i = 0; i < items.length; i++) {
        const item = items[i];
        const ad = item.getAttribute('data-ad') || '';
        const sinif = item.getAttribute('data-sinif') || '';

        const aramaUygun = !aramaMetni || ad.indexOf(aramaMetni) >= 0;
        const sinifUygun = !sinifFiltre || sinif === sinifFiltre;

        item.style.display = (aramaUygun && sinifUygun) ? 'block' : 'none';
    }
}

// Ogrencileri ata
async function ogrencileriAta() {
    const checkboxlar = document.querySelectorAll('#ogrenciListesi input:checked');
    const secilenler = [];
    for (let i = 0; i < checkboxlar.length; i++) {
        secilenler.push(checkboxlar[i].value);
    }

    if (secilenler.length === 0) {
        alert('En az 1 ogrenci secmelisiniz!');
        return;
    }

    if (!confirm(secilenler.length + ' ogrenci pakete atanacak. Onayliyor musunuz?')) {
        return;
    }

    try {
        const response = await fetch('/kurum/paket-ogrenci-ata', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                paket_id: <%= paket.id %>,
                ogrenci_ids: secilenler
            })
        });

        const result = await response.json();

        if (result.success) {
            alert(result.message);
            location.reload();
        } else {
            alert(result.message);
        }
    } catch (error) {
        alert('Bir hata olustu!');
    }
}
</script>

<%- include('../partials/footer-dashboard') %>

