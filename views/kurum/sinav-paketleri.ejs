<%- include('../partials/header-dashboard', { title: 'Sınav Paketleri - Kurum Paneli', user: user }) %>

<style>
    .page-header {
        background: linear-gradient(135deg, #2563eb 0%, #0ea5e9 100%);
        color: white;
        padding: 40px 0;
        margin: -30px -15px 40px;
        border-radius: 0 0 24px 24px;
        box-shadow: 0 8px 32px rgba(37, 99, 235, 0.25);
    }
    
    .paket-card {
        background: white;
        border-radius: 20px;
        padding: 30px;
        box-shadow: 0 4px 16px rgba(0,0,0,0.08);
        transition: all 0.3s ease;
        height: 100%;
        position: relative;
    }
    
    .paket-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 8px 32px rgba(0,0,0,0.12);
    }
    
    .paket-badge {
        display: inline-block;
        padding: 6px 12px;
        border-radius: 8px;
        font-size: 0.85rem;
        font-weight: 600;
        margin-right: 8px;
    }
    
    .btn-action {
        border-radius: 10px;
        padding: 8px 16px;
        font-weight: 600;
        font-size: 0.9rem;
        transition: all 0.2s;
    }
    
    .empty-state {
        text-align: center;
        padding: 60px 20px;
        background: white;
        border-radius: 20px;
        box-shadow: 0 4px 16px rgba(0,0,0,0.08);
    }

    .status-active {
        position: absolute;
        top: 20px;
        right: 20px;
        background: #dcfce7;
        color: #15803d;
        padding: 8px 10px;
        border-radius: 10px;
        font-weight: 700;
    }

    .status-passive {
        position: absolute;
        top: 20px;
        right: 20px;
        background: #e2e8f0;
        color: #475569;
        padding: 8px 10px;
        border-radius: 10px;
        font-weight: 700;
    }

    .paket-icon {
        width: 70px;
        height: 70px;
        background: linear-gradient(135deg, #2563eb 0%, #0ea5e9 100%);
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 20px;
        box-shadow: 0 8px 20px rgba(37, 99, 235, 0.25);
    }

    .badge-sinav {
        background: #e0f2fe;
        color: #1d4ed8;
    }

    .badge-sinif {
        background: #eef2ff;
        color: #4338ca;
    }

    .badge-ogrenci {
        background: #ecfdf3;
        color: #15803d;
    }

    .price-primary {
        font-weight: 800;
        color: #1d4ed8;
        margin: 0;
    }

    .btn-primary-gradient {
        background: linear-gradient(135deg, #2563eb 0%, #0ea5e9 100%);
        border: none;
        color: #fff;
    }

    .btn-edit-ghost {
        background: #e0f2fe;
        color: #0f172a;
        border: none;
    }

    .btn-delete-soft {
        background: #fee2e2;
        color: #b91c1c;
        border: none;
    }
</style>

<!-- Page Header -->
<div class="page-header">
    <div class="container">
        <h1 style="font-weight: 800; margin-bottom: 8px;">
            <i class="bi bi-box-seam"></i> Sınav Paketleri
        </h1>
        <p style="opacity: 0.9; margin: 0;">Birden fazla sınav içeren paketler oluşturun ve öğrencilere atayın</p>
        <div class="mt-3">
            <a href="/kurum/sinav-paketi-olustur" class="btn" style="border-radius: 10px; font-weight: 700; border: none; background: #ffffff; color: #2563eb; padding: 12px 20px; box-shadow: 0 8px 24px rgba(0,0,0,0.12);">
                <i class="bi bi-plus-lg"></i> Yeni Paket Oluştur
            </a>
        </div>
    </div>
</div>

<% const canManage = (typeof isYonetim !== 'undefined' && isYonetim) || (user && user.type && user.type.startsWith('kurum')); %>

<!-- Success/Error Messages -->
<% if (success) { %>
<div class="alert alert-success alert-dismissible fade show" role="alert">
    <i class="bi bi-check-circle"></i> <%= success %>
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
</div>
<% } %>

<% if (error) { %>
<div class="alert alert-danger alert-dismissible fade show" role="alert">
    <i class="bi bi-exclamation-triangle"></i> <%= error %>
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
</div>
<% } %>

<!-- Yeni Paket Oluştur Butonu -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 style="font-weight: 700; color: #1e293b; margin: 0;">
        <i class="bi bi-list-ul"></i> Paket Listesi (<%= paketler.length %>)
    </h3>
    <% if (canManage) { %>
    <a href="/kurum/sinav-paketi-olustur" class="btn btn-primary btn-primary-gradient" style="border-radius: 12px; padding: 12px 24px; font-weight: 600;">
        <i class="bi bi-plus-circle"></i> Yeni Paket Oluştur
    </a>
    <% } %>
</div>

<!-- Paket Listesi -->
<% if (paketler.length === 0) { %>
<div class="empty-state">
    <i class="bi bi-box-seam" style="font-size: 4rem; color: #e2e8f0; margin-bottom: 20px;"></i>
    <h4 style="color: #64748b; margin-bottom: 16px;">Henüz Paket Oluşturulmamış</h4>
    <p style="color: #94a3b8; margin-bottom: 24px;">İlk sınav paketinizi oluşturarak başlayın</p>
    <a href="/kurum/sinav-paketi-olustur" class="btn btn-primary btn-lg btn-primary-gradient" style="border-radius: 12px;">
        <i class="bi bi-plus-circle"></i> Paket Oluştur
    </a>
</div>
<% } else { %>
<div class="row g-4">
    <% paketler.forEach(function(paket) { %>
    <div class="col-md-6 col-lg-4">
        <div class="paket-card">
            <!-- Durum Badge -->
            <% if (paket.aktif) { %>
            <span class="badge status-active">
                <i class="bi bi-check-circle"></i> Aktif
            </span>
            <% } else { %>
            <span class="badge status-passive">
                <i class="bi bi-x-circle"></i> Pasif
            </span>
            <% } %>
            
            <!-- Paket İkonu -->
            <div class="paket-icon">
                <i class="bi bi-box-seam" style="font-size: 2rem; color: white;"></i>
            </div>
            
            <!-- Paket Adı -->
            <h5 style="font-weight: 700; color: #1e293b; margin-bottom: 12px;">
                <%= paket.ad %>
            </h5>
            
            <!-- Açıklama -->
            <% if (paket.aciklama) { %>
            <p style="color: #64748b; font-size: 0.9rem; margin-bottom: 16px;">
                <%= paket.aciklama.substring(0, 80) %><%= paket.aciklama.length > 80 ? '...' : '' %>
            </p>
            <% } %>
            
            <!-- İstatistikler -->
            <div style="display: flex; gap: 12px; margin-bottom: 20px; flex-wrap: wrap;">
                <span class="paket-badge badge-sinav">
                    <i class="bi bi-journals"></i> <%= paket.sinav_sayisi || 0 %> Sınav
                </span>
                <span class="paket-badge badge-sinif">
                    <%= paket.sinif %>. Sınıf
                </span>
                <span class="paket-badge badge-ogrenci">
                    <i class="bi bi-people"></i> <%= paket.ogrenci_sayisi || 0 %> Öğrenci
                </span>
            </div>
            
            <!-- Fiyat -->
            <div style="margin-bottom: 20px;">
                <h3 class="price-primary">
                    <%= paket.fiyat ? paket.fiyat.toLocaleString('tr-TR', { minimumFractionDigits: 0, maximumFractionDigits: 0 }) : '0' %> ₺
                </h3>
            </div>
            
            <!-- Tarih -->
            <p style="color: #94a3b8; font-size: 0.85rem; margin-bottom: 20px;">
                <i class="bi bi-calendar"></i> <%= new Date(paket.olusturulma_tarihi).toLocaleDateString('tr-TR', { day: 'numeric', month: 'long', year: 'numeric' }) %>
            </p>
            
            <!-- Butonlar -->
            <% if (canManage) { %>
            <div class="d-flex gap-2">
                <a href="/kurum/sinav-paketi-detay/<%= paket.id %>" class="btn btn-primary btn-action flex-grow-1 btn-primary-gradient">
                    <i class="bi bi-eye"></i> Detay
                </a>
                <a href="/kurum/sinav-paketi-duzenle/<%= paket.id %>" class="btn btn-warning btn-action btn-edit-ghost">
                    <i class="bi bi-pencil-square"></i>
                </a>
                <button class="btn btn-danger btn-action btn-delete-soft" onclick="paketSil(<%= paket.id %>, '<%= paket.ad %>')">
                    <i class="bi bi-trash"></i>
                </button>
            </div>
            <% } else { %>
            <div class="d-flex gap-2">
                <a href="/kurum/sinav-paketi-detay/<%= paket.id %>" class="btn btn-primary btn-action flex-grow-1 btn-primary-gradient">
                    <i class="bi bi-eye"></i> Detay
                </a>
            </div>
            <% } %>
        </div>
    </div>
    <% }); %>
</div>
<% } %>

<script>
function paketSil(paketId, paketAdi) {
    if (!confirm(`"${paketAdi}" paketini silmek istediğinize emin misiniz?\n\nBu işlem geri alınamaz!`)) {
        return;
    }
    
    fetch(`/kurum/sinav-paketi-sil/${paketId}`, {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json'
        }
    })
    .then(res => res.json())
    .then(data => {
        if (data.success) {
            alert('✅ ' + data.message);
            location.reload();
        } else {
            alert('❌ ' + data.message);
        }
    })
    .catch(error => {
        console.error('Silme hatası:', error);
        alert('Bir hata oluştu!');
    });
}
</script>

<%- include('../partials/footer-dashboard') %>

