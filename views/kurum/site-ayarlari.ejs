<%- include('../partials/header-dashboard', { title: 'Site Ayarları - Sınav Merkezi', user: user }) %>

<div class="container mt-4">
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2><i class="bi bi-gear-fill"></i> Site Ayarları</h2>
                <a href="/kurum/dashboard" class="btn btn-secondary">
                    <i class="bi bi-arrow-left"></i> Geri Dön
                </a>
            </div>

            <% if (success) { %>
                <div class="alert alert-success alert-dismissible fade show">
                    <i class="bi bi-check-circle-fill me-2"></i><%= success %>
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            <% } %>
            <% if (error) { %>
                <div class="alert alert-danger alert-dismissible fade show">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i><%= error %>
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            <% } %>

            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0"><i class="bi bi-building"></i> Kurum Bilgileri</h5>
                </div>
                <div class="card-body">
                    <form method="POST" action="/kurum/site-ayarlari">
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Site Adı</label>
                                <input type="text" class="form-control" name="site_adi" 
                                       value="<%= ayarlar.site_adi || 'Sınav Merkezi' %>" required>
                                <small class="text-muted">Footer'da görünecek kurum adı</small>
                            </div>
                            
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">E-posta</label>
                                <input type="email" class="form-control" name="site_email" 
                                       value="<%= ayarlar.site_email || '' %>" required>
                                <small class="text-muted">İletişim e-posta adresi</small>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Telefon</label>
                                <input type="text" class="form-control" name="site_telefon" 
                                       value="<%= ayarlar.site_telefon || '' %>" required>
                                <small class="text-muted">İletişim telefon numarası</small>
                            </div>
                            
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Adres</label>
                                <input type="text" class="form-control" name="site_adres" 
                                       value="<%= ayarlar.site_adres || '' %>" required>
                                <small class="text-muted">Fiziksel adres</small>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Site Açıklaması</label>
                            <textarea class="form-control" name="site_aciklama" rows="3" required><%= ayarlar.site_aciklama || '' %></textarea>
                            <small class="text-muted">Footer'da görünecek kısa açıklama</small>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary btn-lg">
                                <i class="bi bi-save"></i> Kaydet
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<%- include('../partials/footer-dashboard') %>

