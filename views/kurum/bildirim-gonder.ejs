<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mobil Bildirim Gönder - Sınav Merkezi</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <style>
        body { background: linear-gradient(135deg, #f0f9ff 0%, #e0f2fe 100%); min-height: 100vh; padding: 40px 0; }
        .wrap { max-width: 760px; margin: 0 auto; }
        .head { background: linear-gradient(135deg, #7c3aed 0%, #2563eb 100%); color: #fff; border-radius: 24px 24px 0 0; padding: 36px 40px; text-align: center; }
        .head .ico { font-size: 3rem; margin-bottom: 10px; }
        .body { background: #fff; border-radius: 0 0 24px 24px; padding: 36px 40px; box-shadow: 0 10px 40px rgba(0,0,0,.08); }
        .stat { background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 14px; padding: 14px 18px; display: flex; align-items: center; gap: 10px; margin-bottom: 22px; color: #475569; }
        .stat b { color: #1e293b; }
        label.fw { font-weight: 600; color: #334155; }
        .form-control, .form-select { border-radius: 12px; padding: 12px 14px; border: 2px solid #e2e8f0; }
        .form-control:focus, .form-select:focus { border-color: #2563eb; box-shadow: none; }
        .btn-gonder { background: linear-gradient(135deg, #7c3aed 0%, #2563eb 100%); color: #fff; border: none; border-radius: 12px; padding: 13px; font-weight: 700; width: 100%; }
        .btn-gonder:hover { opacity: .92; color:#fff; }
        .geri { color: #64748b; text-decoration: none; }
        .hedef-box { border: 2px solid #e2e8f0; border-radius: 12px; padding: 12px 14px; margin-bottom: 10px; cursor: pointer; }
        .hedef-box input { margin-right: 8px; }
        .onizleme { background:#0f172a; color:#e2e8f0; border-radius:16px; padding:16px; margin-top:8px; }
        .onizleme .t { font-weight:700; }
        .onizleme .b { color:#94a3b8; font-size:14px; margin-top:4px; }
        .char { font-size:12px; color:#94a3b8; text-align:right; }
    </style>
</head>
<body>
    <div class="wrap">
        <div class="head">
            <div class="ico"><i class="bi bi-bell-fill"></i></div>
            <h3 class="mb-1">Mobil Bildirim Gönder</h3>
            <p class="mb-0" style="opacity:.9">Veli uygulamasına anlık push bildirimi yolla</p>
        </div>
        <div class="body">
            <a href="/kurum/dashboard" class="geri"><i class="bi bi-arrow-left"></i> Panele dön</a>

            <% if (typeof success !== 'undefined' && success) { %>
                <div class="alert alert-success mt-3"><i class="bi bi-check-circle-fill"></i> <%= success %></div>
            <% } %>
            <% if (typeof error !== 'undefined' && error) { %>
                <div class="alert alert-danger mt-3"><i class="bi bi-exclamation-triangle-fill"></i> <%= error %></div>
            <% } %>

            <div class="stat mt-3">
                <i class="bi bi-phone fs-5"></i>
                <span>Bildirim alabilecek (uygulamayı kurup izin vermiş) veli sayısı: <b><%= tokenliVeliSayisi %></b></span>
            </div>

            <% if (tokenliVeliSayisi === 0) { %>
                <div class="alert alert-warning">Henüz hiçbir veli mobil uygulamada bildirim iznini açmamış. Token kaydı olmadan bildirim ulaşmaz.</div>
            <% } %>

            <form method="POST" action="/kurum/bildirim-gonder" onsubmit="return onayla()">
                <div class="mb-3">
                    <label class="fw mb-1">Başlık</label>
                    <input type="text" class="form-control" name="baslik" id="baslik" maxlength="80" required
                           placeholder="Örn: Önemli Duyuru" oninput="onizle()">
                    <div class="char"><span id="bc">0</span>/80</div>
                </div>

                <div class="mb-3">
                    <label class="fw mb-1">Mesaj</label>
                    <textarea class="form-control" name="mesaj" id="mesaj" rows="3" maxlength="180" required
                              placeholder="Bildirim içeriği..." oninput="onizle()"></textarea>
                    <div class="char"><span id="mc">0</span>/180</div>
                </div>

                <label class="fw mb-2 d-block">Kime gönderilsin?</label>
                <label class="hedef-box d-block">
                    <input type="radio" name="hedef" value="tum" checked onchange="sinifGoster()">
                    Tüm veliler
                </label>
                <label class="hedef-box d-block">
                    <input type="radio" name="hedef" value="sinif" onchange="sinifGoster()">
                    Belirli bir sınıfın velileri
                </label>
                <div class="mb-3" id="sinifWrap" style="display:none;">
                    <select class="form-select" name="sinif">
                        <option value="">Sınıf seçin...</option>
                        <% (siniflar || []).forEach(function(s){ %>
                            <option value="<%= s %>"><%= s %></option>
                        <% }); %>
                    </select>
                </div>

                <label class="fw mb-1 d-block">Önizleme</label>
                <div class="onizleme mb-3">
                    <div class="t" id="pT">Başlık</div>
                    <div class="b" id="pB">Mesaj burada görünecek</div>
                </div>

                <button type="submit" class="btn-gonder"><i class="bi bi-send-fill"></i> Bildirimi Gönder</button>
            </form>
        </div>
    </div>

    <script>
        function onizle() {
            var b = document.getElementById('baslik').value;
            var m = document.getElementById('mesaj').value;
            document.getElementById('pT').textContent = b || 'Başlık';
            document.getElementById('pB').textContent = m || 'Mesaj burada görünecek';
            document.getElementById('bc').textContent = b.length;
            document.getElementById('mc').textContent = m.length;
        }
        function sinifGoster() {
            var sinif = document.querySelector('input[name="hedef"]:checked').value === 'sinif';
            document.getElementById('sinifWrap').style.display = sinif ? 'block' : 'none';
        }
        function onayla() {
            var hedef = document.querySelector('input[name="hedef"]:checked').value;
            var kime = hedef === 'tum' ? 'TÜM velilere' : 'seçili sınıfın velilerine';
            return confirm('Bildirim ' + kime + ' gönderilecek. Onaylıyor musunuz?');
        }
    </script>
</body>
</html>
