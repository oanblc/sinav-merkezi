<%- include('partials/header-dashboard', { title: 'Profilim - Sınav Merkezi', user: user }) %>
<%- include('partials/veli-panel-styles') %>

<style>
    /* Profil Header */
    .vp-profile-header {
        background: var(--vp-gradient-primary);
        color: white;
        padding: clamp(20px, 5vw, 40px) 0;
        margin: -20px -12px clamp(16px, 4vw, 24px);
        border-radius: 0 0 var(--vp-radius-lg) var(--vp-radius-lg);
        text-align: center;
    }

    .vp-profile-avatar {
        width: clamp(70px, 18vw, 100px);
        height: clamp(70px, 18vw, 100px);
        background: white;
        border-radius: var(--vp-radius-lg);
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto clamp(12px, 3vw, 20px);
        font-size: clamp(1.8rem, 6vw, 2.5rem);
        font-weight: 700;
        color: var(--vp-primary);
    }

    .vp-profile-header h3 {
        font-size: clamp(1.1rem, 4vw, 1.4rem);
        font-weight: 700;
        margin-bottom: 4px;
    }

    .vp-profile-header p {
        font-size: clamp(0.85rem, 3vw, 0.95rem);
        opacity: 0.9;
        margin: 0;
    }

    /* Form Grubu */
    .vp-form-group {
        margin-bottom: 16px;
    }

    .vp-form-group label {
        display: block;
        font-weight: 600;
        color: var(--vp-text);
        margin-bottom: 8px;
        font-size: clamp(0.85rem, 3vw, 0.95rem);
    }

    /* Bilgi Karti */
    .vp-info-box {
        background: linear-gradient(135deg, #dbeafe 0%, #bfdbfe 100%);
        border: 2px solid #93c5fd;
        border-radius: var(--vp-radius);
        padding: clamp(16px, 4vw, 24px);
        margin-bottom: 16px;
    }

    .vp-info-box h5 {
        color: #1e40af;
        font-weight: 700;
        font-size: clamp(0.95rem, 3.5vw, 1.1rem);
        margin-bottom: 12px;
    }

    .vp-info-box p {
        color: #1e40af;
        margin-bottom: 8px;
        font-size: clamp(0.85rem, 3vw, 0.95rem);
    }

    /* Sifre Degistirme Kutusu */
    .vp-password-box {
        background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%);
        border: 2px solid #fbbf24;
        border-radius: var(--vp-radius);
        padding: clamp(16px, 4vw, 20px);
        margin-bottom: 20px;
    }

    .vp-password-box h6 {
        color: #92400e;
        font-weight: 700;
        font-size: clamp(0.9rem, 3.2vw, 1rem);
        margin-bottom: 12px;
    }

    /* Talep Kartlari */
    .vp-request-card {
        background: white;
        border: 1px solid var(--vp-border);
        border-radius: var(--vp-radius);
        padding: clamp(14px, 3vw, 20px);
        margin-bottom: 12px;
    }

    .vp-request-icon {
        width: clamp(44px, 10vw, 52px);
        height: clamp(44px, 10vw, 52px);
        background: var(--vp-gradient-primary);
        border-radius: var(--vp-radius);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: clamp(1.2rem, 4vw, 1.5rem);
        color: white;
        flex-shrink: 0;
    }

    .vp-request-title {
        font-weight: 700;
        color: var(--vp-text);
        font-size: clamp(0.9rem, 3.2vw, 1rem);
        margin-bottom: 4px;
    }

    .vp-request-meta {
        font-size: clamp(0.75rem, 2.8vw, 0.85rem);
        color: var(--vp-text-muted);
    }
</style>

<!-- Profil Header -->
<div class="vp-profile-header">
    <div class="container">
        <div class="vp-profile-avatar">
            <% if (kullanici.ad_soyad) { %>
                <%= kullanici.ad_soyad.split(' ').map(n => n.charAt(0)).join('').toUpperCase() %>
            <% } else { %>
                <%= kullanici.username.charAt(0).toUpperCase() %>
            <% } %>
        </div>
        <h3><%= kullanici.ad_soyad || kullanici.username %></h3>
        <p><i class="bi bi-person-badge"></i> Veli</p>
    </div>
</div>

<div class="container">
    <% if (error) { %>
    <div class="alert alert-danger alert-dismissible fade show" role="alert" style="border-radius: var(--vp-radius); font-size: 0.9rem;">
        <i class="bi bi-exclamation-triangle"></i> <%= error %>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
    <% } %>

    <% if (success) { %>
    <div class="alert alert-success alert-dismissible fade show" role="alert" style="border-radius: var(--vp-radius); font-size: 0.9rem;">
        <i class="bi bi-check-circle"></i> <%= success %>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
    <% } %>

    <div class="row">
        <!-- Profil Formu -->
        <div class="col-lg-8 mb-4">
            <div class="vp-card">
                <form method="POST" action="/veli/profil">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="vp-form-group">
                                <label><i class="bi bi-person"></i> Ad Soyad *</label>
                                <input type="text" name="ad_soyad" class="vp-form-control"
                                       value="<%= kullanici.ad_soyad || '' %>" placeholder="Adiniz Soyadiniz" required>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="vp-form-group">
                                <label><i class="bi bi-telephone"></i> Telefon</label>
                                <input type="tel" name="telefon" class="vp-form-control"
                                       value="<%= kullanici.telefon || '' %>" placeholder="0555 555 55 55">
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="vp-form-group">
                                <label><i class="bi bi-person-badge"></i> Kullanici Adi</label>
                                <input type="text" class="vp-form-control" value="<%= kullanici.username %>" disabled style="background: #f8fafc;">
                                <small style="color: var(--vp-text-muted); font-size: 0.75rem;">Kullanici adi degistirilemez</small>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="vp-form-group">
                                <label><i class="bi bi-envelope"></i> E-posta</label>
                                <input type="email" class="vp-form-control" value="<%= kullanici.email %>" disabled style="background: #f8fafc;">
                                <small style="color: var(--vp-text-muted); font-size: 0.75rem;">E-posta degistirilemez</small>
                            </div>
                        </div>
                    </div>

                    <!-- Sifre Degistirme -->
                    <div class="vp-password-box">
                        <h6><i class="bi bi-shield-lock"></i> Sifre Degistir</h6>
                        <p class="small" style="color: #92400e; margin-bottom: 12px;">
                            Sifrenizi degistirmek isterseniz asagidaki alani doldurun.
                        </p>
                        <div class="row">
                            <div class="col-md-6">
                                <div class="vp-form-group">
                                    <label><i class="bi bi-key"></i> Mevcut Sifre</label>
                                    <input type="password" name="current_password" class="vp-form-control" placeholder="Mevcut sifreniz">
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="vp-form-group">
                                    <label><i class="bi bi-key"></i> Yeni Sifre</label>
                                    <input type="password" name="new_password" class="vp-form-control" placeholder="Yeni sifreniz (min. 6 karakter)">
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex gap-2 flex-wrap">
                        <button type="submit" class="vp-btn vp-btn-primary flex-grow-1">
                            <i class="bi bi-check-circle"></i> Profili Guncelle
                        </button>
                        <a href="/veli/dashboard" class="vp-btn vp-btn-secondary">
                            Iptal
                        </a>
                    </div>
                </form>
            </div>
        </div>

        <!-- Yan Bilgiler -->
        <div class="col-lg-4">
            <div class="vp-info-box">
                <h5><i class="bi bi-info-circle-fill"></i> Hesap Bilgileri</h5>
                <p><strong>Kullanici Adi:</strong> <%= kullanici.username %></p>
                <p><strong>Hesap Turu:</strong> <span class="vp-badge vp-badge-primary">Veli</span></p>
                <p style="margin: 0;"><strong>Kayit Tarihi:</strong> <%= new Date(kullanici.created_at).toLocaleDateString('tr-TR') %></p>
            </div>

            <div class="vp-card" style="text-align: center;">
                <i class="bi bi-calendar-check" style="font-size: 2rem; color: var(--vp-primary); margin-bottom: 8px;"></i>
                <h3 style="font-size: 1.8rem; font-weight: 700; color: var(--vp-primary); margin: 0;">
                    <%= Math.floor((new Date() - new Date(kullanici.created_at)) / (1000 * 60 * 60 * 24)) %>
                </h3>
                <p style="color: var(--vp-text-muted); margin: 4px 0 0; font-size: 0.85rem;">Gun Sistemde</p>
            </div>
        </div>
    </div>

    <!-- Talep Edilen Sinavlar -->
    <div class="vp-section-title" style="margin-top: 24px;">
        <i class="bi bi-send-check"></i>
        <span>Talep Edilen Sinavlar</span>
    </div>

    <% if (talepEdilenSinavlar && talepEdilenSinavlar.length > 0) { %>
        <div class="row">
            <% talepEdilenSinavlar.forEach(sinav => { %>
            <div class="col-md-6 col-lg-4 mb-3">
                <div class="vp-request-card">
                    <div class="d-flex align-items-start gap-3 mb-3">
                        <div class="vp-request-icon">
                            <i class="bi bi-file-earmark-text"></i>
                        </div>
                        <div class="flex-grow-1" style="min-width: 0;">
                            <div class="vp-request-title"><%= sinav.ad %></div>
                            <div class="vp-request-meta">
                                <i class="bi bi-calendar-event"></i>
                                <%= new Date(sinav.tarih).toLocaleDateString('tr-TR', { day: '2-digit', month: 'short', year: 'numeric' }) %>
                            </div>
                        </div>
                        <% if (sinav.durum === 'beklemede') { %>
                            <span class="vp-badge vp-badge-warning">Beklemede</span>
                        <% } else if (sinav.durum === 'onaylandi') { %>
                            <span class="vp-badge vp-badge-success">Onaylandi</span>
                        <% } else if (sinav.durum === 'reddedildi') { %>
                            <span class="vp-badge vp-badge-danger">Reddedildi</span>
                        <% } %>
                    </div>

                    <div class="vp-request-meta mb-2">
                        <i class="bi bi-clock-history"></i> Talep: <%= new Date(sinav.talep_tarihi).toLocaleDateString('tr-TR') %>
                    </div>

                    <% if (sinav.yanit) { %>
                    <div style="background: #f8fafc; border-radius: 8px; padding: 10px; margin-top: 8px;">
                        <div style="font-weight: 600; font-size: 0.75rem; color: var(--vp-text-muted); margin-bottom: 4px;">
                            <i class="bi bi-chat-left-text"></i> Yanit:
                        </div>
                        <div style="font-size: 0.85rem; color: var(--vp-text);">
                            <%= sinav.yanit %>
                        </div>
                    </div>
                    <% } %>
                </div>
            </div>
            <% }); %>
        </div>
    <% } else { %>
        <div class="vp-empty">
            <i class="bi bi-inbox"></i>
            <h4>Henuz Talep Gonderilmedi</h4>
            <p>Sinav paketleri sayfasindan sinav erisimi icin talep gonderebilirsiniz.</p>
            <a href="/sinav-paketleri" class="vp-btn vp-btn-primary">
                <i class="bi bi-journals"></i> Sinav Paketleri
            </a>
        </div>
    <% } %>
</div>

<%- include('partials/footer-dashboard') %>
